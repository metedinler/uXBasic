                fn_F64_4_13 = procAddr
                rvF64 = fn_F64_4_13(argValuesF64(0), argValuesU64(1), argValuesF64(2), argValuesF64(3))
            Case 14
                Dim fn_F64_4_14 As MIRFnArg4F64_UFFF
                fn_F64_4_14 = procAddr
                rvF64 = fn_F64_4_14(argValuesU64(0), argValuesF64(1), argValuesF64(2), argValuesF64(3))
            Case 15
                Dim fn_F64_4_15 As MIRFnArg4F64_FFFF
                fn_F64_4_15 = procAddr
                rvF64 = fn_F64_4_15(argValuesF64(0), argValuesF64(1), argValuesF64(2), argValuesF64(3))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case Else
            errMsg = "MIR: CALL DLL x64 mixed en fazla 4 arguman destekler"
            Return 0
        End Select
    Else
        Select Case argCount
        Case 0
            Dim fn0U As MIRFnNoArgU64
            fn0U = procAddr
            rvU64 = fn0U()
        Case 1
            Select Case argMask
            Case 0
                Dim fn_U64_1_0 As MIRFnArg1U64_U
                fn_U64_1_0 = procAddr
                rvU64 = fn_U64_1_0(argValuesU64(0))
            Case 1
                Dim fn_U64_1_1 As MIRFnArg1U64_F
                fn_U64_1_1 = procAddr
                rvU64 = fn_U64_1_1(argValuesF64(0))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case 2
            Select Case argMask
            Case 0
                Dim fn_U64_2_0 As MIRFnArg2U64_UU
                fn_U64_2_0 = procAddr
                rvU64 = fn_U64_2_0(argValuesU64(0), argValuesU64(1))
            Case 1
                Dim fn_U64_2_1 As MIRFnArg2U64_FU
                fn_U64_2_1 = procAddr
                rvU64 = fn_U64_2_1(argValuesF64(0), argValuesU64(1))
            Case 2
                Dim fn_U64_2_2 As MIRFnArg2U64_UF
                fn_U64_2_2 = procAddr
                rvU64 = fn_U64_2_2(argValuesU64(0), argValuesF64(1))
            Case 3
                Dim fn_U64_2_3 As MIRFnArg2U64_FF
                fn_U64_2_3 = procAddr
                rvU64 = fn_U64_2_3(argValuesF64(0), argValuesF64(1))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case 3
            Select Case argMask
            Case 0
                Dim fn_U64_3_0 As MIRFnArg3U64_UUU
                fn_U64_3_0 = procAddr
                rvU64 = fn_U64_3_0(argValuesU64(0), argValuesU64(1), argValuesU64(2))
            Case 1
                Dim fn_U64_3_1 As MIRFnArg3U64_FUU
                fn_U64_3_1 = procAddr
                rvU64 = fn_U64_3_1(argValuesF64(0), argValuesU64(1), argValuesU64(2))
            Case 2
                Dim fn_U64_3_2 As MIRFnArg3U64_UFU
                fn_U64_3_2 = procAddr
                rvU64 = fn_U64_3_2(argValuesU64(0), argValuesF64(1), argValuesU64(2))
            Case 3
                Dim fn_U64_3_3 As MIRFnArg3U64_FFU
                fn_U64_3_3 = procAddr
                rvU64 = fn_U64_3_3(argValuesF64(0), argValuesF64(1), argValuesU64(2))
            Case 4
                Dim fn_U64_3_4 As MIRFnArg3U64_UUF
                fn_U64_3_4 = procAddr
                rvU64 = fn_U64_3_4(argValuesU64(0), argValuesU64(1), argValuesF64(2))
            Case 5
                Dim fn_U64_3_5 As MIRFnArg3U64_FUF
                fn_U64_3_5 = procAddr
                rvU64 = fn_U64_3_5(argValuesF64(0), argValuesU64(1), argValuesF64(2))
            Case 6
                Dim fn_U64_3_6 As MIRFnArg3U64_UFF
                fn_U64_3_6 = procAddr
                rvU64 = fn_U64_3_6(argValuesU64(0), argValuesF64(1), argValuesF64(2))
            Case 7
                Dim fn_U64_3_7 As MIRFnArg3U64_FFF
                fn_U64_3_7 = procAddr
                rvU64 = fn_U64_3_7(argValuesF64(0), argValuesF64(1), argValuesF64(2))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case 4
            Select Case argMask
            Case 0
                Dim fn_U64_4_0 As MIRFnArg4U64_UUUU
                fn_U64_4_0 = procAddr
                rvU64 = fn_U64_4_0(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3))
            Case 1
                Dim fn_U64_4_1 As MIRFnArg4U64_FUUU
                fn_U64_4_1 = procAddr
                rvU64 = fn_U64_4_1(argValuesF64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3))
            Case 2
                Dim fn_U64_4_2 As MIRFnArg4U64_UFUU
                fn_U64_4_2 = procAddr
                rvU64 = fn_U64_4_2(argValuesU64(0), argValuesF64(1), argValuesU64(2), argValuesU64(3))
            Case 3
                Dim fn_U64_4_3 As MIRFnArg4U64_FFUU
                fn_U64_4_3 = procAddr
                rvU64 = fn_U64_4_3(argValuesF64(0), argValuesF64(1), argValuesU64(2), argValuesU64(3))
            Case 4
                Dim fn_U64_4_4 As MIRFnArg4U64_UUFU
                fn_U64_4_4 = procAddr
                rvU64 = fn_U64_4_4(argValuesU64(0), argValuesU64(1), argValuesF64(2), argValuesU64(3))
            Case 5
                Dim fn_U64_4_5 As MIRFnArg4U64_FUFU
                fn_U64_4_5 = procAddr
                rvU64 = fn_U64_4_5(argValuesF64(0), argValuesU64(1), argValuesF64(2), argValuesU64(3))
            Case 6
                Dim fn_U64_4_6 As MIRFnArg4U64_UFFU
                fn_U64_4_6 = procAddr
                rvU64 = fn_U64_4_6(argValuesU64(0), argValuesF64(1), argValuesF64(2), argValuesU64(3))
            Case 7
                Dim fn_U64_4_7 As MIRFnArg4U64_FFFU
                fn_U64_4_7 = procAddr
                rvU64 = fn_U64_4_7(argValuesF64(0), argValuesF64(1), argValuesF64(2), argValuesU64(3))
            Case 8
                Dim fn_U64_4_8 As MIRFnArg4U64_UUUF
                fn_U64_4_8 = procAddr
                rvU64 = fn_U64_4_8(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesF64(3))
            Case 9
                Dim fn_U64_4_9 As MIRFnArg4U64_FUUF
                fn_U64_4_9 = procAddr
                rvU64 = fn_U64_4_9(argValuesF64(0), argValuesU64(1), argValuesU64(2), argValuesF64(3))
            Case 10
                Dim fn_U64_4_10 As MIRFnArg4U64_UFUF
                fn_U64_4_10 = procAddr
                rvU64 = fn_U64_4_10(argValuesU64(0), argValuesF64(1), argValuesU64(2), argValuesF64(3))
            Case 11
                Dim fn_U64_4_11 As MIRFnArg4U64_FFUF
                fn_U64_4_11 = procAddr
                rvU64 = fn_U64_4_11(argValuesF64(0), argValuesF64(1), argValuesU64(2), argValuesF64(3))
            Case 12
                Dim fn_U64_4_12 As MIRFnArg4U64_UUFF
                fn_U64_4_12 = procAddr
