            End Select
        Case Else
            errMsg = "MIR: CALL DLL x64 mixed en fazla 4 arguman destekler"
            Return 0
        End Select
    End If

    Return 1
End Function

Private Function MIRNormalizeFfiTypeToken(ByRef tokenText As String, ByRef typeOut As String) As Integer
    typeOut = UCase(Trim(tokenText))
    If typeOut = "BYVAL" Then typeOut = "VOID"
    If typeOut = "CDECL" Or typeOut = "STDCALL" Then Return 0

    Select Case typeOut
    Case "VOID", "I32", "U64", "F64", "PTR", "STRPTR", "BYREF"
        Return 1
    End Select

    Return 0
End Function

Private Function MIRSplitFfiArgTypes(ByRef listText As String, argTypes() As String, ByRef argTypeCount As Integer) As Integer
    argTypeCount = 0
    If Instr(listText, ",") = 0 Then Return 0

    Dim scanPos As Integer
    scanPos = 1
    Do While scanPos <= Len(listText)
        Dim commaPos As Integer
        commaPos = Instr(scanPos, listText, ",")
        Dim part As String
        If commaPos = 0 Then
            part = Mid(listText, scanPos)
            scanPos = Len(listText) + 1
        Else
            part = Mid(listText, scanPos, commaPos - scanPos)
            scanPos = commaPos + 1
        End If
        If argTypeCount > UBound(argTypes) Then Return 0
        If MIRNormalizeFfiTypeToken(part, argTypes(argTypeCount)) = 0 Then Return 0
        argTypeCount += 1
    Loop

    Return IIf(argTypeCount > 0, 1, 0)
End Function

Private Function MIREvalFfiArgSlot(ByRef state As MIREvaluatorState, ByVal argPos As Integer, ByRef argType As String, ByRef keepAlive As String, ByRef outValueU64 As ULongInt, ByRef outValueF64 As Double, ByRef isF64Out As Integer, ByRef errMsg As String) As Integer
    Dim v As MIRValue
    If MIRTryGetCallArg(state, argPos, v) = 0 Then
        errMsg = "MIR: CALL DLL arguman cozumlene medi"
        Return 0
    End If

    Dim t As String
    If MIRNormalizeFfiTypeToken(argType, t) = 0 Then
        errMsg = "MIR: CALL DLL gecersiz arguman tipi " & Trim(argType)
        Return 0
    End If

    keepAlive = ""
    outValueU64 = 0
    outValueF64 = 0#
    isF64Out = 0

    Select Case t
    Case "F64"
        Select Case v.valueType
        Case "FLOAT"
            outValueF64 = v.floatValue
        Case "INTEGER"
            outValueF64 = CDbl(v.intValue)
        Case Else
            errMsg = "MIR: CALL DLL F64 sayisal arguman ister"
            Return 0
        End Select
        isF64Out = 1
        Return 1

    Case "STRPTR"
        keepAlive = MIRValueToText(v)
#Ifdef __FB_64BIT__
        outValueU64 = CULngInt(CLngInt(CPtr(Any Ptr, StrPtr(keepAlive))))
#Else
        outValueU64 = CULngInt(CULng(CPtr(Any Ptr, StrPtr(keepAlive))))
#EndIf
        Return 1

    Case Else
        Dim li As LongInt
        If MIRAsInteger(v, li) = 0 Then
            errMsg = "MIR: CALL DLL sayisal/pointer arguman ister"
            Return 0
        End If
        If t = "U64" And li < 0 Then
            errMsg = "MIR: CALL DLL U64 arguman negatif olamaz"
            Return 0
        End If
        outValueU64 = CULngInt(li)
        Return 1
    End Select
End Function

Private Function MIRInvokeDllCall(ByRef state As MIREvaluatorState, ByRef ret As MIRValue, ByRef errMsg As String) As Integer
    If gMirInstr.operandCount < 4 Then
        errMsg = "MIR: CALL DLL en az library/symbol/signature ister"
        Return 0
    End If

    Dim dllName As String, symbolName As String, retType As String
    If MIRCallArgText(state, 0, dllName) = 0 Then errMsg = "MIR: CALL DLL library cozumlene medi": Return 0
    If MIRCallArgText(state, 1, symbolName) = 0 Then errMsg = "MIR: CALL DLL symbol cozumlene medi": Return 0
    If MIRCallArgText(state, 2, retType) = 0 Then errMsg = "MIR: CALL DLL signature cozumlene medi": Return 0
    If InStr(dllName, ".") = 0 Then dllName &= ".dll"

    Dim conventionText As String
    conventionText = "CDECL"

    Dim argStartPos As Integer
    argStartPos = 3
    If gMirInstr.operandCount >= 5 Then
        Dim convText As String
        If MIRCallArgText(state, 3, convText) <> 0 Then
            If MIRIsDllConvention(convText) <> 0 Then
                conventionText = UCase(Trim(convText))
                argStartPos = 4
            End If
        End If
    End If

    Dim argTypes(0 To 15) As String
    Dim argTypeCount As Integer
    Dim hasTypeList As Integer
    hasTypeList = 0
    If gMirInstr.operandCount >= argStartPos + 2 Then
        Dim typeListText As String
        If MIRCallArgText(state, argStartPos, typeListText) <> 0 Then
            hasTypeList = MIRSplitFfiArgTypes(typeListText, argTypes(), argTypeCount)
            If hasTypeList <> 0 Then argStartPos += 1
        End If
    End If

    Dim runtimeArgCount As Integer
    runtimeArgCount = gMirInstr.operandCount - 1 - argStartPos
    If runtimeArgCount < 0 Then runtimeArgCount = 0
    If runtimeArgCount > 8 Then
        errMsg = "MIR: CALL DLL en fazla 8 arguman destekler"
        Return 0
    End If

    Dim i As Integer
    If hasTypeList = 0 Then
        For i = 0 To runtimeArgCount - 1
            If MIRNormalizeFfiTypeToken(retType, argTypes(i)) = 0 Then
                errMsg = "MIR: CALL DLL gecersiz signature " & retType
                Return 0
            End If
        Next i
    ElseIf argTypeCount <> runtimeArgCount Then
        errMsg = "MIR: CALL DLL arguman tip listesi sayisi uyusmuyor"
        Return 0
    End If

    Dim h As Any Ptr
    h = MIRLoadLibraryA(StrPtr(dllName))
    If h = 0 Then
        errMsg = "MIR: CALL DLL LoadLibrary failed " & dllName
        Return 0
    End If

    Dim p As Any Ptr
    p = MIRGetProcAddress(h, StrPtr(symbolName))
    If p = 0 Then
        errMsg = "MIR: CALL DLL GetProcAddress failed " & symbolName
        Return 0
    End If

    Dim argValuesU64(0 To 7) As ULongInt
    Dim argValuesF64(0 To 7) As Double
    Dim keepAlive(0 To 7) As String
    Dim argF64Mask As Integer
    Dim hasF64Arg As Integer
    argF64Mask = 0
    hasF64Arg = 0
    For i = 0 To runtimeArgCount - 1
        Dim isF64 As Integer
        If MIREvalFfiArgSlot(state, argStartPos + i, argTypes(i), keepAlive(i), argValuesU64(i), argValuesF64(i), isF64, errMsg) = 0 Then Return 0
        If isF64 <> 0 Then
            hasF64Arg = 1
            argF64Mask = argF64Mask Or (1 Shl i)
        End If
    Next i

    Dim rv As ULongInt
    If SizeOf(Any Ptr) = 4 Then
        If conventionText = "STDCALL" Then
            Select Case runtimeArgCount
            Case 0
                Dim fn0s As MIRFnNoArgU32StdCall
                fn0s = p
                rv = fn0s()
            Case 1
                Dim fn1s As MIRFnArg1U32StdCall
                fn1s = p
                rv = fn1s(CUInt(argValuesU64(0)))
            Case 2
                Dim fn2s As MIRFnArg2U32StdCall
                fn2s = p
                rv = fn2s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)))
            Case 3
                Dim fn3s As MIRFnArg3U32StdCall
                fn3s = p
                rv = fn3s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)))
            Case 4
                Dim fn4s As MIRFnArg4U32StdCall
                fn4s = p
                rv = fn4s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)))
            Case 5
                Dim fn5s As MIRFnArg5U32StdCall
                fn5s = p
                rv = fn5s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)))
            Case 6
                Dim fn6s As MIRFnArg6U32StdCall
                fn6s = p
                rv = fn6s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)), CUInt(argValuesU64(5)))
            Case 7
                Dim fn7s As MIRFnArg7U32StdCall
                fn7s = p
                rv = fn7s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)), CUInt(argValuesU64(5)), CUInt(argValuesU64(6)))
            Case 8
                Dim fn8s As MIRFnArg8U32StdCall
                fn8s = p
                rv = fn8s(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)), CUInt(argValuesU64(5)), CUInt(argValuesU64(6)), CUInt(argValuesU64(7)))
            End Select
        Else
            Select Case runtimeArgCount
            Case 0
                Dim fn0c As MIRFnNoArgU32Cdecl
                fn0c = p
                rv = fn0c()
            Case 1
                Dim fn1c As MIRFnArg1U32Cdecl
                fn1c = p
                rv = fn1c(CUInt(argValuesU64(0)))
            Case 2
                Dim fn2c As MIRFnArg2U32Cdecl
                fn2c = p
                rv = fn2c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)))
            Case 3
                Dim fn3c As MIRFnArg3U32Cdecl
                fn3c = p
                rv = fn3c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)))
            Case 4
                Dim fn4c As MIRFnArg4U32Cdecl
                fn4c = p
                rv = fn4c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)))
            Case 5
                Dim fn5c As MIRFnArg5U32Cdecl
                fn5c = p
                rv = fn5c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)))
            Case 6
                Dim fn6c As MIRFnArg6U32Cdecl
                fn6c = p
                rv = fn6c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)), CUInt(argValuesU64(5)))
            Case 7
                Dim fn7c As MIRFnArg7U32Cdecl
                fn7c = p
                rv = fn7c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)), CUInt(argValuesU64(5)), CUInt(argValuesU64(6)))
            Case 8
                Dim fn8c As MIRFnArg8U32Cdecl
                fn8c = p
                rv = fn8c(CUInt(argValuesU64(0)), CUInt(argValuesU64(1)), CUInt(argValuesU64(2)), CUInt(argValuesU64(3)), CUInt(argValuesU64(4)), CUInt(argValuesU64(5)), CUInt(argValuesU64(6)), CUInt(argValuesU64(7)))
            End Select
        End If
    Else
        If hasF64Arg <> 0 Then
            If runtimeArgCount > 4 Then
                errMsg = "MIR: CALL DLL x64 mixed en fazla 4 arguman destekler"
                Return 0
            End If

            Dim rvF64 As Double
            Dim usesF64Return As Integer
            If MIRDispatchX64MixedCall(p, retType, runtimeArgCount, argF64Mask, argValuesU64(), argValuesF64(), rv, rvF64, usesF64Return, errMsg) = 0 Then
                Return 0
            End If

            ret.valueType = "INTEGER"
            If usesF64Return <> 0 Then
                If rvF64 > 2147483647# Then
                    ret.intValue = 2147483647
                ElseIf rvF64 < -2147483648# Then
                    ret.intValue = -2147483648
                Else
                    ret.intValue = CLngInt(rvF64)
                End If
            Else
                If rv > CULngInt(2147483647) Then ret.intValue = 2147483647 Else ret.intValue = CLngInt(rv)
            End If
            Return 1
        End If

        Select Case runtimeArgCount
        Case 0
            Dim fn0 As MIRFnNoArgU64
            fn0 = p
            rv = fn0()
        Case 1
            Dim fn1 As MIRFnArg1U64
            fn1 = p
            rv = fn1(argValuesU64(0))
        Case 2
            Dim fn2 As MIRFnArg2U64
            fn2 = p
            rv = fn2(argValuesU64(0), argValuesU64(1))
        Case 3
            Dim fn3 As MIRFnArg3U64
            fn3 = p
            rv = fn3(argValuesU64(0), argValuesU64(1), argValuesU64(2))
        Case 4
            Dim fn4 As MIRFnArg4U64
            fn4 = p
            rv = fn4(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3))
        Case 5
            Dim fn5 As MIRFnArg5U64
            fn5 = p
            rv = fn5(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3), argValuesU64(4))
        Case 6
            Dim fn6 As MIRFnArg6U64
            fn6 = p
            rv = fn6(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3), argValuesU64(4), argValuesU64(5))
        Case 7
            Dim fn7 As MIRFnArg7U64
            fn7 = p
            rv = fn7(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3), argValuesU64(4), argValuesU64(5), argValuesU64(6))
        Case 8
            Dim fn8 As MIRFnArg8U64
            fn8 = p
            rv = fn8(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3), argValuesU64(4), argValuesU64(5), argValuesU64(6), argValuesU64(7))
        End Select
    End If

    ret.valueType = "INTEGER"
    If rv > CULngInt(2147483647) Then ret.intValue = 2147483647 Else ret.intValue = CLngInt(rv)
    Return 1
End Function

