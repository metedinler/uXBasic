Type MIRFnArg4F64_FUFF As Function Cdecl (ByVal a0 As Double, ByVal a1 As ULongInt, ByVal a2 As Double, ByVal a3 As Double) As Double
Type MIRFnArg4F64_UFFF As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As Double, ByVal a2 As Double, ByVal a3 As Double) As Double
Type MIRFnArg4F64_FFFF As Function Cdecl (ByVal a0 As Double, ByVal a1 As Double, ByVal a2 As Double, ByVal a3 As Double) As Double

Private Function MIRDispatchX64MixedCall(ByVal procAddr As Any Ptr, ByRef retType As String, ByVal argCount As Integer, ByVal argMask As Integer, argValuesU64() As ULongInt, argValuesF64() As Double, ByRef rvU64 As ULongInt, ByRef rvF64 As Double, ByRef usesF64Return As Integer, ByRef errMsg As String) As Integer
    Dim retClass As String
    retClass = UCase(Trim(retType))
    If retClass = "F64" Then
        usesF64Return = 1
    Else
        usesF64Return = 0
    End If

    If usesF64Return <> 0 Then
        Select Case argCount
        Case 0
            Dim fn0F As MIRFnNoArgF64
            fn0F = procAddr
            rvF64 = fn0F()
        Case 1
            Select Case argMask
            Case 0
                Dim fn_F64_1_0 As MIRFnArg1F64_U
                fn_F64_1_0 = procAddr
                rvF64 = fn_F64_1_0(argValuesU64(0))
            Case 1
                Dim fn_F64_1_1 As MIRFnArg1F64_F
                fn_F64_1_1 = procAddr
                rvF64 = fn_F64_1_1(argValuesF64(0))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case 2
            Select Case argMask
            Case 0
                Dim fn_F64_2_0 As MIRFnArg2F64_UU
                fn_F64_2_0 = procAddr
                rvF64 = fn_F64_2_0(argValuesU64(0), argValuesU64(1))
            Case 1
                Dim fn_F64_2_1 As MIRFnArg2F64_FU
                fn_F64_2_1 = procAddr
                rvF64 = fn_F64_2_1(argValuesF64(0), argValuesU64(1))
            Case 2
                Dim fn_F64_2_2 As MIRFnArg2F64_UF
                fn_F64_2_2 = procAddr
                rvF64 = fn_F64_2_2(argValuesU64(0), argValuesF64(1))
            Case 3
                Dim fn_F64_2_3 As MIRFnArg2F64_FF
                fn_F64_2_3 = procAddr
                rvF64 = fn_F64_2_3(argValuesF64(0), argValuesF64(1))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case 3
            Select Case argMask
            Case 0
                Dim fn_F64_3_0 As MIRFnArg3F64_UUU
                fn_F64_3_0 = procAddr
                rvF64 = fn_F64_3_0(argValuesU64(0), argValuesU64(1), argValuesU64(2))
            Case 1
                Dim fn_F64_3_1 As MIRFnArg3F64_FUU
                fn_F64_3_1 = procAddr
                rvF64 = fn_F64_3_1(argValuesF64(0), argValuesU64(1), argValuesU64(2))
            Case 2
                Dim fn_F64_3_2 As MIRFnArg3F64_UFU
                fn_F64_3_2 = procAddr
                rvF64 = fn_F64_3_2(argValuesU64(0), argValuesF64(1), argValuesU64(2))
            Case 3
                Dim fn_F64_3_3 As MIRFnArg3F64_FFU
                fn_F64_3_3 = procAddr
                rvF64 = fn_F64_3_3(argValuesF64(0), argValuesF64(1), argValuesU64(2))
            Case 4
                Dim fn_F64_3_4 As MIRFnArg3F64_UUF
                fn_F64_3_4 = procAddr
                rvF64 = fn_F64_3_4(argValuesU64(0), argValuesU64(1), argValuesF64(2))
            Case 5
                Dim fn_F64_3_5 As MIRFnArg3F64_FUF
                fn_F64_3_5 = procAddr
                rvF64 = fn_F64_3_5(argValuesF64(0), argValuesU64(1), argValuesF64(2))
            Case 6
                Dim fn_F64_3_6 As MIRFnArg3F64_UFF
                fn_F64_3_6 = procAddr
                rvF64 = fn_F64_3_6(argValuesU64(0), argValuesF64(1), argValuesF64(2))
            Case 7
                Dim fn_F64_3_7 As MIRFnArg3F64_FFF
                fn_F64_3_7 = procAddr
                rvF64 = fn_F64_3_7(argValuesF64(0), argValuesF64(1), argValuesF64(2))
            Case Else
                errMsg = "MIR: CALL DLL x64 mixed arg mask unsupported"
                Return 0
            End Select
        Case 4
            Select Case argMask
            Case 0
                Dim fn_F64_4_0 As MIRFnArg4F64_UUUU
                fn_F64_4_0 = procAddr
                rvF64 = fn_F64_4_0(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3))
            Case 1
                Dim fn_F64_4_1 As MIRFnArg4F64_FUUU
                fn_F64_4_1 = procAddr
                rvF64 = fn_F64_4_1(argValuesF64(0), argValuesU64(1), argValuesU64(2), argValuesU64(3))
            Case 2
                Dim fn_F64_4_2 As MIRFnArg4F64_UFUU
                fn_F64_4_2 = procAddr
                rvF64 = fn_F64_4_2(argValuesU64(0), argValuesF64(1), argValuesU64(2), argValuesU64(3))
            Case 3
                Dim fn_F64_4_3 As MIRFnArg4F64_FFUU
                fn_F64_4_3 = procAddr
                rvF64 = fn_F64_4_3(argValuesF64(0), argValuesF64(1), argValuesU64(2), argValuesU64(3))
            Case 4
                Dim fn_F64_4_4 As MIRFnArg4F64_UUFU
                fn_F64_4_4 = procAddr
                rvF64 = fn_F64_4_4(argValuesU64(0), argValuesU64(1), argValuesF64(2), argValuesU64(3))
            Case 5
                Dim fn_F64_4_5 As MIRFnArg4F64_FUFU
                fn_F64_4_5 = procAddr
                rvF64 = fn_F64_4_5(argValuesF64(0), argValuesU64(1), argValuesF64(2), argValuesU64(3))
            Case 6
