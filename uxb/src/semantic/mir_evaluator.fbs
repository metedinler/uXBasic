                fn_F64_4_8 = procAddr
                rvF64 = fn_F64_4_8(argValuesU64(0), argValuesU64(1), argValuesU64(2), argValuesF64(3))
            Case 9
                Dim fn_F64_4_9 As MIRFnArg4F64_FUUF
                fn_F64_4_9 = procAddr
                rvF64 = fn_F64_4_9(argValuesF64(0), argValuesU64(1), argValuesU64(2), argValuesF64(3))
            Case 10
