Type MIRFnArg4F64_UFUU As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As Double, ByVal a2 As ULongInt, ByVal a3 As ULongInt) As Double
Type MIRFnArg4F64_FFUU As Function Cdecl (ByVal a0 As Double, ByVal a1 As Double, ByVal a2 As ULongInt, ByVal a3 As ULongInt) As Double
Type MIRFnArg4F64_UUFU As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As ULongInt, ByVal a2 As Double, ByVal a3 As ULongInt) As Double
Type MIRFnArg4F64_FUFU As Function Cdecl (ByVal a0 As Double, ByVal a1 As ULongInt, ByVal a2 As Double, ByVal a3 As ULongInt) As Double
Type MIRFnArg4F64_UFFU As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As Double, ByVal a2 As Double, ByVal a3 As ULongInt) As Double
Type MIRFnArg4F64_FFFU As Function Cdecl (ByVal a0 As Double, ByVal a1 As Double, ByVal a2 As Double, ByVal a3 As ULongInt) As Double
Type MIRFnArg4F64_UUUF As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As ULongInt, ByVal a2 As ULongInt, ByVal a3 As Double) As Double
Type MIRFnArg4F64_FUUF As Function Cdecl (ByVal a0 As Double, ByVal a1 As ULongInt, ByVal a2 As ULongInt, ByVal a3 As Double) As Double
