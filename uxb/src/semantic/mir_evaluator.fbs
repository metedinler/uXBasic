Type MIRFnArg4U64_UFFU As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As Double, ByVal a2 As Double, ByVal a3 As ULongInt) As ULongInt
Type MIRFnArg4U64_FFFU As Function Cdecl (ByVal a0 As Double, ByVal a1 As Double, ByVal a2 As Double, ByVal a3 As ULongInt) As ULongInt
Type MIRFnArg4U64_UUUF As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As ULongInt, ByVal a2 As ULongInt, ByVal a3 As Double) As ULongInt
Type MIRFnArg4U64_FUUF As Function Cdecl (ByVal a0 As Double, ByVal a1 As ULongInt, ByVal a2 As ULongInt, ByVal a3 As Double) As ULongInt
Type MIRFnArg4U64_UFUF As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As Double, ByVal a2 As ULongInt, ByVal a3 As Double) As ULongInt
Type MIRFnArg4U64_FFUF As Function Cdecl (ByVal a0 As Double, ByVal a1 As Double, ByVal a2 As ULongInt, ByVal a3 As Double) As ULongInt
Type MIRFnArg4U64_UUFF As Function Cdecl (ByVal a0 As ULongInt, ByVal a1 As ULongInt, ByVal a2 As Double, ByVal a3 As Double) As ULongInt
