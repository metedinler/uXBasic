
CLASS A
PUBLIC
VIRTUAL METHOD Speak() AS I32
    RETURN 1
END METHOD
END CLASS

CLASS B EXTENDS A
PUBLIC
OVERRIDE METHOD Speak() AS I32
    RETURN 2
END METHOD
END CLASS

CLASS C EXTENDS B
PUBLIC
OVERRIDE METHOD Speak() AS I32
    RETURN 3
END METHOD
END CLASS

DIM a AS A
a = NEW C
PRINT a.Speak()
END
