CLASS Base
PUBLIC
id AS I32
VIRTUAL METHOD Speak() AS I32
RETURN 11
END METHOD
END CLASS

CLASS Dog EXTENDS Base
PUBLIC
tag AS I32
OVERRIDE METHOD Speak() AS I32
RETURN 42
END METHOD
END CLASS

CLASS Cat EXTENDS Base
PUBLIC
kind AS I32
OVERRIDE METHOD Speak() AS I32
RETURN 7
END METHOD
END CLASS

DIM d AS Dog
DIM c AS Cat
PRINT d.Speak()
PRINT c.Speak()
END
