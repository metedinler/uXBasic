    X64EmitText cg, "    sub rsp, 40"
    X64EmitText cg, "    call fread"
    X64EmitText cg, "    add rsp, 40"
    X64EmitText cg, "    cmp rax, [rel __uxb_file_tmp_result]"
    X64EmitText cg, "    jne .file_get_fail"
    X64EmitText cg, "    mov r9, [rel __uxb_file_tmp_dest]"
    X64EmitText cg, "    mov eax, dword [rel __uxb_file_io_tmp]"
    X64EmitText cg, "    mov [r9], eax"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ".file_get_fail:"
    X64EmitText cg, "    xor eax, eax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_file_put_i32:"
    X64EmitText cg, "    cmp rcx, 1"
    X64EmitText cg, "    jl .file_put_fail"
    X64EmitText cg, "    cmp rcx, 255"
    X64EmitText cg, "    jg .file_put_fail"
    X64EmitText cg, "    lea r11, [rel __uxb_file_handles]"
    X64EmitText cg, "    mov r10, [r11 + rcx*8]"
    X64EmitText cg, "    test r10, r10"
    X64EmitText cg, "    jz .file_put_fail"
    X64EmitText cg, "    lea r11, [rel __uxb_file_can_write]"
    X64EmitText cg, "    cmp dword [r11 + rcx*4], 0"
    X64EmitText cg, "    je .file_put_fail"
    X64EmitText cg, "    cmp r8d, 0"
    X64EmitText cg, "    jg .file_put_have_bytes"
    X64EmitText cg, "    lea r11, [rel __uxb_file_record_len]"
    X64EmitText cg, "    mov r8d, dword [r11 + rcx*4]"
    X64EmitText cg, ".file_put_have_bytes:"
