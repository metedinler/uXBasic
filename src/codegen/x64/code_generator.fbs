Private Function X64NextLabel(ByRef cg As X64CodegenContext, ByRef prefixText As String) As String
    gX64GlobalLabelCounter += 1
    cg.labelSeed = gX64GlobalLabelCounter
    Return "__uxb_" & prefixText & "_" & LTrim(Str(gX64GlobalLabelCounter))
End Function

Private Function X64MakeScopedKey(ByRef scopeText As String, ByRef symbolText As String) As String
    Return X64Upper(Trim(scopeText)) & "::" & X64Upper(Trim(symbolText))
End Function

Private Function X64FindSymbol(ByRef cg As X64CodegenContext, ByRef keyText As String) As Integer
    Dim i As Integer
    For i = 0 To cg.symbolCount - 1
        If gX64SymbolKeys(i) = keyText Then Return i
    Next i
    Return -1
End Function

Private Function X64FindRoutine(ByRef cg As X64CodegenContext, ByRef routineKey As String) As Integer
    Dim i As Integer
    For i = 0 To cg.routineCount - 1
        If gX64RoutineKeys(i) = routineKey Then Return i
    Next i
    Return -1
End Function

Private Function X64FindGlobalSymbol(ByRef cg As X64CodegenContext, ByRef symbolText As String) As Integer
    Dim keyText As String
    keyText = X64Upper(Trim(symbolText))
    If keyText = "" Then Return -1

    Dim i As Integer
    For i = 0 To cg.globalCount - 1
        If gX64GlobalKeys(i) = keyText Then Return i
    Next i
    Return -1
End Function

Private Function X64EnsureGlobalSymbol(ByRef cg As X64CodegenContext, ByRef symbolText As String, ByVal elemCount As Integer, ByVal elemBytes As Integer) As String
    ' elemCount: number of elements; elemBytes: bytes per element (e.g., 8,10,4)
    If elemCount < 1 Then elemCount = 1
    If elemBytes <= 0 Then elemBytes = 8

    Dim existing As Integer
    existing = X64FindGlobalSymbol(cg, symbolText)
    If existing <> -1 Then Return gX64GlobalLabels(existing)

    Dim labelText As String
    labelText = "__uxb_var_global_" & X64SanitizeSymbol(symbolText)

    If cg.globalCount <= 4095 Then
        gX64GlobalKeys(cg.globalCount) = X64Upper(Trim(symbolText))
        gX64GlobalLabels(cg.globalCount) = labelText
        gX64GlobalSlots(cg.globalCount) = elemCount
        gX64GlobalElemBytes(cg.globalCount) = elemBytes
        cg.globalCount += 1
    End If

    Select Case elemBytes
    Case 10
        If elemCount = 1 Then
            X64EmitData cg, labelText & ": dt 0"
        Else
            X64EmitData cg, labelText & ": times " & X64ToStr(elemCount) & " dt 0"
        End If
    Case 8
        If elemCount = 1 Then
            X64EmitData cg, labelText & ": dq 0"
        Else
            X64EmitData cg, labelText & ": times " & X64ToStr(elemCount) & " dq 0"
        End If
    Case 4
        If elemCount = 1 Then
            X64EmitData cg, labelText & ": dd 0"
        Else
            X64EmitData cg, labelText & ": times " & X64ToStr(elemCount) & " dd 0"
        End If
    Case Else
        ' Fallback: allocate total bytes as db
        Dim totalBytes As Integer
        totalBytes = elemCount * elemBytes
        X64EmitData cg, labelText & ": times " & X64ToStr(totalBytes) & " db 0"
    End Select

    Return labelText
End Function

Private Function X64ExtractTypeNameFromNode(ByRef ps As ParseState, ByVal nodeIdx As Integer) As String
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return ""

    Dim typeText As String
    typeText = Trim(ps.ast.nodes(nodeIdx).value)
    If typeText = "" Then typeText = Trim(ps.ast.nodes(nodeIdx).op)

    If typeText = "" Then
        Dim ch As Integer
        ch = ps.ast.nodes(nodeIdx).firstChild
        Do While ch <> -1
            typeText = Trim(ps.ast.nodes(ch).value)
            If typeText = "" Then typeText = Trim(ps.ast.nodes(ch).op)
            If typeText = "" Then
                Dim childKind As String
                childKind = X64Upper(Trim(ps.ast.nodes(ch).kind))
                If Left(childKind, 5) = "TYPE_" Then
                    typeText = Mid(childKind, 6)
                End If
            End If
            If typeText <> "" Then Exit Do
            ch = ps.ast.nodes(ch).nextSibling
        Loop
    End If

    If typeText = "" Then
        Dim k As String
        k = X64Upper(Trim(ps.ast.nodes(nodeIdx).kind))
        If Left(k, 5) = "TYPE_" Then
            typeText = Mid(k, 6)
        End If
    End If

    Return X64Upper(Trim(typeText))
End Function

Private Function X64ExtractRoutineReturnType(ByRef ps As ParseState, ByVal routineNode As Integer) As String
    If routineNode < 0 Or routineNode >= ps.ast.count Then Return ""

    Dim ch As Integer
    ch = ps.ast.nodes(routineNode).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) = "RETURN_TYPE" Then
            Return X64ExtractTypeNameFromNode(ps, ch)
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return ""
End Function

Private Sub X64RegisterRoutineSignature(ByRef ps As ParseState, ByVal routineNode As Integer, ByRef cg As X64CodegenContext)
    If routineNode < 0 Or routineNode >= ps.ast.count Then Exit Sub

    Dim routineName As String
    routineName = Trim(ps.ast.nodes(routineNode).value)
    If routineName = "" Then Exit Sub

    Dim routineKey As String
    routineKey = X64Upper(routineName)

    Dim argCount As Integer
    argCount = 0

    Dim ch As Integer
    ch = ps.ast.nodes(routineNode).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) <> "PARAM_DECL" Then Exit Do
        argCount += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Dim isFn As Integer
    isFn = IIf(X64Upper(ps.ast.nodes(routineNode).kind) = "FUNCTION_STMT", 1, 0)

    Dim i As Integer
    i = X64FindRoutine(cg, routineKey)
    If i <> -1 Then
        gX64RoutineArgCounts(i) = argCount
        gX64RoutineIsFunction(i) = isFn
        Dim retTypeExisting As String
        retTypeExisting = X64ExtractRoutineReturnType(ps, routineNode)
        gX64RoutineReturnTypes(i) = retTypeExisting
        Exit Sub
    End If

    If cg.routineCount > 1023 Then Exit Sub
    gX64RoutineKeys(cg.routineCount) = routineKey
    gX64RoutineArgCounts(cg.routineCount) = argCount
    gX64RoutineIsFunction(cg.routineCount) = isFn
    Dim retTypeNew As String
    retTypeNew = X64ExtractRoutineReturnType(ps, routineNode)
    gX64RoutineReturnTypes(cg.routineCount) = retTypeNew
    cg.routineCount += 1
End Sub

Private Function X64TryGetRoutineReturnType(ByRef cg As X64CodegenContext, ByRef routineName As String, ByRef returnTypeOut As String) As Integer
    returnTypeOut = ""
    Dim keyText As String
    keyText = X64Upper(Trim(routineName))
    If keyText = "" Then Return 0

    Dim i As Integer
    i = X64FindRoutine(cg, keyText)
    If i = -1 Then Return 0

    returnTypeOut = gX64RoutineReturnTypes(i)
    Return 1
End Function

Private Function X64TryGetRoutineSignature(ByRef cg As X64CodegenContext, ByRef routineName As String, ByRef argCountOut As Integer, ByRef isFunctionOut As Integer) As Integer
    argCountOut = -1
    isFunctionOut = 0

    Dim keyText As String
    keyText = X64Upper(Trim(routineName))
    If keyText = "" Then Return 0

    Dim i As Integer
    i = X64FindRoutine(cg, keyText)
    If i = -1 Then Return 0

    argCountOut = gX64RoutineArgCounts(i)
    isFunctionOut = gX64RoutineIsFunction(i)
    Return 1
End Function

Private Sub X64RegisterProcedureParams(ByRef ps As ParseState, ByVal routineNode As Integer, ByRef cg As X64CodegenContext)
    cg.paramCount = 0

    Dim ch As Integer
    ch = ps.ast.nodes(routineNode).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) <> "PARAM_DECL" Then Exit Do

        Dim paramName As String
        paramName = Trim(ps.ast.nodes(ch).value)
        If paramName <> "" Then
            Dim pElemBytes As Integer
            pElemBytes = 8
            Dim pType As String
            pType = ""
            If X64TryGetVarType(cg, paramName, pType) <> 0 Then
                Select Case X64TypeToFloatKind(pType)
                Case UXF_F80
                    pElemBytes = 10
                Case UXF_F32
                    pElemBytes = 4
                Case Else
                    pElemBytes = 8
                End Select
            End If
            X64EnsureLocalSlot(cg, paramName, 1, pElemBytes)
            If cg.paramCount <= 255 Then
                gX64ParamNames(cg.paramCount) = paramName
                cg.paramCount += 1
            End If
        End If

        ch = ps.ast.nodes(ch).nextSibling
    Loop
End Sub

Private Function X64EnsureSymbol(ByRef cg As X64CodegenContext, ByRef scopeText As String, ByRef symbolText As String, ByVal slotCount As Integer) As String
    If slotCount < 1 Then slotCount = 1

    Dim defaultElemBytes As Integer
    defaultElemBytes = 8
    Dim inferredType As String
    inferredType = ""
    If X64TryGetVarType(cg, symbolText, inferredType) <> 0 Then
        Select Case X64TypeToFloatKind(inferredType)
        Case UXF_F80
            defaultElemBytes = 10
        Case UXF_F32
            defaultElemBytes = 4
        Case Else
            defaultElemBytes = 8
        End Select
    End If

    If X64Upper(Trim(scopeText)) = "GLOBAL" Then
        Return X64EnsureGlobalSymbol(cg, symbolText, slotCount, defaultElemBytes)
    End If

    Dim keyText As String
    keyText = X64MakeScopedKey(scopeText, symbolText)

    Dim existing As Integer
    existing = X64FindSymbol(cg, keyText)
    If existing <> -1 Then Return gX64SymbolLabels(existing)

    Dim labelText As String
    labelText = "__uxb_var_" & X64SanitizeSymbol(scopeText) & "_" & X64SanitizeSymbol(symbolText)

    gX64SymbolKeys(cg.symbolCount) = keyText
    gX64SymbolLabels(cg.symbolCount) = labelText
    cg.symbolCount += 1

    Select Case defaultElemBytes
    Case 4
        X64EmitData cg, labelText & ": times " & X64ToStr(slotCount) & " dd 0"
    Case 8
        X64EmitData cg, labelText & ": times " & X64ToStr(slotCount) & " dq 0"
    Case 10
        X64EmitData cg, labelText & ": times " & X64ToStr(slotCount) & " dt 0"
    Case Else
        X64EmitData cg, labelText & ": times " & X64ToStr(slotCount * defaultElemBytes) & " db 0"
    End Select
    Return labelText
End Function

Private Function X64TryFindSymbolLabel(ByRef cg As X64CodegenContext, ByRef scopeText As String, ByRef symbolText As String, ByRef labelOut As String) As Integer
    Dim keyText As String
    keyText = X64MakeScopedKey(scopeText, symbolText)

    Dim i As Integer
    i = X64FindSymbol(cg, keyText)
    If i <> -1 Then
        labelOut = gX64SymbolLabels(i)
        Return 1
    End If

    i = X64FindGlobalSymbol(cg, symbolText)
    If i <> -1 Then
        labelOut = gX64GlobalLabels(i)
        Return 1
    End If

    labelOut = ""
    Return 0
End Function

Private Function X64FindLocal(ByRef cg As X64CodegenContext, ByRef varName As String) As Integer
    Dim keyText As String
    keyText = X64Upper(Trim(varName))
    If keyText = "" Then Return -1

    Dim i As Integer
    For i = 0 To cg.localCount - 1
        If gX64LocalKeys(i) = keyText Then Return i
    Next i
    Return -1
End Function

Private Function X64EnsureLocalSlot(ByRef cg As X64CodegenContext, ByRef varName As String, ByVal elemCount As Integer, ByVal elemBytes As Integer) As Integer
    If elemCount < 1 Then elemCount = 1
    If elemBytes <= 0 Then elemBytes = 8

    Dim keyText As String
    keyText = X64Upper(Trim(varName))
    If keyText = "" Then keyText = "__UXB_LOCAL"

    Dim existing As Integer
    existing = X64FindLocal(cg, keyText)
    If existing <> -1 Then Return gX64LocalOffsets(existing)

    Dim totalBytes As Integer
    totalBytes = elemCount * elemBytes

    If cg.localCount > 2047 Then
        cg.localFrameBytes += totalBytes
        Return -cg.localFrameBytes
    End If

    gX64LocalKeys(cg.localCount) = keyText
    cg.localFrameBytes += totalBytes
    gX64LocalOffsets(cg.localCount) = -cg.localFrameBytes
    gX64LocalSlots(cg.localCount) = elemCount
    gX64LocalElemBytes(cg.localCount) = elemBytes
    cg.localCount += 1

    Return gX64LocalOffsets(cg.localCount - 1)
End Function

Private Function X64TryGetLocalElemBytes(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef elemBytesOut As Integer) As Integer
    Dim i As Integer
    i = X64FindLocal(cg, varName)
    If i = -1 Then
        elemBytesOut = 8
        Return 0
    End If
    elemBytesOut = gX64LocalElemBytes(i)
    If elemBytesOut <= 0 Then elemBytesOut = 8
    Return 1
End Function


Private Function X64TryFindLocalOffset(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef offsetOut As Integer) As Integer
    Dim i As Integer
    i = X64FindLocal(cg, varName)
    If i = -1 Then
        offsetOut = 0
        Return 0
    End If

    offsetOut = gX64LocalOffsets(i)
    Return 1
End Function

Private Function X64TryFindLocalInfo(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef offsetOut As Integer, ByRef slotCountOut As Integer) As Integer
    Dim i As Integer
    i = X64FindLocal(cg, varName)
    If i = -1 Then
        offsetOut = 0
        slotCountOut = 0
        Return 0
    End If

    offsetOut = gX64LocalOffsets(i)
    slotCountOut = gX64LocalSlots(i)
    Return 1
End Function

Private Function X64FormatRbpRef(ByVal offset As Integer) As String
    If offset < 0 Then
        Return "[rbp - " & X64ToStr(-offset) & "]"
    ElseIf offset > 0 Then
        Return "[rbp + " & X64ToStr(offset) & "]"
    End If
    Return "[rbp]"
End Function

Private Function X64EnsureVar(ByRef cg As X64CodegenContext, ByRef varName As String) As String
    If cg.currentRoutineLabel <> "" Then
        Dim declType As String
        declType = ""
        Dim elemBytes As Integer
        elemBytes = 8
        If X64TryGetVarType(cg, varName, declType) <> 0 Then
            Select Case X64TypeToFloatKind(declType)
            Case UXF_F80
                elemBytes = 10
            Case UXF_F32
                elemBytes = 4
            Case Else
                elemBytes = 8
            End Select
        End If
        X64EnsureLocalSlot(cg, varName, 1, elemBytes)
        Return ""
    End If

    Dim scopeText As String
    If cg.currentRoutineLabel = "" Then scopeText = "global" Else scopeText = cg.currentRoutineLabel
    Return X64EnsureSymbol(cg, scopeText, varName, 1)
End Function

Private Sub X64EmitLoadVar(ByRef cg As X64CodegenContext, ByRef varName As String)
    Dim localOffset As Integer
    Dim globalIdx As Integer
    Dim loadBytes As Integer
    loadBytes = 8
    If X64TryGetGlobalElemBytes(cg, varName, loadBytes) = 0 Then
        If X64TryGetLocalElemBytes(cg, varName, loadBytes) = 0 Then loadBytes = 8
    End If
    globalIdx = X64FindGlobalSymbol(cg, varName)
    If cg.currentRoutineLabel <> "" Then
        If globalIdx <> -1 Then
            Select Case loadBytes
            Case 1
                X64EmitText cg, "    movsx rax, byte [rel " & gX64GlobalLabels(globalIdx) & "]"
            Case 2
                X64EmitText cg, "    movsx rax, word [rel " & gX64GlobalLabels(globalIdx) & "]"
            Case 4
                X64EmitText cg, "    movsxd rax, dword [rel " & gX64GlobalLabels(globalIdx) & "]"
            Case Else
                X64EmitText cg, "    mov rax, [rel " & gX64GlobalLabels(globalIdx) & "]"
            End Select
            Exit Sub
        End If
        If X64TryFindLocalOffset(cg, varName, localOffset) <> 0 Then
            Select Case loadBytes
            Case 1
                X64EmitText cg, "    movsx rax, byte " & X64FormatRbpRef(localOffset)
            Case 2
                X64EmitText cg, "    movsx rax, word " & X64FormatRbpRef(localOffset)
            Case 4
                X64EmitText cg, "    movsxd rax, dword " & X64FormatRbpRef(localOffset)
            Case Else
                X64EmitText cg, "    mov rax, " & X64FormatRbpRef(localOffset)
            End Select
            Exit Sub
        End If
    End If

    Dim labelText As String
    If X64TryFindSymbolLabel(cg, cg.currentRoutineLabel, varName, labelText) = 0 Then
        If cg.currentRoutineLabel <> "" Then
            Dim vbElemBytes As Integer
            vbElemBytes = 8
            Dim vbType As String
            vbType = ""
            If X64TryGetVarType(cg, varName, vbType) <> 0 Then
                Select Case X64TypeToFloatKind(vbType)
                Case UXF_F80
                    vbElemBytes = 10
                Case UXF_F32
                    vbElemBytes = 4
                Case Else
                    vbElemBytes = 8
                End Select
            End If
            localOffset = X64EnsureLocalSlot(cg, varName, 1, vbElemBytes)
            Select Case vbElemBytes
            Case 1
                X64EmitText cg, "    movsx rax, byte " & X64FormatRbpRef(localOffset)
            Case 2
                X64EmitText cg, "    movsx rax, word " & X64FormatRbpRef(localOffset)
            Case 4
                X64EmitText cg, "    movsxd rax, dword " & X64FormatRbpRef(localOffset)
            Case Else
                X64EmitText cg, "    mov rax, " & X64FormatRbpRef(localOffset)
            End Select
            Exit Sub
        End If
        labelText = X64EnsureVar(cg, varName)
    End If
    Select Case loadBytes
    Case 1
        X64EmitText cg, "    movsx rax, byte [rel " & labelText & "]"
    Case 2
        X64EmitText cg, "    movsx rax, word [rel " & labelText & "]"
    Case 4
        X64EmitText cg, "    movsxd rax, dword [rel " & labelText & "]"
    Case Else
        X64EmitText cg, "    mov rax, [rel " & labelText & "]"
    End Select
End Sub

Private Sub X64EmitStoreVar(ByRef cg As X64CodegenContext, ByRef varName As String)
    Dim localOffset As Integer
    Dim globalIdx As Integer
    Dim storeBytes As Integer
    storeBytes = 8
    If X64TryGetGlobalElemBytes(cg, varName, storeBytes) = 0 Then
        If X64TryGetLocalElemBytes(cg, varName, storeBytes) = 0 Then storeBytes = 8
    End If
    globalIdx = X64FindGlobalSymbol(cg, varName)
    If cg.currentRoutineLabel <> "" Then
        If globalIdx <> -1 Then
            Select Case storeBytes
            Case 1
                X64EmitText cg, "    mov byte [rel " & gX64GlobalLabels(globalIdx) & "], al"
            Case 2
                X64EmitText cg, "    mov word [rel " & gX64GlobalLabels(globalIdx) & "], ax"
            Case 4
                X64EmitText cg, "    mov dword [rel " & gX64GlobalLabels(globalIdx) & "], eax"
            Case Else
                X64EmitText cg, "    mov [rel " & gX64GlobalLabels(globalIdx) & "], rax"
            End Select
            Exit Sub
        End If
        If X64TryFindLocalOffset(cg, varName, localOffset) <> 0 Then
            Select Case storeBytes
            Case 1
                X64EmitText cg, "    mov byte " & X64FormatRbpRef(localOffset) & ", al"
            Case 2
                X64EmitText cg, "    mov word " & X64FormatRbpRef(localOffset) & ", ax"
            Case 4
                X64EmitText cg, "    mov dword " & X64FormatRbpRef(localOffset) & ", eax"
            Case Else
                X64EmitText cg, "    mov " & X64FormatRbpRef(localOffset) & ", rax"
            End Select
            Exit Sub
        End If

        Dim sbElemBytes As Integer
        sbElemBytes = 8
        Dim sbTypeName As String
        sbTypeName = ""
        If X64TryGetVarType(cg, varName, sbTypeName) <> 0 Then
            Select Case X64TypeToFloatKind(sbTypeName)
            Case UXF_F80
                sbElemBytes = 10
            Case UXF_F32
                sbElemBytes = 4
            Case Else
                sbElemBytes = 8
            End Select
        End If

        localOffset = X64EnsureLocalSlot(cg, varName, 1, sbElemBytes)
        Select Case sbElemBytes
        Case 1
            X64EmitText cg, "    mov byte " & X64FormatRbpRef(localOffset) & ", al"
        Case 2
            X64EmitText cg, "    mov word " & X64FormatRbpRef(localOffset) & ", ax"
        Case 4
            X64EmitText cg, "    mov dword " & X64FormatRbpRef(localOffset) & ", eax"
        Case Else
            X64EmitText cg, "    mov " & X64FormatRbpRef(localOffset) & ", rax"
        End Select
        Exit Sub
    End If

    Dim labelText As String
    labelText = X64EnsureVar(cg, varName)
    Select Case storeBytes
    Case 1
        X64EmitText cg, "    mov byte [rel " & labelText & "], al"
    Case 2
        X64EmitText cg, "    mov word [rel " & labelText & "], ax"
    Case 4
        X64EmitText cg, "    mov dword [rel " & labelText & "], eax"
    Case Else
        X64EmitText cg, "    mov [rel " & labelText & "], rax"
    End Select
End Sub

Private Function X64EmitAddrOfVar(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef errText As String) As Integer
    Dim localOffset As Integer
    Dim globalIdx As Integer
    globalIdx = X64FindGlobalSymbol(cg, varName)
    If cg.currentRoutineLabel <> "" Then
        If globalIdx <> -1 Then
            X64EmitText cg, "    lea rax, [rel " & gX64GlobalLabels(globalIdx) & "]"
            Return 1
        End If
        If X64TryFindLocalOffset(cg, varName, localOffset) <> 0 Then
            X64EmitText cg, "    lea rax, " & X64FormatRbpRef(localOffset)
            Return 1
        End If

        Dim aElemBytes As Integer
        aElemBytes = 8
        Dim aTypeName As String
        aTypeName = ""
        If X64TryGetVarType(cg, varName, aTypeName) <> 0 Then
            Select Case X64TypeToFloatKind(aTypeName)
            Case UXF_F80
                aElemBytes = 10
            Case UXF_F32
                aElemBytes = 4
            Case Else
                aElemBytes = 8
            End Select
        End If
        localOffset = X64EnsureLocalSlot(cg, varName, 1, aElemBytes)
        X64EmitText cg, "    lea rax, " & X64FormatRbpRef(localOffset)
        Return 1
    End If

    Dim labelText As String
    labelText = X64EnsureVar(cg, varName)
    If Trim(labelText) = "" Then
        errText = "x64-codegen: address target missing for " & varName
        Return 0
    End If

    X64EmitText cg, "    lea rax, [rel " & labelText & "]"
    Return 1
End Function

Private Function X64EmitPipeInvoke(ByRef ps As ParseState, ByVal targetNodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If targetNodeIdx < 0 Or targetNodeIdx >= ps.ast.count Then
        errText = "x64-codegen: pipe target missing"
        Return 0
    End If

    Dim targetKind As String
    targetKind = X64Upper(ps.ast.nodes(targetNodeIdx).kind)
    If targetKind <> "IDENT" And targetKind <> "KEYWORD_REF" Then
        errText = "x64-codegen: |> target must be identifier"
        Return 0
    End If

    Dim targetName As String
    targetName = Trim(ps.ast.nodes(targetNodeIdx).value)

    Dim builtinSym As String
    builtinSym = X64BuiltinCallSymbol(targetName)
    If builtinSym <> "" Then
        Dim upTarget As String
        upTarget = X64Upper(targetName)
        ' Float builtins: accept integer input in rax (pipe source) -> convert to xmm0, call, return double in xmm0
        If upTarget = "SQR" Or upTarget = "SIN" Or upTarget = "COS" Or upTarget = "TAN" Or upTarget = "ATN" Or upTarget = "EXP" Or upTarget = "LOG" Then
            X64EmitText cg, "    cvtsi2sd xmm0, rax"
            X64EmitText cg, "    sub rsp, 40"
            X64EmitText cg, "    call " & builtinSym
            X64EmitText cg, "    add rsp, 40"
            Return 1
        End If

        X64EmitCall1 cg, builtinSym
        Return 1
    End If

    Dim argCount As Integer
    Dim isFunction As Integer
    If X64TryGetRoutineSignature(cg, targetName, argCount, isFunction) = 0 Then
        errText = "x64-codegen: |> unknown target " & targetName
        Return 0
    End If
    If argCount <> 1 Then
        errText = "x64-codegen: |> target must accept exactly 1 argument"
        Return 0
    End If

    X64EmitText cg, "    mov rcx, rax"
    X64EmitText cg, "    xor rdx, rdx"
    X64EmitText cg, "    xor r8, r8"
    X64EmitText cg, "    xor r9, r9"
    X64EmitCall0 cg, targetName
    Return 1
End Function

Private Function X64ModeCodeFromText(ByRef rawMode As String) As Integer
    Select Case X64Upper(Trim(rawMode))
    Case "INPUT", "IN", "I"
        Return 1
    Case "OUTPUT", "OUT", "O"
        Return 2
    Case "APPEND", "A"
        Return 3
    Case "BINARY", "BIN", "B"
        Return 4
    Case "RANDOM", "RAND", "R"
        Return 5
    End Select

    Return 0
End Function

Private Function X64EmitAddrOfIndexedLocal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByVal elemStrideBytes As Integer, ByRef errText As String) As Integer
    Dim baseOffset As Integer
    Dim slotCount As Integer
    If X64TryFindLocalInfo(cg, varName, baseOffset, slotCount) = 0 Then Return 0

    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    Dim strideBytes As Integer
    strideBytes = elemStrideBytes
    If strideBytes <= 0 Then strideBytes = 8

    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideBytes)
    X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(baseOffset)
    X64EmitText cg, "    add rcx, rbx"
    X64EmitText cg, "    mov rax, rcx"
    Return 1
End Function

Private Function X64EmitAddrOfIndexedGlobal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByVal elemStrideBytes As Integer, ByRef errText As String) As Integer
    Dim keyText As String
    keyText = X64Upper(Trim(varName))
    If keyText = "" Then Return 0

    Dim labelText As String
    labelText = ""

    Dim i As Integer
    For i = 0 To cg.globalCount - 1
        If gX64GlobalKeys(i) = keyText Then
            labelText = gX64GlobalLabels(i)
            Exit For
        End If
    Next i

    If labelText = "" Then Return 0

    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    Dim strideBytes As Integer
    strideBytes = elemStrideBytes
    If strideBytes <= 0 Then strideBytes = 8

    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideBytes)
    X64EmitText cg, "    lea rcx, [rel " & labelText & "]"
    X64EmitText cg, "    add rcx, rbx"
    X64EmitText cg, "    mov rax, rcx"
    Return 1
End Function

Private Function X64BuildFieldPath(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef rootNameOut As String, ByRef pathOut As String, ByRef rootNodeOut As Integer) As Integer
    rootNameOut = ""
    pathOut = ""
    rootNodeOut = -1

    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    Dim k As String
    k = X64Upper(n.kind)

    If k = "IDENT" Or k = "KEYWORD_REF" Then
        rootNameOut = X64Upper(Trim(n.value))
        rootNodeOut = nodeIdx
        Return IIf(rootNameOut <> "", 1, 0)
    End If

    If k = "CALL_EXPR" Then
        Dim idxName As String
        Dim idxExpr As Integer
        If X64TryExtractIndexedTarget(ps, nodeIdx, idxName, idxExpr) = 0 Then Return 0

        rootNameOut = X64Upper(Trim(idxName))
        rootNodeOut = nodeIdx
        Return IIf(rootNameOut <> "", 1, 0)
    End If

    If k <> "FIELD_EXPR" Then Return 0

    Dim parentRoot As String
    Dim parentPath As String
    Dim parentRootNode As Integer
    If X64BuildFieldPath(ps, n.left, parentRoot, parentPath, parentRootNode) = 0 Then Return 0

    rootNameOut = parentRoot
    rootNodeOut = parentRootNode
    If parentPath = "" Then
        pathOut = X64Upper(Trim(n.value))
    Else
        pathOut = parentPath & "." & X64Upper(Trim(n.value))
    End If

    Return IIf(rootNameOut <> "" And pathOut <> "", 1, 0)
End Function

Private Function X64ResolveFieldInfo(ByRef ps As ParseState, ByVal fieldNode As Integer, ByRef cg As X64CodegenContext, ByRef rootNameOut As String, ByRef pathTextOut As String, ByRef rootNodeOut As Integer, ByRef rootTypeOut As String, ByRef fieldOffsetOut As Integer, ByRef fieldTypeOut As String, ByRef fieldSizeOut As Integer, ByRef errText As String) As Integer
    rootNameOut = ""
    pathTextOut = ""
    rootNodeOut = -1
    rootTypeOut = ""
    fieldOffsetOut = 0
    fieldTypeOut = ""
    fieldSizeOut = 0

    Dim fieldKind As String
    fieldKind = ""
    If fieldNode >= 0 And fieldNode < ps.ast.count Then fieldKind = X64Upper(ps.ast.nodes(fieldNode).kind)

    If fieldKind = "CALL_EXPR" Then
        Dim callName As String
        callName = Trim(ps.ast.nodes(fieldNode).value)
        Dim dotPos As Integer
        dotPos = InStr(callName, ".")
        If dotPos > 1 Then
            Dim idxNode As Integer
            idxNode = X64ChildAt(ps, fieldNode, 0)
            If idxNode = -1 Or X64ChildAt(ps, fieldNode, 1) <> -1 Then
                errText = "x64-codegen: field index expression is invalid"
                Return 0
            End If

            Dim idxText As String
            idxText = Trim(ps.ast.nodes(idxNode).value)
            If idxText = "" Then
                errText = "x64-codegen: dynamic field index is not supported in x64 backend yet"
                Return 0
            End If

            Dim idxPos As Integer
            idxPos = 1
            If Left(idxText, 1) = "+" Or Left(idxText, 1) = "-" Then
                idxPos = 2
            End If

            If idxPos > Len(idxText) Then
                errText = "x64-codegen: dynamic field index is not supported in x64 backend yet"
                Return 0
            End If

            Dim idxOk As Integer
            idxOk = 1
            Dim idxI As Integer
            For idxI = idxPos To Len(idxText)
                Dim idxCh As String
                idxCh = Mid(idxText, idxI, 1)
                If idxCh < "0" Or idxCh > "9" Then
                    idxOk = 0
                    Exit For
                End If
            Next idxI

            If idxOk = 0 Then
                errText = "x64-codegen: dynamic field index is not supported in x64 backend yet"
                Return 0
            End If

            rootNameOut = X64Upper(Trim(Left(callName, dotPos - 1)))
            pathTextOut = X64Upper(Trim(Mid(callName, dotPos + 1))) & "(" & idxText & ")"
            rootNodeOut = -1
        End If
    End If

    If rootNameOut = "" Or pathTextOut = "" Then
        If X64BuildFieldPath(ps, fieldNode, rootNameOut, pathTextOut, rootNodeOut) = 0 Then
            errText = "x64-codegen: invalid field expression"
            Return 0
        End If
    End If

    If X64FindDeclaredTypeName(ps, rootNameOut, rootTypeOut) = 0 Then
        If X64TryGetVarType(cg, rootNameOut, rootTypeOut) = 0 Then
            If rootNameOut = "THIS" Or rootNameOut = "ME" Then
                If X64ResolveCurrentReceiverClass(ps, cg, rootTypeOut) = 0 Then
                    errText = "x64-codegen: field root type missing for " & rootNameOut
                    Return 0
                End If
            Else
                errText = "x64-codegen: field root type missing for " & rootNameOut
                Return 0
            End If
        End If
    End If

    rootTypeOut = X64Upper(Trim(rootTypeOut))

    Dim layoutErr As String
    If TypeLayoutResolvePath(ps, rootTypeOut, pathTextOut, fieldOffsetOut, fieldTypeOut, fieldSizeOut, layoutErr) = 0 Then
        errText = "x64-codegen: field resolve failed " & layoutErr
        Return 0
    End If

    fieldTypeOut = X64Upper(Trim(fieldTypeOut))
    Return 1
End Function

Private Function X64EmitAddrOfFieldExpr(ByRef ps As ParseState, ByVal fieldNode As Integer, ByRef cg As X64CodegenContext, ByRef fieldTypeOut As String, ByRef fieldSizeOut As Integer, ByRef errText As String) As Integer
    Dim rootName As String
    Dim pathText As String
    Dim rootNode As Integer
    Dim rootType As String
    Dim fieldOffset As Integer

    If X64ResolveFieldInfo(ps, fieldNode, cg, rootName, pathText, rootNode, rootType, fieldOffset, fieldTypeOut, fieldSizeOut, errText) = 0 Then
        Return 0
    End If

    Dim indexedRootName As String
    Dim indexedRootExpr As Integer
    Dim isIndexedRoot As Integer
    isIndexedRoot = X64TryExtractIndexedTarget(ps, rootNode, indexedRootName, indexedRootExpr)

    If isIndexedRoot <> 0 Then
        Dim elemSize As Integer
        Dim elemSlots As Integer
        Dim strideBytes As Integer
        Dim elemLayoutErr As String

        If TypeLayoutSizeOf(ps, rootType, elemSize, elemLayoutErr) = 0 Then
            errText = "x64-codegen: indexed field element layout missing " & elemLayoutErr
            Return 0
        End If

        elemSlots = (elemSize + 7) \ 8
        If elemSlots < 1 Then elemSlots = 1
        strideBytes = elemSlots * 8

        If cg.currentRoutineLabel <> "" Then
            If X64EmitAddrOfIndexedLocal(ps, cg, indexedRootName, indexedRootExpr, strideBytes, errText) <> 0 Then
                ' RAX hazir.
            ElseIf X64EmitAddrOfIndexedGlobal(ps, cg, indexedRootName, indexedRootExpr, strideBytes, errText) = 0 Then
                errText = "x64-codegen: indexed field root currently supports DIM arrays"
                Return 0
            End If
        Else
            If X64EmitAddrOfIndexedGlobal(ps, cg, indexedRootName, indexedRootExpr, strideBytes, errText) = 0 Then
                errText = "x64-codegen: indexed field root currently supports DIM arrays"
                Return 0
            End If
        End If
    Else
        If rootType = "OBJECT" Or X64FindClassDeclNode(ps, rootType) <> -1 Then
            X64EmitLoadVar cg, rootName
        Else
            If X64EmitAddrOfVar(cg, rootName, errText) = 0 Then Return 0
        End If
    End If

    If fieldOffset <> 0 Then
        X64EmitText cg, "    add rax, " & X64ToStr(fieldOffset)
    End If

    Return 1
End Function

Private Function X64EmitStoreIntegerFieldExpr(ByRef ps As ParseState, ByVal fieldNode As Integer, ByRef cg As X64CodegenContext, ByVal fieldSize As Integer, ByRef errText As String) As Integer
    If fieldSize = 1 Then
        X64EmitText cg, "    mov byte [rax], dl"
    ElseIf fieldSize = 2 Then
        X64EmitText cg, "    mov word [rax], dx"
    ElseIf fieldSize = 4 Then
        X64EmitText cg, "    mov dword [rax], edx"
    ElseIf fieldSize = 8 Then
        X64EmitText cg, "    mov [rax], rdx"
    Else
        errText = "x64-codegen: unsupported field store size " & X64ToStr(fieldSize)
        Return 0
    End If

    X64EmitText cg, "    mov rax, rdx"
    Return 1
End Function

Private Function X64EmitStoreFieldFromRhs(ByRef ps As ParseState, ByVal fieldNode As Integer, ByVal rhsNode As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim rootName As String
    Dim pathText As String
    Dim rootNode As Integer
    Dim rootType As String
    Dim fieldOffset As Integer
    Dim fieldType As String
    Dim fieldSize As Integer

    If X64ResolveFieldInfo(ps, fieldNode, cg, rootName, pathText, rootNode, rootType, fieldOffset, fieldType, fieldSize, errText) = 0 Then
        Return 0
    End If

    Dim fk As Integer
    fk = X64TypeToFloatKind(fieldType)

    If fk = UXF_F32 Or fk = UXF_F64 Then
        If X64EmitExprToXmm0As(ps, rhsNode, cg, fk, errText) = 0 Then Return 0

        Dim addrFieldType As String
        Dim addrFieldSize As Integer
        If X64EmitAddrOfFieldExpr(ps, fieldNode, cg, addrFieldType, addrFieldSize, errText) = 0 Then Return 0

        If fk = UXF_F32 Then
            X64EmitText cg, "    movss [rax], xmm0"
        Else
            X64EmitText cg, "    movsd [rax], xmm0"
        End If
        Return 1
    ElseIf fk = UXF_F80 Then
        Dim f80Raw As String
        f80Raw = ""
        If X64TryGetNumberLiteral(ps, rhsNode, f80Raw) = 0 Then
            errText = "x64-codegen: F80 arithmetic not yet supported in x64 backend"
            Return 0
        End If

        Dim f80Label As String
        f80Label = X64CreateFloatConstant(cg, f80Raw, UXF_F80)

        Dim addrFieldType As String
        Dim addrFieldSize As Integer
        If X64EmitAddrOfFieldExpr(ps, fieldNode, cg, addrFieldType, addrFieldSize, errText) = 0 Then Return 0

        X64EmitText cg, "    mov rcx, rax"
        X64EmitStoreF80FromLabelAtRcX(cg, f80Label)
        Return 1
    End If

    If X64EmitExprToRax(ps, rhsNode, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rdx, rax"

    Dim addrType As String
    Dim addrSize As Integer
    If X64EmitAddrOfFieldExpr(ps, fieldNode, cg, addrType, addrSize, errText) = 0 Then Return 0

    Return X64EmitStoreIntegerFieldExpr(ps, fieldNode, cg, fieldSize, errText)
End Function

Private Function X64EmitLoadFieldExpr(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim fieldType As String
    Dim fieldSize As Integer

    If X64EmitAddrOfFieldExpr(ps, nodeIdx, cg, fieldType, fieldSize, errText) = 0 Then
        Return 0
    End If

    Dim fk As Integer
    fk = X64TypeToFloatKind(fieldType)
    If fk = UXF_F32 Then
        X64EmitText cg, "    movss xmm0, [rax]"
        Return 1
    ElseIf fk = UXF_F64 Then
        X64EmitText cg, "    movsd xmm0, [rax]"
        Return 1
    ElseIf fk = UXF_F80 Then
        ' F80 yukunu x87 ile qword'e indirip hem XMM0 hem de RAX fallback'i besle.
        X64EmitText cg, "    sub rsp, 16"
        X64EmitText cg, "    fld tword [rax]"
        X64EmitText cg, "    fstp qword [rsp]"
        X64EmitText cg, "    movsd xmm0, [rsp]"
        X64EmitText cg, "    add rsp, 16"
        X64EmitText cg, "    cvttsd2si rax, xmm0"
        Return 1
    End If

    If fieldSize = 1 Then
        X64EmitText cg, "    movsx rax, byte [rax]"
    ElseIf fieldSize = 2 Then
        X64EmitText cg, "    movsx rax, word [rax]"
    ElseIf fieldSize = 4 Then
        X64EmitText cg, "    movsxd rax, dword [rax]"
    ElseIf fieldSize = 8 Then
        X64EmitText cg, "    mov rax, [rax]"
    Else
        errText = "x64-codegen: unsupported field load size " & X64ToStr(fieldSize)
        Return 0
    End If
    Return 1
End Function

Private Function X64EmitStoreFieldExpr(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim fieldType As String
    Dim fieldSize As Integer
    X64EmitText cg, "    mov rdx, rax"

    If X64EmitAddrOfFieldExpr(ps, nodeIdx, cg, fieldType, fieldSize, errText) = 0 Then
        Return 0
    End If

    Dim fk As Integer
    fk = X64TypeToFloatKind(fieldType)
    If fk = UXF_F32 Or fk = UXF_F64 Then
        errText = "x64-codegen: float field compound store is not supported yet"
        Return 0
    ElseIf fk = UXF_F80 Then
        errText = "x64-codegen: F80 field store is not implemented in x64 backend yet"
        Return 0
    End If

    Return X64EmitStoreIntegerFieldExpr(ps, nodeIdx, cg, fieldSize, errText)
End Function

Private Function X64TryParseInteger(ByRef textValue As String, ByRef outValue As LongInt) As Integer
    Dim t As String
    t = Trim(textValue)
    If t = "" Then Return 0

    Dim sign As LongInt
    sign = 1
    If Left(t, 1) = "+" Then
        t = Mid(t, 2)
    ElseIf Left(t, 1) = "-" Then
        sign = -1
        t = Mid(t, 2)
    End If

    If t = "" Then Return 0

    Dim i As Integer
    Dim acc As LongInt
    acc = 0
    For i = 1 To Len(t)
        Dim ch As String
        ch = Mid(t, i, 1)
        If ch < "0" Or ch > "9" Then Return 0
        acc = acc * 10 + CLngInt(Asc(ch) - Asc("0"))
    Next i

    outValue = acc * sign
    Return 1
End Function

Private Sub X64EmitLabel(ByRef cg As X64CodegenContext, ByRef labelText As String)
    X64EmitText cg, labelText & ":"
End Sub

Private Function X64ChildAt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal childPos As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return -1

    Dim i As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild

    i = 0
    Do While ch <> -1
        If i = childPos Then Return ch
        ch = ps.ast.nodes(ch).nextSibling
        i += 1
    Loop

    Return -1
End Function

Private Function X64ChildCount(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim count As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild

    Do While ch <> -1
        count += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return count
End Function

Private Function X64IsStmtKind(ByRef kindText As String) As Integer
    Dim k As String
    k = X64Upper(kindText)
    If Right(k, 5) = "_STMT" Then Return 1

    Select Case k
    Case "PRINT", "IF", "FOR", "DO", "CALL", "RETURN", "EXIT", "LET", "DIM", "REDIM", "CLS", "COLOR", "LOCATE", "RANDOMIZE"
        Return 1
    End Select

    Return 0
End Function

Private Function X64IsDllCallNode(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)
    If nodeKind <> "CALL_STMT" And nodeKind <> "CALL_EXPR" And nodeKind <> "CALL" Then Return 0

    Dim calleeName As String
    calleeName = X64Upper(ps.ast.nodes(nodeIdx).value)
    If calleeName = "DLL" Then Return 1

    If calleeName = "CALL" Then
        Dim firstArg As Integer
        firstArg = X64ChildAt(ps, nodeIdx, 0)
        If firstArg <> -1 Then
            Dim firstKind As String
            firstKind = X64Upper(ps.ast.nodes(firstArg).kind)
            If firstKind = "IDENT" Or firstKind = "KEYWORD_REF" Then
                Return IIf(X64Upper(ps.ast.nodes(firstArg).value) = "DLL", 1, 0)
            End If
        End If
    End If

    Return 0
End Function

Private Function X64DllCallArgStartPos(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    Dim argc As Integer
    argc = X64ChildCount(ps, nodeIdx)

    Dim callName As String
    callName = X64Upper(ps.ast.nodes(nodeIdx).value)

    Dim argStartPos As Integer
    If callName = "CALL" Then
        argStartPos = 4
        If argc >= 6 Then
            Dim convNode As Integer
            convNode = X64ChildAt(ps, nodeIdx, 4)
            If convNode <> -1 And X64Upper(ps.ast.nodes(convNode).kind) = "KEYWORD_REF" Then
                Dim convCandidate As String
                convCandidate = X64Upper(ps.ast.nodes(convNode).value)
                If convCandidate = "CDECL" Or convCandidate = "STDCALL" Then argStartPos = 5
            End If
        End If
    Else
        argStartPos = 3
        If argc >= 5 Then
            Dim convNode As Integer
            convNode = X64ChildAt(ps, nodeIdx, 3)
            If convNode <> -1 And X64Upper(ps.ast.nodes(convNode).kind) = "KEYWORD_REF" Then
                Dim convCandidate As String
                convCandidate = X64Upper(ps.ast.nodes(convNode).value)
                If convCandidate = "CDECL" Or convCandidate = "STDCALL" Then argStartPos = 4
            End If
        End If
    End If

    Dim typeListNode As Integer
    typeListNode = X64ChildAt(ps, nodeIdx, argStartPos)
    If typeListNode <> -1 And X64Upper(ps.ast.nodes(typeListNode).kind) = "STRING" Then
        If Instr(ps.ast.nodes(typeListNode).value, ",") > 0 Then argStartPos += 1
    End If

    Return argStartPos
End Function

Private Function X64FfiArgCountAt(ByVal idx As Integer) As Integer
    If idx < 0 Or idx > UBound(gX64FfiArgCounts) Then Return 0
    If gX64FfiArgCounts(idx) < 0 Then Return 0
    Return gX64FfiArgCounts(idx)
End Function

Private Sub X64ResetFfiArgCounts()
    Dim i As Integer
    For i = 0 To UBound(gX64FfiArgCounts)
        gX64FfiArgCounts(i) = 0
    Next i
End Sub

Private Sub X64CollectDllCallPlanNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext)
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Exit Sub

    If X64IsDllCallNode(ps, nodeIdx) <> 0 Then
        Dim argc As Integer
        argc = X64ChildCount(ps, nodeIdx)
        Dim argStartPos As Integer
        argStartPos = X64DllCallArgStartPos(ps, nodeIdx)

        If cg.ffiCallTotal >= 0 And cg.ffiCallTotal <= UBound(gX64FfiArgCounts) Then
            gX64FfiArgCounts(cg.ffiCallTotal) = argc - argStartPos
            If gX64FfiArgCounts(cg.ffiCallTotal) < 0 Then gX64FfiArgCounts(cg.ffiCallTotal) = 0
            cg.ffiCallTotal += 1
        End If
    Else
        Dim nodeKind As String
        nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)
        Dim nodeValue As String
        nodeValue = X64Upper(ps.ast.nodes(nodeIdx).value)
        If (nodeKind = "CALL_EXPR" Or nodeKind = "CALL_STMT" Or nodeKind = "CALL") And nodeValue = "CALL" Then
            Dim firstArg As Integer
            firstArg = X64ChildAt(ps, nodeIdx, 0)
            If firstArg <> -1 Then
                Dim firstKind As String
                firstKind = X64Upper(ps.ast.nodes(firstArg).kind)
                If (firstKind = "IDENT" Or firstKind = "KEYWORD_REF") And X64Upper(ps.ast.nodes(firstArg).value) = "DLL" Then
                    Dim argc2 As Integer
                    argc2 = X64ChildCount(ps, nodeIdx)
                    Dim argStartPos2 As Integer
                    argStartPos2 = X64DllCallArgStartPos(ps, nodeIdx)
                    If cg.ffiCallTotal >= 0 And cg.ffiCallTotal <= UBound(gX64FfiArgCounts) Then
                        gX64FfiArgCounts(cg.ffiCallTotal) = argc2 - argStartPos2
                        If gX64FfiArgCounts(cg.ffiCallTotal) < 0 Then gX64FfiArgCounts(cg.ffiCallTotal) = 0
                        cg.ffiCallTotal += 1
                    End If
                End If
            End If
        End If
    End If

    If ps.ast.nodes(nodeIdx).left <> -1 Then X64CollectDllCallPlanNode ps, ps.ast.nodes(nodeIdx).left, cg
    If ps.ast.nodes(nodeIdx).right <> -1 Then X64CollectDllCallPlanNode ps, ps.ast.nodes(nodeIdx).right, cg

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        X64CollectDllCallPlanNode ps, ch, cg
        ch = ps.ast.nodes(ch).nextSibling
    Loop
End Sub

Private Function X64CollectDllCallPlan(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext) As Integer
    cg.ffiCallTotal = 0
    cg.ffiCallEmitIndex = 0
    X64ResetFfiArgCounts
    X64CollectDllCallPlanNode ps, nodeIdx, cg
    Return 1
End Function

Private Sub X64EmitDllExterns(ByRef cg As X64CodegenContext)
    Dim i As Integer
    For i = 0 To cg.ffiCallTotal - 1
        Dim stubId As String
        stubId = X64ToStr(i + 1)
        X64EmitText cg, "extern __uxb_ffi_stub_" & stubId

        Dim argIdx As Integer
        For argIdx = 1 To X64FfiArgCountAt(i)
            X64EmitText cg, "extern __uxb_ffi_arg_" & stubId & "_" & X64ToStr(argIdx)
        Next argIdx
    Next i

    If cg.ffiCallTotal > 0 Then X64EmitText cg, ""
End Sub

Private Sub X64EmitFfiSupport(ByRef cg As X64CodegenContext)
    If cg.ffiCallTotal <= 0 Then Exit Sub

    Dim i As Integer
    For i = 0 To cg.ffiCallTotal - 1
        Dim stubId As String
        stubId = X64ToStr(i + 1)

        X64EmitText cg, "global __uxb_ffi_stub_" & stubId
        X64EmitText cg, "global __uxb_ffi_symptr_" & stubId
        Dim globalArgIdx As Integer
        For globalArgIdx = 1 To X64FfiArgCountAt(i)
            X64EmitText cg, "global __uxb_ffi_arg_" & stubId & "_" & X64ToStr(globalArgIdx)
        Next globalArgIdx
        X64EmitText cg, "__uxb_ffi_stub_" & stubId & ":"
        X64EmitText cg, "    sub rsp, 40"

        If X64FfiArgCountAt(i) >= 1 Then
            X64EmitText cg, "    mov rcx, qword [rel __uxb_ffi_arg_" & stubId & "_1]"
            X64EmitText cg, "    movq xmm0, rcx"
        End If
        If X64FfiArgCountAt(i) >= 2 Then
            X64EmitText cg, "    mov rdx, qword [rel __uxb_ffi_arg_" & stubId & "_2]"
            X64EmitText cg, "    movq xmm1, rdx"
        End If
        If X64FfiArgCountAt(i) >= 3 Then
            X64EmitText cg, "    mov r8, qword [rel __uxb_ffi_arg_" & stubId & "_3]"
            X64EmitText cg, "    movq xmm2, r8"
        End If
        If X64FfiArgCountAt(i) >= 4 Then
            X64EmitText cg, "    mov r9, qword [rel __uxb_ffi_arg_" & stubId & "_4]"
            X64EmitText cg, "    movq xmm3, r9"
        End If

        Dim argIdx As Integer
        For argIdx = 5 To X64FfiArgCountAt(i)
            Dim slotOffset As Integer
            slotOffset = 32 + ((argIdx - 5) * 8)
            X64EmitText cg, "    mov rax, qword [rel __uxb_ffi_arg_" & stubId & "_" & X64ToStr(argIdx) & "]"
            X64EmitText cg, "    mov qword [rsp + " & X64ToStr(slotOffset) & "], rax"
        Next argIdx

        X64EmitText cg, "    mov r11, qword [rel __uxb_ffi_symptr_" & stubId & "]"
        X64EmitText cg, "    test r11, r11"
        X64EmitText cg, "    jnz __uxb_ffi_call_" & stubId
        X64EmitText cg, "    xor rax, rax"
        X64EmitText cg, "    add rsp, 40"
        X64EmitText cg, "    ret"
        X64EmitText cg, "__uxb_ffi_call_" & stubId & ":"
        X64EmitText cg, "    call r11"
        X64EmitText cg, "    add rsp, 40"
        X64EmitText cg, "    ret"
        X64EmitText cg, ""

        X64EmitData cg, "__uxb_ffi_symptr_" & stubId & ": dq 0"
        For argIdx = 1 To X64FfiArgCountAt(i)
            X64EmitData cg, "__uxb_ffi_arg_" & stubId & "_" & X64ToStr(argIdx) & ": dq 0"
        Next argIdx
    Next i
End Sub

Private Function X64EmitDllCallNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If cg.ffiCallEmitIndex >= cg.ffiCallTotal Then
        errText = "x64-codegen: ffi call emit index overflow"
        Return 0
    End If

    Dim stubIdNum As Integer
    stubIdNum = cg.ffiCallEmitIndex + 1
    Dim stubId As String
    stubId = X64ToStr(stubIdNum)

    Dim argc As Integer
    argc = X64ChildCount(ps, nodeIdx)

    Dim argStartPos As Integer
    argStartPos = X64DllCallArgStartPos(ps, nodeIdx)

    Dim argCount As Integer
    argCount = argc - argStartPos
    If argCount < 0 Then argCount = 0

    Dim i As Integer
    For i = 0 To argCount - 1
        Dim argNode As Integer
        argNode = X64ChildAt(ps, nodeIdx, argStartPos + i)
        If argNode = -1 Then Continue For

        Dim argFloatKind As Integer
        argFloatKind = X64InferFloatKindOfExpr(ps, argNode, cg)

        If argFloatKind = UXF_F32 Or argFloatKind = UXF_F64 Then
            ' C/varargs uyumu: float arglar qword-double bit pattern olarak saklanir.
            If X64EmitExprToXmm0As(ps, argNode, cg, UXF_F64, errText) = 0 Then Return 0
            X64EmitText cg, "    movq rax, xmm0"
        Else
            If X64EmitExprToRax(ps, argNode, cg, errText) = 0 Then Return 0
        End If

        X64EmitText cg, "    mov [rel __uxb_ffi_arg_" & stubId & "_" & X64ToStr(i + 1) & "], rax"
    Next i

    X64EmitText cg, "    call __uxb_ffi_stub_" & stubId
    cg.ffiCallEmitIndex += 1
    Return 1
End Function

Private Function X64ComputeDimSlotCount(ByRef ps As ParseState, ByVal declNode As Integer) As Integer
    If declNode < 0 Or declNode >= ps.ast.count Then Return 1

    Dim boundsNode As Integer
    boundsNode = -1

    Dim subNode As Integer
    subNode = ps.ast.nodes(declNode).firstChild
    Do While subNode <> -1
        If X64Upper(ps.ast.nodes(subNode).kind) = "DIM_BOUNDS" Then
            boundsNode = subNode
            Exit Do
        End If
        subNode = ps.ast.nodes(subNode).nextSibling
    Loop


    Dim slotCount As Integer
    slotCount = 1

    Dim typeNode As Integer
    typeNode = -1
    subNode = ps.ast.nodes(declNode).firstChild
    Do While subNode <> -1
        If X64Upper(ps.ast.nodes(subNode).kind) = "TYPE_REF" Then
            typeNode = subNode
            Exit Do
        End If
        subNode = ps.ast.nodes(subNode).nextSibling
    Loop

    ' Determine element byte size (aggSize). Default to 8 bytes.
    Dim elemBytes As Integer
    elemBytes = 8
    If typeNode <> -1 Then
        Dim declType As String
        declType = X64Upper(Trim(ps.ast.nodes(typeNode).value))
        Dim aggSize As Integer
        Dim aggErr As String
        If TypeLayoutSizeOf(ps, declType, aggSize, aggErr) <> 0 Then
            If aggSize > 0 Then elemBytes = aggSize
        End If
    End If

    ' If no bounds, this is a scalar - element count = 1
    If boundsNode = -1 Then
        slotCount = 1
        Return slotCount
    End If

    Dim b As Integer
    b = ps.ast.nodes(boundsNode).firstChild
    Do While b <> -1
        Dim k As String
        k = X64Upper(ps.ast.nodes(b).kind)
        If k = "RANGE_EXPR" Then
            Dim lo As LongInt
            Dim hi As LongInt
            If ps.ast.nodes(b).left <> -1 And ps.ast.nodes(b).right <> -1 And _
               X64TryParseInteger(ps.ast.nodes(ps.ast.nodes(b).left).value, lo) <> 0 And _
               X64TryParseInteger(ps.ast.nodes(ps.ast.nodes(b).right).value, hi) <> 0 Then
                Dim span As LongInt
                span = hi - lo + 1
                If span < 1 Then span = 1
                slotCount *= CInt(span)
            End If
        ElseIf k = "NUMBER" Then
            Dim n As LongInt
            If X64TryParseInteger(ps.ast.nodes(b).value, n) <> 0 Then
                If n < 1 Then n = 1
                slotCount *= CInt(n)
            End If
        End If
        b = ps.ast.nodes(b).nextSibling
    Loop
    ' slotCount now holds element count
    If slotCount < 1 Then slotCount = 1
    Return slotCount
End Function

Private Function X64TryExtractIndexedTarget(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef baseNameOut As String, ByRef indexExprOut As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    baseNameOut = ""
    indexExprOut = -1

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    If nodeKind = "CALL_EXPR" Then
        baseNameOut = Trim(ps.ast.nodes(nodeIdx).value)
        indexExprOut = X64ChildAt(ps, nodeIdx, 0)
        If baseNameOut <> "" And indexExprOut <> -1 And X64ChildCount(ps, nodeIdx) = 1 Then
            Return 1
        End If
        Return 0
    End If

    If nodeKind = "INDEX_EXPR" Or nodeKind = "ARRAY_INDEX" Or nodeKind = "SUBSCRIPT_EXPR" Or nodeKind = "ARRAY_ACCESS" Then
        Dim baseNode As Integer
        baseNode = ps.ast.nodes(nodeIdx).left
        If baseNode = -1 Then baseNode = X64ChildAt(ps, nodeIdx, 0)
        If baseNode <> -1 Then
            Dim baseKind As String
            baseKind = X64Upper(ps.ast.nodes(baseNode).kind)
            If baseKind = "IDENT" Or baseKind = "IDENTIFIER" Or baseKind = "VAR" Or baseKind = "VAR_REF" Then
                baseNameOut = Trim(ps.ast.nodes(baseNode).value)
            End If
        End If

        indexExprOut = ps.ast.nodes(nodeIdx).right
        If indexExprOut = -1 Then indexExprOut = X64ChildAt(ps, nodeIdx, 1)
        If indexExprOut = -1 Then indexExprOut = X64ChildAt(ps, nodeIdx, 0)

        If baseNameOut <> "" And indexExprOut <> -1 Then Return 1
    End If

    Return 0
End Function

Private Function X64EmitLoadIndexedLocal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim baseOffset As Integer
    Dim slotCount As Integer
    If X64TryFindLocalInfo(cg, varName, baseOffset, slotCount) = 0 Then Return 0

    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rbx, rax"
    Dim strideBytes As Integer
    strideBytes = 8
    If X64TryGetLocalElemBytes(cg, varName, strideBytes) = 0 Then strideBytes = 8
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideBytes)
    X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(baseOffset)
    X64EmitText cg, "    add rcx, rbx"
    X64EmitText cg, "    mov rax, [rcx]"
    Return 1
End Function

Private Function X64EmitStoreIndexedLocal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim baseOffset As Integer
    Dim slotCount As Integer
    If X64TryFindLocalInfo(cg, varName, baseOffset, slotCount) = 0 Then Return 0

    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    pop rax"
    Dim strideBytes2 As Integer
    strideBytes2 = 8
    If X64TryGetLocalElemBytes(cg, varName, strideBytes2) = 0 Then strideBytes2 = 8
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideBytes2)
    X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(baseOffset)
    X64EmitText cg, "    add rcx, rbx"
    X64EmitText cg, "    mov [rcx], rax"
    Return 1
End Function

Private Function X64TryFindGlobalInfo(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef labelOut As String, ByRef slotCountOut As Integer) As Integer
    Dim keyText As String
    keyText = X64Upper(Trim(varName))
    If keyText = "" Then
        labelOut = ""
        slotCountOut = 0
        Return 0
    End If

    Dim i As Integer
    For i = 0 To cg.globalCount - 1
        If gX64GlobalKeys(i) = keyText Then
            labelOut = gX64GlobalLabels(i)
            slotCountOut = gX64GlobalSlots(i)
            Return 1
        End If
    Next i

    labelOut = ""
    slotCountOut = 0
    Return 0
End Function

Private Function X64TryGetGlobalElemBytes(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef elemBytesOut As Integer) As Integer
    Dim keyText As String
    keyText = X64Upper(Trim(varName))
    If keyText = "" Then
        elemBytesOut = 8
        Return 0
    End If

    Dim i As Integer
    For i = 0 To cg.globalCount - 1
        If gX64GlobalKeys(i) = keyText Then
            elemBytesOut = gX64GlobalElemBytes(i)
            If elemBytesOut <= 0 Then elemBytesOut = 8
            Return 1
        End If
    Next i

    elemBytesOut = 8
    Return 0
End Function

Private Function X64EmitLoadIndexedGlobal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim labelText As String
    Dim slotCount As Integer
    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) = 0 Then Return 0

    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rbx, rax"
    Dim gStride As Integer
    gStride = 8
    If X64TryGetGlobalElemBytes(cg, varName, gStride) = 0 Then gStride = 8
    X64EmitText cg, "    imul rbx, " & X64ToStr(gStride)
    X64EmitText cg, "    lea rcx, [rel " & labelText & "]"
    X64EmitText cg, "    add rcx, rbx"
    X64EmitText cg, "    mov rax, [rcx]"
    Return 1
End Function

Private Function X64EmitStoreIndexedGlobal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim labelText As String
    Dim slotCount As Integer
    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) = 0 Then Return 0

    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    pop rax"
    Dim gStride2 As Integer
    gStride2 = 8
    If X64TryGetGlobalElemBytes(cg, varName, gStride2) = 0 Then gStride2 = 8
    X64EmitText cg, "    imul rbx, " & X64ToStr(gStride2)
    X64EmitText cg, "    lea rcx, [rel " & labelText & "]"
    X64EmitText cg, "    add rcx, rbx"
    X64EmitText cg, "    mov [rcx], rax"
    Return 1
End Function

Private Sub X64CollectRoutineLocals(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext)
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Exit Sub

    Dim kindText As String
    kindText = X64Upper(ps.ast.nodes(nodeIdx).kind)

    If kindText = "DIM_STMT" Or kindText = "DIM" Or kindText = "REDIM_STMT" Or kindText = "REDIM" Then
        Dim decl As Integer
        decl = ps.ast.nodes(nodeIdx).firstChild
        Do While decl <> -1
            Dim declName As String
            declName = Trim(ps.ast.nodes(decl).value)
            If declName <> "" Then
                Dim elemCountL As Integer
                elemCountL = X64ComputeDimSlotCount(ps, decl)
                ' determine element bytes from declared type if available
                Dim elemBytesL As Integer
                elemBytesL = 8
                Dim declTypeL As String
                declTypeL = ""
                If X64FindDeclaredTypeName(ps, declName, declTypeL) <> 0 Then
                    Dim aSize As Integer
                    Dim aErr As String
                    If TypeLayoutSizeOf(ps, declTypeL, aSize, aErr) <> 0 Then
                        If aSize > 0 Then elemBytesL = aSize
                    Else
                        Select Case X64TypeToFloatKind(declTypeL)
                        Case UXF_F80
                            elemBytesL = 10
                        Case UXF_F32
                            elemBytesL = 4
                        Case Else
                            elemBytesL = 8
                        End Select
                    End If
                End If
                X64EnsureLocalSlot(cg, declName, elemCountL, elemBytesL)
            End If
            decl = ps.ast.nodes(decl).nextSibling
        Loop
    ElseIf kindText = "ASSIGN_STMT" Then
        Dim lhs As Integer
        lhs = ps.ast.nodes(nodeIdx).left
        If lhs <> -1 Then
            Dim lhsName As String
            Dim lhsKind As String
            lhsKind = X64Upper(ps.ast.nodes(lhs).kind)

            If lhsKind = "IDENT" Or lhsKind = "IDENTIFIER" Then
                lhsName = Trim(ps.ast.nodes(lhs).value)
                If lhsName <> "" And X64HasTopLevelGlobalDecl(ps, lhsName) = 0 Then
                    Dim lbElem As Integer
                    lbElem = 8
                    Dim declT As String
                    declT = ""
                    If X64FindDeclaredTypeName(ps, lhsName, declT) <> 0 Then
                        Dim sSize As Integer
                        Dim sErr As String
                        If TypeLayoutSizeOf(ps, declT, sSize, sErr) <> 0 Then
                            If sSize > 0 Then lbElem = sSize
                        Else
                            Select Case X64TypeToFloatKind(declT)
                            Case UXF_F80
                                lbElem = 10
                            Case UXF_F32
                                lbElem = 4
                            Case Else
                                lbElem = 8
                            End Select
                        End If
                    Else
                        Dim tmpType As String
                        tmpType = ""
                        If X64TryGetVarType(cg, lhsName, tmpType) <> 0 Then
                            Select Case X64TypeToFloatKind(tmpType)
                            Case UXF_F80
                                lbElem = 10
                            Case UXF_F32
                                lbElem = 4
                            End Select
                        End If
                    End If
                    X64EnsureLocalSlot(cg, lhsName, 1, lbElem)
                End If
            Else
                Dim idxName As String
                Dim idxExpr As Integer
                If X64TryExtractIndexedTarget(ps, lhs, idxName, idxExpr) <> 0 Then
                    If idxName <> "" And X64HasTopLevelGlobalDecl(ps, idxName) = 0 Then
                        Dim ibElem As Integer
                        ibElem = 8
                        Dim idxDecl As String
                        idxDecl = ""
                        If X64FindDeclaredTypeName(ps, idxName, idxDecl) <> 0 Then
                            Dim isz As Integer
                            Dim ierr As String
                            If TypeLayoutSizeOf(ps, idxDecl, isz, ierr) <> 0 Then
                                If isz > 0 Then ibElem = isz
                            Else
                                Select Case X64TypeToFloatKind(idxDecl)
                                Case UXF_F80
                                    ibElem = 10
                                Case UXF_F32
                                    ibElem = 4
                                End Select
                            End If
                        Else
                            Dim itmp As String
                            itmp = ""
                            If X64TryGetVarType(cg, idxName, itmp) <> 0 Then
                                Select Case X64TypeToFloatKind(itmp)
                                Case UXF_F80
                                    ibElem = 10
                                Case UXF_F32
                                    ibElem = 4
                                End Select
                            End If
                        End If
                        X64EnsureLocalSlot(cg, idxName, 1, ibElem)
                    End If
                End If
            End If
        End If
    ElseIf kindText = "INCDEC_STMT" Then
        Dim lhs As Integer
        lhs = ps.ast.nodes(nodeIdx).left
        If lhs <> -1 Then
            Dim lhsName As String
            lhsName = Trim(ps.ast.nodes(lhs).value)
            If lhsName <> "" And X64HasTopLevelGlobalDecl(ps, lhsName) = 0 Then
                Dim dElem As Integer
                dElem = 8
                Dim dDecl As String
                dDecl = ""
                If X64FindDeclaredTypeName(ps, lhsName, dDecl) <> 0 Then
                    Dim ds As Integer
                    Dim de As String
                    If TypeLayoutSizeOf(ps, dDecl, ds, de) <> 0 Then
                        If ds > 0 Then dElem = ds
                    Else
                        Select Case X64TypeToFloatKind(dDecl)
                        Case UXF_F80
                            dElem = 10
                        Case UXF_F32
                            dElem = 4
                        End Select
                    End If
                Else
                    Dim dtTmp As String
                    dtTmp = ""
                    If X64TryGetVarType(cg, lhsName, dtTmp) <> 0 Then
                        Select Case X64TypeToFloatKind(dtTmp)
                        Case UXF_F80
                            dElem = 10
                        Case UXF_F32
                            dElem = 4
                        End Select
                    End If
                End If
                X64EnsureLocalSlot(cg, lhsName, 1, dElem)
            End If
        End If
    ElseIf kindText = "FOR_STMT" Or kindText = "FOR" Then
        Dim loopVar As String
        loopVar = Trim(ps.ast.nodes(nodeIdx).value)
        If loopVar <> "" And X64HasTopLevelGlobalDecl(ps, loopVar) = 0 Then
            Dim lvElem As Integer
            lvElem = 8
            Dim lvDecl As String
            lvDecl = ""
            If X64FindDeclaredTypeName(ps, loopVar, lvDecl) <> 0 Then
                Dim lvs As Integer
                Dim lve As String
                If TypeLayoutSizeOf(ps, lvDecl, lvs, lve) <> 0 Then
                    If lvs > 0 Then lvElem = lvs
                Else
                    Select Case X64TypeToFloatKind(lvDecl)
                    Case UXF_F80
                        lvElem = 10
                    Case UXF_F32
                        lvElem = 4
                    End Select
                End If
            End If
            X64EnsureLocalSlot(cg, loopVar, 1, lvElem)
        End If
    End If

    If kindText = "SUB_STMT" Or kindText = "FUNCTION_STMT" Then Exit Sub

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        X64CollectRoutineLocals(ps, ch, cg)
        ch = ps.ast.nodes(ch).nextSibling
    Loop
End Sub

Private Function X64EmitExprToRax(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "x64-codegen: invalid expr node"
        Return 0
    End If

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case nodeKind
    Case "NUMBER", "INTEGER", "INT", "INT_LITERAL"
        Dim rawNumber As String
        rawNumber = Trim(ps.ast.nodes(nodeIdx).value)
        If rawNumber = "" Then rawNumber = "0"
        Dim intNumber As LongInt
        If X64TryParseInteger(rawNumber, intNumber) <> 0 Then
            X64EmitText cg, "    mov rax, " & LTrim(Str(intNumber))
        Else
            X64EmitText cg, "    mov rax, " & LTrim(Str(CLng(Val(rawNumber))))
        End If
        Return 1
    Case "STRING", "STRING_LITERAL"
        Dim strLabel As String
        Dim rawString As String
        Dim escapedString As String
        Dim si As Integer
        strLabel = X64NextLabel(cg, "str")
        rawString = ps.ast.nodes(nodeIdx).value
        escapedString = ""
        For si = 1 To Len(rawString)
            Dim sch As String
            sch = Mid(rawString, si, 1)
            If sch = Chr(34) Then
                escapedString &= Chr(34) & Chr(34)
            Else
                escapedString &= sch
            End If
        Next si
        X64EmitData cg, strLabel & ": db " & Chr(34) & escapedString & Chr(34) & ", 0"
        X64EmitText cg, "    lea rax, [rel " & strLabel & "]"
        Return 1
    Case "IDENT", "IDENTIFIER", "VAR", "NAME", "VAR_REF", "KEYWORD_REF"
        Dim identName As String
        identName = Trim(ps.ast.nodes(nodeIdx).value)
        If X64Upper(identName) = "TRUE" Then
            X64EmitText cg, "    mov rax, 1"
        ElseIf X64Upper(identName) = "FALSE" Then
            X64EmitText cg, "    xor rax, rax"
        Else
            If VarMappingEmitLoad(cg.localVars, cg.currentRoutineLabel, identName, cg.textSection) = 0 Then
                X64EmitLoadVar cg, identName
            End If
        End If
        Return 1
    Case "CALL_EXPR"
        Dim indexedBaseName As String
        Dim indexedExpr As Integer
        If X64TryExtractIndexedTarget(ps, nodeIdx, indexedBaseName, indexedExpr) <> 0 Then
            If InStr(indexedBaseName, ".") > 0 Then
                Return X64EmitLoadFieldExpr(ps, nodeIdx, cg, errText)
            End If
            If cg.currentRoutineLabel <> "" And X64EmitLoadIndexedLocal(ps, cg, indexedBaseName, indexedExpr, errText) <> 0 Then
                Return 1
            End If
            If X64EmitLoadIndexedGlobal(ps, cg, indexedBaseName, indexedExpr, errText) <> 0 Then
                Return 1
            End If
        End If
        Return X64EmitCallNode(ps, nodeIdx, cg, errText)
    Case "NEW_EXPR"
        Dim classTypeName As String
        classTypeName = UCase(Trim(ps.ast.nodes(nodeIdx).value))
        If classTypeName = "" Then
            errText = "x64-codegen: NEW_EXPR missing class type"
            Return 0
        End If

        Dim classSize As Integer
        Dim layoutErr As String
        If TypeLayoutSizeOf(ps, classTypeName, classSize, layoutErr) = 0 Then
            errText = "x64-codegen: NEW_EXPR layout resolve failed " & layoutErr
            Return 0
        End If
        If classSize <= 0 Then
            errText = "x64-codegen: unresolved class layout: " & classTypeName
            Return 0
        End If

        X64EmitComment cg, "NEW_EXPR native allocation"
        X64EmitText cg, "    mov rcx, 1"
        X64EmitText cg, "    mov rdx, " & X64ToStr(classSize)
        X64EmitText cg, "    sub rsp, 32"
        X64EmitText cg, "    call calloc"
        X64EmitText cg, "    add rsp, 32"

        ' initialize vptr to class vtable
        X64EmitText cg, "    lea rdx, [rel " & X64ClassVTableLabel(classTypeName) & "]"
        X64EmitText cg, "    mov [rax], rdx"

        Dim ctorName As String
        ctorName = classTypeName & "_CTOR"

        Dim exactCtorSymbol As String
        If X64FindRoutineSymbolName(ps, ctorName, exactCtorSymbol) <> 0 Then
            ctorName = exactCtorSymbol
        Else
            ctorName = LCase(ctorName)
        End If

        Dim ctorArgCount As Integer
        Dim ctorIsFunction As Integer
        Dim ctorFound As Integer
        ctorFound = X64TryGetRoutineSignature(cg, ctorName, ctorArgCount, ctorIsFunction)

        If ctorFound <> 0 Then
            Dim newArgCount As Integer
            newArgCount = X64ChildCount(ps, nodeIdx)
            Dim totalCtorArgs As Integer
            totalCtorArgs = newArgCount + 1

            If ctorArgCount <> totalCtorArgs Then
                errText = "x64-codegen: constructor argument count mismatch for " & ctorName & " expected=" & X64ToStr(ctorArgCount) & " actual=" & X64ToStr(totalCtorArgs)
                Return 0
            End If

            Dim skipCtorLabel As String
            skipCtorLabel = X64NextLabel(cg, "new_ctor_skip")
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    je " & skipCtorLabel

            Dim stackArgCount As Integer
            stackArgCount = 0
            If totalCtorArgs > 4 Then stackArgCount = totalCtorArgs - 4

            Dim regSpillSlots As Integer
            regSpillSlots = totalCtorArgs
            If regSpillSlots > 4 Then regSpillSlots = 4

            Dim reserveBytes As Integer
            reserveBytes = 32
            reserveBytes += stackArgCount * 8
            reserveBytes += regSpillSlots * 8
            If (reserveBytes Mod 16) <> 0 Then reserveBytes += 8

            X64EmitText cg, "    sub rsp, " & X64ToStr(reserveBytes)

            Dim selfSpillOffset As Integer
            selfSpillOffset = 32 + (stackArgCount * 8)
            X64EmitText cg, "    mov [rsp + " & X64ToStr(selfSpillOffset) & "], rax"

            Dim argPos As Integer
            For argPos = 0 To newArgCount - 1
                Dim argNode As Integer
                argNode = X64ChildAt(ps, nodeIdx, argPos)
                If argNode = -1 Then
                    X64EmitText cg, "    xor rax, rax"
                Else
                    If X64EmitExprToRax(ps, argNode, cg, errText) = 0 Then Return 0
                End If

                Dim dstIndex As Integer
                dstIndex = argPos + 1
                If dstIndex < 4 Then
                    Dim spillOffset As Integer
                    spillOffset = 32 + (stackArgCount * 8) + (dstIndex * 8)
                    X64EmitText cg, "    mov [rsp + " & X64ToStr(spillOffset) & "], rax"
                Else
                    Dim stackOffset As Integer
                    stackOffset = 32 + ((dstIndex - 4) * 8)
                    X64EmitText cg, "    mov [rsp + " & X64ToStr(stackOffset) & "], rax"
                End If
            Next argPos

            Dim regOrder(0 To 3) As String
            regOrder(0) = "rcx"
            regOrder(1) = "rdx"
            regOrder(2) = "r8"
            regOrder(3) = "r9"

            Dim regIdx As Integer
            For regIdx = 0 To regSpillSlots - 1
                Dim loadOffset As Integer
                loadOffset = 32 + (stackArgCount * 8) + (regIdx * 8)
                X64EmitText cg, "    mov " & regOrder(regIdx) & ", [rsp + " & X64ToStr(loadOffset) & "]"
            Next regIdx

            X64EmitText cg, "    call " & ctorName
            X64EmitText cg, "    mov rax, [rsp + " & X64ToStr(selfSpillOffset) & "]"
            X64EmitText cg, "    add rsp, " & X64ToStr(reserveBytes)
            X64EmitLabel cg, skipCtorLabel
        End If
        Return 1
    Case "INCDEC_EXPR"
        Dim incTarget As Integer
        incTarget = ps.ast.nodes(nodeIdx).left
        If incTarget = -1 Then
            errText = "x64-codegen: INCDEC expression missing target"
            Return 0
        End If

        Dim incName As String
        Dim incIndexExpr As Integer
        Dim incIndexed As Integer
        incIndexExpr = -1
        incIndexed = 0

        If X64Upper(ps.ast.nodes(incTarget).kind) = "IDENT" Or X64Upper(ps.ast.nodes(incTarget).kind) = "IDENTIFIER" Then
            incName = Trim(ps.ast.nodes(incTarget).value)
        ElseIf X64TryExtractIndexedTarget(ps, incTarget, incName, incIndexExpr) <> 0 Then
            incIndexed = 1
        End If

        If incName = "" Then
            errText = "x64-codegen: INCDEC expression invalid target"
            Return 0
        End If

        If incIndexed <> 0 Then
            If cg.currentRoutineLabel <> "" And X64EmitLoadIndexedLocal(ps, cg, incName, incIndexExpr, errText) <> 0 Then
            ElseIf X64EmitLoadIndexedGlobal(ps, cg, incName, incIndexExpr, errText) = 0 Then
                errText = "x64-codegen: INCDEC expression indexed target currently supports DIM arrays"
                Return 0
            End If
        Else
            X64EmitLoadVar cg, incName
        End If

        If X64Upper(Trim(ps.ast.nodes(nodeIdx).value)) = "POST" Then
            X64EmitText cg, "    mov rdx, rax"
        End If

        If Trim(ps.ast.nodes(nodeIdx).op) = "--" Then
            X64EmitText cg, "    sub rax, 1"
        Else
            X64EmitText cg, "    add rax, 1"
        End If

        If incIndexed <> 0 Then
            If cg.currentRoutineLabel <> "" And X64EmitStoreIndexedLocal(ps, cg, incName, incIndexExpr, errText) <> 0 Then
            ElseIf X64EmitStoreIndexedGlobal(ps, cg, incName, incIndexExpr, errText) = 0 Then
                errText = "x64-codegen: INCDEC expression indexed target currently supports DIM arrays"
                Return 0
            End If
        Else
            X64EmitStoreVar cg, incName
        End If

        If X64Upper(Trim(ps.ast.nodes(nodeIdx).value)) = "POST" Then
            X64EmitText cg, "    mov rax, rdx"
        End If
        Return 1
    Case "FIELD_EXPR"
        Return X64EmitLoadFieldExpr(ps, nodeIdx, cg, errText)
    Case "INDEX_EXPR", "ARRAY_INDEX", "SUBSCRIPT_EXPR", "ARRAY_ACCESS"
        Dim indexedBaseName As String
        Dim indexedExpr As Integer
        If X64TryExtractIndexedTarget(ps, nodeIdx, indexedBaseName, indexedExpr) = 0 Then
            errText = "x64-codegen: invalid indexed expression"
            Return 0
        End If

        If cg.currentRoutineLabel <> "" And X64EmitLoadIndexedLocal(ps, cg, indexedBaseName, indexedExpr, errText) <> 0 Then
            Return 1
        End If

        If X64EmitLoadIndexedGlobal(ps, cg, indexedBaseName, indexedExpr, errText) <> 0 Then
            Return 1
        End If

        errText = "x64-codegen: indexed load currently supports DIM arrays"
        Return 0
    Case "UNARY"
        Dim unaryRhs As Integer
        unaryRhs = ps.ast.nodes(nodeIdx).right
        If unaryRhs = -1 Then unaryRhs = X64ChildAt(ps, nodeIdx, 0)
        If unaryRhs = -1 Then
            errText = "x64-codegen: unary expression missing operand"
            Return 0
        End If

        If X64EmitExprToRax(ps, unaryRhs, cg, errText) = 0 Then Return 0

        Select Case X64Upper(Trim(ps.ast.nodes(nodeIdx).op))
        Case "", "+"
            Return 1
        Case "-"
            X64EmitText cg, "    neg rax"
            Return 1
        Case "LNOT", "!"
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    sete al"
            X64EmitText cg, "    movzx eax, al"
            Return 1
        Case "NOT"
            X64EmitText cg, "    not rax"
            Return 1
        Case Else
            errText = "x64-codegen: unsupported unary op " & ps.ast.nodes(nodeIdx).op
            Return 0
        End Select
    Case "BINARY", "BINARY_EXPR", "BINOP", "OP", "ADD", "SUB", "MUL", "DIV"
        If X64Upper(Trim(ps.ast.nodes(nodeIdx).op)) = "|>" Then
            If GenerateExpression(ps, ps.ast.nodes(nodeIdx).left, cg, errText) = 0 Then Return 0
            Return X64EmitPipeInvoke(ps, ps.ast.nodes(nodeIdx).right, cg, errText)
        End If

        Dim lhs As Integer
        Dim rhs As Integer
        lhs = ps.ast.nodes(nodeIdx).left
        rhs = ps.ast.nodes(nodeIdx).right

        If lhs = -1 Then lhs = X64ChildAt(ps, nodeIdx, 0)
        If rhs = -1 Then rhs = X64ChildAt(ps, nodeIdx, 1)

        If lhs = -1 Or rhs = -1 Then
            errText = "x64-codegen: binary expression missing operand"
            Return 0
        End If

        Dim opKey As String
        opKey = X64Upper(ps.ast.nodes(nodeIdx).op)
        If opKey = "" Then opKey = nodeKind

        If opKey = "AND" Or opKey = "&&" Then
            Dim andFalseLabel As String
            Dim andEndLabel As String
            andFalseLabel = X64NextLabel(cg, "logic_and_false")
            andEndLabel = X64NextLabel(cg, "logic_and_end")

            If GenerateExpression(ps, lhs, cg, errText) = 0 Then Return 0
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    je " & andFalseLabel

            If GenerateExpression(ps, rhs, cg, errText) = 0 Then Return 0
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    je " & andFalseLabel

            X64EmitText cg, "    mov rax, -1"
            X64EmitText cg, "    jmp " & andEndLabel
            X64EmitLabel cg, andFalseLabel
            X64EmitText cg, "    xor rax, rax"
            X64EmitLabel cg, andEndLabel
            Return 1
        End If

        If opKey = "OR" Or opKey = "||" Then
            Dim orTrueLabel As String
            Dim orEndLabel As String
            orTrueLabel = X64NextLabel(cg, "logic_or_true")
            orEndLabel = X64NextLabel(cg, "logic_or_end")

            If GenerateExpression(ps, lhs, cg, errText) = 0 Then Return 0
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    jne " & orTrueLabel

            If GenerateExpression(ps, rhs, cg, errText) = 0 Then Return 0
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    jne " & orTrueLabel

            X64EmitText cg, "    xor rax, rax"
            X64EmitText cg, "    jmp " & orEndLabel
            X64EmitLabel cg, orTrueLabel
            X64EmitText cg, "    mov rax, -1"
            X64EmitLabel cg, orEndLabel
            Return 1
        End If

        ' Operator-overload hook: if LHS is class instance and class defines OP_ADD/ADD, call method instead
        If opKey = "+" Or opKey = "ADD" Then
            Dim lhsKind As String
            lhsKind = X64Upper(ps.ast.nodes(lhs).kind)
            Dim lhsType As String
            lhsType = ""
            If lhsKind = "IDENT" Or lhsKind = "IDENTIFIER" Or lhsKind = "VAR" Or lhsKind = "VAR_REF" Or lhsKind = "KEYWORD_REF" Then
                If X64TryGetVarType(cg, Trim(ps.ast.nodes(lhs).value), lhsType) = 0 Then
                    X64FindDeclaredTypeName ps, Trim(ps.ast.nodes(lhs).value), lhsType
                End If
            ElseIf lhsKind = "FIELD_EXPR" Then
                Dim rootName As String
                Dim pathText As String
                Dim rootNode As Integer
                Dim fieldOffset As Integer
                Dim fieldType As String
                Dim fieldSize As Integer
                Dim resolveErr As String
                If X64ResolveFieldInfo(ps, lhs, cg, rootName, pathText, rootNode, lhsType, fieldOffset, fieldType, fieldSize, resolveErr) <> 0 Then
                    lhsType = X64Upper(Trim(lhsType))
                End If
            End If

            If lhsType <> "" Then lhsType = X64Upper(Trim(lhsType))
            If lhsType <> "" And X64FindClassDeclNode(ps, lhsType) <> -1 Then
                Dim candidate As String
                candidate = ""
                If X64FindClassMethodDeclNode(ps, lhsType, "OP_ADD") <> -1 Then candidate = "OP_ADD"
                If candidate = "" And X64FindClassMethodDeclNode(ps, lhsType, "ADD") <> -1 Then candidate = "ADD"
                If candidate <> "" Then
                    ' emit method call: receiver + rhs
                    Dim calleeSym As String
                    calleeSym = lhsType & "_" & candidate
                    Dim exactSym As String
                    If X64FindRoutineSymbolName(ps, calleeSym, exactSym) <> 0 Then calleeSym = exactSym Else calleeSym = LCase(calleeSym)

                    Dim actualArgCount As Integer
                    actualArgCount = 2
                    Dim stackArgCount As Integer
                    stackArgCount = 0
                    If actualArgCount > 4 Then stackArgCount = actualArgCount - 4
                    Dim regSpillSlots As Integer
                    regSpillSlots = actualArgCount
                    If regSpillSlots > 4 Then regSpillSlots = 4
                    Dim reserveBytes As Integer
                    reserveBytes = 32
                    reserveBytes += stackArgCount * 8
                    reserveBytes += regSpillSlots * 8
                    If (reserveBytes Mod 16) <> 0 Then reserveBytes += 8

                    X64EmitText cg, "    sub rsp, " & X64ToStr(reserveBytes)

                    Dim recvSpillOffset As Integer
                    recvSpillOffset = 32 + (stackArgCount * 8)

                    ' evaluate receiver
                    If X64EmitExprToRax(ps, lhs, cg, errText) = 0 Then Return 0
                    X64EmitText cg, "    mov [rsp + " & X64ToStr(recvSpillOffset) & "], rax"

                    ' evaluate rhs
                    If X64EmitExprToRax(ps, rhs, cg, errText) = 0 Then Return 0
                    Dim spillOffset As Integer
                    spillOffset = 32 + (stackArgCount * 8) + (1 * 8)
                    X64EmitText cg, "    mov [rsp + " & X64ToStr(spillOffset) & "], rax"

                    Dim regOrder(0 To 3) As String
                    regOrder(0) = "rcx"
                    regOrder(1) = "rdx"
                    regOrder(2) = "r8"
                    regOrder(3) = "r9"
                    Dim i As Integer
                    For i = 0 To regSpillSlots - 1
                        Dim loadOffset As Integer
                        loadOffset = 32 + (stackArgCount * 8) + (i * 8)
                        X64EmitText cg, "    mov " & regOrder(i) & ", [rsp + " & X64ToStr(loadOffset) & "]"
                    Next i

                    ' virtual dispatch if available
                    Dim vslot As Integer
                    vslot = -1
                    If X64FindVTableSlot(cg, lhsType, candidate, vslot) <> 0 Then
                        Dim vcallNullObjLbl2 As String
                        Dim vcallNullVtblLbl2 As String
                        Dim vcallNullSlotLbl2 As String
                        Dim vcallAfterLbl2 As String
                        vcallNullObjLbl2 = X64NextLabel(cg, "vcall_null_obj")
                        vcallNullVtblLbl2 = X64NextLabel(cg, "vcall_null_vtbl")
                        vcallNullSlotLbl2 = X64NextLabel(cg, "vcall_null_slot")
                        vcallAfterLbl2 = X64NextLabel(cg, "vcall_after")

                        X64EmitText cg, "    test rcx, rcx"
                        X64EmitText cg, "    jz " & vcallNullObjLbl2
                        X64EmitText cg, "    mov rax, [rcx]"
                        X64EmitText cg, "    test rax, rax"
                        X64EmitText cg, "    jz " & vcallNullVtblLbl2
                        X64EmitText cg, "    mov r11, [rax + " & X64ToStr(vslot * 8) & "]"
                        X64EmitText cg, "    test r11, r11"
                        X64EmitText cg, "    jz " & vcallNullSlotLbl2
                        X64EmitText cg, "    call r11"
                        X64EmitText cg, "    jmp " & vcallAfterLbl2

                        X64EmitLabel cg, vcallNullObjLbl2
                        X64EmitText cg, "    xor rax, rax"
                        X64EmitText cg, "    jmp " & vcallAfterLbl2
                        X64EmitLabel cg, vcallNullVtblLbl2
                        X64EmitText cg, "    xor rax, rax"
                        X64EmitText cg, "    jmp " & vcallAfterLbl2
                        X64EmitLabel cg, vcallNullSlotLbl2
                        X64EmitText cg, "    xor rax, rax"
                        X64EmitLabel cg, vcallAfterLbl2
                    Else
                        X64EmitText cg, "    call " & calleeSym
                    End If

                    If reserveBytes > 0 Then X64EmitText cg, "    add rsp, " & X64ToStr(reserveBytes)
                    Return 1
                End If
            End If
        End If

        If GenerateExpression(ps, lhs, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    push rax"
        If GenerateExpression(ps, rhs, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    mov rbx, rax"
        X64EmitText cg, "    pop rax"

        Select Case opKey
        Case "+", "ADD"
            X64EmitText cg, "    add rax, rbx"
        Case "-", "SUB"
            X64EmitText cg, "    sub rax, rbx"
        Case "*", "MUL"
            X64EmitText cg, "    imul rax, rbx"
        Case "/", "DIV", "\"
            X64EmitText cg, "    cqo"
            X64EmitText cg, "    idiv rbx"
        Case "%", "MOD"
            X64EmitText cg, "    cqo"
            X64EmitText cg, "    idiv rbx"
            X64EmitText cg, "    mov rax, rdx"
        Case "&"
            X64EmitText cg, "    and rax, rbx"
        Case "|"
            X64EmitText cg, "    or rax, rbx"
        Case "AND", "&&"
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    setne al"
            X64EmitText cg, "    movzx rax, al"
            X64EmitText cg, "    cmp rbx, 0"
            X64EmitText cg, "    setne bl"
            X64EmitText cg, "    movzx rbx, bl"
            X64EmitText cg, "    and rax, rbx"
            X64EmitText cg, "    neg rax"
        Case "OR", "||"
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    setne al"
            X64EmitText cg, "    movzx rax, al"
            X64EmitText cg, "    cmp rbx, 0"
            X64EmitText cg, "    setne bl"
            X64EmitText cg, "    movzx rbx, bl"
            X64EmitText cg, "    or rax, rbx"
            X64EmitText cg, "    neg rax"
        Case "XOR"
            X64EmitText cg, "    xor rax, rbx"
        Case "^"
            X64EmitText cg, "    xor rax, rbx"
        Case "SHL", "<<"
            X64EmitText cg, "    mov ecx, ebx"
            X64EmitText cg, "    shl rax, cl"
        Case "SHR", ">>"
            X64EmitText cg, "    mov ecx, ebx"
            X64EmitText cg, "    sar rax, cl"
        Case "ROL"
            X64EmitText cg, "    mov ecx, ebx"
            X64EmitText cg, "    rol rax, cl"
        Case "ROR"
            X64EmitText cg, "    mov ecx, ebx"
            X64EmitText cg, "    ror rax, cl"
        Case "="
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    sete al"
            X64EmitText cg, "    movzx eax, al"
        Case "=="
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    sete al"
            X64EmitText cg, "    movzx eax, al"
        Case "<>"
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    setne al"
            X64EmitText cg, "    movzx eax, al"
        Case "!="
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    setne al"
            X64EmitText cg, "    movzx eax, al"
        Case "<"
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    setl al"
            X64EmitText cg, "    movzx eax, al"
        Case ">"
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    setg al"
            X64EmitText cg, "    movzx eax, al"
        Case "<="
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    setle al"
            X64EmitText cg, "    movzx eax, al"
        Case ">="
            X64EmitText cg, "    cmp rax, rbx"
            X64EmitText cg, "    setge al"
            X64EmitText cg, "    movzx eax, al"
        Case Else
            X64EmitComment cg, "TODO: unsupported binary op '" & ps.ast.nodes(nodeIdx).op & "'"
            X64EmitText cg, "    xor rax, rax"
        End Select

        Return 1
    Case "TERNARY_EXPR"
        Dim condNode As Integer
        condNode = ps.ast.nodes(nodeIdx).left
        Dim thenNode As Integer
        thenNode = X64ChildAt(ps, nodeIdx, 0)
        Dim elseNode As Integer
        elseNode = ps.ast.nodes(nodeIdx).right
        If condNode = -1 Or thenNode = -1 Or elseNode = -1 Then
            errText = "x64-codegen: ternary expression incomplete"
            Return 0
        End If

        Dim elseLabel As String
        Dim endLabel As String
        elseLabel = X64NextLabel(cg, "tern_else")
        endLabel = X64NextLabel(cg, "tern_end")

        If X64EmitExprToRax(ps, condNode, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    cmp rax, 0"
        X64EmitText cg, "    je " & elseLabel
        If X64EmitExprToRax(ps, thenNode, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    jmp " & endLabel
        X64EmitLabel cg, elseLabel
        If X64EmitExprToRax(ps, elseNode, cg, errText) = 0 Then Return 0
        X64EmitLabel cg, endLabel
        Return 1
    Case Else
        X64EmitComment cg, "TODO: expression kind '" & ps.ast.nodes(nodeIdx).kind & "'"
        X64EmitText cg, "    xor rax, rax"
        Return 1
    End Select
End Function

Private Function GenerateExpression(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Return X64EmitExprToRax(ps, nodeIdx, cg, errText)
End Function

Private Sub EmitFunctionProlog(ByRef cg As X64CodegenContext, ByVal frameBytes As Integer)
    X64EmitText cg, "    push rbp"
    X64EmitText cg, "    mov rbp, rsp"
    X64EmitText cg, "    sub rsp, " & X64ToStr(frameBytes)
End Sub

Private Sub EmitFunctionEpilog(ByRef cg As X64CodegenContext)
    X64EmitText cg, "    leave"
    X64EmitText cg, "    ret"
End Sub

Private Function GenerateRoutine(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal isFunction As Integer, ByRef routineName As String) As Integer
    cg.currentRoutineLabel = routineName
    cg.localCount = 0
    cg.localFrameBytes = 0
    cg.paramCount = 0
    cg.currentEpilogLabel = ""
    cg.currentRoutineIsFunction = isFunction

    Dim routineKindUpper As String
    routineKindUpper = X64Upper(Trim(ps.ast.nodes(nodeIdx).kind))

    Dim receiverClassType As String
    receiverClassType = ""

    Dim hiddenReceiverShift As Integer
    hiddenReceiverShift = 0

    If routineKindUpper = "CLASS_METHOD_DECL" Or routineKindUpper = "CLASS_CONSTRUCTOR_DECL" Or routineKindUpper = "CLASS_DESTRUCTOR_DECL" Then
        hiddenReceiverShift = 1
        If X64FindOwningClassName(ps, nodeIdx, receiverClassType) = 0 Then receiverClassType = ""
    Else
        If X64InferRoutineReceiverClass(ps, routineName, receiverClassType) = 0 Then receiverClassType = ""
    End If

    X64RegisterProcedureParams ps, nodeIdx, cg

    Dim scanNode As Integer
    scanNode = ps.ast.nodes(nodeIdx).firstChild
    Do While scanNode <> -1
        X64CollectRoutineLocals(ps, scanNode, cg)
        scanNode = ps.ast.nodes(scanNode).nextSibling
    Loop

    If receiverClassType <> "" Then
        Dim thisOffsetPre As Integer
        Dim meOffsetPre As Integer
        thisOffsetPre = X64EnsureLocalSlot(cg, "THIS", 1, 8)
        meOffsetPre = X64EnsureLocalSlot(cg, "ME", 1, 8)
        VarMappingAddLocal(cg.localVars, cg.currentRoutineLabel, "THIS", thisOffsetPre, 1)
        VarMappingAddLocal(cg.localVars, cg.currentRoutineLabel, "ME", meOffsetPre, 1)
        X64RegisterVarType cg, "THIS", receiverClassType
        X64RegisterVarType cg, "ME", receiverClassType
    End If

    Dim frameBytes As Integer
    frameBytes = X64Align16(cg.localFrameBytes)
    cg.currentEpilogLabel = X64NextLabel(cg, "ret")

    X64EmitText cg, "global " & routineName
    X64EmitLabel cg, routineName
    EmitFunctionProlog cg, frameBytes
    If isFunction <> 0 Then
        X64EmitText cg, "    xor rax, rax"
    End If

    Dim paramRegs(0 To 3) As String
    paramRegs(0) = "rcx"
    paramRegs(1) = "rdx"
    paramRegs(2) = "r8"
    paramRegs(3) = "r9"

    Dim paramIndex As Integer
    For paramIndex = 0 To cg.paramCount - 1
        Dim paramOffset As Integer
        If X64TryFindLocalOffset(cg, gX64ParamNames(paramIndex), paramOffset) <> 0 Then
            Dim incomingIndex As Integer
            incomingIndex = paramIndex + hiddenReceiverShift
            If incomingIndex <= 3 Then
                X64EmitText cg, "    mov " & X64FormatRbpRef(paramOffset) & ", " & paramRegs(incomingIndex)
            Else
                Dim stackOffset As Integer
                stackOffset = 48 + ((incomingIndex - 4) * 8)
                X64EmitText cg, "    mov rax, [rbp + " & X64ToStr(stackOffset) & "]"
                X64EmitText cg, "    mov " & X64FormatRbpRef(paramOffset) & ", rax"
            End If
        End If
    Next paramIndex

    If receiverClassType <> "" Then
        Dim thisOffset As Integer
        Dim meOffset As Integer
        If X64TryFindLocalOffset(cg, "THIS", thisOffset) <> 0 Then X64EmitText cg, "    mov " & X64FormatRbpRef(thisOffset) & ", rcx"
        If X64TryFindLocalOffset(cg, "ME", meOffset) <> 0 Then X64EmitText cg, "    mov " & X64FormatRbpRef(meOffset) & ", rcx"
    End If

    Dim body As Integer
    body = ps.ast.nodes(nodeIdx).firstChild
    Do While body <> -1
        Dim k As String
        k = X64Upper(ps.ast.nodes(body).kind)

        If k = "PARAM_DECL" Or k = "RETURN_TYPE" Then
            ' metadata node
        ElseIf k = "DIM_STMT" Or k = "DIM" Or k = "REDIM_STMT" Or k = "REDIM" Or _
               k = "PRINT_STMT" Or k = "PRINT" Or k = "CALL_STMT" Or k = "CALL_EXPR" Or k = "CALL" Then
            If GenerateStatement(ps, body, cg, errText) = 0 Then Return 0
        Else
            If X64EmitNode(ps, body, cg, errText) = 0 Then Return 0
        End If

        body = ps.ast.nodes(body).nextSibling
    Loop

    X64EmitLabel cg, cg.currentEpilogLabel
    EmitFunctionEpilog cg

    cg.currentRoutineLabel = ""
    cg.localCount = 0
    cg.localFrameBytes = 0
    cg.paramCount = 0
    cg.currentEpilogLabel = ""
    cg.currentRoutineIsFunction = 0
    Return 1
End Function

Private Function GenerateStatement(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 1

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case nodeKind
    Case "DIM_STMT", "DIM", "REDIM_STMT", "REDIM"
        Return GenerateLocalDim(ps, nodeIdx, cg, errText)
    Case "DEFTYPE_STMT", "SETSTRINGSIZE_STMT"
        X64EmitComment cg, "stmt: " & nodeKind & " (metadata-only for x64 emit)"
        Return 1
    Case "PRINT_STMT", "PRINT"
        Return GeneratePrint(ps, nodeIdx, cg, errText)
    Case "CLS_STMT"
        Return X64EmitClsStmt(ps, nodeIdx, cg, errText)
    Case "LOCATE_STMT"
        Return X64EmitLocateStmt(ps, nodeIdx, cg, errText)
    Case "COLOR_STMT"
        Return X64EmitColorStmt(ps, nodeIdx, cg, errText)
    Case "RANDOMIZE_STMT"
        Return X64EmitRandomizeStmt(ps, nodeIdx, cg, errText)
    Case "INPUT_STMT"
        Return X64EmitInputStmt(ps, nodeIdx, cg, errText)
    Case "INPUT_FILE_STMT"
        Return X64EmitInputFileStmt(ps, nodeIdx, cg, errText)
    Case "OPEN_STMT"
        Return X64EmitOpenStmt(ps, nodeIdx, cg, errText)
    Case "CLOSE_STMT"
        Return X64EmitCloseStmt(ps, nodeIdx, cg, errText)
    Case "GET_STMT"
        Return X64EmitGetStmt(ps, nodeIdx, cg, errText)
    Case "PUT_STMT"
        Return X64EmitPutStmt(ps, nodeIdx, cg, errText)
    Case "SEEK_STMT"
        Return X64EmitSeekStmt(ps, nodeIdx, cg, errText)
    Case "POKEB_STMT"
        Return X64EmitPokeStmt(ps, nodeIdx, cg, errText, "__uxb_mem_pokeb", "POKEB")
    Case "POKEW_STMT"
        Return X64EmitPokeStmt(ps, nodeIdx, cg, errText, "__uxb_mem_pokew", "POKEW")
    Case "POKED_STMT"
        Return X64EmitPokeStmt(ps, nodeIdx, cg, errText, "__uxb_mem_poked", "POKED")
    Case "POKES_STMT"
        Return X64EmitPokesStmt(ps, nodeIdx, cg, errText)
    Case "MEMCOPYB_STMT"
        Return X64EmitMemCopyStmt(ps, nodeIdx, cg, errText, "__uxb_mem_copyb", "MEMCOPYB")
    Case "MEMCOPYW_STMT"
        Return X64EmitMemCopyStmt(ps, nodeIdx, cg, errText, "__uxb_mem_copyw", "MEMCOPYW")
    Case "MEMCOPYD_STMT"
        Return X64EmitMemCopyStmt(ps, nodeIdx, cg, errText, "__uxb_mem_copyd", "MEMCOPYD")
    Case "MEMFILLB_STMT"
        Return X64EmitMemFillStmt(ps, nodeIdx, cg, errText, "__uxb_mem_fillb", "MEMFILLB")
    Case "MEMFILLW_STMT"
        Return X64EmitMemFillStmt(ps, nodeIdx, cg, errText, "__uxb_mem_fillw", "MEMFILLW")
    Case "MEMFILLD_STMT"
        Return X64EmitMemFillStmt(ps, nodeIdx, cg, errText, "__uxb_mem_filld", "MEMFILLD")
    Case "SETNEWOFFSET_STMT"
        Return X64EmitSetNewOffsetStmt(ps, nodeIdx, cg, errText)
    Case "EVENT_STMT", "THREAD_STMT", "PARALEL_STMT", "PIPE_STMT", "SLOT_STMT", "SLOT_CONTROL_STMT", "TRIGGER_STMT"
        Return X64EmitSlotLaneStmt(ps, nodeIdx, cg, errText)
    Case "CALL_STMT", "CALL_EXPR", "CALL"
        Return GenerateCall(ps, nodeIdx, cg, errText)
    Case "IF_STMT", "IF"
        Return GenerateIf(ps, nodeIdx, cg, errText)
    Case "SELECT_STMT"
        Return X64EmitSelectStmt(ps, nodeIdx, cg, errText)
    Case "FOR_STMT", "FOR"
        Return GenerateFor(ps, nodeIdx, cg, errText)
    Case "FOR_EACH_STMT"
        Return X64EmitForEachStmt(ps, nodeIdx, cg, errText)
    Case "DO_STMT"
        Return X64EmitDoStmt(ps, nodeIdx, cg, errText)
    Case "DO_EACH_STMT"
        Return X64EmitDoEachStmt(ps, nodeIdx, cg, errText)
    Case "LABEL_STMT"
        Return X64EmitLabelStmt(ps, nodeIdx, cg, errText)
    Case "GOTO_STMT"
        Return X64EmitGotoStmt(ps, nodeIdx, cg, errText)
    Case "GOSUB_STMT"
        Return X64EmitGosubStmt(ps, nodeIdx, cg, errText)
    Case "EXIT_STMT"
        Return X64EmitExitStmt(ps, nodeIdx, cg, errText)
    Case Else
        errText = "x64-codegen: unsupported statement in GenerateStatement: " & ps.ast.nodes(nodeIdx).kind
        Return 0
    End Select
End Function

Private Function GenerateLocalDim(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: DIM"
    Return X64EmitDimStmt(ps, nodeIdx, cg, errText)
End Function

Private Function GeneratePrint(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: PRINT"
    Return X64EmitPrintStmt(ps, nodeIdx, cg, errText)
End Function

Private Function X64EmitClsStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: CLS"
    X64EmitCall0 cg, "__uxb_runtime_cls"
    Return 1
End Function

Private Function X64EmitLocateStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim rowExpr As Integer
    Dim colExpr As Integer
    rowExpr = X64ChildAt(ps, nodeIdx, 0)
    colExpr = X64ChildAt(ps, nodeIdx, 1)
    If rowExpr = -1 Or colExpr = -1 Then
        errText = "x64-codegen: LOCATE missing row/col"
        Return 0
    End If

    X64EmitComment cg, "stmt: LOCATE"
    If X64EmitExprToRax(ps, rowExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, colExpr, cg, errText) = 0 Then Return 0
    X64EmitCall2 cg, "__uxb_runtime_locate"
    Return 1
End Function

Private Function X64EmitColorStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim fgExpr As Integer
    Dim bgExpr As Integer
    fgExpr = X64ChildAt(ps, nodeIdx, 0)
    bgExpr = X64ChildAt(ps, nodeIdx, 1)
    If fgExpr = -1 Or bgExpr = -1 Then
        errText = "x64-codegen: COLOR missing fg/bg"
        Return 0
    End If

    X64EmitComment cg, "stmt: COLOR"
    If X64EmitExprToRax(ps, fgExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, bgExpr, cg, errText) = 0 Then Return 0
    X64EmitCall2 cg, "__uxb_runtime_color"
    Return 1
End Function

Private Function X64EmitRandomizeStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim seedExpr As Integer
    seedExpr = X64ChildAt(ps, nodeIdx, 0)

    X64EmitComment cg, "stmt: RANDOMIZE"
    If seedExpr = -1 Then
        X64EmitCall0 cg, "__uxb_runtime_randomize_auto"
        Return 1
    End If

    If X64EmitExprToRax(ps, seedExpr, cg, errText) = 0 Then Return 0
    X64EmitCall1 cg, "__uxb_runtime_randomize_seed"
    Return 1
End Function

Private Function X64EmitInputFileStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim childCount As Integer
    childCount = X64ChildCount(ps, nodeIdx)
    If childCount < 2 Then
        errText = "x64-codegen: INPUT# handle/target missing"
        Return 0
    End If

    Dim handleExpr As Integer
    handleExpr = X64ChildAt(ps, nodeIdx, 0)
    If handleExpr = -1 Then
        errText = "x64-codegen: INPUT# handle missing"
        Return 0
    End If

    Dim inputPos As Integer
    For inputPos = 1 To childCount - 1
        Dim targetExpr As Integer
        targetExpr = X64ChildAt(ps, nodeIdx, inputPos)
        If targetExpr = -1 Then
            errText = "x64-codegen: INPUT# target missing"
            Return 0
        End If
        If X64Upper(ps.ast.nodes(targetExpr).kind) <> "IDENT" Then
            errText = "x64-codegen: INPUT# target must be IDENT"
            Return 0
        End If

        If X64EmitExprToRax(ps, handleExpr, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    push rax"
        If X64EmitAddrOfVar(cg, ps.ast.nodes(targetExpr).value, errText) = 0 Then Return 0
        X64EmitText cg, "    mov r9, rax"
        X64EmitText cg, "    xor r8d, r8d"
        X64EmitText cg, "    mov rdx, -1"
        X64EmitText cg, "    pop rcx"
        X64EmitCall0 cg, "__uxb_file_get_i32"
    Next inputPos

    Return 1
End Function

Private Function X64EmitInputStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim childCount As Integer
    childCount = X64ChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "x64-codegen: INPUT target missing"
        Return 0
    End If

    Dim startPos As Integer
    startPos = 0

    Dim firstChild As Integer
    firstChild = X64ChildAt(ps, nodeIdx, 0)
    If firstChild <> -1 And X64Upper(ps.ast.nodes(firstChild).kind) = "PROMPT_EXPR" Then
        Dim promptExpr As Integer
        promptExpr = ps.ast.nodes(firstChild).left
        If promptExpr = -1 Then promptExpr = X64ChildAt(ps, firstChild, 0)
        If promptExpr = -1 Then
            errText = "x64-codegen: INPUT prompt missing"
            Return 0
        End If

        If X64EmitExprToRax(ps, promptExpr, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    mov rcx, rax"
        X64EmitCall0 cg, "__uxb_runtime_input_prompt"
        startPos = 1
    End If

    If startPos >= childCount Then
        errText = "x64-codegen: INPUT target missing"
        Return 0
    End If

    Dim inputPos As Integer
    For inputPos = startPos To childCount - 1
        Dim targetNode As Integer
        targetNode = X64ChildAt(ps, nodeIdx, inputPos)
        If targetNode = -1 Then
            errText = "x64-codegen: INPUT target missing"
            Return 0
        End If
        If X64Upper(ps.ast.nodes(targetNode).kind) <> "IDENT" Then
            errText = "x64-codegen: INPUT target must be IDENT"
            Return 0
        End If
        If X64EmitAddrOfVar(cg, ps.ast.nodes(targetNode).value, errText) = 0 Then Return 0
        X64EmitText cg, "    mov rcx, rax"
        X64EmitCall0 cg, "__uxb_runtime_input_i32"
    Next inputPos

    Return 1
End Function

Private Function X64EmitPokeStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal helperName As String, ByVal stmtName As String) As Integer
    If X64ChildCount(ps, nodeIdx) <> 2 Then
        errText = "x64-codegen: " & stmtName & " expects address,value"
        Return 0
    End If

    Dim addrExpr As Integer
    Dim valueExpr As Integer
    addrExpr = X64ChildAt(ps, nodeIdx, 0)
    valueExpr = X64ChildAt(ps, nodeIdx, 1)
    If addrExpr = -1 Or valueExpr = -1 Then
        errText = "x64-codegen: " & stmtName & " arguments missing"
        Return 0
    End If

    If X64EmitExprToRax(ps, addrExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, valueExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rdx, rax"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, helperName
    Return 1
End Function

Private Function X64EmitPokesStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If X64ChildCount(ps, nodeIdx) <> 2 Then
        errText = "x64-codegen: POKES expects address,text"
        Return 0
    End If

    Dim addrExpr As Integer
    Dim textExpr As Integer
    addrExpr = X64ChildAt(ps, nodeIdx, 0)
    textExpr = X64ChildAt(ps, nodeIdx, 1)
    If addrExpr = -1 Or textExpr = -1 Then
        errText = "x64-codegen: POKES arguments missing"
        Return 0
    End If

    If X64EmitExprToRax(ps, addrExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, textExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rdx, rax"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, "__uxb_mem_pokes"
    Return 1
End Function

Private Function X64EmitMemCopyStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal helperName As String, ByVal stmtName As String) As Integer
    If X64ChildCount(ps, nodeIdx) <> 3 Then
        errText = "x64-codegen: " & stmtName & " expects src,dst,len"
        Return 0
    End If

    Dim srcExpr As Integer
    Dim dstExpr As Integer
    Dim lenExpr As Integer
    srcExpr = X64ChildAt(ps, nodeIdx, 0)
    dstExpr = X64ChildAt(ps, nodeIdx, 1)
    lenExpr = X64ChildAt(ps, nodeIdx, 2)
    If srcExpr = -1 Or dstExpr = -1 Or lenExpr = -1 Then
        errText = "x64-codegen: " & stmtName & " arguments missing"
        Return 0
    End If

    If X64EmitExprToRax(ps, srcExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, dstExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, lenExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov r8, rax"
    X64EmitText cg, "    pop rdx"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, helperName
    Return 1
End Function

Private Function X64EmitMemFillStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal helperName As String, ByVal stmtName As String) As Integer
    If X64ChildCount(ps, nodeIdx) <> 3 Then
        errText = "x64-codegen: " & stmtName & " expects address,value,len"
        Return 0
    End If

    Dim addrExpr As Integer
    Dim valueExpr As Integer
    Dim lenExpr As Integer
    addrExpr = X64ChildAt(ps, nodeIdx, 0)
    valueExpr = X64ChildAt(ps, nodeIdx, 1)
    lenExpr = X64ChildAt(ps, nodeIdx, 2)
    If addrExpr = -1 Or valueExpr = -1 Or lenExpr = -1 Then
        errText = "x64-codegen: " & stmtName & " arguments missing"
        Return 0
    End If

    If X64EmitExprToRax(ps, addrExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, valueExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, lenExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov r8, rax"
    X64EmitText cg, "    pop rdx"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, helperName
    Return 1
End Function

Private Function X64EmitSetNewOffsetStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If X64ChildCount(ps, nodeIdx) <> 2 Then
        errText = "x64-codegen: SETNEWOFFSET expects ident,address"
        Return 0
    End If

    Dim targetNode As Integer
    Dim addrExpr As Integer
    targetNode = X64ChildAt(ps, nodeIdx, 0)
    addrExpr = X64ChildAt(ps, nodeIdx, 1)
    If targetNode = -1 Or addrExpr = -1 Then
        errText = "x64-codegen: SETNEWOFFSET arguments missing"
        Return 0
    End If

    Dim targetKind As String
    targetKind = X64Upper(ps.ast.nodes(targetNode).kind)
    If targetKind <> "IDENT" And targetKind <> "IDENTIFIER" Then
        errText = "x64-codegen: SETNEWOFFSET target must be IDENT"
        Return 0
    End If

    If X64EmitAddrOfVar(cg, ps.ast.nodes(targetNode).value, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, addrExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rdx, rax"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, "__uxb_set_new_offset"
    Return 1
End Function

Private Function X64EmitSlotLaneStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: slot lane " & X64Upper(ps.ast.nodes(nodeIdx).kind) & " (native noop)"
    Return 1
End Function

Private Function X64EmitOpenStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim fileExpr As Integer
    Dim modeNode As Integer
    Dim handleExpr As Integer
    fileExpr = X64ChildAt(ps, nodeIdx, 0)
    modeNode = X64ChildAt(ps, nodeIdx, 1)
    handleExpr = X64ChildAt(ps, nodeIdx, 2)
    If fileExpr = -1 Or modeNode = -1 Or handleExpr = -1 Then
        errText = "x64-codegen: OPEN args missing"
        Return 0
    End If

    Dim modeCode As Integer
    modeCode = X64ModeCodeFromText(ps.ast.nodes(modeNode).value)
    If modeCode = 0 Then
        errText = "x64-codegen: OPEN invalid mode"
        Return 0
    End If

    If X64EmitExprToRax(ps, fileExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov [rel __uxb_file_tmp_path], rax"
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, handleExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"

    Dim lenExpr As Integer
    lenExpr = X64ChildAt(ps, nodeIdx, 3)
    If lenExpr <> -1 Then
        If X64EmitExprToRax(ps, lenExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    xor eax, eax"
    End If

    X64EmitText cg, "    mov r9, rax"
    X64EmitText cg, "    pop r8"
    X64EmitText cg, "    mov edx, " & X64ToStr(modeCode)
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, "__uxb_file_open"
    Return 1
End Function

Private Function X64EmitCloseStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim childCount As Integer
    childCount = X64ChildCount(ps, nodeIdx)
    If childCount = 0 Then Return 1

    Dim closePos As Integer
    For closePos = 0 To childCount - 1
        Dim handleExpr As Integer
        handleExpr = X64ChildAt(ps, nodeIdx, closePos)
        If handleExpr = -1 Then
            errText = "x64-codegen: CLOSE handle missing"
            Return 0
        End If
        If X64EmitExprToRax(ps, handleExpr, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    mov rcx, rax"
        X64EmitCall0 cg, "__uxb_file_close"
    Next closePos

    Return 1
End Function

Private Function X64EmitGetStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim childCount As Integer
    childCount = X64ChildCount(ps, nodeIdx)
    If childCount < 2 Or childCount > 4 Then
        errText = "x64-codegen: GET argument count invalid"
        Return 0
    End If

    Dim handleExpr As Integer, targetExpr As Integer
    Dim posExpr As Integer, bytesExpr As Integer
    handleExpr = X64ChildAt(ps, nodeIdx, 0)
    If handleExpr = -1 Then errText = "x64-codegen: GET handle missing": Return 0

    If childCount = 2 Then
        targetExpr = X64ChildAt(ps, nodeIdx, 1)
    ElseIf childCount = 3 Then
        posExpr = X64ChildAt(ps, nodeIdx, 1)
        targetExpr = X64ChildAt(ps, nodeIdx, 2)
    Else
        posExpr = X64ChildAt(ps, nodeIdx, 1)
        bytesExpr = X64ChildAt(ps, nodeIdx, 2)
        targetExpr = X64ChildAt(ps, nodeIdx, 3)
    End If

    If targetExpr = -1 Or X64Upper(ps.ast.nodes(targetExpr).kind) <> "IDENT" Then
        errText = "x64-codegen: GET target must be IDENT"
        Return 0
    End If

    If X64EmitExprToRax(ps, handleExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If posExpr <> -1 Then
        If X64EmitExprToRax(ps, posExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    mov rax, -1"
    End If
    X64EmitText cg, "    push rax"
    If bytesExpr <> -1 Then
        If X64EmitExprToRax(ps, bytesExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    xor eax, eax"
    End If
    X64EmitText cg, "    push rax"
    If X64EmitAddrOfVar(cg, ps.ast.nodes(targetExpr).value, errText) = 0 Then Return 0
    X64EmitText cg, "    mov r9, rax"
    X64EmitText cg, "    pop r8"
    X64EmitText cg, "    pop rdx"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, "__uxb_file_get_i32"
    Return 1
End Function

Private Function X64EmitPutStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim childCount As Integer
    childCount = X64ChildCount(ps, nodeIdx)
    If childCount < 2 Or childCount > 4 Then
        errText = "x64-codegen: PUT argument count invalid"
        Return 0
    End If

    Dim handleExpr As Integer, sourceExpr As Integer
    Dim posExpr As Integer, bytesExpr As Integer
    handleExpr = X64ChildAt(ps, nodeIdx, 0)
    If handleExpr = -1 Then errText = "x64-codegen: PUT handle missing": Return 0

    If childCount = 2 Then
        sourceExpr = X64ChildAt(ps, nodeIdx, 1)
    ElseIf childCount = 3 Then
        posExpr = X64ChildAt(ps, nodeIdx, 1)
        sourceExpr = X64ChildAt(ps, nodeIdx, 2)
    Else
        posExpr = X64ChildAt(ps, nodeIdx, 1)
        bytesExpr = X64ChildAt(ps, nodeIdx, 2)
        sourceExpr = X64ChildAt(ps, nodeIdx, 3)
    End If
    If sourceExpr = -1 Then errText = "x64-codegen: PUT source missing": Return 0

    If X64EmitExprToRax(ps, handleExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"
    If posExpr <> -1 Then
        If X64EmitExprToRax(ps, posExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    mov rax, -1"
    End If
    X64EmitText cg, "    push rax"
    If bytesExpr <> -1 Then
        If X64EmitExprToRax(ps, bytesExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    xor eax, eax"
    End If
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, sourceExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov r9, rax"
    X64EmitText cg, "    pop r8"
    X64EmitText cg, "    pop rdx"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, "__uxb_file_put_i32"
    Return 1
End Function

Private Function X64EmitSeekStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim handleExpr As Integer
    handleExpr = X64ChildAt(ps, nodeIdx, 0)
    If handleExpr = -1 Then
        errText = "x64-codegen: SEEK handle missing"
        Return 0
    End If
    If X64EmitExprToRax(ps, handleExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    push rax"

    Dim posExpr As Integer
    posExpr = X64ChildAt(ps, nodeIdx, 1)
    If posExpr <> -1 Then
        If X64EmitExprToRax(ps, posExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    mov rax, -1"
    End If
    X64EmitText cg, "    mov rdx, rax"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, "__uxb_file_seek"
    Return 1
End Function

Private Function GenerateCall(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: CALL"
    Return X64EmitCallStmt(ps, nodeIdx, cg, errText)
End Function

Private Function GenerateIf(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: IF"
    Dim condNode As Integer
    condNode = X64ChildAt(ps, nodeIdx, 0)
    If condNode = -1 Then
        errText = "x64-codegen: IF without condition"
        Return 0
    End If

    Dim lblThen As String
    Dim lblElse As String
    Dim lblEnd As String

    lblThen = X64NextLabel(cg, "if_then")
    lblElse = X64NextLabel(cg, "if_else")
    lblEnd = X64NextLabel(cg, "if_end")
    If gX64IfDepth > 255 Then
        errText = "x64-codegen: IF nesting too deep"
        Return 0
    End If
    gX64IfEndLabels(gX64IfDepth) = lblEnd
    gX64IfDepth += 1

    If X64EmitExprToRax(ps, condNode, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    cmp rax, 0"
    X64EmitText cg, "    je " & lblElse
    X64EmitText cg, "    jmp " & lblThen

    X64EmitLabel cg, lblThen

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    If ch <> -1 Then ch = ps.ast.nodes(ch).nextSibling

    Do While ch <> -1
        Dim kindText As String
        kindText = X64Upper(ps.ast.nodes(ch).kind)
        If kindText = "ELSEIF_PART" Or kindText = "ELSE_PART" Then Exit Do
        If X64EmitNode(ps, ch, cg, errText) = 0 Then Return 0
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    X64EmitText cg, "    jmp " & lblEnd
    X64EmitLabel cg, lblElse

    Do While ch <> -1
        Dim kindText As String
        kindText = X64Upper(ps.ast.nodes(ch).kind)

        If kindText = "ELSEIF_PART" Then
            Dim elseifCond As Integer
            elseifCond = X64ChildAt(ps, ch, 0)
            If elseifCond = -1 Then
                errText = "x64-codegen: ELSEIF without condition"
                Return 0
            End If

            Dim lblElseIfThen As String
            Dim lblElseIfNext As String
            lblElseIfThen = X64NextLabel(cg, "elseif_then")
            lblElseIfNext = X64NextLabel(cg, "elseif_next")

            If X64EmitExprToRax(ps, elseifCond, cg, errText) = 0 Then Return 0
            X64EmitText cg, "    cmp rax, 0"
            X64EmitText cg, "    je " & lblElseIfNext
            X64EmitText cg, "    jmp " & lblElseIfThen

            X64EmitLabel cg, lblElseIfThen

            Dim partChild As Integer
            partChild = ps.ast.nodes(ch).firstChild
            If partChild <> -1 Then partChild = ps.ast.nodes(partChild).nextSibling
            Do While partChild <> -1
                If X64EmitNode(ps, partChild, cg, errText) = 0 Then Return 0
                partChild = ps.ast.nodes(partChild).nextSibling
            Loop

            X64EmitText cg, "    jmp " & lblEnd
            X64EmitLabel cg, lblElseIfNext
        ElseIf kindText = "ELSE_PART" Then
            Dim elseChild As Integer
            elseChild = ps.ast.nodes(ch).firstChild
            Do While elseChild <> -1
                If X64EmitNode(ps, elseChild, cg, errText) = 0 Then Return 0
                elseChild = ps.ast.nodes(elseChild).nextSibling
            Loop
        End If

        ch = ps.ast.nodes(ch).nextSibling
    Loop

    X64EmitLabel cg, lblEnd
    gX64IfDepth -= 1
    gX64IfEndLabels(gX64IfDepth) = ""
    Return 1
End Function

Private Function GenerateFor(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: FOR"

    Dim loopVar As String
    loopVar = Trim(ps.ast.nodes(nodeIdx).value)
    If loopVar = "" Then loopVar = X64NextLabel(cg, "forv")

    Dim startExpr As Integer
    Dim endExpr As Integer
    Dim stepExpr As Integer
    Dim bodyNode As Integer
    startExpr = X64ChildAt(ps, nodeIdx, 0)
    endExpr = X64ChildAt(ps, nodeIdx, 1)
    stepExpr = X64ChildAt(ps, nodeIdx, 2)
    bodyNode = X64ChildAt(ps, nodeIdx, 3)

    If startExpr = -1 Or endExpr = -1 Then
        errText = "x64-codegen: FOR missing start/end"
        Return 0
    End If

    If bodyNode = -1 And stepExpr <> -1 Then
        bodyNode = stepExpr
        stepExpr = -1
    End If

    Dim lblStart As String
    Dim lblEnd As String
    lblStart = X64NextLabel(cg, "for_start")
    lblEnd = X64NextLabel(cg, "for_end")

    Dim stepVar As String
    Dim limitVar As String
    stepVar = X64NextLabel(cg, "for_step_tmp")
    limitVar = X64NextLabel(cg, "for_limit_tmp")

    If X64EmitExprToRax(ps, startExpr, cg, errText) = 0 Then Return 0
    X64EmitStoreVar cg, loopVar

    If X64EmitExprToRax(ps, endExpr, cg, errText) = 0 Then Return 0
    X64EmitStoreVar cg, limitVar

    If stepExpr <> -1 Then
        If X64EmitExprToRax(ps, stepExpr, cg, errText) = 0 Then Return 0
    Else
        X64EmitText cg, "    mov rax, 1"
    End If
    X64EmitStoreVar cg, stepVar

    cg.loopDepth += 1
    If cg.loopDepth > 255 Then
        errText = "x64-codegen: loop nesting too deep"
        Return 0
    End If
    gX64LoopVars(cg.loopDepth - 1) = loopVar
    gX64LoopStartLabels(cg.loopDepth - 1) = lblStart
    gX64LoopEndLabels(cg.loopDepth - 1) = lblEnd
    gX64LoopStepLabels(cg.loopDepth - 1) = lblStart

    X64EmitLabel cg, lblStart

    X64EmitLoadVar cg, loopVar
    X64EmitText cg, "    mov rbx, rax"
    X64EmitLoadVar cg, limitVar
    X64EmitText cg, "    mov rcx, rax"
    X64EmitLoadVar cg, stepVar
    X64EmitText cg, "    cmp rax, 0"
    X64EmitText cg, "    jl " & lblStart & "_neg"
    X64EmitText cg, "    cmp rbx, rcx"
    X64EmitText cg, "    jg " & lblEnd
    X64EmitText cg, "    jmp " & lblStart & "_body"
    X64EmitLabel cg, lblStart & "_neg"
    X64EmitText cg, "    cmp rbx, rcx"
    X64EmitText cg, "    jl " & lblEnd
    X64EmitLabel cg, lblStart & "_body"

    Do While bodyNode <> -1
        If X64EmitNode(ps, bodyNode, cg, errText) = 0 Then Return 0
        bodyNode = ps.ast.nodes(bodyNode).nextSibling
    Loop

    X64EmitLoadVar cg, loopVar
    X64EmitText cg, "    mov rbx, rax"
    X64EmitLoadVar cg, stepVar
    X64EmitText cg, "    add rbx, rax"
    X64EmitText cg, "    mov rax, rbx"
    X64EmitStoreVar cg, loopVar

    X64EmitText cg, "    jmp " & lblStart
    X64EmitLabel cg, lblEnd
    gX64LoopVars(cg.loopDepth - 1) = ""
    gX64LoopStartLabels(cg.loopDepth - 1) = ""
    gX64LoopEndLabels(cg.loopDepth - 1) = ""
    gX64LoopStepLabels(cg.loopDepth - 1) = ""
    cg.loopDepth -= 1
    Return 1
End Function

Private Function X64EmitNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 1

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case nodeKind
    Case "PROGRAM"
        Return X64EmitProgram(ps, nodeIdx, cg, errText)
    Case "SUB_STMT", "SUB_DECL", "SUB"
        Return X64EmitSubStmt(ps, nodeIdx, cg, errText)
    Case "FUNCTION_STMT", "FUNCTION_DECL", "FUNCTION"
        Return X64EmitFunctionStmt(ps, nodeIdx, cg, errText)
    Case "CLASS_STMT", "CLASS_FIELD", "CLASS_METHOD_FLAG", "CLASS_ACCESS", "CLASS_BASE_REF", "CLASS_IMPLEMENTS_REF", "CLASS_FRIEND_STMT", "FRIEND_ITEM", "INTERFACE_STMT", "INTERFACE_METHOD_DECL"
        ' Class/interface metadata is consumed by semantic/layout and call resolution.
        Return 1
    Case "CLASS_METHOD_DECL", "CLASS_CONSTRUCTOR_DECL", "CLASS_DESTRUCTOR_DECL"
        Return X64EmitClassRoutineNode(ps, nodeIdx, cg, errText)
    Case "DIM_STMT", "DIM", "REDIM_STMT", "REDIM"
        Return GenerateStatement(ps, nodeIdx, cg, errText)
    Case "IF_STMT", "IF"
        Return X64EmitIfStmt(ps, nodeIdx, cg, errText)
    Case "SELECT_STMT"
        Return X64EmitSelectStmt(ps, nodeIdx, cg, errText)
    Case "FOR_STMT", "FOR"
        Return X64EmitForStmt(ps, nodeIdx, cg, errText)
    Case "FOR_EACH_STMT"
        Return X64EmitForEachStmt(ps, nodeIdx, cg, errText)
    Case "DO_STMT"
        Return X64EmitDoStmt(ps, nodeIdx, cg, errText)
    Case "DO_EACH_STMT"
        Return X64EmitDoEachStmt(ps, nodeIdx, cg, errText)
    Case "LABEL_STMT"
        Return X64EmitLabelStmt(ps, nodeIdx, cg, errText)
    Case "GOTO_STMT"
        Return X64EmitGotoStmt(ps, nodeIdx, cg, errText)
    Case "GOSUB_STMT"
        Return X64EmitGosubStmt(ps, nodeIdx, cg, errText)
    Case "NEXT_STMT", "NEXT"
        Return X64EmitNextStmt(ps, nodeIdx, cg, errText)
    Case "CALL_STMT", "CALL_EXPR", "CALL"
        Return GenerateStatement(ps, nodeIdx, cg, errText)
    Case "PRINT_STMT", "PRINT"
        Return GenerateStatement(ps, nodeIdx, cg, errText)
    Case "CLS_STMT", "LOCATE_STMT", "COLOR_STMT", "RANDOMIZE_STMT", "INPUT_STMT", "INPUT_FILE_STMT", "OPEN_STMT", "CLOSE_STMT", "GET_STMT", "PUT_STMT", "SEEK_STMT", "POKEB_STMT", "POKEW_STMT", "POKED_STMT", "POKES_STMT", "MEMCOPYB_STMT", "MEMCOPYW_STMT", "MEMCOPYD_STMT", "MEMFILLB_STMT", "MEMFILLW_STMT", "MEMFILLD_STMT", "SETNEWOFFSET_STMT", "EVENT_STMT", "THREAD_STMT", "PARALEL_STMT", "PIPE_STMT", "SLOT_STMT", "SLOT_CONTROL_STMT", "TRIGGER_STMT", "DEFTYPE_STMT", "SETSTRINGSIZE_STMT"
        Return GenerateStatement(ps, nodeIdx, cg, errText)
    Case "RETURN_STMT", "RETURN"
        Return X64EmitReturnStmt(ps, nodeIdx, cg, errText)
    Case "EXIT_STMT"
        Return X64EmitExitStmt(ps, nodeIdx, cg, errText)
    Case "DELETE_STMT"
        Return X64EmitDeleteStmt(ps, nodeIdx, cg, errText)
    Case "BLOCK", "SCOPE_BLOCK", "BODY"
        Return X64EmitBlockStmt(ps, nodeIdx, cg, errText)
    Case "EXPR_STMT", "LET_STMT"
        Return X64EmitExprStmt(ps, nodeIdx, cg, errText)
    Case "ASSIGN_STMT"
        Return X64EmitAssignStmt(ps, nodeIdx, cg, errText)
    Case "INCDEC_STMT"
        Return X64EmitIncDecStmt(ps, nodeIdx, cg, errText)
    Case Else
        Return X64EmitUnknownNode(ps, nodeIdx, cg, errText)
    End Select
End Function

Private Function X64EmitDeleteStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim targetNode As Integer
    targetNode = ps.ast.nodes(nodeIdx).left
    If targetNode = -1 Then targetNode = X64ChildAt(ps, nodeIdx, 0)
    If targetNode = -1 Then
        errText = "x64-codegen: DELETE target missing"
        Return 0
    End If

    Dim targetName As String
    Dim targetKind As String
    targetKind = X64Upper(ps.ast.nodes(targetNode).kind)
    If targetKind = "IDENT" Or targetKind = "IDENTIFIER" Then
        targetName = Trim(ps.ast.nodes(targetNode).value)
    End If

    If X64EmitExprToRax(ps, targetNode, cg, errText) = 0 Then Return 0

    Dim declType As String
    If targetName <> "" Then
        If X64FindDeclaredTypeName(ps, targetName, declType) <> 0 Then
            Dim dtorName As String
            dtorName = declType & "_DTOR"

            Dim exactDtorSymbol As String
            If X64FindRoutineSymbolName(ps, dtorName, exactDtorSymbol) <> 0 Then
                dtorName = exactDtorSymbol
            Else
                dtorName = LCase(dtorName)
            End If

            Dim dtorArgCount As Integer
            Dim dtorIsFunction As Integer
            If X64TryGetRoutineSignature(cg, dtorName, dtorArgCount, dtorIsFunction) <> 0 Then
                If dtorArgCount <> 1 Then
                    errText = "x64-codegen: destructor signature must be 1 arg for " & dtorName
                    Return 0
                End If

                Dim skipDtorLabel As String
                skipDtorLabel = X64NextLabel(cg, "delete_dtor_skip")
                X64EmitText cg, "    cmp rax, 0"
                X64EmitText cg, "    je " & skipDtorLabel
                X64EmitText cg, "    mov [rel __uxb_file_io_tmp], rax"
                X64EmitText cg, "    mov rcx, rax"
                X64EmitText cg, "    sub rsp, 32"
                X64EmitText cg, "    call " & dtorName
                X64EmitText cg, "    add rsp, 32"
                X64EmitText cg, "    mov rax, [rel __uxb_file_io_tmp]"
                X64EmitLabel cg, skipDtorLabel
            End If
        End If
    End If

    Dim skipFreeLabel As String
    skipFreeLabel = X64NextLabel(cg, "delete_free_skip")
    X64EmitText cg, "    cmp rax, 0"
    X64EmitText cg, "    je " & skipFreeLabel
    X64EmitText cg, "    mov rcx, rax"
    X64EmitText cg, "    sub rsp, 32"
    X64EmitText cg, "    call free"
    X64EmitText cg, "    add rsp, 32"
    X64EmitLabel cg, skipFreeLabel

    If targetName <> "" Then
        X64EmitText cg, "    xor rax, rax"
        X64EmitStoreVar cg, targetName
    End If

    Return 1
End Function

Private Function X64EmitProgram(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitText cg, "bits 64"
    X64EmitText cg, "default rel"
    X64EmitText cg, "section .text"
    X64EmitText cg, "extern printf"
    X64EmitText cg, "extern scanf"
    X64EmitText cg, "extern sprintf"
    X64EmitText cg, "extern atoi"
    X64EmitText cg, "extern calloc"
    X64EmitText cg, "extern free"
    X64EmitText cg, "extern fopen"
    X64EmitText cg, "extern fclose"
    X64EmitText cg, "extern fflush"
    X64EmitText cg, "extern fread"
    X64EmitText cg, "extern fwrite"
    X64EmitText cg, "extern fseek"
    X64EmitText cg, "extern ftell"
    X64EmitText cg, "extern feof"
    X64EmitText cg, "extern memmove"
    X64EmitText cg, "extern memset"
    X64EmitText cg, "extern rand"
    X64EmitText cg, "extern srand"
    X64EmitText cg, "extern sin"
    X64EmitText cg, "extern cos"
    X64EmitText cg, "extern tan"
    X64EmitText cg, "extern atan"
    X64EmitText cg, "extern exp"
    X64EmitText cg, "extern log"
    X64EmitText cg, "extern GetTickCount64"
    X64CollectDllCallPlan ps, nodeIdx, cg
    If cg.ffiCallTotal > 0 Then X64EmitText cg, "extern __uxb_ffi_resolve_all"
    X64EmitText cg, ""

    X64EmitBuiltinSupport cg
    X64EmitFfiSupport cg

    Dim sigScan As Integer
    sigScan = ps.ast.nodes(nodeIdx).firstChild
    Do While sigScan <> -1
        Dim sigKind As String
        sigKind = X64Upper(ps.ast.nodes(sigScan).kind)
        If sigKind = "SUB_STMT" Or sigKind = "FUNCTION_STMT" Then
            X64RegisterRoutineSignature ps, sigScan, cg
        ElseIf sigKind = "CLASS_STMT" Then
            Dim sigMember As Integer
            sigMember = ps.ast.nodes(sigScan).firstChild
            Do While sigMember <> -1
                Dim sigMemberKind As String
                sigMemberKind = X64Upper(ps.ast.nodes(sigMember).kind)
                If sigMemberKind = "CLASS_METHOD_DECL" Or sigMemberKind = "CLASS_CONSTRUCTOR_DECL" Or sigMemberKind = "CLASS_DESTRUCTOR_DECL" Then
                    X64RegisterClassRoutineSignature ps, sigMember, cg
                End If
                sigMember = ps.ast.nodes(sigMember).nextSibling
            Loop
            ' Emit vtable data for the class
            Dim errText As String
            If X64EmitClassVTable(ps, sigScan, cg, errText) = 0 Then Return 0
        End If
        sigScan = ps.ast.nodes(sigScan).nextSibling
    Loop

    Dim mainLabel As String
    mainLabel = "__uxb_main"

    cg.currentRoutineLabel = ""
    cg.localCount = 0
    cg.localFrameBytes = 0
    cg.paramCount = 0
    cg.currentRoutineIsFunction = 1
    cg.currentEpilogLabel = X64NextLabel(cg, "ret")
    cg.ffiCallEmitIndex = 0

    X64EmitText cg, "global main"
    X64EmitText cg, "global __uxb_main"
    X64EmitLabel cg, "main"
    X64EmitLabel cg, mainLabel
    EmitFunctionProlog cg, 0
    If cg.ffiCallTotal > 0 Then
        X64EmitText cg, "    sub rsp, 32"
        X64EmitText cg, "    call __uxb_ffi_resolve_all"
        X64EmitText cg, "    add rsp, 32"
    End If
    X64EmitText cg, "    xor rax, rax"

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        Dim k As String
        k = X64Upper(ps.ast.nodes(ch).kind)
        If k <> "SUB_STMT" And k <> "FUNCTION_STMT" And k <> "CLASS_STMT" Then
            If X64EmitNode(ps, ch, cg, errText) = 0 Then Return 0
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    X64EmitLabel cg, cg.currentEpilogLabel
    EmitFunctionEpilog cg
    X64EmitText cg, ""

    cg.currentRoutineLabel = ""
    cg.localCount = 0
    cg.localFrameBytes = 0
    cg.paramCount = 0
    cg.currentRoutineIsFunction = 0
    cg.currentEpilogLabel = ""

    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        Dim k As String
        k = X64Upper(ps.ast.nodes(ch).kind)
        If k = "SUB_STMT" Or k = "FUNCTION_STMT" Then
            If X64EmitNode(ps, ch, cg, errText) = 0 Then Return 0
            X64EmitText cg, ""
        ElseIf k = "CLASS_STMT" Then
            Dim classMember As Integer
            classMember = ps.ast.nodes(ch).firstChild
            Do While classMember <> -1
                Dim classMemberKind As String
                classMemberKind = X64Upper(ps.ast.nodes(classMember).kind)
                If classMemberKind = "CLASS_METHOD_DECL" Or classMemberKind = "CLASS_CONSTRUCTOR_DECL" Or classMemberKind = "CLASS_DESTRUCTOR_DECL" Then
                    If X64EmitClassRoutineNode(ps, classMember, cg, errText) = 0 Then Return 0
                    If X64ClassRoutineHasBody(ps, classMember) <> 0 Then X64EmitText cg, ""
                End If
                classMember = ps.ast.nodes(classMember).nextSibling
            Loop
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 1
End Function

Private Function X64EmitSubStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim procName As String
    procName = Trim(ps.ast.nodes(nodeIdx).value)
    If procName = "" Then procName = X64NextLabel(cg, "sub")
    Return GenerateRoutine(ps, nodeIdx, cg, errText, 0, procName)
End Function

Private Function X64EmitFunctionStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim fnName As String
    fnName = Trim(ps.ast.nodes(nodeIdx).value)
    If fnName = "" Then fnName = X64NextLabel(cg, "fn")
    Return GenerateRoutine(ps, nodeIdx, cg, errText, 1, fnName)
End Function

Private Function X64EmitClassRoutineNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim nodeKind As String
    nodeKind = X64Upper(Trim(ps.ast.nodes(nodeIdx).kind))
    If nodeKind <> "CLASS_METHOD_DECL" And nodeKind <> "CLASS_CONSTRUCTOR_DECL" And nodeKind <> "CLASS_DESTRUCTOR_DECL" Then Return 1

    If X64ClassRoutineHasBody(ps, nodeIdx) = 0 Then Return 1

    Dim routineName As String
    If X64ResolveClassRoutineName(ps, nodeIdx, routineName) = 0 Then
        errText = "x64-codegen: class routine name resolve failed"
        Return 0
    End If

    Dim isFunction As Integer
    isFunction = IIf(nodeKind = "CLASS_METHOD_DECL" And X64NodeHasReturnType(ps, nodeIdx) <> 0, 1, 0)
    Return GenerateRoutine(ps, nodeIdx, cg, errText, isFunction, routineName)
End Function

Private Function X64EmitDimStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        Dim declName As String
        declName = Trim(ps.ast.nodes(ch).value)
        If declName = "" Then declName = X64NextLabel(cg, "dim")

        Dim boundsNode As Integer
        boundsNode = -1

        Dim elemCount As Integer
        elemCount = X64ComputeDimSlotCount(ps, ch)

        ' Determine element byte size from declared type (if any)
        Dim elemBytes As Integer
        elemBytes = 8
        Dim declTypeName As String
        declTypeName = ""
        Dim declIsClass As Integer
        Dim declIsObject As Integer
        declIsClass = 0
        declIsObject = 0
        If X64FindDeclaredTypeName(ps, declName, declTypeName) <> 0 Then
            declTypeName = X64Upper(Trim(declTypeName))
            declIsClass = IIf(X64FindClassDeclNode(ps, declTypeName) <> -1, 1, 0)
            declIsObject = IIf(declTypeName = "OBJECT", 1, 0)

            If declIsClass <> 0 Or declIsObject <> 0 Then
                ' CLASS/OBJECT variables are pointer slots in x64 lane.
                elemBytes = 8
            Else
                Dim aggSize As Integer
                Dim aggErr As String
                If TypeLayoutSizeOf(ps, declTypeName, aggSize, aggErr) <> 0 Then
                    If aggSize > 0 Then elemBytes = aggSize
                Else
                    ' fallback for float kinds
                    Select Case X64TypeToFloatKind(declTypeName)
                    Case UXF_F80
                        elemBytes = 10
                    Case UXF_F32
                        elemBytes = 4
                    Case Else
                        elemBytes = 8
                    End Select
                End If
            End If
        End If

        If cg.currentRoutineLabel = "" Then
            X64EnsureGlobalSymbol(cg, declName, elemCount, elemBytes)
        Else
            Dim localOffset As Integer
            localOffset = X64EnsureLocalSlot(cg, declName, elemCount, elemBytes)
            VarMappingAddLocal(cg.localVars, cg.currentRoutineLabel, declName, localOffset, elemCount)
        End If
        '
        ' Register declared type (if any) for this variable into the codegen var-type registry
        declTypeName = ""
        If X64FindDeclaredTypeName(ps, declName, declTypeName) <> 0 Then
            X64RegisterVarType(cg, declName, declTypeName)
        End If

        Dim subNode As Integer
        Dim hasInitExpr As Integer
        hasInitExpr = 0
        Dim hasBounds As Integer
        hasBounds = 0
        subNode = ps.ast.nodes(ch).firstChild
        Do While subNode <> -1
            Dim subKind As String
            subKind = X64Upper(ps.ast.nodes(subNode).kind)

            If subKind = "DIM_BOUNDS" Then hasBounds = 1

            If subKind = "INIT_EXPR" And ps.ast.nodes(subNode).left <> -1 Then
                hasInitExpr = 1
                Dim initExpr As Integer
                initExpr = ps.ast.nodes(subNode).left
                Dim declType As String
                declType = ""
                If X64FindDeclaredTypeName(ps, declName, declType) <> 0 Then
                    Dim initFloatKind As Integer
                    initFloatKind = X64TypeToFloatKind(declType)
                    If initFloatKind = UXF_F32 Or initFloatKind = UXF_F64 Then
                        If X64EmitExprToXmm0As(ps, initExpr, cg, initFloatKind, errText) = 0 Then Return 0
                        X64EmitStoreVarXmm cg, declName
                    ElseIf initFloatKind = UXF_F80 Then
                        Dim f80InitRaw As String
                        f80InitRaw = ""
                        If X64TryGetNumberLiteral(ps, initExpr, f80InitRaw) = 0 Then
                            errText = "x64-codegen: F80 arithmetic not yet supported in x64 backend"
                            Return 0
                        End If
                        If X64EmitStoreF80LiteralVar(ps, cg, declName, f80InitRaw, errText) = 0 Then Return 0
                    Else
                        If X64EmitExprToRax(ps, initExpr, cg, errText) = 0 Then Return 0
                        X64EmitStoreVar cg, declName
                    End If
                Else
                    If X64EmitExprToRax(ps, initExpr, cg, errText) = 0 Then Return 0
                    X64EmitStoreVar cg, declName
                End If
            End If
            subNode = ps.ast.nodes(subNode).nextSibling
        Loop

        If declIsClass <> 0 And hasInitExpr = 0 And hasBounds = 0 Then
            Dim classSize As Integer
            Dim classErr As String
            If TypeLayoutSizeOf(ps, declTypeName, classSize, classErr) = 0 Then
                errText = "x64-codegen: DIM class layout resolve failed " & classErr
                Return 0
            End If
            If classSize <= 0 Then
                errText = "x64-codegen: unresolved class layout: " & declTypeName
                Return 0
            End If

            X64EmitComment cg, "DIM class default allocation"
            X64EmitText cg, "    mov rcx, 1"
            X64EmitText cg, "    mov rdx, " & X64ToStr(classSize)
            X64EmitText cg, "    sub rsp, 32"
            X64EmitText cg, "    call calloc"
            X64EmitText cg, "    add rsp, 32"
            ' initialize vptr for class instance
            X64EmitText cg, "    lea rdx, [rel " & X64ClassVTableLabel(declTypeName) & "]"
            X64EmitText cg, "    mov [rax], rdx"
            X64EmitStoreVar cg, declName
        End If

        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 1
End Function

Private Function X64EmitIfStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Return GenerateIf(ps, nodeIdx, cg, errText)
End Function

Private Function X64EmitForStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Return GenerateFor(ps, nodeIdx, cg, errText)
End Function

Private Function X64EmitNextStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    ' Parsed FOR bodies already consume NEXT tokens.
    Return 1
End Function

Private Function X64EmitSelectStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: SELECT"

    Dim selectCount As Integer
    selectCount = X64ChildCount(ps, nodeIdx)
    If selectCount < 1 Then
        errText = "x64-codegen: SELECT selector missing"
        Return 0
    End If

    Dim selectorExpr As Integer
    selectorExpr = X64ChildAt(ps, nodeIdx, 0)
    If selectorExpr = -1 Then
        errText = "x64-codegen: SELECT selector missing"
        Return 0
    End If

    Dim selectorVar As String
    selectorVar = X64NextLabel(cg, "select_tmp")
    If X64EmitExprToRax(ps, selectorExpr, cg, errText) = 0 Then Return 0
    X64EmitStoreVar cg, selectorVar

    Dim endLabel As String
    endLabel = X64NextLabel(cg, "select_end")
    Dim condLabel As String
    condLabel = X64NextLabel(cg, "select_case")

    X64EmitText cg, "    jmp " & condLabel

    Dim casePos As Integer
    For casePos = 1 To selectCount - 1
        Dim caseNode As Integer
        caseNode = X64ChildAt(ps, nodeIdx, casePos)
        If caseNode = -1 Then
            errText = "x64-codegen: SELECT case missing"
            Return 0
        End If

        X64EmitLabel cg, condLabel

        Dim caseKind As String
        caseKind = X64Upper(ps.ast.nodes(caseNode).kind)
        If caseKind = "CASE_ELSE" Then
            Dim elseStmt As Integer
            elseStmt = ps.ast.nodes(caseNode).firstChild
            Do While elseStmt <> -1
                If X64EmitNode(ps, elseStmt, cg, errText) = 0 Then Return 0
                elseStmt = ps.ast.nodes(elseStmt).nextSibling
            Loop
            X64EmitText cg, "    jmp " & endLabel
            Exit For
        End If

        If caseKind <> "CASE_BLOCK" Then
            errText = "x64-codegen: unexpected SELECT case node " & ps.ast.nodes(caseNode).kind
            Return 0
        End If

        Dim caseChildCount As Integer
        caseChildCount = X64ChildCount(ps, caseNode)

        Dim bodyStart As Integer
        bodyStart = caseChildCount

        Dim cp As Integer
        For cp = 0 To caseChildCount - 1
            Dim cchild As Integer
            cchild = X64ChildAt(ps, caseNode, cp)
            If cchild <> -1 And X64IsStmtKind(ps.ast.nodes(cchild).kind) <> 0 Then
                bodyStart = cp
                Exit For
            End If
        Next cp

        If bodyStart <= 0 Then
            errText = "x64-codegen: CASE values missing"
            Return 0
        End If

        Dim bodyLabel As String
        Dim nextLabel As String
        bodyLabel = X64NextLabel(cg, "select_body")
        If casePos < selectCount - 1 Then
            nextLabel = X64NextLabel(cg, "select_case")
        Else
            nextLabel = endLabel
        End If

        For cp = 0 To bodyStart - 1
            Dim cexpr As Integer
            cexpr = X64ChildAt(ps, caseNode, cp)
            If cexpr = -1 Then
                errText = "x64-codegen: CASE expression missing"
                Return 0
            End If

            X64EmitLoadVar cg, selectorVar
            X64EmitText cg, "    push rax"

            If X64Upper(ps.ast.nodes(cexpr).kind) = "CASE_IS_VALUE" Then
                If ps.ast.nodes(cexpr).left = -1 Then
                    errText = "x64-codegen: CASE IS expression missing"
                    Return 0
                End If
                If X64EmitExprToRax(ps, ps.ast.nodes(cexpr).left, cg, errText) = 0 Then Return 0
                X64EmitText cg, "    mov rbx, rax"
                X64EmitText cg, "    pop rax"

                Select Case Trim(ps.ast.nodes(cexpr).op)
                Case "="
                    X64EmitText cg, "    cmp rax, rbx"
                    X64EmitText cg, "    je " & bodyLabel
                Case "<>"
                    X64EmitText cg, "    cmp rax, rbx"
                    X64EmitText cg, "    jne " & bodyLabel
                Case "<"
                    X64EmitText cg, "    cmp rax, rbx"
                    X64EmitText cg, "    jl " & bodyLabel
                Case ">"
                    X64EmitText cg, "    cmp rax, rbx"
                    X64EmitText cg, "    jg " & bodyLabel
                Case "<="
                    X64EmitText cg, "    cmp rax, rbx"
                    X64EmitText cg, "    jle " & bodyLabel
                Case ">="
                    X64EmitText cg, "    cmp rax, rbx"
                    X64EmitText cg, "    jge " & bodyLabel
                Case Else
                    errText = "x64-codegen: CASE IS invalid relop " & ps.ast.nodes(cexpr).op
                    Return 0
                End Select
            Else
                If X64EmitExprToRax(ps, cexpr, cg, errText) = 0 Then Return 0
                X64EmitText cg, "    mov rbx, rax"
                X64EmitText cg, "    pop rax"
                X64EmitText cg, "    cmp rax, rbx"
                X64EmitText cg, "    je " & bodyLabel
            End If
        Next cp

        X64EmitText cg, "    jmp " & nextLabel
        X64EmitLabel cg, bodyLabel

        For cp = bodyStart To caseChildCount - 1
            Dim bodyStmt As Integer
            bodyStmt = X64ChildAt(ps, caseNode, cp)
            If bodyStmt <> -1 Then
                If X64EmitNode(ps, bodyStmt, cg, errText) = 0 Then Return 0
            End If
        Next cp

        X64EmitText cg, "    jmp " & endLabel
        condLabel = nextLabel
    Next casePos

    X64EmitLabel cg, endLabel
    Return 1
End Function

Private Function X64EmitDoStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: DO"

    Dim doMode As String
    doMode = X64Upper(ps.ast.nodes(nodeIdx).op)

    Dim doCount As Integer
    doCount = X64ChildCount(ps, nodeIdx)

    Dim hasPreCond As Integer
    Dim hasPostCond As Integer
    hasPreCond = (doMode = "DO_WHILE" Or doMode = "DO_UNTIL")
    hasPostCond = (doMode = "LOOP_WHILE" Or doMode = "LOOP_UNTIL")

    Dim preCondPos As Integer
    Dim postCondPos As Integer
    Dim bodyStartPos As Integer
    Dim bodyEndPos As Integer
    preCondPos = IIf(hasPreCond <> 0, 0, -1)
    postCondPos = IIf(hasPostCond <> 0, doCount - 1, -1)
    bodyStartPos = IIf(hasPreCond <> 0, 1, 0)
    bodyEndPos = IIf(hasPostCond <> 0, doCount - 2, doCount - 1)

    Dim lblStart As String
    Dim lblCond As String
    Dim lblEnd As String
    lblStart = X64NextLabel(cg, "do_start")
    lblCond = X64NextLabel(cg, "do_cond")
    lblEnd = X64NextLabel(cg, "do_end")

    cg.loopDepth += 1
    If cg.loopDepth > 255 Then
        errText = "x64-codegen: loop nesting too deep"
        Return 0
    End If
    gX64LoopEndLabels(cg.loopDepth - 1) = lblEnd
    gX64LoopStepLabels(cg.loopDepth - 1) = lblCond

    X64EmitLabel cg, lblStart

    If hasPreCond <> 0 Then
        Dim preExpr As Integer
        preExpr = X64ChildAt(ps, nodeIdx, preCondPos)
        If preExpr = -1 Then
            errText = "x64-codegen: DO pre-condition missing"
            Return 0
        End If
        If X64EmitExprToRax(ps, preExpr, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    cmp rax, 0"
        If doMode = "DO_WHILE" Then
            X64EmitText cg, "    je " & lblEnd
        Else
            X64EmitText cg, "    jne " & lblEnd
        End If
    End If

    Dim bodyPos As Integer
    For bodyPos = bodyStartPos To bodyEndPos
        If bodyPos < 0 Then Exit For
        Dim bodyStmt As Integer
        bodyStmt = X64ChildAt(ps, nodeIdx, bodyPos)
        If bodyStmt <> -1 Then
            If X64EmitNode(ps, bodyStmt, cg, errText) = 0 Then Return 0
        End If
    Next bodyPos

    X64EmitLabel cg, lblCond
    If hasPostCond <> 0 Then
        Dim postExpr As Integer
        postExpr = X64ChildAt(ps, nodeIdx, postCondPos)
        If postExpr = -1 Then
            errText = "x64-codegen: LOOP post-condition missing"
            Return 0
        End If
        If X64EmitExprToRax(ps, postExpr, cg, errText) = 0 Then Return 0
        X64EmitText cg, "    cmp rax, 0"
        If doMode = "LOOP_WHILE" Then
            X64EmitText cg, "    jne " & lblStart
        Else
            X64EmitText cg, "    je " & lblStart
        End If
    Else
        X64EmitText cg, "    jmp " & lblStart
    End If

    X64EmitLabel cg, lblEnd
    gX64LoopEndLabels(cg.loopDepth - 1) = ""
    gX64LoopStepLabels(cg.loopDepth - 1) = ""
    cg.loopDepth -= 1
    Return 1
End Function

Private Function X64EmitForEachStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: FOR EACH"

    Dim itemsNode As Integer
    Dim bodyNode As Integer
    itemsNode = X64ChildAt(ps, nodeIdx, 0)
    bodyNode = X64ChildAt(ps, nodeIdx, 1)
    If itemsNode = -1 Or bodyNode = -1 Then
        errText = "x64-codegen: FOR EACH items/body missing"
        Return 0
    End If

    Dim itemCount As Integer
    itemCount = X64ChildCount(ps, itemsNode)

    Dim endLabel As String
    endLabel = X64NextLabel(cg, "foreach_end")
    cg.loopDepth += 1
    If cg.loopDepth > 255 Then
        errText = "x64-codegen: loop nesting too deep"
        Return 0
    End If
    gX64LoopEndLabels(cg.loopDepth - 1) = endLabel

    Dim itemVarNames(Any) As String
    If itemCount > 0 Then ReDim itemVarNames(itemCount - 1)

    Dim i As Integer
    For i = 0 To itemCount - 1
        Dim itemExpr As Integer
        itemExpr = X64ChildAt(ps, itemsNode, i)
        If itemExpr = -1 Then
            errText = "x64-codegen: FOR EACH item missing"
            Return 0
        End If
        itemVarNames(i) = X64NextLabel(cg, "foreach_item")
        If X64EmitExprToRax(ps, itemExpr, cg, errText) = 0 Then Return 0
        X64EmitStoreVar cg, itemVarNames(i)
    Next i

    For i = 0 To itemCount - 1
        X64EmitLoadVar cg, itemVarNames(i)
        X64EmitStoreVar cg, ps.ast.nodes(nodeIdx).value
        If Trim(ps.ast.nodes(nodeIdx).op) <> "" Then
            X64EmitText cg, "    mov rax, " & X64ToStr(i)
            X64EmitStoreVar cg, ps.ast.nodes(nodeIdx).op
        End If

        Dim bodyStmt As Integer
        bodyStmt = ps.ast.nodes(bodyNode).firstChild
        Do While bodyStmt <> -1
            If X64EmitNode(ps, bodyStmt, cg, errText) = 0 Then Return 0
            bodyStmt = ps.ast.nodes(bodyStmt).nextSibling
        Loop
    Next i

    X64EmitLabel cg, endLabel
    gX64LoopEndLabels(cg.loopDepth - 1) = ""
    cg.loopDepth -= 1
    Return 1
End Function

Private Function X64EmitDoEachStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: DO EACH"

    Dim itemsNode As Integer
    Dim bodyNode As Integer
    itemsNode = X64ChildAt(ps, nodeIdx, 0)
    bodyNode = X64ChildAt(ps, nodeIdx, 1)
    If itemsNode = -1 Or bodyNode = -1 Then
        errText = "x64-codegen: DO EACH items/body missing"
        Return 0
    End If

    Dim itemCount As Integer
    itemCount = X64ChildCount(ps, itemsNode)

    Dim endLabel As String
    endLabel = X64NextLabel(cg, "doeach_end")
    cg.loopDepth += 1
    If cg.loopDepth > 255 Then
        errText = "x64-codegen: loop nesting too deep"
        Return 0
    End If
    gX64LoopEndLabels(cg.loopDepth - 1) = endLabel

    Dim i As Integer
    For i = 0 To itemCount - 1
        Dim itemExpr As Integer
        itemExpr = X64ChildAt(ps, itemsNode, i)
        If itemExpr = -1 Then
            errText = "x64-codegen: DO EACH item missing"
            Return 0
        End If
        If X64EmitExprToRax(ps, itemExpr, cg, errText) = 0 Then Return 0
        X64EmitStoreVar cg, ps.ast.nodes(nodeIdx).value

        Dim bodyStmt As Integer
        bodyStmt = ps.ast.nodes(bodyNode).firstChild
        Do While bodyStmt <> -1
            If X64EmitNode(ps, bodyStmt, cg, errText) = 0 Then Return 0
            bodyStmt = ps.ast.nodes(bodyStmt).nextSibling
        Loop
    Next i

    X64EmitLabel cg, endLabel
    gX64LoopEndLabels(cg.loopDepth - 1) = ""
    cg.loopDepth -= 1
    Return 1
End Function

Private Function X64EmitExitStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: EXIT"

    Dim exitMode As String
    exitMode = X64Upper(Trim(ps.ast.nodes(nodeIdx).op))
    If exitMode = "" Then exitMode = "ANY"

    Select Case exitMode
    Case "IF"
        If gX64IfDepth > 0 Then
            X64EmitText cg, "    jmp " & gX64IfEndLabels(gX64IfDepth - 1)
            Return 1
        End If
        errText = "x64-codegen: EXIT IF used outside IF block"
        Return 0
    Case "FOR", "DO"
        If cg.loopDepth <= 0 Then
            errText = "x64-codegen: EXIT " & exitMode & " used outside loop"
            Return 0
        End If
        X64EmitText cg, "    jmp " & gX64LoopEndLabels(cg.loopDepth - 1)
        Return 1
    Case Else
        errText = "x64-codegen: unsupported EXIT mode " & ps.ast.nodes(nodeIdx).op
        Return 0
    End Select
End Function

Private Function X64EmitLabelStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim labelName As String
    labelName = Trim(ps.ast.nodes(nodeIdx).value)
    If labelName = "" Then
        errText = "x64-codegen: LABEL name missing"
        Return 0
    End If

    X64EmitLabel cg, X64ScopedLabelSymbol(cg, labelName)
    Return 1
End Function

Private Function X64EmitGotoStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim labelName As String
    labelName = Trim(ps.ast.nodes(nodeIdx).value)
    If labelName = "" Then
        errText = "x64-codegen: GOTO target missing"
        Return 0
    End If

    X64EmitText cg, "    jmp " & X64ScopedLabelSymbol(cg, labelName)
    Return 1
End Function

Private Function X64EmitGosubStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim labelName As String
    labelName = Trim(ps.ast.nodes(nodeIdx).value)
    If labelName = "" Then
        errText = "x64-codegen: GOSUB target missing"
        Return 0
    End If

    X64EmitText cg, "    call " & X64ScopedLabelSymbol(cg, labelName)
    Return 1
End Function

Private Function X64EmitCallStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Return X64EmitCallNode(ps, nodeIdx, cg, errText)
End Function

Private Function X64EmitCallNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim calleeName As String
    calleeName = Trim(ps.ast.nodes(nodeIdx).value)
    If calleeName = "" Then calleeName = "__uxb_unknown_call"

    Dim argCount As Integer
    argCount = X64ChildCount(ps, nodeIdx)

    Dim builtinName As String
    builtinName = X64Upper(calleeName)

    If X64IsDllCallNode(ps, nodeIdx) <> 0 Then
        Return X64EmitDllCallNode(ps, nodeIdx, cg, errText)
    End If

    If builtinName = "CALL" Then
        Dim firstArg As Integer
        firstArg = X64ChildAt(ps, nodeIdx, 0)
        If firstArg <> -1 Then
            Dim firstKind As String
            firstKind = X64Upper(ps.ast.nodes(firstArg).kind)
            If (firstKind = "IDENT" Or firstKind = "KEYWORD_REF") And X64Upper(ps.ast.nodes(firstArg).value) = "DLL" Then
                Return X64EmitDllCallNode(ps, nodeIdx, cg, errText)
            End If
        End If
    End If

    If builtinName = "FIX" Then
        If argCount <> 1 Then
            errText = "x64-codegen: FIX expects 1 argument"
            Return 0
        End If
        Return X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 0), cg, errText)
    End If

    If builtinName = "VARPTR" Then
        If argCount <> 1 Then
            errText = "x64-codegen: VARPTR expects 1 argument"
            Return 0
        End If

        Dim ptrArg As Integer
        ptrArg = X64ChildAt(ps, nodeIdx, 0)
        If ptrArg = -1 Then
            errText = "x64-codegen: VARPTR argument missing"
            Return 0
        End If

        Dim ptrKind As String
        ptrKind = X64Upper(ps.ast.nodes(ptrArg).kind)
        If ptrKind <> "IDENT" And ptrKind <> "KEYWORD_REF" Then
            errText = "x64-codegen: VARPTR requires identifier argument"
            Return 0
        End If

        Dim ptrDeclType As String
        If X64FindDeclaredTypeName(ps, ps.ast.nodes(ptrArg).value, ptrDeclType) <> 0 Then
            If ptrDeclType = "OBJECT" Or X64FindClassDeclNode(ps, ptrDeclType) <> -1 Then
                X64EmitLoadVar cg, ps.ast.nodes(ptrArg).value
                Return 1
            End If
        End If

        Return X64EmitAddrOfVar(cg, ps.ast.nodes(ptrArg).value, errText)
    End If

    If builtinName = "OFFSETOF" Then
        If argCount <> 2 Then
            errText = "x64-codegen: OFFSETOF expects 2 arguments"
            Return 0
        End If

        Dim typeNode As Integer
        Dim pathNode As Integer
        typeNode = X64ChildAt(ps, nodeIdx, 0)
        pathNode = X64ChildAt(ps, nodeIdx, 1)
        If typeNode = -1 Or pathNode = -1 Then
            errText = "x64-codegen: OFFSETOF arguments missing"
            Return 0
        End If

        Dim typeKind As String
        Dim pathKind As String
        typeKind = X64Upper(ps.ast.nodes(typeNode).kind)
        pathKind = X64Upper(ps.ast.nodes(pathNode).kind)
        If typeKind <> "IDENT" And typeKind <> "KEYWORD_REF" Then
            errText = "x64-codegen: OFFSETOF first argument must be type name"
            Return 0
        End If
        If pathKind <> "STRING" Then
            errText = "x64-codegen: OFFSETOF second argument must be path string"
            Return 0
        End If

        Dim offsetValue As Integer
        Dim offsetErr As String
        If TypeLayoutOffsetOf(ps, ps.ast.nodes(typeNode).value, ps.ast.nodes(pathNode).value, offsetValue, offsetErr) = 0 Then
            errText = "x64-codegen: OFFSETOF resolve failed " & offsetErr
            Return 0
        End If

        X64EmitText cg, "    mov rax, " & X64ToStr(offsetValue)
        Return 1
    End If

    If builtinName = "PEEKB" Or builtinName = "PEEKW" Or builtinName = "PEEKD" Then
        If argCount <> 1 Then
            errText = "x64-codegen: " & builtinName & " expects 1 argument"
            Return 0
        End If

        If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 0), cg, errText) = 0 Then Return 0
        X64EmitText cg, "    mov rcx, rax"

        Select Case builtinName
        Case "PEEKB"
            X64EmitCall0 cg, "__uxb_mem_peekb"
        Case "PEEKW"
            X64EmitCall0 cg, "__uxb_mem_peekw"
        Case Else
            X64EmitCall0 cg, "__uxb_mem_peekd"
        End Select
        Return 1
    End If

    Dim methodPrependReceiver As Integer
    Dim methodReceiverOwner As String
    Dim methodReceiverType As String
    methodPrependReceiver = 0
    methodReceiverOwner = ""
    methodReceiverType = ""

    Dim methodOwner As String
    Dim methodName As String
    If X64SplitMethodCallName(calleeName, methodOwner, methodName) <> 0 Then
        Dim ownerUpper As String
        Dim methodUpper As String
        ownerUpper = X64Upper(methodOwner)
        methodUpper = X64Upper(methodName)

        If X64FindClassDeclNode(ps, ownerUpper) <> -1 Then
            Dim staticOwner As String
            staticOwner = ownerUpper
            If X64ResolveMethodOwnerType(ps, ownerUpper, methodUpper, staticOwner) = 0 Then staticOwner = ownerUpper
            calleeName = staticOwner & "_" & methodUpper
        Else
            Dim receiverType As String
            If X64FindDeclaredTypeName(ps, ownerUpper, receiverType) = 0 Then
                If X64TryGetVarType(cg, ownerUpper, receiverType) = 0 Then
                    If ownerUpper = "THIS" Or ownerUpper = "ME" Then
                        If X64ResolveCurrentReceiverClass(ps, cg, receiverType) = 0 Then
                            errText = "x64-codegen: unknown method receiver " & ownerUpper
                            Return 0
                        End If
                    Else
                        errText = "x64-codegen: unknown method receiver " & ownerUpper
                        Return 0
                    End If
                End If
            End If
            receiverType = X64Upper(Trim(receiverType))
            If receiverType = "" Or X64FindClassDeclNode(ps, receiverType) = -1 Then
                errText = "x64-codegen: method receiver is not class instance " & ownerUpper
                Return 0
            End If

            Dim resolvedOwner As String
            resolvedOwner = receiverType
            If X64ResolveMethodOwnerType(ps, receiverType, methodUpper, resolvedOwner) = 0 Then resolvedOwner = receiverType

            calleeName = resolvedOwner & "_" & methodUpper
            methodPrependReceiver = 1
            methodReceiverOwner = ownerUpper
            methodReceiverType = receiverType
        End If

        Dim exactMethodSymbol As String
        If X64FindRoutineSymbolName(ps, calleeName, exactMethodSymbol) <> 0 Then
            calleeName = exactMethodSymbol
        Else
            calleeName = LCase(calleeName)
        End If

        builtinName = X64Upper(calleeName)
    End If

    Dim builtinSymbol As String
    builtinSymbol = X64BuiltinCallSymbol(builtinName)
    If builtinSymbol <> "" Then
        ' Special-case: STR for F64 arguments -> call sprintf with xmm0 holding double
        If UCase(builtinName) = "STR" And argCount = 1 Then
            Dim strArg As Integer
            strArg = X64ChildAt(ps, nodeIdx, 0)
            Dim argDecl As String
            argDecl = ""
            If strArg <> -1 Then
                If X64FindDeclaredTypeName(ps, ps.ast.nodes(strArg).value, argDecl) <> 0 And UCase(argDecl) = "F64" Then
                    If X64EmitExprToXmm0(ps, strArg, cg, errText) = 0 Then Return 0
                    X64EmitText cg, "    lea rcx, [rel __uxb_str_buf]"
                    X64EmitText cg, "    lea rdx, [rel __uxb_fmt_f64]"
                    X64EmitText cg, "    sub rsp, 40"
                    X64EmitText cg, "    call sprintf"
                    X64EmitText cg, "    add rsp, 40"
                    X64EmitText cg, "    lea rax, [rel __uxb_str_buf]"
                    Return 1
                End If
            End If
        End If

        ' Float-returning builtins: evaluate argument to xmm0 and call; builtin returns double in xmm0
        Dim upBuiltin As String
        upBuiltin = X64Upper(builtinName)
        If upBuiltin = "SQR" Or upBuiltin = "SIN" Or upBuiltin = "COS" Or upBuiltin = "TAN" Or upBuiltin = "ATN" Or upBuiltin = "EXP" Or upBuiltin = "LOG" Then
            Select Case argCount
            Case 0
                X64EmitText cg, "    xorps xmm0, xmm0"
            Case 1
                If X64EmitExprToXmm0(ps, X64ChildAt(ps, nodeIdx, 0), cg, errText) = 0 Then Return 0
            Case Else
                errText = "x64-codegen: float builtin " & builtinName & " unsupported argcount=" & X64ToStr(argCount)
                Return 0
            End Select
            X64EmitText cg, "    sub rsp, 40"
            X64EmitText cg, "    call " & builtinSymbol
            X64EmitText cg, "    add rsp, 40"
            Return 1
        End If

        Select Case argCount
        Case 0
            X64EmitCall0 cg, builtinSymbol
            Return 1
        Case 1
            If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 0), cg, errText) = 0 Then Return 0
            X64EmitCall1 cg, builtinSymbol
            Return 1
        Case 2
            If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 0), cg, errText) = 0 Then Return 0
            X64EmitText cg, "    push rax"
            If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 1), cg, errText) = 0 Then Return 0
            X64EmitCall2 cg, builtinSymbol
            Return 1
        Case 3
            If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 0), cg, errText) = 0 Then Return 0
            X64EmitText cg, "    push rax"
            If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 1), cg, errText) = 0 Then Return 0
            X64EmitText cg, "    push rax"
            If X64EmitExprToRax(ps, X64ChildAt(ps, nodeIdx, 2), cg, errText) = 0 Then Return 0
            X64EmitCall3 cg, builtinSymbol
            Return 1
        Case Else
            errText = "x64-codegen: builtin argument count not supported for " & builtinName
            Return 0
        End Select
    End If

    Dim expectedArgCount As Integer
    Dim calleeIsFunction As Integer
    Dim actualArgCount As Integer
    actualArgCount = argCount + methodPrependReceiver

    If X64TryGetRoutineSignature(cg, calleeName, expectedArgCount, calleeIsFunction) <> 0 Then
        If actualArgCount <> expectedArgCount Then
            errText = "x64-codegen: argument count mismatch for " & calleeName & " expected=" & X64ToStr(expectedArgCount) & " actual=" & X64ToStr(actualArgCount)
            Return 0
        End If
    End If

    Dim regOrder(0 To 3) As String
    regOrder(0) = "rcx"
    regOrder(1) = "rdx"
    regOrder(2) = "r8"
    regOrder(3) = "r9"

    Dim stackArgCount As Integer
    stackArgCount = 0
    If actualArgCount > 4 Then stackArgCount = actualArgCount - 4

    Dim regSpillSlots As Integer
    regSpillSlots = actualArgCount
    If regSpillSlots > 4 Then regSpillSlots = 4

    Dim reserveBytes As Integer
    reserveBytes = 32
    reserveBytes += stackArgCount * 8
    reserveBytes += regSpillSlots * 8
    If (reserveBytes Mod 16) <> 0 Then reserveBytes += 8

    If reserveBytes > 0 Then X64EmitText cg, "    sub rsp, " & X64ToStr(reserveBytes)

    If methodPrependReceiver <> 0 Then
        If methodReceiverType = "" Or methodReceiverType = "OBJECT" Or X64FindClassDeclNode(ps, methodReceiverType) <> -1 Then
            X64EmitLoadVar cg, methodReceiverOwner
        Else
            If X64EmitAddrOfVar(cg, methodReceiverOwner, errText) = 0 Then Return 0
        End If

        Dim recvSpillOffset As Integer
        recvSpillOffset = 32 + (stackArgCount * 8)
        X64EmitText cg, "    mov [rsp + " & X64ToStr(recvSpillOffset) & "], rax"
    End If

    Dim i As Integer
    For i = 0 To argCount - 1
        Dim argNode As Integer
        argNode = X64ChildAt(ps, nodeIdx, i)
        If argNode = -1 Then Continue For

        If X64EmitExprToRax(ps, argNode, cg, errText) = 0 Then Return 0

        Dim dstIndex As Integer
        dstIndex = i + methodPrependReceiver

        If dstIndex < 4 Then
            Dim spillOffset As Integer
            spillOffset = 32 + (stackArgCount * 8) + (dstIndex * 8)
            X64EmitText cg, "    mov [rsp + " & X64ToStr(spillOffset) & "], rax"
        Else
            Dim stackOffset As Integer
            stackOffset = 32 + ((dstIndex - 4) * 8)
            X64EmitText cg, "    mov [rsp + " & X64ToStr(stackOffset) & "], rax"
        End If
    Next i

    For i = 0 To regSpillSlots - 1
        Dim loadOffset As Integer
        loadOffset = 32 + (stackArgCount * 8) + (i * 8)
        X64EmitText cg, "    mov " & regOrder(i) & ", [rsp + " & X64ToStr(loadOffset) & "]"
    Next i

    ' If this is a method call with a receiver, and the method is virtual, emit vtable indirect call
    If methodPrependReceiver <> 0 Then
        Dim methodUpperLookup As String
        methodUpperLookup = X64Upper(Trim(methodName))
        Dim vslot As Integer
        vslot = -1
        If methodUpperLookup <> "" And methodReceiverType <> "" Then
            If X64FindVTableSlot(cg, methodReceiverType, methodUpperLookup, vslot) <> 0 Then
                ' rcx currently holds receiver after reg loads; perform indirect vtable call
                Dim vcallNullObjLbl As String
                Dim vcallNullVtblLbl As String
                Dim vcallNullSlotLbl As String
                Dim vcallAfterLbl As String
                vcallNullObjLbl = X64NextLabel(cg, "vcall_null_obj")
                vcallNullVtblLbl = X64NextLabel(cg, "vcall_null_vtbl")
                vcallNullSlotLbl = X64NextLabel(cg, "vcall_null_slot")
                vcallAfterLbl = X64NextLabel(cg, "vcall_after")

                X64EmitText cg, "    test rcx, rcx"
                X64EmitText cg, "    jz " & vcallNullObjLbl
                X64EmitText cg, "    mov rax, [rcx]"
                X64EmitText cg, "    test rax, rax"
                X64EmitText cg, "    jz " & vcallNullVtblLbl
                X64EmitText cg, "    mov r11, [rax + " & X64ToStr(vslot * 8) & "]"
                X64EmitText cg, "    test r11, r11"
                X64EmitText cg, "    jz " & vcallNullSlotLbl
                X64EmitText cg, "    call r11"
                X64EmitText cg, "    jmp " & vcallAfterLbl

                X64EmitLabel cg, vcallNullObjLbl
                X64EmitText cg, "    xor rax, rax"
                X64EmitText cg, "    jmp " & vcallAfterLbl
                X64EmitLabel cg, vcallNullVtblLbl
                X64EmitText cg, "    xor rax, rax"
                X64EmitText cg, "    jmp " & vcallAfterLbl
                X64EmitLabel cg, vcallNullSlotLbl
                X64EmitText cg, "    xor rax, rax"
                X64EmitLabel cg, vcallAfterLbl
                If reserveBytes > 0 Then X64EmitText cg, "    add rsp, " & X64ToStr(reserveBytes)
                Return 1
            End If
        End If
    End If

    X64EmitText cg, "    call " & calleeName
    If reserveBytes > 0 Then X64EmitText cg, "    add rsp, " & X64ToStr(reserveBytes)
    Return 1
End Function

Private Function X64InferFloatKindOfExpr(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case nodeKind
    Case "NUMBER", "INTEGER", "INT", "INT_LITERAL"
        Return UXF_F64
    Case "IDENT", "IDENTIFIER", "VAR", "NAME", "VAR_REF", "KEYWORD_REF"
        Dim identName As String
        identName = Trim(ps.ast.nodes(nodeIdx).value)
        If identName = "" Then Return 0

        Dim declType As String
        declType = ""
        If X64TryGetVarType(cg, identName, declType) <> 0 Then
            Return X64TypeToFloatKind(declType)
        End If
        If X64FindDeclaredTypeName(ps, identName, declType) <> 0 Then
            Return X64TypeToFloatKind(declType)
        End If
        Return 0
    Case "CALL_EXPR"
        Dim callName As String
        callName = Trim(ps.ast.nodes(nodeIdx).value)
        If callName = "" Then Return 0

        If InStr(callName, ".") > 0 Then
            Dim rootName As String
            Dim pathText As String
            Dim rootNode As Integer
            Dim rootType As String
            Dim fieldOffset As Integer
            Dim fieldType As String
            Dim fieldSize As Integer
            Dim resolveErr As String
            If X64ResolveFieldInfo(ps, nodeIdx, cg, rootName, pathText, rootNode, rootType, fieldOffset, fieldType, fieldSize, resolveErr) <> 0 Then
                Return X64TypeToFloatKind(fieldType)
            End If
        End If

        Dim retType As String
        retType = ""
        If X64TryGetRoutineReturnType(cg, callName, retType) <> 0 Then
            Return X64TypeToFloatKind(retType)
        End If
        Return 0
    Case "FIELD_EXPR"
        Dim rootName As String
        Dim pathText As String
        Dim rootNode As Integer
        Dim rootType As String
        Dim fieldOffset As Integer
        Dim fieldType As String
        Dim fieldSize As Integer
        Dim resolveErr As String
        If X64ResolveFieldInfo(ps, nodeIdx, cg, rootName, pathText, rootNode, rootType, fieldOffset, fieldType, fieldSize, resolveErr) <> 0 Then
            Return X64TypeToFloatKind(fieldType)
        End If
        Return 0
    Case "BINARY", "BINARY_EXPR", "BINOP", "OP", "ADD", "SUB", "MUL", "DIV"
        Dim lhs As Integer
        Dim rhs As Integer
        lhs = ps.ast.nodes(nodeIdx).left
        rhs = ps.ast.nodes(nodeIdx).right
        If lhs = -1 Then lhs = X64ChildAt(ps, nodeIdx, 0)
        If rhs = -1 Then rhs = X64ChildAt(ps, nodeIdx, 1)

        Dim lk As Integer
        Dim rk As Integer
        lk = X64InferFloatKindOfExpr(ps, lhs, cg)
        rk = X64InferFloatKindOfExpr(ps, rhs, cg)

        If lk = UXF_F80 Or rk = UXF_F80 Then Return UXF_F80
        If lk = UXF_F64 Or rk = UXF_F64 Then Return UXF_F64
        If lk = UXF_F32 Or rk = UXF_F32 Then Return UXF_F32
        Return 0
    Case Else
        Dim baseName As String
        Dim indexExpr As Integer
        If X64TryExtractIndexedTarget(ps, nodeIdx, baseName, indexExpr) <> 0 Then
            Dim baseType As String
            baseType = ""
            If X64TryGetVarType(cg, baseName, baseType) <> 0 Then
                Return X64TypeToFloatKind(baseType)
            End If
            If X64FindDeclaredTypeName(ps, baseName, baseType) <> 0 Then
                Return X64TypeToFloatKind(baseType)
            End If
        End If
    End Select

    Return 0
End Function

Private Function X64EmitPrintStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim hadItems As Integer
    hadItems = 0
    Dim suppressNewline As Integer
    suppressNewline = 0

    Dim itemNode As Integer
    itemNode = ps.ast.nodes(nodeIdx).firstChild
    Do While itemNode <> -1
        Dim exprNode As Integer
        exprNode = ps.ast.nodes(itemNode).left
        If exprNode = -1 Then exprNode = X64ChildAt(ps, itemNode, 0)
        If exprNode <> -1 Then
            Dim inferredFloatKind As Integer
            inferredFloatKind = X64InferFloatKindOfExpr(ps, exprNode, cg)

            If inferredFloatKind = UXF_UNKNOWN Then
                Dim inferKindExpr As String
                inferKindExpr = X64Upper(ps.ast.nodes(exprNode).kind)
                If inferKindExpr = "FIELD_EXPR" Or (inferKindExpr = "CALL_EXPR" And InStr(Trim(ps.ast.nodes(exprNode).value), ".") > 0) Then
                    Dim inferRootName As String
                    Dim inferPathText As String
                    Dim inferRootNode As Integer
                    Dim inferRootType As String
                    Dim inferFieldOffset As Integer
                    Dim inferFieldType As String
                    Dim inferFieldSize As Integer
                    Dim inferErr As String
                    If X64ResolveFieldInfo(ps, exprNode, cg, inferRootName, inferPathText, inferRootNode, inferRootType, inferFieldOffset, inferFieldType, inferFieldSize, inferErr) <> 0 Then
                        inferredFloatKind = X64TypeToFloatKind(inferFieldType)
                    End If
                End If
            End If

            If inferredFloatKind = UXF_F80 Then
                Dim exprKind As String
                exprKind = X64Upper(ps.ast.nodes(exprNode).kind)

                If exprKind = "FIELD_EXPR" Or (exprKind = "CALL_EXPR" And InStr(Trim(ps.ast.nodes(exprNode).value), ".") > 0) Then
                    Dim f80FieldType As String
                    Dim f80FieldSize As Integer
                    If X64EmitAddrOfFieldExpr(ps, exprNode, cg, f80FieldType, f80FieldSize, errText) = 0 Then Return 0
                ElseIf exprKind = "IDENT" Or exprKind = "IDENTIFIER" Or exprKind = "VAR" Or exprKind = "VAR_REF" Or exprKind = "KEYWORD_REF" Then
                    If X64EmitAddrOfVar(cg, Trim(ps.ast.nodes(exprNode).value), errText) = 0 Then Return 0
                Else
                    errText = "x64-codegen: PRINT F80 currently supports variable/field expressions only"
                    Return 0
                End If

                ' x87 uzerinden tword -> qword donusumu yapip mevcut PRINT(f64) yolunu kullan.
                X64EmitText cg, "    sub rsp, 16"
                X64EmitText cg, "    fld tword [rax]"
                X64EmitText cg, "    fstp qword [rsp]"
                X64EmitText cg, "    movsd xmm0, [rsp]"
                X64EmitText cg, "    add rsp, 16"

                X64EmitText cg, "    lea rcx, [rel __uxb_str_buf]"
                X64EmitText cg, "    lea rdx, [rel __uxb_fmt_f64]"
                X64EmitText cg, "    movapd xmm2, xmm0"
                X64EmitText cg, "    movq r8, xmm0"
                X64EmitText cg, "    sub rsp, 32"
                X64EmitText cg, "    call sprintf"
                X64EmitText cg, "    add rsp, 32"
                X64EmitText cg, "    lea rax, [rel __uxb_str_buf]"
                X64EmitText cg, "    mov rcx, rax"
                X64EmitText cg, "    call __uxb_runtime_print"
            ElseIf inferredFloatKind = UXF_F32 Or inferredFloatKind = UXF_F64 Then
                If X64EmitExprToXmm0As(ps, exprNode, cg, UXF_F64, errText) = 0 Then Return 0
                X64EmitText cg, "    lea rcx, [rel __uxb_str_buf]"
                X64EmitText cg, "    lea rdx, [rel __uxb_fmt_f64]"
                X64EmitText cg, "    movapd xmm2, xmm0"
                X64EmitText cg, "    movq r8, xmm0"
                X64EmitText cg, "    sub rsp, 32"
                X64EmitText cg, "    call sprintf"
                X64EmitText cg, "    add rsp, 32"
                X64EmitText cg, "    lea rax, [rel __uxb_str_buf]"
                X64EmitText cg, "    mov rcx, rax"
                X64EmitText cg, "    call __uxb_runtime_print"
            Else
                If X64EmitExprToRax(ps, exprNode, cg, errText) = 0 Then Return 0
                X64EmitText cg, "    mov r8, rax"
                X64EmitText cg, "    lea rcx, [rel __uxb_str_buf]"
                X64EmitText cg, "    lea rdx, [rel __uxb_fmt_num]"
                X64EmitText cg, "    sub rsp, 32"
                X64EmitText cg, "    call sprintf"
                X64EmitText cg, "    add rsp, 32"
                X64EmitText cg, "    lea rcx, [rel __uxb_str_buf]"
                X64EmitText cg, "    call __uxb_runtime_print"
            End If
            hadItems = 1
        End If

        Dim sepOp As String
        sepOp = Trim(ps.ast.nodes(itemNode).op)
        If sepOp = "," Then
            X64EmitText cg, "    call __uxb_runtime_print_sep_comma"
            suppressNewline = 0
        ElseIf sepOp = ";" Then
            X64EmitText cg, "    call __uxb_runtime_print_sep_semicolon"
            suppressNewline = 1
        Else
            suppressNewline = 0
        End If

        itemNode = ps.ast.nodes(itemNode).nextSibling
    Loop

    If hadItems = 0 Then
        X64EmitText cg, "    call __uxb_runtime_print_newline"
    ElseIf suppressNewline = 0 Then
        X64EmitText cg, "    call __uxb_runtime_print_newline"
    End If
    X64EmitText cg, "    xor rcx, rcx"
    X64EmitCall0 cg, "fflush"
    Return 1
End Function

Private Function X64EmitReturnStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: RETURN"
    Dim retExpr As Integer
    retExpr = X64ChildAt(ps, nodeIdx, 0)

    If retExpr <> -1 Then
        Dim routineRetType As String
        Dim routineRetKind As Integer
        routineRetType = ""
        routineRetKind = 0

        If cg.currentRoutineIsFunction <> 0 And X64TryGetRoutineReturnType(cg, cg.currentRoutineLabel, routineRetType) <> 0 Then
            routineRetKind = X64TypeToFloatKind(routineRetType)
        End If

        If routineRetKind = UXF_F32 Or routineRetKind = UXF_F64 Then
            If X64EmitExprToXmm0As(ps, retExpr, cg, routineRetKind, errText) = 0 Then Return 0
        ElseIf routineRetKind = UXF_F80 Then
            errText = "x64-codegen: F80 function return requires x87/ST0 path"
            Return 0
        Else
            If X64EmitExprToRax(ps, retExpr, cg, errText) = 0 Then Return 0
        End If
    ElseIf cg.currentRoutineIsFunction = 0 Then
        X64EmitComment cg, "SUB RETURN uses control transfer only"
    End If

    If Trim(cg.currentRoutineLabel) = "" Then
        X64EmitText cg, "    ret"
    ElseIf cg.currentEpilogLabel <> "" Then
        X64EmitText cg, "    jmp " & cg.currentEpilogLabel
    Else
        X64EmitText cg, "    leave"
        X64EmitText cg, "    ret"
    End If
    Return 1
End Function

Private Function X64EmitBlockStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild

    Do While ch <> -1
        If X64EmitNode(ps, ch, cg, errText) = 0 Then Return 0
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 1
End Function

Private Function X64EmitExprStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: EXPR"
    Dim exprNode As Integer
    exprNode = ps.ast.nodes(nodeIdx).left
    If exprNode = -1 Then exprNode = X64ChildAt(ps, nodeIdx, 0)

    If exprNode <> -1 Then
        Return X64EmitExprToRax(ps, exprNode, cg, errText)
    End If

    Return 1
End Function

Private Function X64EmitAssignStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: ASSIGN"
    Dim lhs As Integer
    Dim rhs As Integer
    lhs = ps.ast.nodes(nodeIdx).left
    rhs = ps.ast.nodes(nodeIdx).right

    If lhs = -1 Or rhs = -1 Then
        errText = "x64-codegen: ASSIGN_STMT missing lhs/rhs"
        Return 0
    End If

    Dim lhsName As String
    Dim lhsKind As String
    lhsKind = X64Upper(ps.ast.nodes(lhs).kind)

    Dim lhsIndexExpr As Integer
    lhsIndexExpr = -1
    Dim lhsIsIndexed As Integer
    lhsIsIndexed = 0

    If lhsKind = "IDENT" Or lhsKind = "IDENTIFIER" Then
        lhsName = Trim(ps.ast.nodes(lhs).value)
    ElseIf X64TryExtractIndexedTarget(ps, lhs, lhsName, lhsIndexExpr) <> 0 Then
        If InStr(lhsName, ".") > 0 Then
            lhsKind = "FIELD_EXPR"
            lhsName = "__FIELD__"
        Else
            lhsIsIndexed = 1
        End If
    ElseIf lhsKind = "FIELD_EXPR" Then
        lhsName = "__FIELD__"
    Else
        errText = "x64-codegen: assignment target must be identifier/index/field"
        Return 0
    End If

    If lhsName = "" Then
        errText = "x64-codegen: assignment target is empty"
        Return 0
    End If

    Dim opText As String
    opText = Trim(ps.ast.nodes(nodeIdx).op)

    Dim lhsTypeText As String
    Dim lhsFloatKind As Integer
    lhsTypeText = ""
    lhsFloatKind = 0

    If X64TryGetVarType(cg, lhsName, lhsTypeText) <> 0 Then
        lhsFloatKind = X64TypeToFloatKind(lhsTypeText)
    End If
    If lhsFloatKind = 0 And X64FindDeclaredTypeName(ps, lhsName, lhsTypeText) <> 0 Then
        lhsFloatKind = X64TypeToFloatKind(lhsTypeText)
    End If

    If lhsFloatKind = UXF_F32 Or lhsFloatKind = UXF_F64 Or lhsFloatKind = UXF_F80 Then
        If opText <> "=" And opText <> "" Then
            errText = "x64-codegen: float compound assignment unsupported"
            Return 0
        End If

        If lhsFloatKind = UXF_F80 Then
            Dim f80Raw As String
            f80Raw = ""
            If X64TryGetNumberLiteral(ps, rhs, f80Raw) = 0 Then
                errText = "x64-codegen: F80 arithmetic not yet supported in x64 backend"
                Return 0
            End If
            If lhsKind = "FIELD_EXPR" Then
                errText = "x64-codegen: FIELD_EXPR float assignment not supported yet"
                Return 0
            ElseIf lhsIsIndexed <> 0 Then
                If cg.currentRoutineLabel <> "" And X64EmitStoreIndexedLocalF80Literal(ps, cg, lhsName, lhsIndexExpr, f80Raw, errText) <> 0 Then
                    Return 1
                End If
                If X64EmitStoreIndexedGlobalF80Literal(ps, cg, lhsName, lhsIndexExpr, f80Raw, errText) = 0 Then
                    errText = "x64-codegen: indexed store currently supports DIM arrays"
                    Return 0
                End If
                Return 1
            End If

            Return X64EmitStoreF80LiteralVar(ps, cg, lhsName, f80Raw, errText)
        End If

        If X64EmitExprToXmm0As(ps, rhs, cg, lhsFloatKind, errText) = 0 Then Return 0

        If lhsKind = "FIELD_EXPR" Then
            errText = "x64-codegen: FIELD_EXPR float assignment not supported yet"
            Return 0
        End If

        If lhsIsIndexed <> 0 Then
            If cg.currentRoutineLabel <> "" And X64EmitStoreIndexedLocalXmm(ps, cg, lhsName, lhsIndexExpr, errText) <> 0 Then
                Return 1
            End If
            If X64EmitStoreIndexedGlobalXmm(ps, cg, lhsName, lhsIndexExpr, errText) = 0 Then
                errText = "x64-codegen: indexed float store currently supports DIM arrays"
                Return 0
            End If
            Return 1
        End If

        If X64EmitStoreXmm0ToFloatVarAs(cg, lhsName, lhsFloatKind, errText) = 0 Then Return 0
        Return 1
    End If

    If opText = "=" Or opText = "" Then
        If lhsKind = "FIELD_EXPR" Then
            Return X64EmitStoreFieldFromRhs(ps, lhs, rhs, cg, errText)
        End If

        If X64EmitExprToRax(ps, rhs, cg, errText) = 0 Then Return 0
        If lhsIsIndexed <> 0 Then
            If cg.currentRoutineLabel <> "" And X64EmitStoreIndexedLocal(ps, cg, lhsName, lhsIndexExpr, errText) <> 0 Then
                Return 1
            End If
            If X64EmitStoreIndexedGlobal(ps, cg, lhsName, lhsIndexExpr, errText) = 0 Then
                errText = "x64-codegen: indexed store currently supports DIM arrays"
                Return 0
            End If
            Return 1
        Else
            If cg.currentRoutineLabel <> "" And X64HasTopLevelGlobalDecl(ps, lhsName) <> 0 Then
                Dim lhsGlobalLabel As String
                If X64TryFindSymbolLabel(cg, cg.currentRoutineLabel, lhsName, lhsGlobalLabel) = 0 Then
                    lhsGlobalLabel = X64EnsureVar(cg, lhsName)
                End If
                X64EmitText cg, "    mov [rel " & lhsGlobalLabel & "], rax"
            Else
                X64EmitStoreVar cg, lhsName
            End If
        End If
        Return 1
    End If

    If lhsKind = "FIELD_EXPR" Then
        Dim cmpFieldType As String
        Dim cmpFieldSize As Integer
        Dim cmpDummyRoot As String
        Dim cmpDummyPath As String
        Dim cmpDummyRootNode As Integer
        Dim cmpDummyRootType As String
        Dim cmpDummyOffset As Integer
        If X64ResolveFieldInfo(ps, lhs, cg, cmpDummyRoot, cmpDummyPath, cmpDummyRootNode, cmpDummyRootType, cmpDummyOffset, cmpFieldType, cmpFieldSize, errText) = 0 Then
            Return 0
        End If
        Dim cmpFk As Integer
        cmpFk = X64TypeToFloatKind(cmpFieldType)
        If cmpFk = UXF_F32 Or cmpFk = UXF_F64 Or cmpFk = UXF_F80 Then
            errText = "x64-codegen: float field compound assignment unsupported"
            Return 0
        End If
    End If

    If lhsKind = "FIELD_EXPR" Then
        If X64EmitLoadFieldExpr(ps, lhs, cg, errText) = 0 Then Return 0
    ElseIf lhsIsIndexed <> 0 Then
        If cg.currentRoutineLabel <> "" And X64EmitLoadIndexedLocal(ps, cg, lhsName, lhsIndexExpr, errText) <> 0 Then
        ElseIf X64EmitLoadIndexedGlobal(ps, cg, lhsName, lhsIndexExpr, errText) = 0 Then
            errText = "x64-codegen: indexed assignment currently supports DIM arrays"
            Return 0
        End If
    Else
        If cg.currentRoutineLabel <> "" And X64HasTopLevelGlobalDecl(ps, lhsName) <> 0 Then
            Dim lhsLoadGlobalLabel As String
            If X64TryFindSymbolLabel(cg, cg.currentRoutineLabel, lhsName, lhsLoadGlobalLabel) = 0 Then
                lhsLoadGlobalLabel = X64EnsureVar(cg, lhsName)
            End If
            X64EmitText cg, "    mov rax, [rel " & lhsLoadGlobalLabel & "]"
        Else
            X64EmitLoadVar cg, lhsName
        End If
    End If
    X64EmitText cg, "    push rax"
    If X64EmitExprToRax(ps, rhs, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    pop rax"

    Select Case opText
    Case "+=", "=+"
        X64EmitText cg, "    add rax, rbx"
    Case "-=", "=-"
        X64EmitText cg, "    sub rax, rbx"
    Case "*="
        X64EmitText cg, "    imul rax, rbx"
    Case "/=", "\="
        X64EmitText cg, "    cqo"
        X64EmitText cg, "    idiv rbx"
    Case Else
        errText = "x64-codegen: unsupported assignment operator '" & opText & "'"
        Return 0
    End Select

    If lhsKind = "FIELD_EXPR" Then
        Return X64EmitStoreFieldExpr(ps, lhs, cg, errText)
    ElseIf lhsIsIndexed <> 0 Then
        If cg.currentRoutineLabel <> "" And X64EmitStoreIndexedLocal(ps, cg, lhsName, lhsIndexExpr, errText) <> 0 Then
        ElseIf X64EmitStoreIndexedGlobal(ps, cg, lhsName, lhsIndexExpr, errText) = 0 Then
            errText = "x64-codegen: indexed assignment currently supports DIM arrays"
            Return 0
        End If
    Else
        X64EmitStoreVar cg, lhsName
    End If
    Return 1
End Function

Private Function X64EmitIncDecStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "stmt: INCDEC"
    Dim lhs As Integer
    lhs = ps.ast.nodes(nodeIdx).left
    If lhs = -1 Then
        errText = "x64-codegen: INCDEC_STMT missing target"
        Return 0
    End If

    Dim lhsName As String
    Dim lhsIndexExpr As Integer
    Dim lhsIsIndexed As Integer
    lhsIndexExpr = -1
    lhsIsIndexed = 0

    If X64Upper(ps.ast.nodes(lhs).kind) = "IDENT" Or X64Upper(ps.ast.nodes(lhs).kind) = "IDENTIFIER" Then
        lhsName = Trim(ps.ast.nodes(lhs).value)
    ElseIf X64TryExtractIndexedTarget(ps, lhs, lhsName, lhsIndexExpr) <> 0 Then
        If InStr(lhsName, ".") > 0 Then
            lhsName = ""
        Else
            lhsIsIndexed = 1
        End If
    End If

    If lhsName = "" And X64Upper(ps.ast.nodes(lhs).kind) <> "FIELD_EXPR" AndAlso (X64Upper(ps.ast.nodes(lhs).kind) <> "CALL_EXPR" OrElse InStr(Trim(ps.ast.nodes(lhs).value), ".") = 0) Then
        errText = "x64-codegen: INCDEC_STMT invalid target"
        Return 0
    End If

    If X64Upper(ps.ast.nodes(lhs).kind) = "FIELD_EXPR" Or (X64Upper(ps.ast.nodes(lhs).kind) = "CALL_EXPR" AndAlso InStr(Trim(ps.ast.nodes(lhs).value), ".") > 0) Then
        If X64EmitLoadFieldExpr(ps, lhs, cg, errText) = 0 Then Return 0
    ElseIf lhsIsIndexed <> 0 Then
        If cg.currentRoutineLabel <> "" And X64EmitLoadIndexedLocal(ps, cg, lhsName, lhsIndexExpr, errText) <> 0 Then
        ElseIf X64EmitLoadIndexedGlobal(ps, cg, lhsName, lhsIndexExpr, errText) = 0 Then
            errText = "x64-codegen: INCDEC indexed target currently supports DIM arrays"
            Return 0
        End If
    Else
        X64EmitLoadVar cg, lhsName
    End If
    If Trim(ps.ast.nodes(nodeIdx).op) = "--" Then
        X64EmitText cg, "    sub rax, 1"
    Else
        X64EmitText cg, "    add rax, 1"
    End If
    If X64Upper(ps.ast.nodes(lhs).kind) = "FIELD_EXPR" Or (X64Upper(ps.ast.nodes(lhs).kind) = "CALL_EXPR" AndAlso InStr(Trim(ps.ast.nodes(lhs).value), ".") > 0) Then
        Return X64EmitStoreFieldExpr(ps, lhs, cg, errText)
    ElseIf lhsIsIndexed <> 0 Then
        If cg.currentRoutineLabel <> "" And X64EmitStoreIndexedLocal(ps, cg, lhsName, lhsIndexExpr, errText) <> 0 Then
        ElseIf X64EmitStoreIndexedGlobal(ps, cg, lhsName, lhsIndexExpr, errText) = 0 Then
            errText = "x64-codegen: INCDEC indexed target currently supports DIM arrays"
            Return 0
        End If
    Else
        X64EmitStoreVar cg, lhsName
    End If
    Return 1
End Function


Private Function X64CodegenAssembleOutput(ByRef cg As X64CodegenContext, ByRef asmText As String) As Integer
    asmText = cg.textSection

    If Len(cg.dataSection) > 0 Then
        asmText &= Chr(10) & "section .data" & Chr(10) & cg.dataSection
    End If

    asmText = X64CompactBlankLines(asmText)

    Return 1
End Function

Private Function GenerateX64Code(ByRef ps As ParseState, ByRef outputText As String, ByRef errText As String) As Integer
    outputText = ""
    errText = ""

    If ps.rootNode < 0 Or ps.rootNode >= ps.ast.count Then
        errText = "x64-codegen: AST root is missing"
        Return 0
    End If

    Dim cg As X64CodegenContext
    cg.textSection = ""
    cg.dataSection = ""
    cg.bssSection = ""
    cg.currentRoutineLabel = ""
    cg.labelSeed = 0
    cg.symbolCount = 0
    cg.globalCount = 0
    cg.loopDepth = 0
    VarMappingInit(cg.localVars)
    cg.localCount = 0
    cg.localFrameBytes = 0
    cg.paramCount = 0
    cg.currentEpilogLabel = ""
    cg.currentRoutineIsFunction = 0
    cg.routineCount = 0

    Dim i As Integer
    For i = 0 To 4095
        gX64SymbolKeys(i) = ""
        gX64SymbolLabels(i) = ""
        gX64GlobalKeys(i) = ""
        gX64GlobalLabels(i) = ""
        gX64GlobalSlots(i) = 0
    Next i

    For i = 0 To 255
        gX64LoopVars(i) = ""
        gX64LoopStartLabels(i) = ""
        gX64LoopEndLabels(i) = ""
        gX64LoopStepLabels(i) = ""
        gX64LoopLimitLabels(i) = ""
        gX64IfEndLabels(i) = ""
        gX64ParamNames(i) = ""
    Next i
    gX64IfDepth = 0

    For i = 0 To 1023
        gX64RoutineKeys(i) = ""
        gX64RoutineArgCounts(i) = 0
        gX64RoutineIsFunction(i) = 0
    Next i

    For i = 0 To 2047
        gX64LocalKeys(i) = ""
        gX64LocalOffsets(i) = 0
        gX64LocalSlots(i) = 0
    Next i

    X64EmitData cg, "format_str: db " & Chr(34) & "%s" & Chr(34) & ", 10, 0"
    X64EmitData cg, "format_int: db " & Chr(34) & "%lld" & Chr(34) & ", 10, 0"
    X64EmitData cg, "__uxb_prompt_fmt: db " & Chr(34) & "%s" & Chr(34) & ", 0"
    X64EmitData cg, "__uxb_scan_int: db " & Chr(34) & "%lld" & Chr(34) & ", 0"
    X64EmitData cg, "__uxb_fmt_num: db " & Chr(34) & "%lld" & Chr(34) & ", 0"
    X64EmitData cg, "__uxb_fmt_f64: db " & Chr(34) & "%g" & Chr(34) & ", 0"
    X64EmitData cg, "__uxb_print_space: db " & Chr(34) & " " & Chr(34) & ", 0"
    X64EmitData cg, "__uxb_print_newline: db 10, 0"
    X64EmitData cg, "__uxb_chr_buf: times 2 db 0"
    X64EmitData cg, "__uxb_str_buf: times 64 db 0"
    X64EmitData cg, "__uxb_ltrim_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_rtrim_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_ucase_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_lcase_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_space_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_string_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_mid_buf: times 4096 db 0"
    X64EmitData cg, "__uxb_mode_rb: db ""rb"", 0"
    X64EmitData cg, "__uxb_mode_wb: db ""wb"", 0"
    X64EmitData cg, "__uxb_mode_ab: db ""ab"", 0"
    X64EmitData cg, "__uxb_mode_rplusb: db ""r+b"", 0"
    X64EmitData cg, "__uxb_mode_wplusb: db ""w+b"", 0"
    X64EmitData cg, "__uxb_file_handles: times 256 dq 0"
    X64EmitData cg, "__uxb_file_can_read: times 256 dd 0"
    X64EmitData cg, "__uxb_file_can_write: times 256 dd 0"
    X64EmitData cg, "__uxb_file_allow_seek: times 256 dd 0"
    X64EmitData cg, "__uxb_file_record_len: times 256 dd 0"
    X64EmitData cg, "__uxb_file_tmp_path: dq 0"
    X64EmitData cg, "__uxb_file_tmp_handle: dq 0"
    X64EmitData cg, "__uxb_file_tmp_fileptr: dq 0"
    X64EmitData cg, "__uxb_file_tmp_dest: dq 0"
    X64EmitData cg, "__uxb_file_tmp_value: dq 0"
    X64EmitData cg, "__uxb_file_tmp_result: dq 0"
    X64EmitData cg, "__uxb_file_io_tmp: dq 0"
    X64EmitData cg, "__uxb_print_col: dq 0"
    X64EmitData cg, "__uxb_mem_space: times 1048576 db 0"

    If X64EmitNode(ps, ps.rootNode, cg, errText) = 0 Then Return 0

    If X64CodegenAssembleOutput(cg, outputText) = 0 Then
        errText = "x64-codegen: output assembly failed"
        Return 0
    End If

    Return 1
End Function

Function X64CodegenEmitNasm(ByRef ps As ParseState, ByRef asmText As String, ByRef errText As String) As Integer
    Return GenerateX64Code(ps, asmText, errText)
End Function

Function X64CodegenValidate(ByRef ps As ParseState, ByRef errText As String) As Integer
    If ps.rootNode < 0 Or ps.rootNode >= ps.ast.count Then
        errText = "x64-codegen: AST root is missing"
        Return 0
    End If

    errText = ""
    Return 1
End Function
Private Function X64EmitUnknownNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    X64EmitComment cg, "TODO: emit node kind='" & ps.ast.nodes(nodeIdx).kind & "'"

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If X64EmitNode(ps, ch, cg, errText) = 0 Then Return 0
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 1
End Function
