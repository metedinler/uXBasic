#include once "cg_context.fbs"
Declare Function X64EmitInputStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
Declare Function X64EmitPokeStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal helperName As String, ByVal stmtName As String) As Integer
Declare Function X64EmitPokesStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
Declare Function X64EmitMemCopyStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal helperName As String, ByVal stmtName As String) As Integer
Declare Function X64EmitMemFillStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String, ByVal helperName As String, ByVal stmtName As String) As Integer
Declare Function X64EmitSetNewOffsetStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
Declare Function X64EmitSlotLaneStmt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
Declare Function X64NextLabel(ByRef cg As X64CodegenContext, ByRef stem As String) As String
Declare Sub X64EmitData(ByRef cg As X64CodegenContext, ByRef lineText As String)
Declare Sub X64EmitText(ByRef cg As X64CodegenContext, ByRef lineText As String)
Declare Sub X64EmitLabel(ByRef cg As X64CodegenContext, ByRef labelText As String)
Declare Function X64TryFindLocalInfo(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef offsetOut As Integer, ByRef slotCountOut As Integer) As Integer
Declare Function X64FormatRbpRef(ByVal localOffset As Integer) As String
Declare Function X64EnsureGlobalSymbol(ByRef cg As X64CodegenContext, ByRef symbolText As String, ByVal elemCount As Integer, ByVal elemBytes As Integer) As String
Declare Function X64ToStr(ByVal n As Integer) As String
Declare Sub X64EmitComment(ByRef cg As X64CodegenContext, ByRef commentText As String)
Declare Function X64ChildAt(ByRef ps As ParseState, ByVal parentIdx As Integer, ByVal childOrdinal As Integer) As Integer
Declare Function X64HasTopLevelGlobalDecl(ByRef ps As ParseState, ByRef varName As String) As Integer
Declare Function X64TryFindSymbolLabel(ByRef cg As X64CodegenContext, ByRef scopeName As String, ByRef symbolText As String, ByRef labelOut As String) As Integer
Declare Function X64FindRoutine(ByRef cg As X64CodegenContext, ByRef routineKey As String) As Integer
Declare Function X64ExtractRoutineReturnType(ByRef ps As ParseState, ByVal routineNode As Integer) As String
Declare Function X64EnsureVar(ByRef cg As X64CodegenContext, ByRef varName As String) As String
Declare Sub X64EmitLoadVar(ByRef cg As X64CodegenContext, ByRef varName As String)
Declare Sub X64EmitStoreVar(ByRef cg As X64CodegenContext, ByRef varName As String)
Declare Function X64EmitLoadIndexedLocal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
Declare Function X64InferFloatKindOfExpr(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext) As Integer
Declare Function X64EmitClassRoutineNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer

Private Function X64Upper(ByRef s As String) As String
    Return UCase(Trim(s))
End Function

' Find first child of node with matching kind (case-insensitive)
Private Function X64FindChildByKind(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef kindText As String) As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) = X64Upper(kindText) Then Return ch
        ch = ps.ast.nodes(ch).nextSibling
    Loop
    Return -1
End Function

' Float kind constants
Private Const UXF_UNKNOWN = 0
Private Const UXF_F32 = 1
Private Const UXF_F64 = 2
Private Const UXF_F80 = 3

Private Function X64VarTypeKey(ByRef cg As X64CodegenContext, ByRef varName As String) As String
    Dim n As String
    n = X64Upper(Trim(varName))
    If n = "" Then Return ""

    If cg.currentRoutineLabel <> "" Then
        Return X64Upper(cg.currentRoutineLabel) & "::" & n
    End If

    Return "__GLOBAL::" & n
End Function

Private Sub X64RegisterVarType(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef typeName As String)
    Dim key As String
    key = X64VarTypeKey(cg, varName)
    If key = "" Then Exit Sub

    Dim i As Integer
    For i = 0 To gX64VarTypeCount - 1
        If gX64VarTypeKeys(i) = key Then
            gX64VarTypeNames(i) = X64Upper(Trim(typeName))
            Exit Sub
        End If
    Next

    If gX64VarTypeCount > 4095 Then Exit Sub

    gX64VarTypeKeys(gX64VarTypeCount) = key
    gX64VarTypeNames(gX64VarTypeCount) = X64Upper(Trim(typeName))
    gX64VarTypeCount += 1
End Sub

' Build and emit vtable for a class (base-first ordering)
Private Function X64EmitClassVTable(ByRef ps As ParseState, ByVal classNode As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    errText = ""
    If classNode < 0 Or classNode >= ps.ast.count Then Return 1

    Dim className As String
    className = X64Upper(Trim(ps.ast.nodes(classNode).value))
    If className = "" Then Return 1

    ' Already registered?
    Dim ci As Integer
    For ci = 0 To gX64VTableClassCount - 1
        If gX64VTableClassKeys(ci) = className Then Return 1
    Next ci

    ' Build vtable from semantic CLASS_METHOD_SLOT metadata (base-first; overrides replace implementer)
    Dim typesList() As String
    Dim typeCount As Integer
    typeCount = 0

    Dim curType As String
    curType = className
    Do While curType <> ""
        If typeCount = 0 Then
            ReDim typesList(0)
        Else
            ReDim Preserve typesList(typeCount)
        End If
        typesList(typeCount) = X64Upper(Trim(curType))
        typeCount += 1

        Dim cnode As Integer
        cnode = X64FindClassDeclNode(ps, typesList(typeCount - 1))
        If cnode = -1 Then Exit Do
        Dim baseNode As Integer
        baseNode = X64FindChildByKind(ps, cnode, "CLASS_BASE_REF")
        If baseNode = -1 Then Exit Do
        curType = ps.ast.nodes(baseNode).value
    Loop

    ' Determine max slot
    Dim maxSlot As Integer
    maxSlot = -1
    Dim ti As Integer
    For ti = typeCount - 1 To 0 Step -1
        Dim cnode2 As Integer
        cnode2 = X64FindClassDeclNode(ps, typesList(ti))
        If cnode2 = -1 Then Continue For
        Dim ch As Integer
        ch = ps.ast.nodes(cnode2).firstChild
        Do While ch <> -1
            If X64Upper(ps.ast.nodes(ch).kind) = "CLASS_METHOD_DECL" Then
                Dim mch As Integer
                mch = X64FindChildByKind(ps, ch, "CLASS_METHOD_SLOT")
                If mch <> -1 Then
                    Dim si As Integer
                    si = Val(ps.ast.nodes(mch).value)
                    If si > maxSlot Then maxSlot = si
                End If
            End If
            ch = ps.ast.nodes(ch).nextSibling
        Loop
    Next ti

    Dim slotCount As Integer
    If maxSlot < 0 Then
        slotCount = 0
    Else
        slotCount = maxSlot + 1
    End If

    Dim vtblLabel As String
    vtblLabel = X64ClassVTableLabel(className)

    If slotCount = 0 Then
        X64EmitData cg, vtblLabel & ": dq 0"
    Else
        Dim implOwner() As String
        Dim implMethod() As String
        ReDim implOwner(slotCount - 1)
        ReDim implMethod(slotCount - 1)

        ' base-first: later (derived) entries overwrite earlier (base) entries
        For ti = typeCount - 1 To 0 Step -1
            Dim cn As Integer
            cn = X64FindClassDeclNode(ps, typesList(ti))
            If cn = -1 Then Continue For
            Dim ch2 As Integer
            ch2 = ps.ast.nodes(cn).firstChild
            Do While ch2 <> -1
                If X64Upper(ps.ast.nodes(ch2).kind) = "CLASS_METHOD_DECL" Then
                    Dim mname As String
                    mname = X64Upper(Trim(ps.ast.nodes(ch2).value))
                    Dim slotMeta As Integer
                    slotMeta = X64FindChildByKind(ps, ch2, "CLASS_METHOD_SLOT")
                    If slotMeta <> -1 Then
                        Dim sidx As Integer
                        sidx = Val(ps.ast.nodes(slotMeta).value)
                        If sidx >= 0 And sidx < slotCount Then
                            implOwner(sidx) = typesList(ti)
                            implMethod(sidx) = mname
                        End If
                    End If
                End If
                ch2 = ps.ast.nodes(ch2).nextSibling
            Loop
        Next ti

        Dim entriesText As String
        entriesText = ""
        Dim si2 As Integer
        For si2 = 0 To slotCount - 1
            Dim implKey As String
            implKey = ""
            If implOwner(si2) <> "" And implMethod(si2) <> "" Then
                implKey = implOwner(si2) & "_" & implMethod(si2)
            End If
            Dim emitSym As String
            emitSym = "0"
            If implKey <> "" Then
                Dim exact As String
                If X64FindRoutineSymbolName(ps, implKey, exact) <> 0 Then
                    emitSym = exact
                Else
                    emitSym = LCase(implKey)
                End If
            End If

            If entriesText <> "" Then entriesText &= ", "
            entriesText &= emitSym
        Next si2

        X64EmitData cg, vtblLabel & ": dq " & entriesText

        ' register class index and entries
        Dim classIdx As Integer
        classIdx = gX64VTableClassCount
        gX64VTableClassKeys(classIdx) = className
        gX64VTableClassSlots(classIdx) = slotCount
        gX64VTableClassCount = gX64VTableClassCount + 1

        If slotCount > 0 Then
            Dim kidx As Integer
            For si2 = 0 To slotCount - 1
                Dim entryKey As String
                entryKey = className & "_" & UCase(Trim(implMethod(si2)))
                kidx = gX64VTableEntryCount
                gX64VTableEntryKeys(kidx) = X64Upper(Trim(entryKey))
                gX64VTableEntrySlots(kidx) = si2
                gX64VTableEntryClassIndex(kidx) = classIdx
                gX64VTableEntryCount = gX64VTableEntryCount + 1
            Next si2
        End If
    End If

    Return 1
End Function

Private Function X64FindVTableSlot(ByRef cg As X64CodegenContext, ByRef className As String, ByRef methodName As String, ByRef slotOut As Integer) As Integer
    slotOut = -1
    Dim key As String
    key = X64Upper(Trim(className & "_" & methodName))
    If key = "" Then Return 0

    Dim i As Integer
    For i = 0 To gX64VTableEntryCount - 1
        If gX64VTableEntryKeys(i) = key Then
            slotOut = gX64VTableEntrySlots(i)
            Return 1
        End If
    Next i
    Return 0
End Function

Private Function X64RegisterClassVTable(ByRef ps As ParseState, ByVal classNodeIdx As Integer, ByRef cg As X64CodegenContext) As Integer
    Dim errText As String
    If classNodeIdx < 0 Or classNodeIdx >= ps.ast.count Then Return 1
    X64EmitClassVTable ps, classNodeIdx, cg, errText
    Return IIf(errText = "", 1, 0)
End Function

Private Function X64TryGetVarType(ByRef cg As X64CodegenContext, ByRef varName As String, ByRef typeNameOut As String) As Integer
    Dim key As String
    key = X64VarTypeKey(cg, varName)

    Dim i As Integer
    For i = 0 To gX64VarTypeCount - 1
        If gX64VarTypeKeys(i) = key Then
            typeNameOut = gX64VarTypeNames(i)
            Return 1
        End If
    Next

    key = "__GLOBAL::" & X64Upper(Trim(varName))
    For i = 0 To gX64VarTypeCount - 1
        If gX64VarTypeKeys(i) = key Then
            typeNameOut = gX64VarTypeNames(i)
            Return 1
        End If
    Next

    typeNameOut = ""
    Return 0
End Function

Private Function X64TypeToFloatKind(ByRef typeName As String) As Integer
    Dim t As String
    t = X64Upper(Trim(typeName))
    If t = "" Then Return UXF_UNKNOWN
    Select Case t
    Case "F32", "SINGLE", "SNG", "SNGLE"
        Return UXF_F32
    Case "F64", "DOUBLE", "DBL", "DBLE"
        Return UXF_F64
    Case "F80", "EXTENDED", "EXT"
        Return UXF_F80
    End Select
    Return UXF_UNKNOWN
End Function

Private Function X64GetElemBytesForType(ByRef ps As ParseState, ByRef typeName As String) As Integer
    Dim t As String
    t = X64Upper(Trim(typeName))
    If t = "" Then Return 8

    Dim sizeOut As Integer
    Dim terr As String
    terr = ""
    If TypeLayoutSizeOf(ps, t, sizeOut, terr) <> 0 Then
        If sizeOut > 0 Then Return sizeOut
    End If

    Select Case X64TypeToFloatKind(typeName)
    Case UXF_F32
        Return 4
    Case UXF_F64
        Return 8
    Case UXF_F80
        Return 10
    End Select

    Select Case t
    Case "I8", "U8", "BYTE", "BOOLEAN"
        Return 1
    Case "I16", "U16", "SHORT"
        Return 2
    Case "I32", "U32", "INTEGER", "LONG"
        Return 4
    Case "I64", "U64", "LONGINT", "PTR", "STRING"
        Return 8
    End Select

    Return 8
End Function

Private Function X64GetElemBytesForDeclaredType(ByRef ps As ParseState, ByRef typeName As String) As Integer
    Return X64GetElemBytesForType(ps, typeName)
End Function

Private Function X64IsFloatKind(ByVal k As Integer) As Integer
    Return IIf(k = UXF_F32 Or k = UXF_F64 Or k = UXF_F80, 1, 0)
End Function

Private Function X64ElemBytesForFloatKind(ByVal k As Integer) As Integer
    Select Case k
    Case UXF_F32
        Return 4
    Case UXF_F80
        Return 10
    Case Else
        Return 8
    End Select
End Function

Private Function X64CreateFloatConstant(ByRef cg As X64CodegenContext, ByRef rawNumber As String, ByVal kind As Integer) As String
    Dim lbl As String
    If rawNumber = "" Then rawNumber = "0.0"
    Dim normalizedNumber As String
    normalizedNumber = rawNumber
    If InStr(normalizedNumber, ".") = 0 And InStr(UCase(normalizedNumber), "E") = 0 Then
        normalizedNumber &= ".0"
    End If
    Select Case kind
    Case UXF_F64
        lbl = X64NextLabel(cg, "dbl")
        X64EmitData cg, lbl & ": dq " & normalizedNumber
        Return lbl
    Case UXF_F32
        lbl = X64NextLabel(cg, "flt")
        X64EmitData cg, lbl & ": dd " & normalizedNumber
        Return lbl
    Case UXF_F80
        ' DİKKAT: F80 için 10-byte (tword) depolama kullan.
        ' NASM/YASM 'dt' directive: define tword (10 bytes)
        lbl = X64NextLabel(cg, "ext")
        X64EmitData cg, lbl & ": dt " & normalizedNumber
        Return lbl
    End Select
    lbl = X64NextLabel(cg, "dbl")
    X64EmitData cg, lbl & ": dq " & normalizedNumber
    Return lbl
End Function

Private Function X64EmitLoadFloatVarToXmm0As(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal kind As Integer, ByRef errText As String) As Integer
    If kind = UXF_F80 Then
        errText = "x64-codegen: F80 variable load requires x87/ST0 path"
        Return 0
    End If

    Dim localOffset As Integer
    Dim slotCount As Integer
    Dim labelText As String

    If cg.currentRoutineLabel <> "" Then
        If X64TryFindLocalInfo(cg, varName, localOffset, slotCount) <> 0 Then
            If kind = UXF_F32 Then
                X64EmitText cg, "    movss xmm0, " & X64FormatRbpRef(localOffset)
            Else
                X64EmitText cg, "    movsd xmm0, " & X64FormatRbpRef(localOffset)
            End If
            Return 1
        End If
    End If

    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) <> 0 Then
        If kind = UXF_F32 Then
            X64EmitText cg, "    movss xmm0, [rel " & labelText & "]"
        Else
            X64EmitText cg, "    movsd xmm0, [rel " & labelText & "]"
        End If
        Return 1
    End If

    errText = "x64-codegen: unknown float variable " & varName
    Return 0
End Function

Private Function X64EmitLoadFloatVarToXmm0(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal kind As Integer, ByRef errText As String) As Integer
    Return X64EmitLoadFloatVarToXmm0As(ps, cg, varName, kind, errText)
End Function

Private Function X64EmitStoreXmm0ToFloatVarAs(ByRef cg As X64CodegenContext, ByRef varName As String, ByVal kind As Integer, ByRef errText As String) As Integer
    If kind = UXF_F80 Then
        errText = "x64-codegen: F80 variable store requires x87/ST0 path"
        Return 0
    End If

    Dim localOffset As Integer
    Dim labelText As String
    Dim slotCount As Integer

    If cg.currentRoutineLabel <> "" Then
        If X64TryFindLocalInfo(cg, varName, localOffset, slotCount) <> 0 Then
            If kind = UXF_F32 Then
                X64EmitText cg, "    movss " & X64FormatRbpRef(localOffset) & ", xmm0"
            Else
                X64EmitText cg, "    movsd " & X64FormatRbpRef(localOffset) & ", xmm0"
            End If
            Return 1
        End If
    End If

    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) <> 0 Then
        If kind = UXF_F32 Then
            X64EmitText cg, "    movss [rel " & labelText & "], xmm0"
        Else
            X64EmitText cg, "    movsd [rel " & labelText & "], xmm0"
        End If
        Return 1
    End If

    If cg.currentRoutineLabel <> "" Then
        localOffset = X64EnsureLocalSlot(cg, varName, 1, X64ElemBytesForFloatKind(kind))
        If kind = UXF_F32 Then
            X64EmitText cg, "    movss " & X64FormatRbpRef(localOffset) & ", xmm0"
        Else
            X64EmitText cg, "    movsd " & X64FormatRbpRef(localOffset) & ", xmm0"
        End If
        Return 1
    End If

    labelText = X64EnsureGlobalSymbol(cg, varName, 1, X64ElemBytesForFloatKind(kind))
    If labelText <> "" Then
        If kind = UXF_F32 Then
            X64EmitText cg, "    movss [rel " & labelText & "], xmm0"
        Else
            X64EmitText cg, "    movsd [rel " & labelText & "], xmm0"
        End If
        Return 1
    End If

    errText = "x64-codegen: cannot store float variable " & varName
    Return 0
End Function


Private Function X64EmitExprToXmm0(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByRef errText As String) As Integer
    Return X64EmitExprToXmm0As(ps, nodeIdx, cg, UXF_F64, errText)
End Function

Private Function X64EmitCallNodeToXmm0(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByVal targetKind As Integer, ByRef errText As String) As Integer
    Return X64EmitCallNodeToXmm0As(ps, nodeIdx, cg, targetKind, errText)
End Function

Private Function X64EmitCallNodeToXmm0As(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByVal targetKind As Integer, ByRef errText As String) As Integer
    Dim calleeName As String
    calleeName = Trim(ps.ast.nodes(nodeIdx).value)
    If calleeName = "" Then
        errText = "x64-codegen: cannot use CALL_EXPR as float; return type unknown"
        Return 0
    End If

    Dim retType As String
    retType = ""
    If X64TryGetRoutineReturnType(cg, calleeName, retType) = 0 Then
        errText = "x64-codegen: cannot use CALL_EXPR as float; return type unknown"
        Return 0
    End If

    Dim retKind As Integer
    retKind = X64TypeToFloatKind(retType)

    Select Case retKind
    Case UXF_F80
        errText = "x64-codegen: F80 call return requires x87/ST0 path"
        Return 0
    Case UXF_F32, UXF_F64
        ' supported
    Case Else
        errText = "x64-codegen: CALL_EXPR does not return float"
        Return 0
    End Select

    If X64EmitCallNode(ps, nodeIdx, cg, errText) = 0 Then Return 0

    If targetKind = UXF_F32 And retKind = UXF_F64 Then
        X64EmitText cg, "    cvtsd2ss xmm0, xmm0"
    ElseIf targetKind = UXF_F64 And retKind = UXF_F32 Then
        X64EmitText cg, "    cvtss2sd xmm0, xmm0"
    End If

    Return 1
End Function

Private Function X64EmitFloatBinaryAs(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByVal kind As Integer, ByRef errText As String) As Integer
    If kind = UXF_F80 Then
        errText = "x64-codegen: F80 arithmetic not yet supported in x64 backend"
        Return 0
    End If

    Dim lhs As Integer
    Dim rhs As Integer
    lhs = ps.ast.nodes(nodeIdx).left
    rhs = ps.ast.nodes(nodeIdx).right

    If lhs = -1 Then lhs = X64ChildAt(ps, nodeIdx, 0)
    If rhs = -1 Then rhs = X64ChildAt(ps, nodeIdx, 1)

    If lhs = -1 Or rhs = -1 Then
        errText = "x64-codegen: float binary expression missing operand"
        Return 0
    End If

    Dim lhsKind As Integer
    Dim rhsKind As Integer
    Dim opKind As Integer
    lhsKind = X64InferFloatKindOfExpr(ps, lhs, cg)
    rhsKind = X64InferFloatKindOfExpr(ps, rhs, cg)

    opKind = kind
    If lhsKind = UXF_F64 Or rhsKind = UXF_F64 Then
        opKind = UXF_F64
    ElseIf lhsKind = UXF_F32 Or rhsKind = UXF_F32 Then
        opKind = UXF_F32
    End If

    If X64EmitExprToXmm0As(ps, lhs, cg, opKind, errText) = 0 Then Return 0

    X64EmitText cg, "    sub rsp, 16"
    If opKind = UXF_F32 Then
        X64EmitText cg, "    movss [rsp], xmm0"
    Else
        X64EmitText cg, "    movsd [rsp], xmm0"
    End If

    If X64EmitExprToXmm0As(ps, rhs, cg, opKind, errText) = 0 Then
        X64EmitText cg, "    add rsp, 16"
        Return 0
    End If

    If opKind = UXF_F32 Then
        X64EmitText cg, "    movss xmm1, xmm0"
        X64EmitText cg, "    movss xmm0, [rsp]"
    Else
        X64EmitText cg, "    movsd xmm1, xmm0"
        X64EmitText cg, "    movsd xmm0, [rsp]"
    End If

    X64EmitText cg, "    add rsp, 16"

    Dim opKey As String
    opKey = X64Upper(Trim(ps.ast.nodes(nodeIdx).op))
    If opKey = "" Then opKey = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case opKey
    Case "+", "ADD"
        If opKind = UXF_F32 Then
            X64EmitText cg, "    addss xmm0, xmm1"
        Else
            X64EmitText cg, "    addsd xmm0, xmm1"
        End If
    Case "-", "SUB"
        If opKind = UXF_F32 Then
            X64EmitText cg, "    subss xmm0, xmm1"
        Else
            X64EmitText cg, "    subsd xmm0, xmm1"
        End If
    Case "*", "MUL"
        If opKind = UXF_F32 Then
            X64EmitText cg, "    mulss xmm0, xmm1"
        Else
            X64EmitText cg, "    mulsd xmm0, xmm1"
        End If
    Case "/", "DIV"
        If opKind = UXF_F32 Then
            X64EmitText cg, "    divss xmm0, xmm1"
        Else
            X64EmitText cg, "    divsd xmm0, xmm1"
        End If
    Case Else
        errText = "x64-codegen: unsupported float binary operator " & opKey
        Return 0
    End Select

    If kind = UXF_F32 And opKind = UXF_F64 Then
        X64EmitText cg, "    cvtsd2ss xmm0, xmm0"
    ElseIf kind = UXF_F64 And opKind = UXF_F32 Then
        X64EmitText cg, "    cvtss2sd xmm0, xmm0"
    End If

    Return 1
End Function

Private Function X64EmitExprToXmm0As(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef cg As X64CodegenContext, ByVal targetKind As Integer, ByRef errText As String) As Integer
    If targetKind = UXF_F80 Then
        errText = "x64-codegen: F80 expression requires x87/ST0 path; XMM0 path is invalid"
        Return 0
    End If

    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "x64-codegen: invalid expr node"
        Return 0
    End If

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case nodeKind
    Case "NUMBER", "INTEGER", "INT", "INT_LITERAL"
        Dim rawNumber As String
        rawNumber = Trim(ps.ast.nodes(nodeIdx).value)
        If rawNumber = "" Then rawNumber = "0"
        Dim lbl As String
        lbl = X64CreateFloatConstant(cg, rawNumber, targetKind)
        If targetKind = UXF_F32 Then
            X64EmitText cg, "    movss xmm0, [rel " & lbl & "]"
        Else
            X64EmitText cg, "    movsd xmm0, [rel " & lbl & "]"
        End If
        Return 1
    Case "BINARY", "BINARY_EXPR", "BINOP", "OP", "ADD", "SUB", "MUL", "DIV"
        Dim opKey As String
        opKey = X64Upper(Trim(ps.ast.nodes(nodeIdx).op))
        If opKey = "" Then opKey = nodeKind

        If opKey = "+" Or opKey = "ADD" Or opKey = "-" Or opKey = "SUB" Or opKey = "*" Or opKey = "MUL" Or opKey = "/" Or opKey = "DIV" Then
            Return X64EmitFloatBinaryAs(ps, nodeIdx, cg, targetKind, errText)
        End If
    Case "STRING", "STRING_LITERAL"
        errText = "x64-codegen: cannot use string as float"
        Return 0
    Case "IDENT", "IDENTIFIER", "VAR", "NAME", "VAR_REF", "KEYWORD_REF"
        Dim identName As String
        identName = Trim(ps.ast.nodes(nodeIdx).value)
        If X64Upper(identName) = "TRUE" Then
            If targetKind = UXF_F32 Then
                X64EmitText cg, "    mov eax, 1"
                X64EmitText cg, "    cvtsi2ss xmm0, eax"
            Else
                X64EmitText cg, "    mov rax, 1"
                X64EmitText cg, "    cvtsi2sd xmm0, rax"
            End If
            Return 1
        ElseIf X64Upper(identName) = "FALSE" Then
            If targetKind = UXF_F32 Then
                X64EmitText cg, "    xor eax, eax"
                X64EmitText cg, "    cvtsi2ss xmm0, eax"
            Else
                X64EmitText cg, "    xor rax, rax"
                X64EmitText cg, "    cvtsi2sd xmm0, rax"
            End If
            Return 1
        Else
            If VarMappingEmitLoadXmm(cg.localVars, cg.currentRoutineLabel, identName, cg.textSection) <> 0 Then
                Return 1
            End If
            Dim declType As String
            declType = ""
            If X64TryGetVarType(cg, identName, declType) <> 0 Then
                Dim declKind As Integer
                declKind = X64TypeToFloatKind(declType)
                If declKind = UXF_F80 Then
                    errText = "x64-codegen: F80 variable load requires x87/ST0 path"
                    Return 0
                End If

                If declKind = UXF_F32 Or declKind = UXF_F64 Then
                    If X64EmitLoadFloatVarToXmm0As(ps, cg, identName, declKind, errText) = 0 Then Return 0
                    If declKind = UXF_F32 And targetKind = UXF_F64 Then
                        X64EmitText cg, "    cvtss2sd xmm0, xmm0"
                    ElseIf declKind = UXF_F64 And targetKind = UXF_F32 Then
                        X64EmitText cg, "    cvtsd2ss xmm0, xmm0"
                    End If
                    Return 1
                End If
            End If

            ' fallback: load as integer and convert
            X64EmitLoadVar cg, identName
            If targetKind = UXF_F32 Then
                X64EmitText cg, "    cvtsi2ss xmm0, rax"
            Else
                X64EmitText cg, "    cvtsi2sd xmm0, rax"
            End If
            Return 1
        End If
    Case "CALL_EXPR"
        Dim indexedBaseName As String
        Dim indexedExpr As Integer
        If X64TryExtractIndexedTarget(ps, nodeIdx, indexedBaseName, indexedExpr) <> 0 Then
            If cg.currentRoutineLabel <> "" And X64EmitLoadIndexedLocalXmm(ps, cg, indexedBaseName, indexedExpr, errText) <> 0 Then
                Return 1
            End If
            If X64EmitLoadIndexedGlobalXmm(ps, cg, indexedBaseName, indexedExpr, errText) <> 0 Then
                Return 1
            End If
        End If

        ' handle builtin float calls and math
        Dim callName As String
        callName = X64Upper(Trim(ps.ast.nodes(nodeIdx).value))
        Dim argNode As Integer
        argNode = X64ChildAt(ps, nodeIdx, 0)
        If callName = "SQR" Then
            If argNode <> -1 Then
                If X64EmitExprToXmm0As(ps, argNode, cg, targetKind, errText) = 0 Then Return 0
            Else
                X64EmitText cg, "    xorps xmm0, xmm0"
            End If
            If targetKind = UXF_F32 Then
                X64EmitText cg, "    sqrtss xmm0, xmm0"
            Else
                X64EmitText cg, "    sqrtsd xmm0, xmm0"
            End If
            Return 1
        ElseIf callName = "SIN" Or callName = "COS" Or callName = "TAN" Or callName = "ATN" Or callName = "EXP" Or callName = "LOG" Then
            If argNode <> -1 Then
                If X64EmitExprToXmm0As(ps, argNode, cg, targetKind, errText) = 0 Then Return 0
            Else
                X64EmitText cg, "    xorps xmm0, xmm0"
            End If
            X64EmitText cg, "    sub rsp, 40"
            X64EmitText cg, "    call " & LCase(Trim(ps.ast.nodes(nodeIdx).value))
            X64EmitText cg, "    add rsp, 40"
            Return 1
        End If

        ' generic call - consult routine registry
        If X64EmitCallNodeToXmm0As(ps, nodeIdx, cg, targetKind, errText) = 0 Then Return 0
        Return 1
    Case Else
        ' fallback: evaluate to integer and convert
        If X64EmitExprToRax(ps, nodeIdx, cg, errText) = 0 Then Return 0
        If targetKind = UXF_F32 Then
            X64EmitText cg, "    cvtsi2ss xmm0, rax"
        Else
            X64EmitText cg, "    cvtsi2sd xmm0, rax"
        End If
        Return 1
    End Select
End Function

Private Sub X64EmitStoreVarXmm(ByRef cg As X64CodegenContext, ByRef varName As String)
    Dim errText As String
    errText = ""
    If X64EmitStoreXmm0ToFloatVarAs(cg, varName, UXF_F64, errText) = 0 Then
        X64EmitComment cg, errText
    End If
End Sub

Private Function X64EmitStoreIndexedLocalXmm(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim localOffset As Integer
    Dim slotCount As Integer
    If X64TryFindLocalInfo(cg, varName, localOffset, slotCount) = 0 Then Return 0
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rbx, rax"
    Dim strideL As Integer
    strideL = 8
    If X64TryGetLocalElemBytes(cg, varName, strideL) = 0 Then strideL = 8
    Dim idxOverflowL As String
    idxOverflowL = X64NextLabel(cg, "idx_overflow")
    Dim idxScaledL As String
    idxScaledL = X64NextLabel(cg, "idx_scaled")
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideL)
    X64EmitText cg, "    jno " & idxScaledL
    X64EmitText cg, "    mov rbx, 0"
    X64EmitText cg, "    jmp " & idxOverflowL
    X64EmitLabel cg, idxScaledL
    X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(localOffset)
    X64EmitText cg, "    add rcx, rbx"
    If strideL = 4 Then
        X64EmitText cg, "    movss [rcx], xmm0"
    ElseIf strideL = 8 Then
        X64EmitText cg, "    movsd [rcx], xmm0"
    ElseIf strideL = 10 Then
        errText = "x64-codegen: F80 indexed XMM load/store is invalid"
        Return 0
    Else
        X64EmitText cg, "    movsd [rcx], xmm0"
    End If
    X64EmitLabel cg, idxOverflowL
    Return 1
End Function

Private Function X64EmitStoreIndexedGlobalXmm(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim labelText As String
    Dim slotCount As Integer
    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) = 0 Then Return 0
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rbx, rax"
    Dim gStrideX As Integer
    gStrideX = 8
    If X64TryGetGlobalElemBytes(cg, varName, gStrideX) = 0 Then gStrideX = 8
    Dim idxOverflowG As String
    idxOverflowG = X64NextLabel(cg, "idx_overflow")
    Dim idxScaledG As String
    idxScaledG = X64NextLabel(cg, "idx_scaled")
    X64EmitText cg, "    imul rbx, " & X64ToStr(gStrideX)
    X64EmitText cg, "    jno " & idxScaledG
    X64EmitText cg, "    mov rbx, 0"
    X64EmitText cg, "    jmp " & idxOverflowG
    X64EmitLabel cg, idxScaledG
    X64EmitText cg, "    lea rcx, [rel " & labelText & "]"
    X64EmitText cg, "    add rcx, rbx"
    If gStrideX = 4 Then
        X64EmitText cg, "    movss [rcx], xmm0"
    ElseIf gStrideX = 8 Then
        X64EmitText cg, "    movsd [rcx], xmm0"
    ElseIf gStrideX = 10 Then
        errText = "x64-codegen: F80 indexed XMM load/store is invalid"
        Return 0
    Else
        X64EmitText cg, "    movsd [rcx], xmm0"
    End If
    X64EmitLabel cg, idxOverflowG
    Return 1
End Function

Private Function X64EmitLoadIndexedLocalXmm(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim baseOffset As Integer
    Dim slotCount As Integer
    If X64TryFindLocalInfo(cg, varName, baseOffset, slotCount) = 0 Then Return 0

    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    X64EmitText cg, "    mov rbx, rax"
    Dim strideLL As Integer
    strideLL = 8
    If X64TryGetLocalElemBytes(cg, varName, strideLL) = 0 Then strideLL = 8
    Dim idxOverflowLL As String
    idxOverflowLL = X64NextLabel(cg, "idx_overflow")
    Dim idxScaledLL As String
    idxScaledLL = X64NextLabel(cg, "idx_scaled")
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideLL)
    X64EmitText cg, "    jno " & idxScaledLL
    X64EmitText cg, "    mov rbx, 0"
    X64EmitText cg, "    jmp " & idxOverflowLL
    X64EmitLabel cg, idxScaledLL
    X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(baseOffset)
    X64EmitText cg, "    add rcx, rbx"
    If strideLL = 4 Then
        X64EmitText cg, "    movss xmm0, [rcx]"
    ElseIf strideLL = 8 Then
        X64EmitText cg, "    movsd xmm0, [rcx]"
    ElseIf strideLL = 10 Then
        errText = "x64-codegen: F80 indexed XMM load/store is invalid"
        Return 0
    Else
        X64EmitText cg, "    movsd xmm0, [rcx]"
    End If
    X64EmitLabel cg, idxOverflowLL
    Return 1
End Function

Private Function X64EmitLoadIndexedGlobalXmm(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef errText As String) As Integer
    Dim labelText As String
    Dim slotCount As Integer
    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) = 0 Then Return 0
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0
    X64EmitText cg, "    mov rbx, rax"
    Dim gStrideXX As Integer
    gStrideXX = 8
    If X64TryGetGlobalElemBytes(cg, varName, gStrideXX) = 0 Then gStrideXX = 8
    Dim idxOverflowGG As String
    idxOverflowGG = X64NextLabel(cg, "idx_overflow")
    Dim idxScaledGG As String
    idxScaledGG = X64NextLabel(cg, "idx_scaled")
    X64EmitText cg, "    imul rbx, " & X64ToStr(gStrideXX)
    X64EmitText cg, "    jno " & idxScaledGG
    X64EmitText cg, "    mov rbx, 0"
    X64EmitText cg, "    jmp " & idxOverflowGG
    X64EmitLabel cg, idxScaledGG
    X64EmitText cg, "    lea rcx, [rel " & labelText & "]"
    X64EmitText cg, "    add rcx, rbx"
    If gStrideXX = 4 Then
        X64EmitText cg, "    movss xmm0, [rcx]"
    ElseIf gStrideXX = 8 Then
        X64EmitText cg, "    movsd xmm0, [rcx]"
    ElseIf gStrideXX = 10 Then
        errText = "x64-codegen: F80 indexed XMM load/store is invalid"
        Return 0
    Else
        X64EmitText cg, "    movsd xmm0, [rcx]"
    End If
    X64EmitLabel cg, idxOverflowGG
    Return 1
End Function

Private Function X64TryGetNumberLiteral(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef rawOut As String) As Integer
    rawOut = ""
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim k As String
    k = X64Upper(ps.ast.nodes(nodeIdx).kind)
    If k <> "NUMBER" And k <> "INTEGER" And k <> "INT" And k <> "INT_LITERAL" Then Return 0

    rawOut = Trim(ps.ast.nodes(nodeIdx).value)
    If rawOut = "" Then rawOut = "0.0"
    If InStr(rawOut, ".") = 0 And InStr(UCase(rawOut), "E") = 0 Then rawOut = rawOut & ".0"
    Return 1
End Function

Private Sub X64EmitStoreF80FromLabelAtRcX(ByRef cg As X64CodegenContext, ByRef srcLabel As String)
    X64EmitText cg, "    lea rdx, [rel " & srcLabel & "]"
    X64EmitText cg, "    mov rax, [rdx]"
    X64EmitText cg, "    mov [rcx], rax"
    X64EmitText cg, "    mov ax, [rdx + 8]"
    X64EmitText cg, "    mov [rcx + 8], ax"
End Sub

Private Function X64EmitStoreF80LiteralVar(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByRef rawNumber As String, ByRef errText As String) As Integer
    Dim litLabel As String
    litLabel = X64CreateFloatConstant(cg, rawNumber, UXF_F80)

    Dim localOffset As Integer
    Dim slotCount As Integer
    If cg.currentRoutineLabel <> "" Then
        If X64TryFindLocalInfo(cg, varName, localOffset, slotCount) <> 0 Then
            X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(localOffset)
            X64EmitStoreF80FromLabelAtRcX(cg, litLabel)
            Return 1
        End If
    End If

    Dim globalLabel As String
    If X64TryFindGlobalInfo(cg, varName, globalLabel, slotCount) <> 0 Then
        X64EmitText cg, "    lea rcx, [rel " & globalLabel & "]"
        X64EmitStoreF80FromLabelAtRcX(cg, litLabel)
        Return 1
    End If

    If cg.currentRoutineLabel <> "" And X64HasTopLevelGlobalDecl(ps, varName) = 0 Then
        localOffset = X64EnsureLocalSlot(cg, varName, 1, 10)
        X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(localOffset)
        X64EmitStoreF80FromLabelAtRcX(cg, litLabel)
        Return 1
    End If

    globalLabel = X64EnsureGlobalSymbol(cg, varName, 1, 10)
    X64EmitText cg, "    lea rcx, [rel " & globalLabel & "]"
    X64EmitStoreF80FromLabelAtRcX(cg, litLabel)
    Return 1
End Function

Private Function X64EmitStoreIndexedLocalF80Literal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef rawNumber As String, ByRef errText As String) As Integer
    Dim baseOffset As Integer
    Dim slotCount As Integer
    If X64TryFindLocalInfo(cg, varName, baseOffset, slotCount) = 0 Then Return 0
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    Dim strideBytes As Integer
    strideBytes = 10
    If X64TryGetLocalElemBytes(cg, varName, strideBytes) = 0 Then strideBytes = 10
    If strideBytes <> 10 Then Return 0

    Dim litLabel As String
    litLabel = X64CreateFloatConstant(cg, rawNumber, UXF_F80)

    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideBytes)
    X64EmitText cg, "    lea rcx, " & X64FormatRbpRef(baseOffset)
    X64EmitText cg, "    add rcx, rbx"
    X64EmitStoreF80FromLabelAtRcX(cg, litLabel)
    Return 1
End Function

Private Function X64EmitStoreIndexedGlobalF80Literal(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef varName As String, ByVal indexExpr As Integer, ByRef rawNumber As String, ByRef errText As String) As Integer
    Dim labelText As String
    Dim slotCount As Integer
    If X64TryFindGlobalInfo(cg, varName, labelText, slotCount) = 0 Then Return 0
    If X64EmitExprToRax(ps, indexExpr, cg, errText) = 0 Then Return 0

    Dim strideBytes As Integer
    strideBytes = 10
    If X64TryGetGlobalElemBytes(cg, varName, strideBytes) = 0 Then strideBytes = 10
    If strideBytes <> 10 Then Return 0

    Dim litLabel As String
    litLabel = X64CreateFloatConstant(cg, rawNumber, UXF_F80)

    X64EmitText cg, "    mov rbx, rax"
    X64EmitText cg, "    imul rbx, " & X64ToStr(strideBytes)
    X64EmitText cg, "    lea rcx, [rel " & labelText & "]"
    X64EmitText cg, "    add rcx, rbx"
    X64EmitStoreF80FromLabelAtRcX(cg, litLabel)
    Return 1
End Function

Private Function X64ToStr(ByVal n As Integer) As String
    Return LTrim(Str(n))
End Function

Private Function X64NormalizeTextLine(ByRef lineText As String) As String
    Dim raw As String
    raw = RTrim(lineText)

    Dim t As String
    t = Trim(raw)
    If t = "" Then Return ""

    Dim k As String
    k = X64Upper(t)

    If Left(k, 5) = "BITS " Then Return "bits " & Trim(Mid(t, 6))
    If Left(k, 8) = "DEFAULT " Then Return "default " & Trim(Mid(t, 9))
    If Left(k, 8) = "SECTION " Then Return "section " & Trim(Mid(t, 9))
    If Left(k, 7) = "GLOBAL " Then Return "global " & Trim(Mid(t, 8))
    If Left(k, 7) = "EXTERN " Then Return "extern " & Trim(Mid(t, 8))

    If Right(t, 1) = ":" Then Return t

    If Left(t, 1) = ";" Then Return "    ; " & Trim(Mid(t, 2))

    Dim p As Integer
    p = InStr(t, " ")
    If p = 0 Then Return "    " & LCase(t)

    Dim opText As String
    Dim argText As String
    opText = LCase(Left(t, p - 1))
    argText = Trim(Mid(t, p + 1))

    If argText = "" Then Return "    " & opText
    Return "    " & opText & " " & argText
End Function

Private Function X64NormalizeDataLine(ByRef lineText As String) As String
    Dim t As String
    t = Trim(RTrim(lineText))
    If t = "" Then Return ""

    If Left(t, 1) = ";" Then Return "    ; " & Trim(Mid(t, 2))

    Dim p As Integer
    p = InStr(t, ":")
    If p > 0 Then
        Dim labelText As String
        Dim restText As String
        labelText = Trim(Left(t, p))
        restText = Trim(Mid(t, p + 1))
        If restText = "" Then Return labelText
        Return labelText & " " & restText
    End If

    Return t
End Function

Private Function X64CompactBlankLines(ByRef textIn As String) As String
    Dim outText As String
    Dim prevBlank As Integer
    prevBlank = 0

    Dim i As Integer
    i = 1
    Do While i <= Len(textIn)
        Dim j As Integer
        j = InStr(i, textIn, Chr(10))

        Dim lineText As String
        If j = 0 Then
            lineText = Mid(textIn, i)
            i = Len(textIn) + 1
        Else
            lineText = Mid(textIn, i, j - i)
            i = j + 1
        End If

        lineText = RTrim(lineText)
        If Trim(lineText) = "" Then
            If prevBlank = 0 Then
                outText &= Chr(10)
                prevBlank = 1
            End If
        Else
            outText &= lineText & Chr(10)
            prevBlank = 0
        End If
    Loop

    Do While Len(outText) > 1 And Right(outText, 2) = Chr(10) & Chr(10)
        outText = Left(outText, Len(outText) - 1)
    Loop

    Return outText
End Function

Private Function X64Align16(ByVal n As Integer) As Integer
    If n <= 0 Then Return 0
    Return ((n + 15) \ 16) * 16
End Function

Private Function X64SanitizeSymbol(ByRef rawText As String) As String
    Dim src As String
    src = Trim(rawText)
    If src = "" Then Return "sym"

    Dim outText As String
    Dim i As Integer
    For i = 1 To Len(src)
        Dim ch As String
        ch = Mid(src, i, 1)
        Dim code As Integer
        code = Asc(ch)
        If (code >= Asc("A") And code <= Asc("Z")) Or _
           (code >= Asc("a") And code <= Asc("z")) Or _
           (code >= Asc("0") And code <= Asc("9")) Or _
           ch = "_" Then
            outText &= ch
        Else
            outText &= "_"
        End If
    Next i

    If Len(outText) = 0 Then outText = "sym"
    If Mid(outText, 1, 1) >= "0" And Mid(outText, 1, 1) <= "9" Then outText = "_" & outText
    Return outText
End Function

Private Function X64ClassVTableLabel(ByRef className As String) As String
    Dim s As String
    s = X64SanitizeSymbol(LCase(Trim(className)))
    Return "__uxb_vtbl_" & s
End Function

Private Function X64ScopedLabelSymbol(ByRef cg As X64CodegenContext, ByRef rawLabel As String) As String
    Dim scopeText As String
    scopeText = cg.currentRoutineLabel
    If Trim(scopeText) = "" Then scopeText = "__uxb_main"
    Return "__uxb_label_" & X64SanitizeSymbol(scopeText) & "_" & X64SanitizeSymbol(rawLabel)
End Function

Private Sub X64EmitText(ByRef cg As X64CodegenContext, ByRef lineText As String)
    cg.textSection &= X64NormalizeTextLine(lineText) & Chr(10)
End Sub

Private Sub X64EmitData(ByRef cg As X64CodegenContext, ByRef lineText As String)
    cg.dataSection &= X64NormalizeDataLine(lineText) & Chr(10)
End Sub

Private Sub X64EmitBss(ByRef cg As X64CodegenContext, ByRef lineText As String)
    cg.bssSection &= lineText & Chr(10)
End Sub

Private Sub X64EmitComment(ByRef cg As X64CodegenContext, ByRef commentText As String)
    X64EmitText cg, "; " & commentText
End Sub

Private Sub X64EmitCall0(ByRef cg As X64CodegenContext, ByRef symbolName As String)
    X64EmitText cg, "    sub rsp, 32"
    X64EmitText cg, "    call " & symbolName
    X64EmitText cg, "    add rsp, 32"
End Sub

Private Sub X64EmitCall1(ByRef cg As X64CodegenContext, ByRef symbolName As String)
    X64EmitText cg, "    mov rcx, rax"
    X64EmitText cg, "    xor rdx, rdx"
    X64EmitText cg, "    xor r8, r8"
    X64EmitCall0 cg, symbolName
End Sub

Private Sub X64EmitCall2(ByRef cg As X64CodegenContext, ByRef symbolName As String)
    X64EmitText cg, "    mov rdx, rax"
    X64EmitText cg, "    pop rcx"
    X64EmitText cg, "    xor r8, r8"
    X64EmitCall0 cg, symbolName
End Sub

Private Sub X64EmitCall3(ByRef cg As X64CodegenContext, ByRef symbolName As String)
    X64EmitText cg, "    mov r8, rax"
    X64EmitText cg, "    pop rdx"
    X64EmitText cg, "    pop rcx"
    X64EmitCall0 cg, symbolName
End Sub

Private Function X64BuiltinCallSymbol(ByRef callName As String) As String
    Select Case X64Upper(Trim(callName))
    Case "INKEY"
        Return "__uxb_builtin_inkey"
    Case "GETKEY"
        Return "__uxb_builtin_getkey"
    Case "ABS"
        Return "__uxb_builtin_abs"
    Case "INT"
        Return "__uxb_builtin_int"
    Case "FIX"
        Return "__uxb_builtin_fix"
    Case "SGN"
        Return "__uxb_builtin_sgn"
    Case "VAL"
        Return "__uxb_builtin_val"
    Case "ASC"
        Return "__uxb_builtin_asc"
    Case "RND"
        Return "__uxb_builtin_rnd"
    Case "SQR"
        Return "__uxb_builtin_sqr"
    Case "SIN"
        Return "__uxb_builtin_sin"
    Case "COS"
        Return "__uxb_builtin_cos"
    Case "TAN"
        Return "__uxb_builtin_tan"
    Case "ATN"
        Return "__uxb_builtin_atn"
    Case "EXP"
        Return "__uxb_builtin_exp"
    Case "LOG"
        Return "__uxb_builtin_log"
    Case "GETKEY"
        Return "__uxb_builtin_getkey"
    Case "TIMER"
        Return "__uxb_builtin_timer"
    Case "LTRIM"
        Return "__uxb_builtin_ltrim"
    Case "RTRIM"
        Return "__uxb_builtin_rtrim"
    Case "SPACE"
        Return "__uxb_builtin_space"
    Case "STRING"
        Return "__uxb_builtin_string"
    Case "MID"
        Return "__uxb_builtin_mid"
    Case "UCASE"
        Return "__uxb_builtin_ucase"
    Case "LCASE"
        Return "__uxb_builtin_lcase"
    Case "STR"
        Return "__uxb_builtin_str"
    Case "CHR"
        Return "__uxb_builtin_chr"
    Case "LEN"
        Return "__uxb_builtin_len"
    Case "LOF"
        Return "__uxb_builtin_lof"
    Case "EOF"
        Return "__uxb_builtin_eof"
    End Select

    Return ""
End Function

Private Function X64FindDeclaredTypeName(ByRef ps As ParseState, ByRef varName As String, ByRef typeNameOut As String) As Integer
    typeNameOut = ""

    Dim targetName As String
    targetName = X64Upper(Trim(varName))
    If targetName = "" Then Return 0

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        Dim kindText As String
        kindText = X64Upper(ps.ast.nodes(i).kind)
        If kindText <> "DIM_DECL" And kindText <> "REDIM_DECL" And kindText <> "PARAM_DECL" Then Continue For
        If X64Upper(Trim(ps.ast.nodes(i).value)) <> targetName Then Continue For

        Dim ch As Integer
        ch = ps.ast.nodes(i).firstChild
        Do While ch <> -1
            If X64Upper(ps.ast.nodes(ch).kind) = "TYPE_REF" Then
                typeNameOut = X64Upper(Trim(ps.ast.nodes(ch).value))
                Return IIf(typeNameOut <> "", 1, 0)
            End If
            ch = ps.ast.nodes(ch).nextSibling
        Loop
    Next i

    Return 0
End Function

Private Function X64FindClassDeclNode(ByRef ps As ParseState, ByRef classTypeName As String) As Integer
    Dim targetName As String
    targetName = X64Upper(Trim(classTypeName))
    If targetName = "" Then Return -1

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        If X64Upper(ps.ast.nodes(i).kind) = "CLASS_STMT" Then
            If X64Upper(Trim(ps.ast.nodes(i).value)) = targetName Then Return i
        End If
    Next i

    Return -1
End Function

Private Function X64GetClassBaseTypeName(ByRef ps As ParseState, ByRef classTypeName As String, ByRef baseTypeOut As String) As Integer
    baseTypeOut = ""

    Dim classNode As Integer
    classNode = X64FindClassDeclNode(ps, classTypeName)
    If classNode = -1 Then Return 0

    Dim ch As Integer
    ch = ps.ast.nodes(classNode).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) = "CLASS_BASE_REF" Then
            baseTypeOut = X64Upper(Trim(ps.ast.nodes(ch).value))
            Return IIf(baseTypeOut <> "", 1, 0)
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 0
End Function

Private Function X64FindClassMethodDeclNode(ByRef ps As ParseState, ByRef classTypeName As String, ByRef methodName As String) As Integer
    Dim classNode As Integer
    classNode = X64FindClassDeclNode(ps, classTypeName)
    If classNode = -1 Then Return -1

    Dim methodUpper As String
    methodUpper = X64Upper(Trim(methodName))
    If methodUpper = "" Then Return -1

    Dim ch As Integer
    ch = ps.ast.nodes(classNode).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) = "CLASS_METHOD_DECL" Then
            If X64Upper(Trim(ps.ast.nodes(ch).value)) = methodUpper Then Return ch
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return -1
End Function

Private Function X64ResolveMethodOwnerType(ByRef ps As ParseState, ByRef startTypeName As String, ByRef methodName As String, ByRef ownerTypeOut As String) As Integer
    ownerTypeOut = ""

    Dim curType As String
    curType = X64Upper(Trim(startTypeName))
    Dim methodUpper As String
    methodUpper = X64Upper(Trim(methodName))

    If curType = "" Or methodUpper = "" Then Return 0

    Dim hopGuard As Integer
    Do While curType <> ""
        hopGuard += 1
        If hopGuard > 64 Then Exit Do

        If X64FindClassMethodDeclNode(ps, curType, methodUpper) <> -1 Then
            ownerTypeOut = curType
            Return 1
        End If

        Dim baseType As String
        If X64GetClassBaseTypeName(ps, curType, baseType) = 0 Then Exit Do
        curType = X64Upper(Trim(baseType))
    Loop

    Return 0
End Function

Private Function X64FindOwningClassName(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef classNameOut As String) As Integer
    classNameOut = ""
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim p As Integer
    p = ps.ast.nodes(nodeIdx).parent
    If p >= 0 And p < ps.ast.count Then
        If X64Upper(ps.ast.nodes(p).kind) = "CLASS_STMT" Then
            classNameOut = X64Upper(Trim(ps.ast.nodes(p).value))
            Return IIf(classNameOut <> "", 1, 0)
        End If
    End If

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        If X64Upper(ps.ast.nodes(i).kind) <> "CLASS_STMT" Then Continue For
        Dim ch As Integer
        ch = ps.ast.nodes(i).firstChild
        Do While ch <> -1
            If ch = nodeIdx Then
                classNameOut = X64Upper(Trim(ps.ast.nodes(i).value))
                Return IIf(classNameOut <> "", 1, 0)
            End If
            ch = ps.ast.nodes(ch).nextSibling
        Loop
    Next i

    Return 0
End Function

Private Function X64CountRoutineParams(ByRef ps As ParseState, ByVal routineNode As Integer) As Integer
    If routineNode < 0 Or routineNode >= ps.ast.count Then Return 0

    Dim paramCount As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(routineNode).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) <> "PARAM_DECL" Then Exit Do
        paramCount += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return paramCount
End Function

Private Function X64NodeHasReturnType(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If X64Upper(ps.ast.nodes(ch).kind) = "RETURN_TYPE" Then Return 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 0
End Function

Private Function X64IsStmtLikeNode(ByRef kindRaw As String) As Integer
    Dim k As String
    k = X64Upper(Trim(kindRaw))
    If Right(k, 5) = "_STMT" Then Return 1
    Select Case k
    Case "PRINT", "IF", "FOR", "DO", "CALL", "RETURN", "EXIT", "LET", "DIM", "REDIM", "DELETE", "SELECT", "NEXT", "GOTO", "GOSUB"
        Return 1
    End Select
    Return 0
End Function

Private Function X64ClassRoutineHasBody(ByRef ps As ParseState, ByVal routineNode As Integer) As Integer
    If routineNode < 0 Or routineNode >= ps.ast.count Then Return 0

    Dim ch As Integer
    ch = ps.ast.nodes(routineNode).firstChild
    Do While ch <> -1
        If X64IsStmtLikeNode(ps.ast.nodes(ch).kind) <> 0 Then Return 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 0
End Function

Private Function X64ResolveClassRoutineName(ByRef ps As ParseState, ByVal routineNode As Integer, ByRef routineNameOut As String) As Integer
    routineNameOut = ""
    If routineNode < 0 Or routineNode >= ps.ast.count Then Return 0

    Dim k As String
    k = X64Upper(Trim(ps.ast.nodes(routineNode).kind))

    Dim className As String
    If X64FindOwningClassName(ps, routineNode, className) = 0 Then Return 0

    Select Case k
    Case "CLASS_METHOD_DECL"
        Dim methodName As String
        methodName = X64Upper(Trim(ps.ast.nodes(routineNode).value))
        If methodName = "" Then Return 0
        routineNameOut = className & "_" & methodName
        Return 1
    Case "CLASS_CONSTRUCTOR_DECL"
        routineNameOut = className & "_CTOR"
        Return 1
    Case "CLASS_DESTRUCTOR_DECL"
        routineNameOut = className & "_DTOR"
        Return 1
    End Select

    Return 0
End Function

Private Sub X64RegisterRoutineSignatureDirect(ByRef cg As X64CodegenContext, ByRef routineName As String, ByVal argCount As Integer, ByVal isFunction As Integer, ByRef returnType As String)
    Dim routineKey As String
    routineKey = X64Upper(Trim(routineName))
    If routineKey = "" Then Exit Sub

    If argCount < 0 Then argCount = 0

    Dim i As Integer
    i = X64FindRoutine(cg, routineKey)
    If i <> -1 Then
        gX64RoutineArgCounts(i) = argCount
        gX64RoutineIsFunction(i) = isFunction
        gX64RoutineReturnTypes(i) = X64Upper(Trim(returnType))
        Exit Sub
    End If

    If cg.routineCount > 1023 Then Exit Sub
    gX64RoutineKeys(cg.routineCount) = routineKey
    gX64RoutineArgCounts(cg.routineCount) = argCount
    gX64RoutineIsFunction(cg.routineCount) = isFunction
    gX64RoutineReturnTypes(cg.routineCount) = X64Upper(Trim(returnType))
    cg.routineCount += 1
End Sub

Private Sub X64RegisterClassRoutineSignature(ByRef ps As ParseState, ByVal routineNode As Integer, ByRef cg As X64CodegenContext)
    Dim routineName As String
    If X64ResolveClassRoutineName(ps, routineNode, routineName) = 0 Then Exit Sub

    Dim argCount As Integer
    argCount = X64CountRoutineParams(ps, routineNode) + 1

    Dim isFn As Integer
    isFn = IIf(X64Upper(ps.ast.nodes(routineNode).kind) = "CLASS_METHOD_DECL" And X64NodeHasReturnType(ps, routineNode) <> 0, 1, 0)

    Dim returnTypeText As String
    returnTypeText = X64ExtractRoutineReturnType(ps, routineNode)

    X64RegisterRoutineSignatureDirect cg, routineName, argCount, isFn, returnTypeText
End Sub

Private Function X64InferRoutineReceiverClass(ByRef ps As ParseState, ByRef routineNameRaw As String, ByRef classNameOut As String) As Integer
    classNameOut = ""

    Dim routineName As String
    routineName = X64Upper(Trim(routineNameRaw))
    If routineName = "" Then Return 0

    Dim sepPos As Integer
    sepPos = InStr(routineName, "_")
    If sepPos <= 1 Then Return 0

    Dim className As String
    className = Left(routineName, sepPos - 1)
    If className = "" Then Return 0
    If X64FindClassDeclNode(ps, className) = -1 Then Return 0

    classNameOut = className
    Return 1
End Function

Private Function X64ResolveCurrentReceiverClass(ByRef ps As ParseState, ByRef cg As X64CodegenContext, ByRef classNameOut As String) As Integer
    classNameOut = ""

    If X64TryGetVarType(cg, "THIS", classNameOut) <> 0 Then
        classNameOut = X64Upper(Trim(classNameOut))
        If classNameOut <> "" And X64FindClassDeclNode(ps, classNameOut) <> -1 Then Return 1
    End If

    Return X64InferRoutineReceiverClass(ps, cg.currentRoutineLabel, classNameOut)
End Function

Private Function X64HasTopLevelGlobalDecl(ByRef ps As ParseState, ByRef symbolNameRaw As String) As Integer
    Dim targetName As String
    targetName = X64Upper(Trim(symbolNameRaw))
    If targetName = "" Then Return 0

    Dim rootIdx As Integer
    rootIdx = ps.rootNode
    If rootIdx < 0 Or rootIdx >= ps.ast.count Then Return 0

    Dim ch As Integer
    ch = ps.ast.nodes(rootIdx).firstChild
    Do While ch <> -1
        Dim kindText As String
        kindText = X64Upper(ps.ast.nodes(ch).kind)
        If kindText = "SUB_STMT" Or kindText = "FUNCTION_STMT" Then
            ch = ps.ast.nodes(ch).nextSibling
            Continue Do
        End If

        If kindText = "DIM_STMT" Or kindText = "DIM" Or kindText = "CONST_STMT" Then
            Dim decl As Integer
            decl = ps.ast.nodes(ch).firstChild
            Do While decl <> -1
                If X64Upper(Trim(ps.ast.nodes(decl).value)) = targetName Then Return 1
                decl = ps.ast.nodes(decl).nextSibling
            Loop
        End If

        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 0
End Function

Private Function X64FindRoutineSymbolName(ByRef ps As ParseState, ByRef routineNameRaw As String, ByRef symbolOut As String) As Integer
    symbolOut = ""

    Dim targetName As String
    targetName = X64Upper(Trim(routineNameRaw))
    If targetName = "" Then Return 0

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        Dim kindText As String
        kindText = X64Upper(ps.ast.nodes(i).kind)
        If kindText <> "SUB_STMT" And kindText <> "FUNCTION_STMT" Then Continue For
        If X64Upper(Trim(ps.ast.nodes(i).value)) <> targetName Then Continue For

        symbolOut = Trim(ps.ast.nodes(i).value)
        Return IIf(symbolOut <> "", 1, 0)
    Next i

    For i = 0 To ps.ast.count - 1
        Dim classRoutineKind As String
        classRoutineKind = X64Upper(ps.ast.nodes(i).kind)
        If classRoutineKind <> "CLASS_METHOD_DECL" And classRoutineKind <> "CLASS_CONSTRUCTOR_DECL" And classRoutineKind <> "CLASS_DESTRUCTOR_DECL" Then Continue For

        Dim classRoutineName As String
        classRoutineName = ""
        If X64ResolveClassRoutineName(ps, i, classRoutineName) = 0 Then Continue For
        If X64Upper(Trim(classRoutineName)) <> targetName Then Continue For

        symbolOut = classRoutineName
        Return 1
    Next i

    Return 0
End Function

Private Function X64SplitMethodCallName(ByRef callNameRaw As String, ByRef ownerOut As String, ByRef methodOut As String) As Integer
    Dim callName As String
    callName = Trim(callNameRaw)

    Dim dotPos As Integer
    dotPos = InStr(callName, ".")
    If dotPos <= 1 Then Return 0

    ownerOut = Trim(Left(callName, dotPos - 1))
    methodOut = Trim(Mid(callName, dotPos + 1))
    If ownerOut = "" Or methodOut = "" Then Return 0
    If InStr(methodOut, ".") > 0 Then Return 0
    Return 1
End Function

Private Function X64ExprReturnsString(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim nodeKind As String
    nodeKind = X64Upper(ps.ast.nodes(nodeIdx).kind)

    Select Case nodeKind
    Case "STRING", "STRING_LITERAL"
        Return 1
    Case "IDENT", "IDENTIFIER", "VAR", "NAME", "VAR_REF", "KEYWORD_REF"
        Dim declType As String
        If X64FindDeclaredTypeName(ps, ps.ast.nodes(nodeIdx).value, declType) <> 0 Then
            If declType = "STRING" Then Return 1
        End If
    Case "CALL_EXPR"
        Dim callName As String
        callName = X64Upper(Trim(ps.ast.nodes(nodeIdx).value))
        Select Case callName
        Case "STR", "CHR", "UCASE", "LCASE", "LTRIM", "RTRIM", "SPACE", "STRING", "MID"
            Return 1
        End Select
    End Select

    Return 0
End Function

Private Sub X64EmitBuiltinSupport(ByRef cg As X64CodegenContext)
    X64EmitText cg, "__uxb_runtime_cls:"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_runtime_locate:"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_runtime_color:"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_runtime_randomize_auto:"
    X64EmitText cg, "    sub rsp, 40"
    X64EmitText cg, "    call GetTickCount64"
    X64EmitText cg, "    add rsp, 40"
    X64EmitText cg, "    mov ecx, eax"
    X64EmitText cg, "    sub rsp, 40"
    X64EmitText cg, "    call srand"
    X64EmitText cg, "    add rsp, 40"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_runtime_randomize_seed:"
    X64EmitText cg, "    sub rsp, 40"
    X64EmitText cg, "    call srand"
    X64EmitText cg, "    add rsp, 40"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_builtin_getkey:"
    X64EmitText cg, "    xor rax, rax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_builtin_inkey:"
    X64EmitText cg, "    xor rax, rax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_resolve:"
    X64EmitText cg, "    cmp rcx, 1048576"
    X64EmitText cg, "    jae .mem_resolve_passthrough"
    X64EmitText cg, "    lea rax, [rel __uxb_mem_space]"
    X64EmitText cg, "    add rax, rcx"
    X64EmitText cg, "    ret"
    X64EmitText cg, ".mem_resolve_passthrough:"
    X64EmitText cg, "    mov rax, rcx"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_peekb:"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    movzx eax, byte [rax]"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_peekw:"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    movzx eax, word [rax]"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_peekd:"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov eax, dword [rax]"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_pokeb:"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov byte [rax], dl"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_pokew:"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov word [rax], dx"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_poked:"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov dword [rax], edx"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_pokes:"
    X64EmitText cg, "    mov r8, rcx"
    X64EmitText cg, "    mov r9, rdx"
    X64EmitText cg, "    test r9, r9"
    X64EmitText cg, "    jz .mem_pokes_done"
    X64EmitText cg, "    mov rcx, r8"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov r8, rax"
    X64EmitText cg, "    xor r10, r10"
    X64EmitText cg, ".mem_pokes_loop:"
    X64EmitText cg, "    mov al, [r9 + r10]"
    X64EmitText cg, "    test al, al"
    X64EmitText cg, "    jz .mem_pokes_done"
    X64EmitText cg, "    mov [r8 + r10], al"
    X64EmitText cg, "    inc r10"
    X64EmitText cg, "    jmp .mem_pokes_loop"
    X64EmitText cg, ".mem_pokes_done:"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_copyb:"
    X64EmitText cg, "    test r8, r8"
    X64EmitText cg, "    js .mem_copy_fail"
    X64EmitText cg, "    jz .mem_copy_done"
    X64EmitText cg, "    mov r9, rcx"
    X64EmitText cg, "    mov r10, rdx"
    X64EmitText cg, "    mov r11, r8"
    X64EmitText cg, "    mov rcx, r9"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov r9, rax"
    X64EmitText cg, "    mov rcx, r10"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov r10, rax"
    X64EmitText cg, "    mov rcx, r10"
    X64EmitText cg, "    mov rdx, r9"
    X64EmitText cg, "    mov r8, r11"
    X64EmitText cg, "    sub rsp, 32"
    X64EmitText cg, "    call memmove"
    X64EmitText cg, "    add rsp, 32"
    X64EmitText cg, ".mem_copy_done:"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ".mem_copy_fail:"
    X64EmitText cg, "    xor eax, eax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_copyw:"
    X64EmitText cg, "    test r8, r8"
    X64EmitText cg, "    js .mem_copyw_fail"
    X64EmitText cg, "    lea r8, [r8 * 2]"
    X64EmitText cg, "    jmp __uxb_mem_copyb"
    X64EmitText cg, ".mem_copyw_fail:"
    X64EmitText cg, "    xor eax, eax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_copyd:"
    X64EmitText cg, "    test r8, r8"
    X64EmitText cg, "    js .mem_copyd_fail"
    X64EmitText cg, "    lea r8, [r8 * 4]"
    X64EmitText cg, "    jmp __uxb_mem_copyb"
    X64EmitText cg, ".mem_copyd_fail:"
    X64EmitText cg, "    xor eax, eax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_fillb:"
    X64EmitText cg, "    test r8, r8"
    X64EmitText cg, "    js .mem_fill_fail"
    X64EmitText cg, "    jz .mem_fill_done"
    X64EmitText cg, "    mov r9, rcx"
    X64EmitText cg, "    mov r10, r8"
    X64EmitText cg, "    mov rcx, r9"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov rcx, rax"
    X64EmitText cg, "    mov r8, r10"
    X64EmitText cg, "    sub rsp, 32"
    X64EmitText cg, "    call memset"
    X64EmitText cg, "    add rsp, 32"
    X64EmitText cg, ".mem_fill_done:"
    X64EmitText cg, "    mov eax, 1"
    X64EmitText cg, "    ret"
    X64EmitText cg, ".mem_fill_fail:"
    X64EmitText cg, "    xor eax, eax"
    X64EmitText cg, "    ret"
    X64EmitText cg, ""

    X64EmitText cg, "__uxb_mem_fillw:"
    X64EmitText cg, "    test r8, r8"
    X64EmitText cg, "    js .mem_fillw_fail"
    X64EmitText cg, "    mov r9, rdx"
    X64EmitText cg, "    mov r10, rcx"
    X64EmitText cg, "    mov rcx, r10"
    X64EmitText cg, "    call __uxb_mem_resolve"
    X64EmitText cg, "    mov r10, rax"
    X64EmitText cg, "    xor r11, r11"
