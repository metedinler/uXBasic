' uXBasic MIR (Mid-Level Intermediate Representation)
' Basic block tabanli, backend bagimsiz ara format
' Runtime evaluator icin MIR instruction set

#include once "mir_model.fbs"

#include once "mir_evaluator.fbs"
#include once "mir_exporter_json.fbs"

' Float kind constants for MIR
Private Const MIR_UXF_UNKNOWN = 0
Private Const MIR_UXF_F32 = 1
Private Const MIR_UXF_F64 = 2
Private Const MIR_UXF_F80 = 3

Dim Shared gMirLowerIfEnd(Any) As Integer
Dim Shared gMirLowerIfDepth As Integer

Declare Function MIRChildAt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal childPos As Integer) As Integer
Declare Function MIRFindChildByKind(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef kindText As String) As Integer
Declare Function MIRBuildVTableMap(ByRef ps As ParseState, ByRef module As MIRModule, ByRef errText As String) As Integer

Private Sub MIREnsureMain(ByRef module As MIRModule)
    Dim fnMain As MIRFunction Ptr

    If module.functionCount <> 0 Then Exit Sub

    ReDim module.functions(0)
    module.functionCount = 1
    module.functions(0).name = "MAIN"
    module.functions(0).entryBlock = 0
    fnMain = @module.functions(0)
    ReDim fnMain->blocks(0)
    module.functions(0).blockCount = 1
    module.functions(0).blocks(0).id = 0
    module.functions(0).blocks(0).instructionCount = 0
    module.functions(0).blocks(0).isEntry = 1
    module.functions(0).blocks(0).isExit = 1
End Sub

Private Sub MIRAppendInstruction(ByRef module As MIRModule, ByVal fnIdx As Integer, ByVal blockIdx As Integer, ByRef opcode As String, ByRef resultName As String, ByVal operandCount As Integer, ByRef op0 As String = "", ByRef op1 As String = "", ByRef op2 As String = "", ByRef op3 As String = "", ByRef op4 As String = "", ByRef op5 As String = "", ByRef op6 As String = "", ByRef op7 As String = "")
    Dim inst As MIRIRInstruction
    Dim blk As MIRBasicBlock Ptr
    inst.opcode = opcode
    inst.result = resultName
    inst.blockId = blockIdx
    inst.operandCount = operandCount
    If operandCount > 0 Then inst.operands(0) = op0
    If operandCount > 1 Then inst.operands(1) = op1
    If operandCount > 2 Then inst.operands(2) = op2
    If operandCount > 3 Then inst.operands(3) = op3
    If operandCount > 4 Then inst.operands(4) = op4
    If operandCount > 5 Then inst.operands(5) = op5
    If operandCount > 6 Then inst.operands(6) = op6
    If operandCount > 7 Then inst.operands(7) = op7

    blk = @module.functions(fnIdx).blocks(blockIdx)
    Dim cnt As Integer
    cnt = blk->instructionCount
    If cnt = 0 Then
        ReDim blk->instructions(0)
    Else
        ReDim Preserve blk->instructions(cnt)
    End If
    blk->instructions(cnt) = inst
    blk->instructionCount = cnt + 1
End Sub

Private Function MIRNextTemp(ByRef seed As Integer) As String
    seed += 1
    Return "__t" & LTrim(Str(seed))
End Function

Private Function MIRCanonicalTypeName(ByRef rawType As String) As String
    Dim t As String
    t = UCase(Trim(rawType))

    Select Case t
    Case "SINGLE", "SNG", "SNGLE"
        Return "F32"
    Case "DOUBLE", "DBL", "DBLE"
        Return "F64"
    Case "EXTENDED", "EXT"
        Return "F80"
    End Select

    Return t
End Function

Private Function MIRIsFloatTypeName(ByRef rawType As String) As Integer
    Dim t As String
    t = MIRCanonicalTypeName(rawType)
    Return IIf(t = "F32" Or t = "F64" Or t = "F80", 1, 0)
End Function

Private Function MIRFindNearestDeclaredType(ByRef ps As ParseState, ByVal fromNodeIdx As Integer, ByRef varNameRaw As String, ByRef typeOut As String) As Integer
    typeOut = ""

    Dim target As String
    target = UCase(Trim(varNameRaw))
    If target = "" Then Return 0

    Dim startIdx As Integer
    startIdx = fromNodeIdx
    If startIdx < 0 Or startIdx >= ps.ast.count Then startIdx = ps.ast.count - 1

    Dim i As Integer
    For i = startIdx To 0 Step -1
        Dim k As String
        k = UCase(Trim(ps.ast.nodes(i).kind))
        If k <> "DIM_DECL" And k <> "REDIM_DECL" And k <> "PARAM_DECL" Then Continue For
        If UCase(Trim(ps.ast.nodes(i).value)) <> target Then Continue For

        Dim typeNode As Integer
        typeNode = MIRFindChildByKind(ps, i, "TYPE_REF")
        If typeNode <> -1 Then
            typeOut = MIRCanonicalTypeName(ps.ast.nodes(typeNode).value)
            If typeOut <> "" Then Return 1
        End If
    Next i

    For i = 0 To ps.ast.count - 1
        Dim k2 As String
        k2 = UCase(Trim(ps.ast.nodes(i).kind))
        If k2 <> "DIM_DECL" And k2 <> "REDIM_DECL" And k2 <> "PARAM_DECL" Then Continue For
        If UCase(Trim(ps.ast.nodes(i).value)) <> target Then Continue For

        Dim typeNode2 As Integer
        typeNode2 = MIRFindChildByKind(ps, i, "TYPE_REF")
        If typeNode2 <> -1 Then
            typeOut = MIRCanonicalTypeName(ps.ast.nodes(typeNode2).value)
            If typeOut <> "" Then Return 1
        End If
    Next i

    Return 0
End Function

Private Function MIRFindFunctionReturnType(ByRef ps As ParseState, ByRef funcNameRaw As String, ByRef typeOut As String) As Integer
    typeOut = ""

    Dim fn As String
    fn = UCase(Trim(funcNameRaw))
    If fn = "" Then Return 0

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        Dim k As String
        k = UCase(Trim(ps.ast.nodes(i).kind))
        If k <> "FUNCTION_STMT" And k <> "DECLARE_FUNCTION_STMT" Then Continue For
        If UCase(Trim(ps.ast.nodes(i).value)) <> fn Then Continue For

        Dim typeNode As Integer
        typeNode = MIRFindChildByKind(ps, i, "TYPE_REF")
        If typeNode <> -1 Then
            typeOut = MIRCanonicalTypeName(ps.ast.nodes(typeNode).value)
            If typeOut <> "" Then Return 1
        End If
    Next i

    Return 0
End Function

Private Function MIRInferExprFloatKind(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return MIR_UXF_UNKNOWN

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    Dim k As String
    k = UCase(Trim(n.kind))

    Select Case k
    Case "NUMBER", "INT", "INTEGER", "INT_LITERAL"
        Dim v As String
        v = UCase(Trim(n.value))
        If InStr(v, ".") <> 0 Or InStr(v, "E") <> 0 Then Return MIR_UXF_F64
        Return MIR_UXF_UNKNOWN

    Case "IDENT", "KEYWORD_REF"
        Dim typeName As String
        If MIRFindNearestDeclaredType(ps, nodeIdx, n.value, typeName) <> 0 Then
            Select Case UCase(Trim(typeName))
            Case "F32": Return MIR_UXF_F32
            Case "F64": Return MIR_UXF_F64
            Case "F80": Return MIR_UXF_F80
            End Select
        End If
        Return MIR_UXF_UNKNOWN

    Case "UNARY"
        Return MIRInferExprFloatKind(ps, n.right)

    Case "BINARY"
        Dim lk As Integer
        Dim rk As Integer
        lk = MIRInferExprFloatKind(ps, n.left)
        rk = MIRInferExprFloatKind(ps, n.right)
        If lk = MIR_UXF_F80 Or rk = MIR_UXF_F80 Then Return MIR_UXF_F80
        If lk = MIR_UXF_F64 Or rk = MIR_UXF_F64 Then Return MIR_UXF_F64
        If lk = MIR_UXF_F32 Or rk = MIR_UXF_F32 Then Return MIR_UXF_F32
        If Trim(n.op) = "/" Then Return MIR_UXF_F64
        Return MIR_UXF_UNKNOWN

    Case "TERNARY_EXPR"
        Dim thenNode As Integer
        thenNode = MIRChildAt(ps, nodeIdx, 0)
        If MIRInferExprFloatKind(ps, n.right) <> MIR_UXF_UNKNOWN Then Return MIRInferExprFloatKind(ps, n.right)
        If MIRInferExprFloatKind(ps, thenNode) <> MIR_UXF_UNKNOWN Then Return MIRInferExprFloatKind(ps, thenNode)
        Return MIR_UXF_UNKNOWN

    Case "CALL_EXPR"
        Dim callName As String
        callName = UCase(Trim(n.value))

        Dim retType As String
        If MIRFindFunctionReturnType(ps, callName, retType) <> 0 Then
            Select Case UCase(Trim(retType))
            Case "F32": Return MIR_UXF_F32
            Case "F64": Return MIR_UXF_F64
            Case "F80": Return MIR_UXF_F80
            End Select
        End If

        Select Case callName
        Case "CDBL", "VAL", "SQR", "SIN", "COS", "TAN", "ATN", "EXP", "LOG", "RND", "TIMER", "INPUTF"
            Return MIR_UXF_F64
        Case "CSNG"
            Return MIR_UXF_F32
        End Select

        Return MIR_UXF_UNKNOWN
    End Select

    Return MIR_UXF_UNKNOWN
End Function

Private Function MIRMapBinaryOpcode(ByRef opText As String, ByVal preferFloat As Integer, ByRef opcodeOut As String) As Integer
    Dim opu As String
    opu = UCase(Trim(opText))
    Select Case opu
    Case "+"
        If preferFloat <> 0 Then
            opcodeOut = MIR_OP_FADD
        Else
            opcodeOut = MIR_OP_ADD
        End If
    Case "-"
        If preferFloat <> 0 Then
            opcodeOut = MIR_OP_FSUB
        Else
            opcodeOut = MIR_OP_SUB
        End If
    Case "*"
        If preferFloat <> 0 Then
            opcodeOut = MIR_OP_FMUL
        Else
            opcodeOut = MIR_OP_MUL
        End If
    Case "/"
        If preferFloat <> 0 Then
            opcodeOut = MIR_OP_FDIV
        Else
            opcodeOut = MIR_OP_DIV
        End If
    Case "\"
        opcodeOut = MIR_OP_DIV
    Case "%", "MOD": opcodeOut = MIR_OP_MOD
    Case "=", "==": opcodeOut = MIR_OP_EQ
    Case "<>", "!=": opcodeOut = MIR_OP_NE
    Case "<": opcodeOut = MIR_OP_LT
    Case "<=": opcodeOut = MIR_OP_LE
    Case ">": opcodeOut = MIR_OP_GT
    Case ">=": opcodeOut = MIR_OP_GE
    Case "AND", "&": opcodeOut = MIR_OP_AND
    Case "OR", "|": opcodeOut = MIR_OP_OR
    Case "&&": opcodeOut = MIR_OP_AND
    Case "||": opcodeOut = MIR_OP_OR
    Case "XOR", "^": opcodeOut = MIR_OP_XOR
    Case "SHL", "<<": opcodeOut = MIR_OP_SHL
    Case "SHR", ">>": opcodeOut = MIR_OP_SHR
    Case "ROL": opcodeOut = MIR_OP_ROL
    Case "ROR": opcodeOut = MIR_OP_ROR
    Case Else: Return 0
    End Select
    Return 1
End Function

Private Function MIRRegisterArrayGlobal(ByRef module As MIRModule, ByRef varName As String) As Integer
    Dim nameUpper As String
    nameUpper = UCase(Trim(varName))
    If nameUpper = "" Then Return 0

    Dim i As Integer
    For i = 0 To module.globalVarCount - 1
        If UCase(Trim(module.globalVars(i))) = nameUpper Then Return 1
    Next i

    If module.globalVarCount = 0 Then
        ReDim module.globalVars(0)
    Else
        ReDim Preserve module.globalVars(module.globalVarCount)
    End If
    module.globalVars(module.globalVarCount) = nameUpper
    module.globalVarCount += 1
    Return 1
End Function

Private Function MIRIsKnownArray(ByRef module As MIRModule, ByRef varName As String) As Integer
    Dim nameUpper As String
    nameUpper = UCase(Trim(varName))
    Dim i As Integer
    For i = 0 To module.globalVarCount - 1
        If UCase(Trim(module.globalVars(i))) = nameUpper Then Return 1
    Next i
    Return 0
End Function

Private Function MIRChildCount(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim cnt As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        cnt += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop
    Return cnt
End Function

Private Function MIRChildAt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal childPos As Integer) As Integer
    If childPos < 0 Then Return -1
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return -1

    Dim ch As Integer
    Dim i As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    i = 0
    Do While ch <> -1
        If i = childPos Then Return ch
        i += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop
    Return -1
End Function

Private Function MIRFindChildByKind(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef kindText As String) As Integer
    Dim wantKind As String
    wantKind = UCase(Trim(kindText))

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If UCase(Trim(ps.ast.nodes(ch).kind)) = wantKind Then Return ch
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return -1
End Function

Private Function MIRHasClassDecl(ByRef ps As ParseState, ByRef classNameRaw As String) As Integer
    Dim className As String
    className = UCase(Trim(classNameRaw))
    If className = "" Then Return 0

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        If UCase(Trim(ps.ast.nodes(i).kind)) = "CLASS_STMT" Then
            If UCase(Trim(ps.ast.nodes(i).value)) = className Then Return 1
        End If
    Next i

    Return 0
End Function

Private Function MIRClassHasRoutineDecl(ByRef ps As ParseState, ByRef classNameRaw As String, ByRef routineKindRaw As String) As Integer
    Dim className As String
    Dim routineKind As String
    className = UCase(Trim(classNameRaw))
    routineKind = UCase(Trim(routineKindRaw))
    If className = "" Or routineKind = "" Then Return 0

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        If UCase(Trim(ps.ast.nodes(i).kind)) <> "CLASS_STMT" Then Continue For
        If UCase(Trim(ps.ast.nodes(i).value)) <> className Then Continue For

        Dim ch As Integer
        ch = ps.ast.nodes(i).firstChild
        Do While ch <> -1
            If UCase(Trim(ps.ast.nodes(ch).kind)) = routineKind Then Return 1
            ch = ps.ast.nodes(ch).nextSibling
        Loop
    Next i

    Return 0
End Function

Private Function MIRClassHasDestructorDecl(ByRef ps As ParseState, ByRef classNameRaw As String) As Integer
    Return MIRClassHasRoutineDecl(ps, classNameRaw, "CLASS_DESTRUCTOR_DECL")
End Function

Private Function MIRFindMethodSlotInClass(ByRef ps As ParseState, ByRef classNameRaw As String, ByRef methodNameRaw As String, ByRef slotOut As Integer) As Integer
    slotOut = -1
    Dim className As String
    className = UCase(Trim(classNameRaw))
    Dim methodName As String
    methodName = UCase(Trim(methodNameRaw))
    If className = "" Or methodName = "" Then Return 0

    Dim curClass As String
    curClass = className
    Dim hop As Integer
    hop = 0
    Do While curClass <> ""
        hop += 1
        If hop > 64 Then Exit Do

        Dim classNode As Integer
        classNode = -1
        Dim i As Integer
        For i = 0 To ps.ast.count - 1
            If UCase(Trim(ps.ast.nodes(i).kind)) = "CLASS_STMT" Then
                If UCase(Trim(ps.ast.nodes(i).value)) = curClass Then
                    classNode = i
                    Exit For
                End If
            End If
        Next i
        If classNode = -1 Then Exit Do

        Dim ch As Integer
        ch = ps.ast.nodes(classNode).firstChild
        Do While ch <> -1
            If UCase(ps.ast.nodes(ch).kind) = "CLASS_METHOD_DECL" Then
                If UCase(Trim(ps.ast.nodes(ch).value)) = methodName Then
                    Dim meta As Integer
                    meta = MIRFindChildByKind(ps, ch, "CLASS_METHOD_SLOT")
                    If meta <> -1 Then
                        slotOut = Val(ps.ast.nodes(meta).value)
                        Return 1
                    Else
                        Return 0
                    End If
                End If
            End If
            ch = ps.ast.nodes(ch).nextSibling
        Loop

        Dim baseNode As Integer
        baseNode = MIRFindChildByKind(ps, classNode, "CLASS_BASE_REF")
        If baseNode = -1 Then Exit Do
        curClass = UCase(Trim(ps.ast.nodes(baseNode).value))
    Loop

    slotOut = -1
    Return 0
End Function

Private Function MIRHasRoutineNamed(ByRef ps As ParseState, ByRef routineNameRaw As String) As Integer
    Dim routineName As String
    routineName = UCase(Trim(routineNameRaw))
    If routineName = "" Then Return 0

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        Dim k As String
        k = UCase(Trim(ps.ast.nodes(i).kind))
        If k <> "SUB_STMT" And k <> "FUNCTION_STMT" Then Continue For
        If UCase(Trim(ps.ast.nodes(i).value)) = routineName Then Return 1
    Next i

    Return 0
End Function

Private Function MIRFindNearestDimDeclType(ByRef ps As ParseState, ByVal fromNodeIdx As Integer, ByRef varNameRaw As String, ByRef typeOut As String) As Integer
    typeOut = ""

    Dim varName As String
    varName = UCase(Trim(varNameRaw))
    If varName = "" Then Return 0

    Dim i As Integer
    For i = fromNodeIdx To 0 Step -1
        If UCase(Trim(ps.ast.nodes(i).kind)) <> "DIM_DECL" Then Continue For
        If UCase(Trim(ps.ast.nodes(i).value)) <> varName Then Continue For

        Dim typeNode As Integer
        typeNode = MIRFindChildByKind(ps, i, "TYPE_REF")
        If typeNode <> -1 Then
            typeOut = UCase(Trim(ps.ast.nodes(typeNode).value))
            If typeOut <> "" Then Return 1
        End If
    Next i

    Return 0
End Function

Private Function MIRSplitMethodCallName(ByRef callNameRaw As String, ByRef ownerOut As String, ByRef methodOut As String) As Integer
    ownerOut = ""
    methodOut = ""

    Dim callName As String
    callName = UCase(Trim(callNameRaw))
    Dim dotPos As Integer
    dotPos = InStr(callName, ".")
    If dotPos <= 1 Then Return 0

    ownerOut = Trim(Left(callName, dotPos - 1))
    methodOut = Trim(Mid(callName, dotPos + 1))
    If ownerOut = "" Or methodOut = "" Then Return 0
    If InStr(methodOut, ".") > 0 Then Return 0
    Return 1
End Function

Private Function MIRResolveMethodCallRoute(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef callNameRaw As String, ByRef loweredNameOut As String, ByRef injectReceiverOut As Integer, ByRef receiverVarOut As String) As Integer
    loweredNameOut = UCase(Trim(callNameRaw))
    injectReceiverOut = 0
    receiverVarOut = ""

    Dim ownerName As String
    Dim methodName As String
    If MIRSplitMethodCallName(callNameRaw, ownerName, methodName) = 0 Then Return 0

    Dim ownerType As String
    If MIRFindNearestDimDeclType(ps, nodeIdx, ownerName, ownerType) <> 0 Then
        ' If semantic assigned a slot for this method on the owner type (or its bases), encode a slot call
        Dim slotIdx As Integer
        If MIRFindMethodSlotInClass(ps, ownerType, methodName, slotIdx) <> 0 And slotIdx >= 0 Then
            loweredNameOut = "__VT_SLOT__:" & UCase(Trim(ownerType)) & ":" & LTrim(Str(slotIdx))
        Else
            loweredNameOut = ownerType & "_" & methodName
        End If
        injectReceiverOut = 1
        receiverVarOut = ownerName
        Return 1
    End If

    If MIRHasClassDecl(ps, ownerName) <> 0 Then
        loweredNameOut = ownerName & "_" & methodName
        injectReceiverOut = 0
        receiverVarOut = ""
        Return 1
    End If

    Return 0
End Function

Private Function MIRBuildFieldPath(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef pathOut As String, ByRef errText As String) As Integer
    pathOut = ""

    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "mir: invalid field node"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    Dim k As String
    k = UCase(Trim(n.kind))

    If k = "IDENT" Or k = "KEYWORD_REF" Then
        pathOut = UCase(Trim(n.value))
        If pathOut = "" Then
            errText = "mir: field root name missing"
            Return 0
        End If
        Return 1
    End If

    If k = "CALL_EXPR" Then
        Dim baseName As String
        baseName = UCase(Trim(n.value))
        If baseName = "" Then
            errText = "mir: field root name missing"
            Return 0
        End If

        If MIRChildCount(ps, nodeIdx) <> 1 Then
            errText = "mir: indexed field root expects one index"
            Return 0
        End If

        Dim idxExpr As Integer
        idxExpr = MIRChildAt(ps, nodeIdx, 0)
        If idxExpr = -1 Then
            errText = "mir: indexed field root missing index"
            Return 0
        End If

        Dim idxText As String
        If MIRDescribeNodeText(ps, idxExpr, idxText) = 0 Then
            errText = "mir: indexed field root index unsupported"
            Return 0
        End If

        pathOut = baseName & "(" & idxText & ")"
        Return 1
    End If

    If k <> "FIELD_EXPR" Then
        errText = "mir: field base must be identifier, indexed access or field"
        Return 0
    End If

    Dim basePath As String
    If MIRBuildFieldPath(ps, n.left, basePath, errText) = 0 Then Return 0

    Dim memberName As String
    memberName = UCase(Trim(n.value))
    If memberName = "" Then
        errText = "mir: field member name missing"
        Return 0
    End If

    If basePath = "" Then
        pathOut = memberName
    Else
        pathOut = basePath & "." & memberName
    End If

    Return 1
End Function

Private Function MIRIsStmtKind(ByRef kindText As String) As Integer
    Dim k As String
    k = UCase(Trim(kindText))

    If Right(k, 5) = "_STMT" Then Return 1
    If k = "EXIT" Then Return 1
    If k = "CONTINUE" Then Return 1
    Return 0
End Function

Private Function MIRAllocBlock(ByRef module As MIRModule, ByVal fnIdx As Integer) As Integer
    Dim fnPtr As MIRFunction Ptr
    Dim bIdx As Integer
    fnPtr = @module.functions(fnIdx)
    bIdx = fnPtr->blockCount

    If bIdx = 0 Then
        ReDim fnPtr->blocks(0)
    Else
        ReDim Preserve fnPtr->blocks(bIdx)
    End If

    fnPtr->blockCount = bIdx + 1
    fnPtr->blocks(bIdx).id = bIdx
    fnPtr->blocks(bIdx).instructionCount = 0
    fnPtr->blocks(bIdx).predecessorCount = 0
    fnPtr->blocks(bIdx).successorCount = 0
    fnPtr->blocks(bIdx).isEntry = 0
    fnPtr->blocks(bIdx).isExit = 0

    Return bIdx
End Function

Private Sub MIRPushLoopContext(ByRef loopType As String, ByVal breakBlock As Integer, ByVal continueBlock As Integer)
    If gMirLowerLoopDepth = 0 Then
        ReDim gMirLowerLoopType(0)
        ReDim gMirLowerLoopBreak(0)
        ReDim gMirLowerLoopContinue(0)
    Else
        ReDim Preserve gMirLowerLoopType(gMirLowerLoopDepth)
        ReDim Preserve gMirLowerLoopBreak(gMirLowerLoopDepth)
        ReDim Preserve gMirLowerLoopContinue(gMirLowerLoopDepth)
    End If

    gMirLowerLoopType(gMirLowerLoopDepth) = UCase(Trim(loopType))
    gMirLowerLoopBreak(gMirLowerLoopDepth) = breakBlock
    gMirLowerLoopContinue(gMirLowerLoopDepth) = continueBlock
    gMirLowerLoopDepth += 1
End Sub

Private Sub MIRPopLoopContext()
    If gMirLowerLoopDepth <= 0 Then Exit Sub
    gMirLowerLoopDepth -= 1
End Sub

Private Function MIRFindLoopContext(ByRef wantType As String, ByRef breakBlockOut As Integer, ByRef continueBlockOut As Integer) As Integer
    Dim i As Integer
    Dim w As String
    w = UCase(Trim(wantType))

    For i = gMirLowerLoopDepth - 1 To 0 Step -1
        If w = "" Or gMirLowerLoopType(i) = w Then
            breakBlockOut = gMirLowerLoopBreak(i)
            continueBlockOut = gMirLowerLoopContinue(i)
            Return 1
        End If
    Next i

    Return 0
End Function

Private Sub MIRPushIfExitTarget(ByVal endBlock As Integer)
    If gMirLowerIfDepth = 0 Then
        ReDim gMirLowerIfEnd(0)
    Else
        ReDim Preserve gMirLowerIfEnd(gMirLowerIfDepth)
    End If
    gMirLowerIfEnd(gMirLowerIfDepth) = endBlock
    gMirLowerIfDepth += 1
End Sub

Private Sub MIRPopIfExitTarget()
    If gMirLowerIfDepth <= 0 Then Exit Sub
    gMirLowerIfDepth -= 1
End Sub

Private Function MIRCurrentIfExitTarget(ByRef endBlockOut As Integer) As Integer
    If gMirLowerIfDepth <= 0 Then Return 0
    endBlockOut = gMirLowerIfEnd(gMirLowerIfDepth - 1)
    Return 1
End Function

Private Sub MIRPushTryTarget(ByVal targetBlock As Integer)
    If gMirLowerTryDepth = 0 Then
        ReDim gMirLowerTryTarget(0)
    Else
        ReDim Preserve gMirLowerTryTarget(gMirLowerTryDepth)
    End If
    gMirLowerTryTarget(gMirLowerTryDepth) = targetBlock
    gMirLowerTryDepth += 1
End Sub

Private Sub MIRPopTryTarget()
    If gMirLowerTryDepth <= 0 Then Exit Sub
    gMirLowerTryDepth -= 1
End Sub

Private Function MIRCurrentTryTarget(ByRef targetOut As Integer) As Integer
    If gMirLowerTryDepth <= 0 Then Return 0
    targetOut = gMirLowerTryTarget(gMirLowerTryDepth - 1)
    Return 1
End Function

Private Sub MIRMarkExceptionActive(ByRef module As MIRModule, ByVal fnIdx As Integer, ByVal blkIdx As Integer, ByRef tempSeed As Integer)
    Dim oneName As String
    oneName = MIRNextTemp(tempSeed)
    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, oneName, 1, "1"
    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, "__mir_exc_active", 1, oneName
End Sub

Private Sub MIRClearExceptionActive(ByRef module As MIRModule, ByVal fnIdx As Integer, ByVal blkIdx As Integer, ByRef tempSeed As Integer)
    Dim zeroName As String
    zeroName = MIRNextTemp(tempSeed)
    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, zeroName, 1, "0"
    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, "__mir_exc_active", 1, zeroName
End Sub

Private Function MIREnsureBoolVar(ByRef module As MIRModule, ByVal fnIdx As Integer, ByVal blkIdx As Integer, ByRef tempSeed As Integer, ByRef inName As String, ByRef outName As String) As Integer
    Dim zeroName As String
    Dim boolName As String

    zeroName = MIRNextTemp(tempSeed)
    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, zeroName, 1, "0"

    boolName = MIRNextTemp(tempSeed)
    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_NE, boolName, 2, inName, zeroName

    outName = boolName
    Return 1
End Function

Private Function MIRLowerStmtRange(ByRef ps As ParseState, ByVal parentIdx As Integer, ByVal fromPos As Integer, ByVal toPos As Integer, ByRef module As MIRModule, ByVal fnIdx As Integer, ByRef blkIdx As Integer, ByRef tempSeed As Integer, ByRef errText As String) As Integer
    Dim p As Integer
    For p = fromPos To toPos
        Dim stIdx As Integer
        stIdx = MIRChildAt(ps, parentIdx, p)
        If stIdx = -1 Then
            errText = "mir: statement child missing"
            Return 0
        End If
        If MIRLowerTopLevelStmt(ps, stIdx, module, fnIdx, blkIdx, tempSeed, errText) = 0 Then Return 0
    Next p
    Return 1
End Function

Private Function MIRLowerExprNode(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef module As MIRModule, ByVal fnIdx As Integer, ByRef blkIdx As Integer, ByRef tempSeed As Integer, ByRef valueNameOut As String, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "mir: invalid expr node"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    Dim k As String
    k = UCase(n.kind)

    If k = "NUMBER" Or k = "STRING" Then
        Dim t As String
        t = MIRNextTemp(tempSeed)
        Dim cText As String
        If k = "STRING" Then
            cText = Chr(34) & n.value & Chr(34)
        Else
            cText = Trim(n.value)
        End If
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, t, 1, cText
        valueNameOut = t
        Return 1
    End If

    If k = "KEYWORD_REF" Then
        Dim kwTemp As String
        kwTemp = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, kwTemp, 1, Chr(34) & n.value & Chr(34)
        valueNameOut = kwTemp
        Return 1
    End If

    If k = "IDENT" Then
        valueNameOut = n.value
        Return 1
    End If

    If k = "UNARY" Then
        Dim rhsName As String
        If MIRLowerExprNode(ps, n.right, module, fnIdx, blkIdx, tempSeed, rhsName, errText) = 0 Then Return 0

        Dim opu As String
        opu = UCase(Trim(n.op))
        Dim t As String
        t = MIRNextTemp(tempSeed)

        If opu = "NOT" Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_NOT, t, 1, rhsName
            valueNameOut = t
            Return 1
        End If

        If opu = "LNOT" Or opu = "!" Then
            Dim zeroTemp As String
            zeroTemp = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, zeroTemp, 1, "0"
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_EQ, t, 2, rhsName, zeroTemp
            valueNameOut = t
            Return 1
        End If

        If opu = "-" Then
            Dim negOp As String
            negOp = MIR_OP_NEG
            Dim rkind As Integer
            rkind = MIRInferExprFloatKind(ps, n.right)
            If rkind = MIR_UXF_F80 Then
                errText = "mir: F80 arithmetic not supported"
                Return 0
            End If
            If rkind <> MIR_UXF_UNKNOWN Then negOp = MIR_OP_FNEG
            MIRAppendInstruction module, fnIdx, blkIdx, negOp, t, 1, rhsName
            valueNameOut = t
            Return 1
        End If

        valueNameOut = rhsName
        Return 1
    End If

    If k = "INCDEC_EXPR" Then
        If n.left = -1 Then
            errText = "mir: INCDEC expression target missing"
            Return 0
        End If

        Dim incTarget As String
        Dim incSource As String
        Dim incOldName As String
        Dim incNewName As String
        Dim incOne As String
        Dim incIndexName As String
        Dim incIndexed As Integer
        incIndexed = 0

        If UCase(ps.ast.nodes(n.left).kind) = "IDENT" Then
            incTarget = ps.ast.nodes(n.left).value
            incSource = incTarget
        ElseIf UCase(ps.ast.nodes(n.left).kind) = "FIELD_EXPR" Then
            If MIRBuildFieldPath(ps, n.left, incTarget, errText) = 0 Then Return 0
            incSource = incTarget
        ElseIf UCase(ps.ast.nodes(n.left).kind) = "CALL_EXPR" And InStr(ps.ast.nodes(n.left).value, ".") = 0 And MIRIsKnownArray(module, ps.ast.nodes(n.left).value) <> 0 And MIRChildCount(ps, n.left) = 1 Then
            incTarget = ps.ast.nodes(n.left).value
            If MIRLowerExprNode(ps, MIRChildAt(ps, n.left, 0), module, fnIdx, blkIdx, tempSeed, incIndexName, errText) = 0 Then Return 0
            incSource = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_INDEXED, incSource, 2, incTarget, incIndexName
            incIndexed = 1
        Else
            errText = "mir: INCDEC expression target must be ident, field, or indexed array"
            Return 0
        End If

        incOldName = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_VAR, incOldName, 1, incSource
        incOne = MIRNextTemp(tempSeed)
        Dim incKind As Integer
        incKind = MIRInferExprFloatKind(ps, n.left)
        If incKind = MIR_UXF_F80 Then
            errText = "mir: F80 arithmetic not supported"
            Return 0
        End If
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, incOne, 1, IIf(incKind <> MIR_UXF_UNKNOWN, "1.0", "1")
        incNewName = MIRNextTemp(tempSeed)
        If Trim(n.op) = "--" Then
            MIRAppendInstruction module, fnIdx, blkIdx, IIf(incKind <> MIR_UXF_UNKNOWN, MIR_OP_FSUB, MIR_OP_SUB), incNewName, 2, incSource, incOne
        Else
            MIRAppendInstruction module, fnIdx, blkIdx, IIf(incKind <> MIR_UXF_UNKNOWN, MIR_OP_FADD, MIR_OP_ADD), incNewName, 2, incSource, incOne
        End If

        If incIndexed <> 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_INDEXED, "", 3, incTarget, incIndexName, incNewName
        Else
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, incTarget, 1, incNewName
        End If

        If UCase(Trim(n.value)) = "POST" Then
            valueNameOut = incOldName
        Else
            valueNameOut = incNewName
        End If
        Return 1
    End If

    If k = "BINARY" Then
        If n.op = "|>" Then
            If n.right = -1 Then
                errText = "mir: pipe target missing"
                Return 0
            End If

            Dim pipeInputName As String
            If MIRLowerExprNode(ps, n.left, module, fnIdx, blkIdx, tempSeed, pipeInputName, errText) = 0 Then Return 0

            Dim pipeTargetKind As String
            pipeTargetKind = UCase(ps.ast.nodes(n.right).kind)
            If pipeTargetKind <> "IDENT" And pipeTargetKind <> "KEYWORD_REF" Then
                errText = "mir: |> target must be identifier"
                Return 0
            End If

            Dim pipeResult As String
            pipeResult = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, pipeResult, 2, UCase(Trim(ps.ast.nodes(n.right).value)), pipeInputName
            valueNameOut = pipeResult
            Return 1
        End If

        Dim logicOpText As String
        logicOpText = UCase(Trim(n.op))

        If logicOpText = "&&" Or logicOpText = "AND" Or logicOpText = "||" Or logicOpText = "OR" Then
            Dim leftName As String
            If MIRLowerExprNode(ps, n.left, module, fnIdx, blkIdx, tempSeed, leftName, errText) = 0 Then Return 0

            Dim leftBool As String
            MIREnsureBoolVar module, fnIdx, blkIdx, tempSeed, leftName, leftBool

            Dim rhsBlock As Integer
            Dim shortBlock As Integer
            Dim endBlock As Integer
            rhsBlock = MIRAllocBlock(module, fnIdx)
            shortBlock = MIRAllocBlock(module, fnIdx)
            endBlock = MIRAllocBlock(module, fnIdx)

            Dim resultTemp As String
            resultTemp = MIRNextTemp(tempSeed)

            If logicOpText = "&&" Or logicOpText = "AND" Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JNZ, "", 2, leftBool, LTrim(Str(rhsBlock))
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(shortBlock))

                blkIdx = shortBlock
                Dim falseName As String
                falseName = MIRNextTemp(tempSeed)
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, falseName, 1, "0"
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, resultTemp, 1, falseName
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))

                blkIdx = rhsBlock
                Dim rightAndName As String
                If MIRLowerExprNode(ps, n.right, module, fnIdx, blkIdx, tempSeed, rightAndName, errText) = 0 Then Return 0
                Dim rightAndBool As String
                MIREnsureBoolVar module, fnIdx, blkIdx, tempSeed, rightAndName, rightAndBool
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, resultTemp, 1, rightAndBool
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))
            Else
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JNZ, "", 2, leftBool, LTrim(Str(shortBlock))
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(rhsBlock))

                blkIdx = shortBlock
                Dim trueName As String
                trueName = MIRNextTemp(tempSeed)
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, trueName, 1, "-1"
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, resultTemp, 1, trueName
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))

                blkIdx = rhsBlock
                Dim rightOrName As String
                If MIRLowerExprNode(ps, n.right, module, fnIdx, blkIdx, tempSeed, rightOrName, errText) = 0 Then Return 0
                Dim rightOrBool As String
                MIREnsureBoolVar module, fnIdx, blkIdx, tempSeed, rightOrName, rightOrBool
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, resultTemp, 1, rightOrBool
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))
            End If

            blkIdx = endBlock
            valueNameOut = resultTemp
            Return 1
        End If

        Dim lName As String
        Dim rName As String
        If MIRLowerExprNode(ps, n.left, module, fnIdx, blkIdx, tempSeed, lName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, n.right, module, fnIdx, blkIdx, tempSeed, rName, errText) = 0 Then Return 0

        Dim bop As String
        Dim preferFloatKind As Integer
        preferFloatKind = MIRInferExprFloatKind(ps, nodeIdx)
        If preferFloatKind = MIR_UXF_F80 Then
            errText = "mir: F80 arithmetic not supported"
            Return 0
        End If
        If MIRMapBinaryOpcode(n.op, IIf(preferFloatKind <> MIR_UXF_UNKNOWN, 1, 0), bop) = 0 Then
            errText = "mir: unsupported binary op " & n.op
            Return 0
        End If

        Dim t As String
        t = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, bop, t, 2, lName, rName
        valueNameOut = t
        Return 1
    End If

    If k = "TERNARY_EXPR" Then
        Dim condName As String
        If MIRLowerExprNode(ps, n.left, module, fnIdx, blkIdx, tempSeed, condName, errText) = 0 Then Return 0

        Dim condBool As String
        MIREnsureBoolVar module, fnIdx, blkIdx, tempSeed, condName, condBool

        Dim thenNode As Integer
        thenNode = MIRChildAt(ps, nodeIdx, 0)
        If thenNode = -1 Then
            errText = "mir: ternary true branch missing"
            Return 0
        End If

        Dim thenBlock As Integer
        Dim elseBlock As Integer
        Dim endBlock As Integer
        thenBlock = MIRAllocBlock(module, fnIdx)
        elseBlock = MIRAllocBlock(module, fnIdx)
        endBlock = MIRAllocBlock(module, fnIdx)

        Dim resultTemp As String
        resultTemp = MIRNextTemp(tempSeed)

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JNZ, "", 2, condBool, LTrim(Str(thenBlock))
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(elseBlock))

        blkIdx = thenBlock
        Dim thenValue As String
        If MIRLowerExprNode(ps, thenNode, module, fnIdx, blkIdx, tempSeed, thenValue, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, resultTemp, 1, thenValue
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))

        blkIdx = elseBlock
        Dim elseValue As String
        If MIRLowerExprNode(ps, n.right, module, fnIdx, blkIdx, tempSeed, elseValue, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, resultTemp, 1, elseValue
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))

        blkIdx = endBlock
        valueNameOut = resultTemp
        Return 1
    End If

    If k = "CALL_EXPR" Then
        Dim callName As String
        Dim skipFirstCallChild As Integer
        Dim injectReceiver As Integer
        Dim receiverVar As String
        callName = UCase(Trim(n.value))
        skipFirstCallChild = 0
        injectReceiver = 0
        receiverVar = ""

        If callName = "OFFSETOF" Then
            If MIRChildCount(ps, nodeIdx) <> 2 Then
                errText = "mir: OFFSETOF expects two arguments"
                Return 0
            End If

            Dim typeNode As Integer
            Dim pathNode As Integer
            typeNode = MIRChildAt(ps, nodeIdx, 0)
            pathNode = MIRChildAt(ps, nodeIdx, 1)
            If typeNode = -1 Or pathNode = -1 Then
                errText = "mir: OFFSETOF arguments missing"
                Return 0
            End If

            Dim typeKind As String
            Dim pathKind As String
            typeKind = UCase(ps.ast.nodes(typeNode).kind)
            pathKind = UCase(ps.ast.nodes(pathNode).kind)
            If typeKind <> "IDENT" And typeKind <> "KEYWORD_REF" Then
                errText = "mir: OFFSETOF first argument must be type name"
                Return 0
            End If
            If pathKind <> "STRING" Then
                errText = "mir: OFFSETOF second argument must be string path"
                Return 0
            End If

            Dim offValue As Integer
            Dim offErr As String
            If TypeLayoutOffsetOf(ps, ps.ast.nodes(typeNode).value, ps.ast.nodes(pathNode).value, offValue, offErr) = 0 Then
                errText = "mir: OFFSETOF resolve failed " & offErr
                Return 0
            End If

            Dim offTemp As String
            offTemp = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, offTemp, 1, LTrim(Str(offValue))
            valueNameOut = offTemp
            Return 1
        End If

        If InStr(callName, ".") = 0 And MIRIsKnownArray(module, callName) <> 0 And MIRChildCount(ps, nodeIdx) = 1 Then
            Dim indexName As String
            Dim indexNode As Integer
            Dim loadTemp As String
            indexNode = MIRChildAt(ps, nodeIdx, 0)
            If indexNode = -1 Then
                errText = "mir: indexed load index missing"
                Return 0
            End If
            If MIRLowerExprNode(ps, indexNode, module, fnIdx, blkIdx, tempSeed, indexName, errText) = 0 Then Return 0
            loadTemp = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_INDEXED, loadTemp, 2, callName, indexName
            valueNameOut = loadTemp
            Return 1
        End If

        If InStr(callName, ".") > 0 Then
            Dim loweredCallName As String
            If MIRResolveMethodCallRoute(ps, nodeIdx, callName, loweredCallName, injectReceiver, receiverVar) <> 0 Then
                callName = loweredCallName
            End If
        End If

        If callName = "CALL" And n.firstChild <> -1 Then
            Dim markerKind As String
            Dim markerValue As String
            markerKind = UCase(Trim(ps.ast.nodes(n.firstChild).kind))
            markerValue = UCase(Trim(ps.ast.nodes(n.firstChild).value))
            If (markerKind = "IDENT" Or markerKind = "KEYWORD_REF") And markerValue = "DLL" Then
                callName = "DLL"
                skipFirstCallChild = 1
            End If
        End If

        Dim childCount As Integer
        childCount = 0
        Dim ch As Integer
        ch = n.firstChild
        Do While ch <> -1
            If skipFirstCallChild = 0 Or ch <> n.firstChild Then childCount += 1
            ch = ps.ast.nodes(ch).nextSibling
        Loop

        If injectReceiver <> 0 Then childCount += 1

        Dim t As String
        t = MIRNextTemp(tempSeed)

        If childCount = 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, t, 1, callName
        Else
            Dim a1 As String, a2 As String, a3 As String, a4 As String, a5 As String, a6 As String, a7 As String, a8 As String
            a1 = callName
            Dim idx As Integer
            idx = 2

            If injectReceiver <> 0 Then
                a2 = receiverVar
                idx = 3
            End If

            ch = n.firstChild
            Do While ch <> -1
                If skipFirstCallChild <> 0 And ch = n.firstChild Then
                    ch = ps.ast.nodes(ch).nextSibling
                    Continue Do
                End If
                Dim argName As String
                If MIRLowerExprNode(ps, ch, module, fnIdx, blkIdx, tempSeed, argName, errText) = 0 Then Return 0
                Select Case idx
                Case 2: a2 = argName
                Case 3: a3 = argName
                Case 4: a4 = argName
                Case 5: a5 = argName
                Case 6: a6 = argName
                Case 7: a7 = argName
                Case 8: a8 = argName
                Case Else
                    errText = "mir: CALL arguman sayisi limiti asildi"
                    Return 0
                End Select
                idx += 1
                ch = ps.ast.nodes(ch).nextSibling
            Loop

            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, t, childCount + 1, a1, a2, a3, a4, a5, a6, a7, a8
        End If

        valueNameOut = t
        Return 1
    End If

    If k = "FIELD_EXPR" Then
        Dim fieldPath As String
        If MIRBuildFieldPath(ps, nodeIdx, fieldPath, errText) = 0 Then Return 0

        Dim t As String
        t = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_VAR, t, 1, fieldPath
        valueNameOut = t
        Return 1
    End If

    If k = "NEW_EXPR" Then
        Dim className As String
        className = UCase(Trim(n.value))
        If className = "" Then
            errText = "mir: NEW class type missing"
            Return 0
        End If

        Dim t As String
        t = MIRNextTemp(tempSeed)

        Dim a1 As String, a2 As String, a3 As String, a4 As String, a5 As String, a6 As String, a7 As String, a8 As String
        a1 = className

        Dim argCount As Integer
        argCount = 1

        Dim ch As Integer
        ch = n.firstChild
        Do While ch <> -1
            Dim argName As String
            If MIRLowerExprNode(ps, ch, module, fnIdx, blkIdx, tempSeed, argName, errText) = 0 Then Return 0

            argCount += 1
            Select Case argCount
            Case 2: a2 = argName
            Case 3: a3 = argName
            Case 4: a4 = argName
            Case 5: a5 = argName
            Case 6: a6 = argName
            Case 7: a7 = argName
            Case 8: a8 = argName
            Case Else
                errText = "mir: NEW arguman sayisi limiti asildi"
                Return 0
            End Select

            ch = ps.ast.nodes(ch).nextSibling
        Loop

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_NEW, t, argCount, a1, a2, a3, a4, a5, a6, a7, a8
        valueNameOut = t
        Return 1
    End If

    errText = "mir: unsupported expr kind " & n.kind
    Return 0
End Function

Private Function MIRLowerTopLevelStmt(ByRef ps As ParseState, ByVal stmtIdx As Integer, ByRef module As MIRModule, ByVal fnIdx As Integer, ByRef blkIdx As Integer, ByRef tempSeed As Integer, ByRef errText As String) As Integer
    If stmtIdx < 0 Or stmtIdx >= ps.ast.count Then Return 1

    Dim st As ASTNode
    st = ps.ast.nodes(stmtIdx)
    Dim k As String
    k = UCase(st.kind)

    Select Case k
    Case "DEFTYPE_STMT"
        Dim defTypeName As String
        Select Case UCase(Trim(st.op))
        Case "DEFINT": defTypeName = "INTEGER"
        Case "DEFLNG": defTypeName = "LONG"
        Case "DEFSNG": defTypeName = "SINGLE"
        Case "DEFDBL": defTypeName = "DOUBLE"
        Case "DEFEXT": defTypeName = "EXTENDED"
        Case "DEFSTR": defTypeName = "STRING"
        Case "DEFBYT": defTypeName = "I8"
        Case Else: defTypeName = UCase(Trim(st.op))
        End Select

        Dim defItem As Integer
        defItem = st.firstChild
        If defItem = -1 Then
            errText = "mir: DEF* range missing"
            Return 0
        End If

        Do While defItem <> -1
            Dim defRangeName As String
            If MIRDescribeNodeText(ps, defItem, defRangeName) = 0 Then
                errText = "mir: DEF* range could not be described"
                Return 0
            End If
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_DEF_TYPE, "", 2, defTypeName, defRangeName
            defItem = ps.ast.nodes(defItem).nextSibling
        Loop
        Return 1

    Case "SETSTRINGSIZE_STMT"
        Dim setStringExpr As Integer
        setStringExpr = MIRChildAt(ps, stmtIdx, 0)
        If setStringExpr = -1 Then
            errText = "mir: SETSTRINGSIZE size missing"
            Return 0
        End If

        Dim setStringName As String
        If MIRLowerExprNode(ps, setStringExpr, module, fnIdx, blkIdx, tempSeed, setStringName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_SETSTRINGSIZE, "", 1, setStringName
        Return 1

    Case "ASSIGN_STMT"
        If st.left = -1 Or st.right = -1 Then
            errText = "mir: assign operands missing"
            Return 0
        End If

        Dim opText As String
        opText = Trim(st.op)
        If opText = "" Then opText = "="

        Dim rhsName As String
        If MIRLowerExprNode(ps, st.right, module, fnIdx, blkIdx, tempSeed, rhsName, errText) = 0 Then Return 0

        Dim lhsKind As String
        Dim assignTarget As String
        Dim assignIndexName As String
        Dim indexedAssign As Integer
        lhsKind = UCase(ps.ast.nodes(st.left).kind)
        indexedAssign = 0

        If lhsKind = "IDENT" Then
            assignTarget = ps.ast.nodes(st.left).value
        ElseIf lhsKind = "FIELD_EXPR" Then
            If MIRBuildFieldPath(ps, st.left, assignTarget, errText) = 0 Then Return 0
        ElseIf lhsKind = "CALL_EXPR" And InStr(ps.ast.nodes(st.left).value, ".") = 0 And MIRIsKnownArray(module, ps.ast.nodes(st.left).value) <> 0 And MIRChildCount(ps, st.left) = 1 Then
            assignTarget = ps.ast.nodes(st.left).value
            If MIRLowerExprNode(ps, MIRChildAt(ps, st.left, 0), module, fnIdx, blkIdx, tempSeed, assignIndexName, errText) = 0 Then Return 0
            indexedAssign = 1
        Else
            errText = "mir: assign lhs must be ident, field, or indexed array"
            Return 0
        End If

        Select Case opText
        Case "="
            If indexedAssign <> 0 Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_INDEXED, "", 3, assignTarget, assignIndexName, rhsName
            Else
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, assignTarget, 1, rhsName
            End If

        Case "=+"
            If indexedAssign <> 0 Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_INDEXED, "", 3, assignTarget, assignIndexName, rhsName
            Else
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, assignTarget, 1, rhsName
            End If

        Case "=-"
            Dim negTmp As String
            negTmp = MIRNextTemp(tempSeed)
            Dim rkindNeg As Integer
            rkindNeg = MIRInferExprFloatKind(ps, st.right)
            If rkindNeg = MIR_UXF_F80 Then
                errText = "mir: F80 arithmetic not supported"
                Return 0
            End If
            MIRAppendInstruction module, fnIdx, blkIdx, IIf(rkindNeg <> MIR_UXF_UNKNOWN, MIR_OP_FNEG, MIR_OP_NEG), negTmp, 1, rhsName
            If indexedAssign <> 0 Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_INDEXED, "", 3, assignTarget, assignIndexName, negTmp
            Else
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, assignTarget, 1, negTmp
            End If

        Case "+=", "-=", "*=", "/=", "\="
            Dim compoundOp As String
            Dim compoundTmp As String
            Dim compoundLhs As String
            Dim compoundFloat As Integer
            Dim lkind As Integer
            Dim rkind As Integer
            lkind = MIRInferExprFloatKind(ps, st.left)
            rkind = MIRInferExprFloatKind(ps, st.right)
            If lkind = MIR_UXF_F80 Or rkind = MIR_UXF_F80 Then
                errText = "mir: F80 arithmetic not supported"
                Return 0
            End If
            compoundFloat = IIf(lkind <> MIR_UXF_UNKNOWN Or rkind <> MIR_UXF_UNKNOWN, 1, 0)

            Select Case opText
            Case "+=": compoundOp = IIf(compoundFloat <> 0, MIR_OP_FADD, MIR_OP_ADD)
            Case "-=": compoundOp = IIf(compoundFloat <> 0, MIR_OP_FSUB, MIR_OP_SUB)
            Case "*=": compoundOp = IIf(compoundFloat <> 0, MIR_OP_FMUL, MIR_OP_MUL)
            Case "/=": compoundOp = IIf(compoundFloat <> 0, MIR_OP_FDIV, MIR_OP_DIV)
            Case "\=": compoundOp = MIR_OP_DIV
            End Select

            compoundLhs = assignTarget
            If indexedAssign <> 0 Then
                compoundLhs = MIRNextTemp(tempSeed)
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_INDEXED, compoundLhs, 2, assignTarget, assignIndexName
            End If

            compoundTmp = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, compoundOp, compoundTmp, 2, compoundLhs, rhsName
            If indexedAssign <> 0 Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_INDEXED, "", 3, assignTarget, assignIndexName, compoundTmp
            Else
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, assignTarget, 1, compoundTmp
            End If

        Case Else
            errText = "mir: unsupported assign op " & opText
            Return 0
        End Select

        Return 1

    Case "DIM_STMT"
        Dim ch As Integer
        ch = st.firstChild
        Do While ch <> -1
            If UCase(ps.ast.nodes(ch).kind) = "DIM_DECL" Then
                Dim varName As String
                varName = ps.ast.nodes(ch).value
                Dim boundsNode As Integer
                boundsNode = MIRFindChildByKind(ps, ch, "DIM_BOUNDS")
                If boundsNode <> -1 And MIRChildCount(ps, boundsNode) = 1 Then
                    Dim lowerName As String
                    Dim upperName As String
                    Dim boundExpr As Integer
                    boundExpr = MIRChildAt(ps, boundsNode, 0)
                    If boundExpr = -1 Then
                        errText = "mir: DIM bound missing"
                        Return 0
                    End If
                    If UCase(ps.ast.nodes(boundExpr).kind) = "RANGE_EXPR" Then
                        If MIRLowerExprNode(ps, ps.ast.nodes(boundExpr).left, module, fnIdx, blkIdx, tempSeed, lowerName, errText) = 0 Then Return 0
                        If MIRLowerExprNode(ps, ps.ast.nodes(boundExpr).right, module, fnIdx, blkIdx, tempSeed, upperName, errText) = 0 Then Return 0
                    Else
                        Dim zeroName As String
                        zeroName = MIRNextTemp(tempSeed)
                        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, zeroName, 1, "0"
                        lowerName = zeroName
                        If MIRLowerExprNode(ps, boundExpr, module, fnIdx, blkIdx, tempSeed, upperName, errText) = 0 Then Return 0
                    End If
                    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_DIM, "", 3, varName, lowerName, upperName
                    MIRRegisterArrayGlobal module, varName
                Else
                    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_DIM, "", 3, varName, "0", "-1"
                End If

                Dim initExprNode As Integer
                initExprNode = MIRFindChildByKind(ps, ch, "INIT_EXPR")
                If initExprNode <> -1 Then
                    If ps.ast.nodes(initExprNode).left <> -1 Then
                        Dim initValueName As String
                        If MIRLowerExprNode(ps, ps.ast.nodes(initExprNode).left, module, fnIdx, blkIdx, tempSeed, initValueName, errText) = 0 Then Return 0
                        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, varName, 1, initValueName
                    End If
                End If
            End If
            ch = ps.ast.nodes(ch).nextSibling
        Loop
        Return 1

    Case "REDIM_STMT"
        Dim preserveFlag As String
        preserveFlag = IIf(UCase(Trim(st.op)) = "PRESERVE", "1", "0")
        Dim ch2 As Integer
        ch2 = st.firstChild
        Do While ch2 <> -1
            If UCase(ps.ast.nodes(ch2).kind) = "REDIM_DECL" Then
                Dim varName2 As String
                varName2 = ps.ast.nodes(ch2).value
                Dim boundsNode2 As Integer
                boundsNode2 = MIRFindChildByKind(ps, ch2, "DIM_BOUNDS")
                If boundsNode2 = -1 Or MIRChildCount(ps, boundsNode2) <> 1 Then
                    errText = "mir: REDIM requires single-dimension bounds"
                    Return 0
                End If
                Dim boundExpr2 As Integer
                Dim lowerName2 As String
                Dim upperName2 As String
                boundExpr2 = MIRChildAt(ps, boundsNode2, 0)
                If boundExpr2 = -1 Then
                    errText = "mir: REDIM bound missing"
                    Return 0
                End If
                If UCase(ps.ast.nodes(boundExpr2).kind) = "RANGE_EXPR" Then
                    If MIRLowerExprNode(ps, ps.ast.nodes(boundExpr2).left, module, fnIdx, blkIdx, tempSeed, lowerName2, errText) = 0 Then Return 0
                    If MIRLowerExprNode(ps, ps.ast.nodes(boundExpr2).right, module, fnIdx, blkIdx, tempSeed, upperName2, errText) = 0 Then Return 0
                Else
                    Dim zeroName2 As String
                    zeroName2 = MIRNextTemp(tempSeed)
                    MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, zeroName2, 1, "0"
                    lowerName2 = zeroName2
                    If MIRLowerExprNode(ps, boundExpr2, module, fnIdx, blkIdx, tempSeed, upperName2, errText) = 0 Then Return 0
                End If
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_REDIM, "", 4, varName2, lowerName2, upperName2, preserveFlag
                MIRRegisterArrayGlobal module, varName2
            End If
            ch2 = ps.ast.nodes(ch2).nextSibling
        Loop
        Return 1

    Case "CONST_STMT"
        Dim ch3 As Integer
        ch3 = st.firstChild
        Do While ch3 <> -1
            If UCase(ps.ast.nodes(ch3).kind) = "CONST_DECL" Then
                Dim cName As String
                cName = ps.ast.nodes(ch3).value
                Dim cExprName As String
                If MIRLowerExprNode(ps, ps.ast.nodes(ch3).left, module, fnIdx, blkIdx, tempSeed, cExprName, errText) = 0 Then Return 0
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, cName, 1, cExprName
            End If
            ch3 = ps.ast.nodes(ch3).nextSibling
        Loop
        Return 1

    Case "EXPR_STMT"
        If st.left <> -1 Then
            Dim sinkName As String
            If MIRLowerExprNode(ps, st.left, module, fnIdx, blkIdx, tempSeed, sinkName, errText) = 0 Then Return 0
            If UCase(ps.ast.nodes(st.left).kind) = "CALL_EXPR" Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, "__result__", 1, sinkName
            End If
        End If
        Return 1

    Case "PRINT_STMT"
        Dim printCount As Integer
        printCount = MIRChildCount(ps, stmtIdx)

        If printCount = 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "PRINTLN"
            Return 1
        End If

        Dim trailingSep As String
        trailingSep = ""

        Dim pp As Integer
        For pp = 0 To printCount - 1
            Dim pItem As Integer
            Dim pExpr As Integer
            pItem = MIRChildAt(ps, stmtIdx, pp)
            If pItem = -1 Then
                errText = "mir: PRINT item missing"
                Return 0
            End If

            trailingSep = ""
            If UCase(ps.ast.nodes(pItem).kind) = "PRINT_ITEM" Then
                pExpr = ps.ast.nodes(pItem).left
                trailingSep = ps.ast.nodes(pItem).op
            Else
                pExpr = pItem
                If pp < printCount - 1 Then trailingSep = " "
            End If

            If pExpr = -1 Then
                errText = "mir: PRINT expression missing"
                Return 0
            End If

            Dim pName As String
            If MIRLowerExprNode(ps, pExpr, module, fnIdx, blkIdx, tempSeed, pName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 2, "PRINT", pName

            If trailingSep = "," Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "PRINT_SEP_COMMA"
            ElseIf trailingSep = " " Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "PRINT_SEP_SPACE"
            End If
        Next pp

        If trailingSep <> ";" And trailingSep <> "," Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "PRINTLN"
        End If
        Return 1

    Case "CLS_STMT"
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "CLS"
        Return 1

    Case "LOCATE_STMT"
        If MIRChildCount(ps, stmtIdx) <> 2 Then
            errText = "mir: LOCATE iki arguman ister"
            Return 0
        End If

        Dim locateRowName As String
        Dim locateColName As String
        If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 0), module, fnIdx, blkIdx, tempSeed, locateRowName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, locateColName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, "LOCATE", locateRowName, locateColName
        Return 1

    Case "COLOR_STMT"
        If MIRChildCount(ps, stmtIdx) <> 2 Then
            errText = "mir: COLOR iki arguman ister"
            Return 0
        End If

        Dim colorFgName As String
        Dim colorBgName As String
        If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 0), module, fnIdx, blkIdx, tempSeed, colorFgName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, colorBgName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, "COLOR", colorFgName, colorBgName
        Return 1

    Case "RANDOMIZE_STMT"
        If MIRChildCount(ps, stmtIdx) = 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "RANDOMIZE"
            Return 1
        End If

        Dim randomSeedName As String
        If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 0), module, fnIdx, blkIdx, tempSeed, randomSeedName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 2, "RANDOMIZE", randomSeedName
        Return 1

    Case "INPUT_STMT"
        Dim inputCount As Integer
        inputCount = MIRChildCount(ps, stmtIdx)
        If inputCount < 1 Then
            errText = "mir: INPUT target missing"
            Return 0
        End If

        Dim inputStartPos As Integer
        inputStartPos = 0
        Dim firstInputChild As Integer
        firstInputChild = MIRChildAt(ps, stmtIdx, 0)
        If firstInputChild <> -1 And UCase(ps.ast.nodes(firstInputChild).kind) = "PROMPT_EXPR" Then
            Dim promptExpr As Integer
            promptExpr = ps.ast.nodes(firstInputChild).left
            If promptExpr = -1 Then promptExpr = MIRChildAt(ps, firstInputChild, 0)
            If promptExpr = -1 Then
                errText = "mir: INPUT prompt missing"
                Return 0
            End If

            Dim promptName As String
            If MIRLowerExprNode(ps, promptExpr, module, fnIdx, blkIdx, tempSeed, promptName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 2, "PRINT", promptName
            inputStartPos = 1
        End If

        If inputStartPos >= inputCount Then
            errText = "mir: INPUT target missing"
            Return 0
        End If

        Dim inputPos As Integer
        For inputPos = inputStartPos To inputCount - 1
            Dim inputTarget As Integer
            inputTarget = MIRChildAt(ps, stmtIdx, inputPos)
            If inputTarget = -1 Or UCase(ps.ast.nodes(inputTarget).kind) <> "IDENT" Then
                errText = "mir: INPUT target must be IDENT"
                Return 0
            End If

            Dim inputValueTemp As String
            inputValueTemp = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, inputValueTemp, 1, "INPUT"
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, ps.ast.nodes(inputTarget).value, 1, inputValueTemp
        Next inputPos
        Return 1

    Case "INPUT_FILE_STMT"
        Dim inputFileCount As Integer
        inputFileCount = MIRChildCount(ps, stmtIdx)
        If inputFileCount < 2 Then
            errText = "mir: INPUT# handle/target missing"
            Return 0
        End If

        Dim inputHandleExpr As Integer
        inputHandleExpr = MIRChildAt(ps, stmtIdx, 0)
        If inputHandleExpr = -1 Then
            errText = "mir: INPUT# handle missing"
            Return 0
        End If

        Dim inputHandleName As String
        If MIRLowerExprNode(ps, inputHandleExpr, module, fnIdx, blkIdx, tempSeed, inputHandleName, errText) = 0 Then Return 0

        Dim inputFilePos As Integer
        For inputFilePos = 1 To inputFileCount - 1
            Dim inputFileTarget As Integer
            inputFileTarget = MIRChildAt(ps, stmtIdx, inputFilePos)
            If inputFileTarget = -1 Or UCase(ps.ast.nodes(inputFileTarget).kind) <> "IDENT" Then
                errText = "mir: INPUT# target must be IDENT"
                Return 0
            End If

            Dim inputFileTemp As String
            inputFileTemp = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, inputFileTemp, 2, "INPUTF", inputHandleName
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, ps.ast.nodes(inputFileTarget).value, 1, inputFileTemp
        Next inputFilePos
        Return 1

    Case "OPEN_STMT"
        Dim openCount As Integer
        openCount = MIRChildCount(ps, stmtIdx)
        If openCount < 3 Or openCount > 4 Then
            errText = "mir: OPEN argument count invalid"
            Return 0
        End If

        Dim openFileExpr As Integer
        Dim openModeExpr As Integer
        Dim openHandleExpr As Integer
        openFileExpr = MIRChildAt(ps, stmtIdx, 0)
        openModeExpr = MIRChildAt(ps, stmtIdx, 1)
        openHandleExpr = MIRChildAt(ps, stmtIdx, 2)
        If openFileExpr = -1 Or openModeExpr = -1 Or openHandleExpr = -1 Then
            errText = "mir: OPEN args missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(openModeExpr).kind) <> "MODE_REF" Then
            errText = "mir: OPEN mode node invalid"
            Return 0
        End If

        Dim openFileName As String
        Dim openHandleName As String
        If MIRLowerExprNode(ps, openFileExpr, module, fnIdx, blkIdx, tempSeed, openFileName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, openHandleExpr, module, fnIdx, blkIdx, tempSeed, openHandleName, errText) = 0 Then Return 0

        Dim openModeConst As String
        openModeConst = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, openModeConst, 1, Chr(34) & ps.ast.nodes(openModeExpr).value & Chr(34)

        If openCount = 3 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 4, "OPEN", openFileName, openModeConst, openHandleName
        Else
            Dim openLenExpr As Integer
            Dim openLenName As String
            openLenExpr = MIRChildAt(ps, stmtIdx, 3)
            If openLenExpr = -1 Then
                errText = "mir: OPEN LEN arg missing"
                Return 0
            End If
            If MIRLowerExprNode(ps, openLenExpr, module, fnIdx, blkIdx, tempSeed, openLenName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 5, "OPEN", openFileName, openModeConst, openHandleName, openLenName
        End If
        Return 1

    Case "CLOSE_STMT"
        Dim closeCount As Integer
        closeCount = MIRChildCount(ps, stmtIdx)

        If closeCount = 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 1, "CLOSE"
            Return 1
        End If

        Dim closePos As Integer
        For closePos = 0 To closeCount - 1
            Dim closeHandleExpr As Integer
            Dim closeHandleName As String
            closeHandleExpr = MIRChildAt(ps, stmtIdx, closePos)
            If closeHandleExpr = -1 Then
                errText = "mir: CLOSE handle missing"
                Return 0
            End If
            If MIRLowerExprNode(ps, closeHandleExpr, module, fnIdx, blkIdx, tempSeed, closeHandleName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 2, "CLOSE", closeHandleName
        Next closePos
        Return 1

    Case "GET_STMT"
        Dim getCount As Integer
        getCount = MIRChildCount(ps, stmtIdx)
        If getCount < 2 Or getCount > 4 Then
            errText = "mir: GET argument count invalid"
            Return 0
        End If

        Dim getHandleExpr As Integer
        getHandleExpr = MIRChildAt(ps, stmtIdx, 0)
        If getHandleExpr = -1 Then
            errText = "mir: GET handle missing"
            Return 0
        End If

        Dim getHandleName As String
        If MIRLowerExprNode(ps, getHandleExpr, module, fnIdx, blkIdx, tempSeed, getHandleName, errText) = 0 Then Return 0

        Dim getTargetExpr As Integer
        If getCount = 2 Then
            getTargetExpr = MIRChildAt(ps, stmtIdx, 1)
        ElseIf getCount = 3 Then
            getTargetExpr = MIRChildAt(ps, stmtIdx, 2)
        Else
            getTargetExpr = MIRChildAt(ps, stmtIdx, 3)
        End If

        If getTargetExpr = -1 Or UCase(ps.ast.nodes(getTargetExpr).kind) <> "IDENT" Then
            errText = "mir: GET target must be IDENT"
            Return 0
        End If

        Dim getResultTemp As String
        getResultTemp = MIRNextTemp(tempSeed)

        If getCount = 2 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, getResultTemp, 2, "GET", getHandleName
        ElseIf getCount = 3 Then
            Dim getPositionName As String
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, getPositionName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, getResultTemp, 3, "GET", getHandleName, getPositionName
        Else
            Dim getPositionName As String
            Dim getBytesName As String
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, getPositionName, errText) = 0 Then Return 0
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 2), module, fnIdx, blkIdx, tempSeed, getBytesName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, getResultTemp, 4, "GET", getHandleName, getPositionName, getBytesName
        End If

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, ps.ast.nodes(getTargetExpr).value, 1, getResultTemp
        Return 1

    Case "PUT_STMT"
        Dim putCount As Integer
        putCount = MIRChildCount(ps, stmtIdx)
        If putCount < 2 Or putCount > 4 Then
            errText = "mir: PUT argument count invalid"
            Return 0
        End If

        Dim putHandleExpr As Integer
        putHandleExpr = MIRChildAt(ps, stmtIdx, 0)
        If putHandleExpr = -1 Then
            errText = "mir: PUT handle missing"
            Return 0
        End If

        Dim putHandleName As String
        If MIRLowerExprNode(ps, putHandleExpr, module, fnIdx, blkIdx, tempSeed, putHandleName, errText) = 0 Then Return 0

        If putCount = 2 Then
            Dim putSourceName As String
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, putSourceName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, "PUT", putHandleName, putSourceName
        ElseIf putCount = 3 Then
            Dim putPositionName As String
            Dim putSourceName As String
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, putPositionName, errText) = 0 Then Return 0
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 2), module, fnIdx, blkIdx, tempSeed, putSourceName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 4, "PUT", putHandleName, putPositionName, putSourceName
        Else
            Dim putPositionName As String
            Dim putBytesName As String
            Dim putSourceName As String
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, putPositionName, errText) = 0 Then Return 0
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 2), module, fnIdx, blkIdx, tempSeed, putBytesName, errText) = 0 Then Return 0
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 3), module, fnIdx, blkIdx, tempSeed, putSourceName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 5, "PUT", putHandleName, putPositionName, putBytesName, putSourceName
        End If
        Return 1

    Case "SEEK_STMT"
        Dim seekCount As Integer
        seekCount = MIRChildCount(ps, stmtIdx)
        If seekCount < 1 Or seekCount > 2 Then
            errText = "mir: SEEK argument count invalid"
            Return 0
        End If

        Dim seekHandleName As String
        If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 0), module, fnIdx, blkIdx, tempSeed, seekHandleName, errText) = 0 Then Return 0

        If seekCount = 1 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 2, "SEEK", seekHandleName
        Else
            Dim seekPositionName As String
            If MIRLowerExprNode(ps, MIRChildAt(ps, stmtIdx, 1), module, fnIdx, blkIdx, tempSeed, seekPositionName, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, "SEEK", seekHandleName, seekPositionName
        End If
        Return 1

    Case "POKES_STMT"
        If MIRChildCount(ps, stmtIdx) <> 2 Then
            errText = "mir: POKES expects address,text"
            Return 0
        End If

        Dim pokeSAddrExpr As Integer
        Dim pokeSTextExpr As Integer
        Dim pokeSAddrName As String
        Dim pokeSTextName As String
        pokeSAddrExpr = MIRChildAt(ps, stmtIdx, 0)
        pokeSTextExpr = MIRChildAt(ps, stmtIdx, 1)
        If pokeSAddrExpr = -1 Or pokeSTextExpr = -1 Then
            errText = "mir: POKES arguments missing"
            Return 0
        End If
        If MIRLowerExprNode(ps, pokeSAddrExpr, module, fnIdx, blkIdx, tempSeed, pokeSAddrName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, pokeSTextExpr, module, fnIdx, blkIdx, tempSeed, pokeSTextName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, "POKES", pokeSAddrName, pokeSTextName
        Return 1

    Case "MEMCOPYB_STMT", "MEMCOPYW_STMT", "MEMCOPYD_STMT"
        If MIRChildCount(ps, stmtIdx) <> 3 Then
            errText = "mir: " & k & " expects src,dst,length"
            Return 0
        End If

        Dim memCopySrcExpr As Integer
        Dim memCopyDstExpr As Integer
        Dim memCopyLenExpr As Integer
        Dim memCopySrcName As String
        Dim memCopyDstName As String
        Dim memCopyLenName As String
        memCopySrcExpr = MIRChildAt(ps, stmtIdx, 0)
        memCopyDstExpr = MIRChildAt(ps, stmtIdx, 1)
        memCopyLenExpr = MIRChildAt(ps, stmtIdx, 2)
        If memCopySrcExpr = -1 Or memCopyDstExpr = -1 Or memCopyLenExpr = -1 Then
            errText = "mir: " & k & " arguments missing"
            Return 0
        End If
        If MIRLowerExprNode(ps, memCopySrcExpr, module, fnIdx, blkIdx, tempSeed, memCopySrcName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, memCopyDstExpr, module, fnIdx, blkIdx, tempSeed, memCopyDstName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, memCopyLenExpr, module, fnIdx, blkIdx, tempSeed, memCopyLenName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 4, Left(k, 8), memCopySrcName, memCopyDstName, memCopyLenName
        Return 1

    Case "MEMFILLB_STMT", "MEMFILLW_STMT", "MEMFILLD_STMT"
        If MIRChildCount(ps, stmtIdx) <> 3 Then
            errText = "mir: " & k & " expects address,value,length"
            Return 0
        End If

        Dim memFillAddrExpr As Integer
        Dim memFillValExpr As Integer
        Dim memFillLenExpr As Integer
        Dim memFillAddrName As String
        Dim memFillValName As String
        Dim memFillLenName As String
        memFillAddrExpr = MIRChildAt(ps, stmtIdx, 0)
        memFillValExpr = MIRChildAt(ps, stmtIdx, 1)
        memFillLenExpr = MIRChildAt(ps, stmtIdx, 2)
        If memFillAddrExpr = -1 Or memFillValExpr = -1 Or memFillLenExpr = -1 Then
            errText = "mir: " & k & " arguments missing"
            Return 0
        End If
        If MIRLowerExprNode(ps, memFillAddrExpr, module, fnIdx, blkIdx, tempSeed, memFillAddrName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, memFillValExpr, module, fnIdx, blkIdx, tempSeed, memFillValName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, memFillLenExpr, module, fnIdx, blkIdx, tempSeed, memFillLenName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 4, Left(k, 8), memFillAddrName, memFillValName, memFillLenName
        Return 1

    Case "SETNEWOFFSET_STMT"
        If MIRChildCount(ps, stmtIdx) <> 2 Then
            errText = "mir: SETNEWOFFSET expects ident,address"
            Return 0
        End If

        Dim setOffsetTargetExpr As Integer
        Dim setOffsetAddrExpr As Integer
        Dim setOffsetAddrName As String
        setOffsetTargetExpr = MIRChildAt(ps, stmtIdx, 0)
        setOffsetAddrExpr = MIRChildAt(ps, stmtIdx, 1)

        If setOffsetTargetExpr = -1 Or setOffsetAddrExpr = -1 Then
            errText = "mir: SETNEWOFFSET arguments missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(setOffsetTargetExpr).kind) <> "IDENT" Then
            errText = "mir: SETNEWOFFSET target must be ident"
            Return 0
        End If

        If MIRLowerExprNode(ps, setOffsetAddrExpr, module, fnIdx, blkIdx, tempSeed, setOffsetAddrName, errText) = 0 Then Return 0

        Dim setOffsetNameConst As String
        setOffsetNameConst = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, setOffsetNameConst, 1, Chr(34) & ps.ast.nodes(setOffsetTargetExpr).value & Chr(34)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, "SETNEWOFFSET", setOffsetNameConst, setOffsetAddrName
        Return 1

    Case "POKEB_STMT", "POKEW_STMT", "POKED_STMT"
        If MIRChildCount(ps, stmtIdx) <> 2 Then
            errText = "mir: " & k & " expects address,value"
            Return 0
        End If

        Dim pokeAddrExpr As Integer
        Dim pokeValExpr As Integer
        Dim pokeAddrName As String
        Dim pokeValName As String
        pokeAddrExpr = MIRChildAt(ps, stmtIdx, 0)
        pokeValExpr = MIRChildAt(ps, stmtIdx, 1)
        If pokeAddrExpr = -1 Or pokeValExpr = -1 Then
            errText = "mir: " & k & " arguments missing"
            Return 0
        End If
        If MIRLowerExprNode(ps, pokeAddrExpr, module, fnIdx, blkIdx, tempSeed, pokeAddrName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, pokeValExpr, module, fnIdx, blkIdx, tempSeed, pokeValName, errText) = 0 Then Return 0
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 3, Left(k, 5), pokeAddrName, pokeValName
        Return 1

    Case "EVENT_STMT", "THREAD_STMT", "PARALEL_STMT", "PIPE_STMT", "SLOT_STMT", "SLOT_CONTROL_STMT", "TRIGGER_STMT"
        Return 1

    Case "INCDEC_STMT"
        If st.left = -1 Then
            errText = "mir: INCDEC target missing"
            Return 0
        End If

        Dim incTarget As String
        Dim incTmp As String
        Dim incOne As String
        Dim incSource As String
        Dim incIndexName As String
        Dim incIndexed As Integer
        incIndexed = 0

        If UCase(ps.ast.nodes(st.left).kind) = "IDENT" Then
            incTarget = ps.ast.nodes(st.left).value
            incSource = incTarget
        ElseIf UCase(ps.ast.nodes(st.left).kind) = "FIELD_EXPR" Then
            If MIRBuildFieldPath(ps, st.left, incTarget, errText) = 0 Then Return 0
            incSource = incTarget
        ElseIf UCase(ps.ast.nodes(st.left).kind) = "CALL_EXPR" And InStr(ps.ast.nodes(st.left).value, ".") = 0 And MIRIsKnownArray(module, ps.ast.nodes(st.left).value) <> 0 And MIRChildCount(ps, st.left) = 1 Then
            incTarget = ps.ast.nodes(st.left).value
            If MIRLowerExprNode(ps, MIRChildAt(ps, st.left, 0), module, fnIdx, blkIdx, tempSeed, incIndexName, errText) = 0 Then Return 0
            incSource = MIRNextTemp(tempSeed)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_INDEXED, incSource, 2, incTarget, incIndexName
            incIndexed = 1
        Else
            errText = "mir: INCDEC target must be ident, field, or indexed array"
            Return 0
        End If

        incTmp = MIRNextTemp(tempSeed)
        incOne = MIRNextTemp(tempSeed)
        Dim incKind As Integer
        incKind = MIRInferExprFloatKind(ps, st.left)
        If incKind = MIR_UXF_F80 Then
            errText = "mir: F80 arithmetic not supported"
            Return 0
        End If
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, incOne, 1, IIf(incKind <> MIR_UXF_UNKNOWN, "1.0", "1")

        If Trim(st.op) = "--" Then
            MIRAppendInstruction module, fnIdx, blkIdx, IIf(incKind <> MIR_UXF_UNKNOWN, MIR_OP_FSUB, MIR_OP_SUB), incTmp, 2, incSource, incOne
        Else
            MIRAppendInstruction module, fnIdx, blkIdx, IIf(incKind <> MIR_UXF_UNKNOWN, MIR_OP_FADD, MIR_OP_ADD), incTmp, 2, incSource, incOne
        End If

        If incIndexed <> 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_INDEXED, "", 3, incTarget, incIndexName, incTmp
        Else
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, incTarget, 1, incTmp
        End If
        Return 1

    Case "CALL_STMT"
        Dim stmtCallName As String
        Dim skipFirstStmtCallChild As Integer
        Dim injectStmtReceiver As Integer
        Dim stmtReceiverVar As String
        stmtCallName = UCase(Trim(st.value))
        skipFirstStmtCallChild = 0
        injectStmtReceiver = 0
        stmtReceiverVar = ""

        If InStr(stmtCallName, ".") > 0 Then
            Dim loweredStmtCallName As String
            If MIRResolveMethodCallRoute(ps, stmtIdx, stmtCallName, loweredStmtCallName, injectStmtReceiver, stmtReceiverVar) <> 0 Then
                stmtCallName = loweredStmtCallName
            End If
        End If

        If stmtCallName = "CALL" And st.firstChild <> -1 Then
            Dim stmtMarkerKind As String
            Dim stmtMarkerValue As String
            stmtMarkerKind = UCase(Trim(ps.ast.nodes(st.firstChild).kind))
            stmtMarkerValue = UCase(Trim(ps.ast.nodes(st.firstChild).value))
            If (stmtMarkerKind = "IDENT" Or stmtMarkerKind = "KEYWORD_REF") And stmtMarkerValue = "DLL" Then
                stmtCallName = "DLL"
                skipFirstStmtCallChild = 1
            End If
        End If

        Dim argCount As Integer
        argCount = MIRChildCount(ps, stmtIdx)
        If skipFirstStmtCallChild <> 0 And argCount > 0 Then argCount -= 1
        If injectStmtReceiver <> 0 Then argCount += 1

        Dim c1 As String, c2 As String, c3 As String, c4 As String, c5 As String, c6 As String, c7 As String, c8 As String
        c1 = stmtCallName
        Dim cPos As Integer
        Dim cSlot As Integer
        cSlot = 2

        If injectStmtReceiver <> 0 Then
            c2 = stmtReceiverVar
            cSlot = 3
        End If

        Dim rawArgCount As Integer
        rawArgCount = MIRChildCount(ps, stmtIdx)
        For cPos = 0 To rawArgCount - 1
            If skipFirstStmtCallChild <> 0 And cPos = 0 Then Continue For
            Dim cArgNode As Integer
            cArgNode = MIRChildAt(ps, stmtIdx, cPos)
            If cArgNode = -1 Then
                errText = "mir: CALL argument missing"
                Return 0
            End If

            Dim cArgName As String
            If MIRLowerExprNode(ps, cArgNode, module, fnIdx, blkIdx, tempSeed, cArgName, errText) = 0 Then Return 0

            Select Case cSlot
            Case 2: c2 = cArgName
            Case 3: c3 = cArgName
            Case 4: c4 = cArgName
            Case 5: c5 = cArgName
            Case 6: c6 = cArgName
            Case 7: c7 = cArgName
            Case 8: c8 = cArgName
            Case Else
                errText = "mir: CALL arguman sayisi limiti asildi"
                Return 0
            End Select
            cSlot += 1
        Next cPos

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", argCount + 1, c1, c2, c3, c4, c5, c6, c7, c8
        Return 1

    Case "DELETE_STMT"
        If st.left = -1 Then
            errText = "mir: DELETE target missing"
            Return 0
        End If

        Dim deleteVarName As String
        If MIRLowerExprNode(ps, st.left, module, fnIdx, blkIdx, tempSeed, deleteVarName, errText) = 0 Then Return 0

        Dim deleteClassType As String
        If MIRFindNearestDimDeclType(ps, stmtIdx, deleteVarName, deleteClassType) <> 0 Then
            Dim deleteDtorName As String
            deleteDtorName = deleteClassType & "_DTOR"
            If MIRClassHasDestructorDecl(ps, deleteClassType) <> 0 Or MIRHasRoutineNamed(ps, deleteDtorName) <> 0 Then
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_CALL, "", 2, deleteDtorName, deleteVarName
            End If
        End If

        Dim deleteZeroName As String
        deleteZeroName = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, deleteZeroName, 1, "0"
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, deleteVarName, 1, deleteZeroName
        Return 1

    Case "RETURN_STMT"
        Dim retValueName As String
        Dim retExprNode As Integer
        retExprNode = MIRChildAt(ps, stmtIdx, 0)
        If retExprNode = -1 Then
            retValueName = "__result__"
        Else
            If MIRLowerExprNode(ps, retExprNode, module, fnIdx, blkIdx, tempSeed, retValueName, errText) = 0 Then Return 0
        End If

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_RET, "", 1, retValueName
        Return 1

    Case "END_STMT"
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_RET, "", 1, "__result__"
        Return 1

    Case "EXIT_STMT"
        Dim exitBreakBlock As Integer
        Dim exitContBlock As Integer
        Dim exitWantType As String
        exitWantType = UCase(Trim(st.op))

        If exitWantType = "IF" Then
            Dim exitIfEndBlock As Integer
            If MIRCurrentIfExitTarget(exitIfEndBlock) = 0 Then
                errText = "mir: EXIT IF used outside IF block"
                Return 0
            End If
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(exitIfEndBlock))
            Return 1
        End If
        If exitWantType <> "FOR" And exitWantType <> "DO" Then exitWantType = ""

        If MIRFindLoopContext(exitWantType, exitBreakBlock, exitContBlock) = 0 Then
            errText = "mir: EXIT icin uygun loop context yok"
            Return 0
        End If

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(exitBreakBlock))
        Return 1

    Case "THROW_STMT"
        Dim throwExprIdx As Integer
        throwExprIdx = MIRChildAt(ps, stmtIdx, 0)
        If throwExprIdx = -1 Then
            errText = "mir: THROW expression missing"
            Return 0
        End If

        Dim throwName As String
        If MIRLowerExprNode(ps, throwExprIdx, module, fnIdx, blkIdx, tempSeed, throwName, errText) = 0 Then Return 0

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, "__mir_exc_value", 1, throwName
        MIRMarkExceptionActive module, fnIdx, blkIdx, tempSeed

        Dim throwTarget As Integer
        If MIRCurrentTryTarget(throwTarget) <> 0 Then
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(throwTarget))
            Return 1
        End If

        errText = "mir: THROW TRY disinda desteklenmiyor"
        Return 0

    Case "ASSERT_STMT"
        Dim asCondIdx As Integer
        asCondIdx = MIRChildAt(ps, stmtIdx, 0)
        If asCondIdx = -1 Then
            errText = "mir: ASSERT condition missing"
            Return 0
        End If

        Dim asCondName As String
        Dim asCondBool As String
        If MIRLowerExprNode(ps, asCondIdx, module, fnIdx, blkIdx, tempSeed, asCondName, errText) = 0 Then Return 0
        MIREnsureBoolVar module, fnIdx, blkIdx, tempSeed, asCondName, asCondBool

        Dim asOkBlock As Integer
        Dim asFailBlock As Integer
        asOkBlock = MIRAllocBlock(module, fnIdx)
        asFailBlock = MIRAllocBlock(module, fnIdx)

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JZ, "", 2, asCondBool, LTrim(Str(asFailBlock))
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(asOkBlock))

        Dim asFailCur As Integer
        asFailCur = asFailBlock
        If MIRChildCount(ps, stmtIdx) >= 2 Then
            Dim asMsgIdx As Integer
            Dim asMsgName As String
            asMsgIdx = MIRChildAt(ps, stmtIdx, 1)
            If asMsgIdx <> -1 Then
                If MIRLowerExprNode(ps, asMsgIdx, module, fnIdx, asFailCur, tempSeed, asMsgName, errText) = 0 Then Return 0
                MIRAppendInstruction module, fnIdx, asFailCur, MIR_OP_STORE_VAR, "__mir_exc_value", 1, asMsgName
            End If
        End If
        MIRMarkExceptionActive module, fnIdx, asFailCur, tempSeed

        Dim asTarget As Integer
        If MIRCurrentTryTarget(asTarget) <> 0 Then
            MIRAppendInstruction module, fnIdx, asFailCur, MIR_OP_JMP, "", 1, LTrim(Str(asTarget))
        Else
            errText = "mir: ASSERT TRY disinda desteklenmiyor"
            Return 0
        End If

        blkIdx = asOkBlock
        Return 1

    Case "DO_STMT"
        Dim doModeText As String
        Dim doChildCnt As Integer
        Dim doHasPre As Integer
        Dim doHasPost As Integer
        Dim doPrePos As Integer
        Dim doPostPos As Integer
        Dim doBodyStart As Integer
        Dim doBodyEnd As Integer

        doModeText = UCase(Trim(st.op))
        doChildCnt = MIRChildCount(ps, stmtIdx)
        doHasPre = IIf(doModeText = "DO_WHILE" Or doModeText = "DO_UNTIL", 1, 0)
        doHasPost = IIf(doModeText = "LOOP_WHILE" Or doModeText = "LOOP_UNTIL", 1, 0)
        doPrePos = IIf(doHasPre <> 0, 0, -1)
        doPostPos = IIf(doHasPost <> 0, doChildCnt - 1, -1)
        doBodyStart = IIf(doHasPre <> 0, 1, 0)
        doBodyEnd = IIf(doHasPost <> 0, doChildCnt - 2, doChildCnt - 1)

        Dim doCondBlock As Integer
        Dim doBodyBlock As Integer
        Dim doPostBlock As Integer
        Dim doEndBlock As Integer

        doCondBlock = MIRAllocBlock(module, fnIdx)
        doBodyBlock = MIRAllocBlock(module, fnIdx)
        doPostBlock = MIRAllocBlock(module, fnIdx)
        doEndBlock = MIRAllocBlock(module, fnIdx)

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(doCondBlock))

        If doHasPre <> 0 Then
            Dim doPreExpr As Integer
            Dim doPreName As String
            Dim doPreBool As String
            doPreExpr = MIRChildAt(ps, stmtIdx, doPrePos)
            If doPreExpr = -1 Then
                errText = "mir: DO pre-condition missing"
                Return 0
            End If
            If MIRLowerExprNode(ps, doPreExpr, module, fnIdx, doCondBlock, tempSeed, doPreName, errText) = 0 Then Return 0
            MIREnsureBoolVar module, fnIdx, doCondBlock, tempSeed, doPreName, doPreBool

            If doModeText = "DO_WHILE" Then
                MIRAppendInstruction module, fnIdx, doCondBlock, MIR_OP_JZ, "", 2, doPreBool, LTrim(Str(doEndBlock))
            Else
                MIRAppendInstruction module, fnIdx, doCondBlock, MIR_OP_JNZ, "", 2, doPreBool, LTrim(Str(doEndBlock))
            End If
            MIRAppendInstruction module, fnIdx, doCondBlock, MIR_OP_JMP, "", 1, LTrim(Str(doBodyBlock))
        Else
            MIRAppendInstruction module, fnIdx, doCondBlock, MIR_OP_JMP, "", 1, LTrim(Str(doBodyBlock))
        End If

        MIRPushLoopContext "DO", doEndBlock, IIf(doHasPost <> 0, doPostBlock, doCondBlock)

        Dim doBodyCur As Integer
        doBodyCur = doBodyBlock
        If doBodyEnd >= doBodyStart Then
            If MIRLowerStmtRange(ps, stmtIdx, doBodyStart, doBodyEnd, module, fnIdx, doBodyCur, tempSeed, errText) = 0 Then
                MIRPopLoopContext
                Return 0
            End If
        End If
        MIRAppendInstruction module, fnIdx, doBodyCur, MIR_OP_JMP, "", 1, LTrim(Str(doPostBlock))

        If doHasPost <> 0 Then
            Dim doPostExpr As Integer
            Dim doPostName As String
            Dim doPostBool As String
            doPostExpr = MIRChildAt(ps, stmtIdx, doPostPos)
            If doPostExpr = -1 Then
                MIRPopLoopContext
                errText = "mir: LOOP post-condition missing"
                Return 0
            End If
            If MIRLowerExprNode(ps, doPostExpr, module, fnIdx, doPostBlock, tempSeed, doPostName, errText) = 0 Then
                MIRPopLoopContext
                Return 0
            End If
            MIREnsureBoolVar module, fnIdx, doPostBlock, tempSeed, doPostName, doPostBool

            If doModeText = "LOOP_WHILE" Then
                MIRAppendInstruction module, fnIdx, doPostBlock, MIR_OP_JZ, "", 2, doPostBool, LTrim(Str(doEndBlock))
            Else
                MIRAppendInstruction module, fnIdx, doPostBlock, MIR_OP_JNZ, "", 2, doPostBool, LTrim(Str(doEndBlock))
            End If
            MIRAppendInstruction module, fnIdx, doPostBlock, MIR_OP_JMP, "", 1, LTrim(Str(doCondBlock))
        Else
            MIRAppendInstruction module, fnIdx, doPostBlock, MIR_OP_JMP, "", 1, LTrim(Str(doCondBlock))
        End If

        MIRPopLoopContext
        blkIdx = doEndBlock
        Return 1

    Case "FOR_EACH_STMT", "DO_EACH_STMT"
        Dim eachItemsNode As Integer
        Dim eachBodyNode As Integer
        Dim eachItemsCount As Integer
        Dim eachItemPos As Integer
        Dim eachBodyCount As Integer
        Dim eachBodyPos As Integer
        Dim eachBreakBlock As Integer
        Dim eachAfterBodyBlock As Integer

        eachItemsNode = MIRChildAt(ps, stmtIdx, 0)
        eachBodyNode = MIRChildAt(ps, stmtIdx, 1)
        If eachItemsNode = -1 Or eachBodyNode = -1 Then
            errText = "mir: EACH items/body missing"
            Return 0
        End If

        eachItemsCount = MIRChildCount(ps, eachItemsNode)
        eachBodyCount = MIRChildCount(ps, eachBodyNode)
        eachBreakBlock = MIRAllocBlock(module, fnIdx)

        MIRPushLoopContext IIf(UCase(st.kind) = "FOR_EACH_STMT", "FOR", "DO"), eachBreakBlock, eachBreakBlock

        For eachItemPos = 0 To eachItemsCount - 1
            Dim eachExprNode As Integer
            Dim eachExprName As String
            eachExprNode = MIRChildAt(ps, eachItemsNode, eachItemPos)
            If eachExprNode = -1 Then
                MIRPopLoopContext
                errText = "mir: EACH item expression missing"
                Return 0
            End If

            If MIRLowerExprNode(ps, eachExprNode, module, fnIdx, blkIdx, tempSeed, eachExprName, errText) = 0 Then
                MIRPopLoopContext
                Return 0
            End If

            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, st.value, 1, eachExprName
            If Trim(st.op) <> "" Then
                Dim eachIdxName As String
                eachIdxName = MIRNextTemp(tempSeed)
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, eachIdxName, 1, LTrim(Str(eachItemPos))
                MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, st.op, 1, eachIdxName
            End If

            For eachBodyPos = 0 To eachBodyCount - 1
                Dim eachStmt As Integer
                eachStmt = MIRChildAt(ps, eachBodyNode, eachBodyPos)
                If eachStmt = -1 Then
                    MIRPopLoopContext
                    errText = "mir: EACH body statement missing"
                    Return 0
                End If
                If MIRLowerTopLevelStmt(ps, eachStmt, module, fnIdx, blkIdx, tempSeed, errText) = 0 Then
                    MIRPopLoopContext
                    Return 0
                End If
            Next eachBodyPos

            eachAfterBodyBlock = MIRAllocBlock(module, fnIdx)
            MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(eachAfterBodyBlock))
            blkIdx = eachAfterBodyBlock
        Next eachItemPos

        MIRPopLoopContext
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(eachBreakBlock))
        blkIdx = eachBreakBlock
        Return 1

    Case "TRY_STMT"
        Dim tryBodyNode As Integer
        Dim tryCatchNode As Integer
        Dim tryFinallyNode As Integer
        Dim tryChildPos As Integer
        Dim tryChildCount As Integer

        tryBodyNode = -1
        tryCatchNode = -1
        tryFinallyNode = -1
        tryChildCount = MIRChildCount(ps, stmtIdx)

        For tryChildPos = 0 To tryChildCount - 1
            Dim tcNode As Integer
            Dim tcKind As String
            tcNode = MIRChildAt(ps, stmtIdx, tryChildPos)
            If tcNode = -1 Then
                errText = "mir: TRY child missing"
                Return 0
            End If
            tcKind = UCase(ps.ast.nodes(tcNode).kind)
            If tcKind = "TRY_BODY" Then
                tryBodyNode = tcNode
            ElseIf tcKind = "CATCH_PART" Then
                If tryCatchNode = -1 Then tryCatchNode = tcNode
            ElseIf tcKind = "FINALLY_PART" Then
                tryFinallyNode = tcNode
            End If
        Next tryChildPos

        If tryBodyNode = -1 Then
            errText = "mir: TRY body missing"
            Return 0
        End If

        Dim tryCatchBlock As Integer
        Dim tryFinallyBlock As Integer
        Dim tryEndBlock As Integer
        Dim tryNoExcBlock As Integer

        tryCatchBlock = IIf(tryCatchNode <> -1, MIRAllocBlock(module, fnIdx), -1)
        tryFinallyBlock = IIf(tryFinallyNode <> -1, MIRAllocBlock(module, fnIdx), -1)
        tryEndBlock = MIRAllocBlock(module, fnIdx)

        MIRClearExceptionActive module, fnIdx, blkIdx, tempSeed
        MIRPushTryTarget IIf(tryCatchBlock <> -1, tryCatchBlock, IIf(tryFinallyBlock <> -1, tryFinallyBlock, tryEndBlock))

        Dim tryBodyCur As Integer
        tryBodyCur = blkIdx
        If MIRLowerStmtRange(ps, tryBodyNode, 0, MIRChildCount(ps, tryBodyNode) - 1, module, fnIdx, tryBodyCur, tempSeed, errText) = 0 Then
            MIRPopTryTarget
            Return 0
        End If
        MIRPopTryTarget

        tryNoExcBlock = MIRAllocBlock(module, fnIdx)
        Dim tryExcName As String
        tryExcName = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, tryBodyCur, MIR_OP_LOAD_VAR, tryExcName, 1, "__mir_exc_active"
        MIRAppendInstruction module, fnIdx, tryBodyCur, MIR_OP_JZ, "", 2, tryExcName, LTrim(Str(tryNoExcBlock))
        MIRAppendInstruction module, fnIdx, tryBodyCur, MIR_OP_JMP, "", 1, LTrim(Str(IIf(tryCatchBlock <> -1, tryCatchBlock, IIf(tryFinallyBlock <> -1, tryFinallyBlock, tryEndBlock))))

        If tryCatchBlock <> -1 Then
            Dim tryCatchCur As Integer
            tryCatchCur = tryCatchBlock
            If MIRLowerStmtRange(ps, tryCatchNode, 0, MIRChildCount(ps, tryCatchNode) - 1, module, fnIdx, tryCatchCur, tempSeed, errText) = 0 Then Return 0
            MIRClearExceptionActive module, fnIdx, tryCatchCur, tempSeed
            MIRAppendInstruction module, fnIdx, tryCatchCur, MIR_OP_JMP, "", 1, LTrim(Str(IIf(tryFinallyBlock <> -1, tryFinallyBlock, tryEndBlock)))
        End If

        Dim noExcCur As Integer
        noExcCur = tryNoExcBlock
        MIRAppendInstruction module, fnIdx, noExcCur, MIR_OP_JMP, "", 1, LTrim(Str(IIf(tryFinallyBlock <> -1, tryFinallyBlock, tryEndBlock)))

        If tryFinallyBlock <> -1 Then
            Dim tryFinCur As Integer
            tryFinCur = tryFinallyBlock
            If MIRLowerStmtRange(ps, tryFinallyNode, 0, MIRChildCount(ps, tryFinallyNode) - 1, module, fnIdx, tryFinCur, tempSeed, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, tryFinCur, MIR_OP_JMP, "", 1, LTrim(Str(tryEndBlock))
        End If

        blkIdx = tryEndBlock
        Return 1

    Case "NAMESPACE_STMT", "MODULE_STMT", "MAIN_STMT"
        Dim child As Integer
        child = st.firstChild
        Do While child <> -1
            If MIRLowerTopLevelStmt(ps, child, module, fnIdx, blkIdx, tempSeed, errText) = 0 Then Return 0
            child = ps.ast.nodes(child).nextSibling
        Loop
        Return 1

    Case "IF_STMT"
        Dim ifCount As Integer
        ifCount = MIRChildCount(ps, stmtIdx)
        If ifCount < 1 Then
            errText = "mir: IF condition missing"
            Return 0
        End If

        Dim endBlock As Integer
        endBlock = MIRAllocBlock(module, fnIdx)
        MIRPushIfExitTarget endBlock

        Dim condBlock As Integer
        condBlock = blkIdx

        Dim partPos As Integer
        partPos = 0

        Do
            Dim partNode As Integer
            Dim partKind As String
            Dim condExpr As Integer
            Dim bodyStart As Integer
            Dim bodyEnd As Integer

            If partPos = 0 Then
                partNode = stmtIdx
                partKind = "IF_STMT"
                condExpr = MIRChildAt(ps, stmtIdx, 0)
                bodyStart = 1

                bodyEnd = ifCount - 1
                Dim z As Integer
                For z = 1 To ifCount - 1
                    Dim zn As Integer
                    zn = MIRChildAt(ps, stmtIdx, z)
                    If zn <> -1 Then
                        Dim zk As String
                        zk = UCase(ps.ast.nodes(zn).kind)
                        If zk = "ELSEIF_PART" Or zk = "ELSE_PART" Then
                            bodyEnd = z - 1
                            Exit For
                        End If
                    End If
                Next z
            Else
                partNode = MIRChildAt(ps, stmtIdx, partPos)
                If partNode = -1 Then Exit Do
                partKind = UCase(ps.ast.nodes(partNode).kind)

                If partKind = "ELSE_PART" Then
                    If MIRLowerStmtRange(ps, partNode, 0, MIRChildCount(ps, partNode) - 1, module, fnIdx, condBlock, tempSeed, errText) = 0 Then Return 0
                    MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))
                    Exit Do
                End If

                If partKind <> "ELSEIF_PART" Then Exit Do
                condExpr = MIRChildAt(ps, partNode, 0)
                bodyStart = 1
                bodyEnd = MIRChildCount(ps, partNode) - 1
            End If

            If condExpr = -1 Then
                errText = "mir: IF/ELSEIF condition missing"
                Return 0
            End If

            Dim condName As String
            Dim condBool As String
            If MIRLowerExprNode(ps, condExpr, module, fnIdx, condBlock, tempSeed, condName, errText) = 0 Then Return 0
            MIREnsureBoolVar module, fnIdx, condBlock, tempSeed, condName, condBool

            Dim trueBlock As Integer
            trueBlock = MIRAllocBlock(module, fnIdx)

            Dim falseBlock As Integer
            falseBlock = endBlock

            Dim nextPartNode As Integer
            nextPartNode = MIRChildAt(ps, stmtIdx, partPos + 1)
            If nextPartNode <> -1 Then
                Dim nextKind As String
                nextKind = UCase(ps.ast.nodes(nextPartNode).kind)
                If nextKind = "ELSEIF_PART" Or nextKind = "ELSE_PART" Then
                    falseBlock = MIRAllocBlock(module, fnIdx)
                End If
            End If

            MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_JZ, "", 2, condBool, LTrim(Str(falseBlock))
            MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_JMP, "", 1, LTrim(Str(trueBlock))

            Dim bodyBlock As Integer
            bodyBlock = trueBlock
            If bodyEnd >= bodyStart Then
                If MIRLowerStmtRange(ps, partNode, bodyStart, bodyEnd, module, fnIdx, bodyBlock, tempSeed, errText) = 0 Then Return 0
            End If
            MIRAppendInstruction module, fnIdx, bodyBlock, MIR_OP_JMP, "", 1, LTrim(Str(endBlock))

            If falseBlock = endBlock Then Exit Do
            condBlock = falseBlock
            partPos += 1
        Loop

        MIRPopIfExitTarget
        blkIdx = endBlock
        Return 1

    Case "SELECT_STMT"
        Dim selCount As Integer
        selCount = MIRChildCount(ps, stmtIdx)
        If selCount < 1 Then
            errText = "mir: SELECT selector missing"
            Return 0
        End If

        Dim selectorExpr As Integer
        Dim selectorName As String
        selectorExpr = MIRChildAt(ps, stmtIdx, 0)
        If selectorExpr = -1 Then
            errText = "mir: SELECT selector missing"
            Return 0
        End If
        If MIRLowerExprNode(ps, selectorExpr, module, fnIdx, blkIdx, tempSeed, selectorName, errText) = 0 Then Return 0

        Dim selEndBlock As Integer
        selEndBlock = MIRAllocBlock(module, fnIdx)

        Dim caseCondBlock As Integer
        caseCondBlock = blkIdx

        Dim casePos As Integer
        For casePos = 1 To selCount - 1
            Dim caseNode As Integer
            caseNode = MIRChildAt(ps, stmtIdx, casePos)
            If caseNode = -1 Then
                errText = "mir: SELECT case missing"
                Return 0
            End If

            Dim caseKind As String
            caseKind = UCase(ps.ast.nodes(caseNode).kind)

            If caseKind = "CASE_ELSE" Then
                If MIRLowerStmtRange(ps, caseNode, 0, MIRChildCount(ps, caseNode) - 1, module, fnIdx, caseCondBlock, tempSeed, errText) = 0 Then Return 0
                MIRAppendInstruction module, fnIdx, caseCondBlock, MIR_OP_JMP, "", 1, LTrim(Str(selEndBlock))
                Exit For
            End If

            If caseKind <> "CASE_BLOCK" Then
                errText = "mir: unexpected SELECT case node " & ps.ast.nodes(caseNode).kind
                Return 0
            End If

            Dim caseChildCount As Integer
            caseChildCount = MIRChildCount(ps, caseNode)

            Dim bodyStart As Integer
            bodyStart = caseChildCount
            Dim cp As Integer
            For cp = 0 To caseChildCount - 1
                Dim cchild As Integer
                cchild = MIRChildAt(ps, caseNode, cp)
                If cchild <> -1 And MIRIsStmtKind(ps.ast.nodes(cchild).kind) <> 0 Then
                    bodyStart = cp
                    Exit For
                End If
            Next cp

            If bodyStart <= 0 Then
                errText = "mir: CASE values missing"
                Return 0
            End If

            Dim orVar As String
            orVar = ""

            For cp = 0 To bodyStart - 1
                Dim cexpr As Integer
                Dim rhsName As String
                Dim cmpVar As String
                Dim cmpOp As String

                cexpr = MIRChildAt(ps, caseNode, cp)
                If cexpr = -1 Then
                    errText = "mir: CASE expression missing"
                    Return 0
                End If

                cmpOp = MIR_OP_EQ
                If UCase(ps.ast.nodes(cexpr).kind) = "CASE_IS_VALUE" Then
                    If ps.ast.nodes(cexpr).left = -1 Then
                        errText = "mir: CASE IS expression missing"
                        Return 0
                    End If
                    If MIRLowerExprNode(ps, ps.ast.nodes(cexpr).left, module, fnIdx, caseCondBlock, tempSeed, rhsName, errText) = 0 Then Return 0

                    Dim rel As String
                    rel = Trim(ps.ast.nodes(cexpr).op)
                    If MIRMapBinaryOpcode(rel, 0, cmpOp) = 0 Then
                        errText = "mir: CASE IS invalid relop " & rel
                        Return 0
                    End If
                Else
                    If MIRLowerExprNode(ps, cexpr, module, fnIdx, caseCondBlock, tempSeed, rhsName, errText) = 0 Then Return 0
                End If

                cmpVar = MIRNextTemp(tempSeed)
                MIRAppendInstruction module, fnIdx, caseCondBlock, cmpOp, cmpVar, 2, selectorName, rhsName

                If orVar = "" Then
                    orVar = cmpVar
                Else
                    Dim nextOr As String
                    nextOr = MIRNextTemp(tempSeed)
                    MIRAppendInstruction module, fnIdx, caseCondBlock, MIR_OP_OR, nextOr, 2, orVar, cmpVar
                    orVar = nextOr
                End If
            Next cp

            If orVar = "" Then
                errText = "mir: CASE condition assembly failed"
                Return 0
            End If

            Dim trueBlock As Integer
            Dim falseBlock As Integer
            trueBlock = MIRAllocBlock(module, fnIdx)
            falseBlock = selEndBlock

            If casePos < selCount - 1 Then
                falseBlock = MIRAllocBlock(module, fnIdx)
            End If

            MIRAppendInstruction module, fnIdx, caseCondBlock, MIR_OP_JZ, "", 2, orVar, LTrim(Str(falseBlock))
            MIRAppendInstruction module, fnIdx, caseCondBlock, MIR_OP_JMP, "", 1, LTrim(Str(trueBlock))

            Dim caseBodyBlock As Integer
            caseBodyBlock = trueBlock
            If MIRLowerStmtRange(ps, caseNode, bodyStart, caseChildCount - 1, module, fnIdx, caseBodyBlock, tempSeed, errText) = 0 Then Return 0
            MIRAppendInstruction module, fnIdx, caseBodyBlock, MIR_OP_JMP, "", 1, LTrim(Str(selEndBlock))

            caseCondBlock = falseBlock
        Next casePos

        blkIdx = selEndBlock
        Return 1

    Case "FOR_STMT"
        Dim forCount As Integer
        forCount = MIRChildCount(ps, stmtIdx)
        If forCount < 3 Then
            errText = "mir: FOR missing start/end/step"
            Return 0
        End If

        Dim startExpr As Integer, endExpr As Integer, stepExpr As Integer
        Dim startName As String, endName As String, stepName As String
        startExpr = MIRChildAt(ps, stmtIdx, 0)
        endExpr = MIRChildAt(ps, stmtIdx, 1)
        stepExpr = MIRChildAt(ps, stmtIdx, 2)
        If startExpr = -1 Or endExpr = -1 Or stepExpr = -1 Then
            errText = "mir: FOR header missing"
            Return 0
        End If

        If MIRLowerExprNode(ps, startExpr, module, fnIdx, blkIdx, tempSeed, startName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, endExpr, module, fnIdx, blkIdx, tempSeed, endName, errText) = 0 Then Return 0
        If MIRLowerExprNode(ps, stepExpr, module, fnIdx, blkIdx, tempSeed, stepName, errText) = 0 Then Return 0

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_STORE_VAR, st.value, 1, startName

        Dim forFloat As Integer
        forFloat = 0
        Dim skind As Integer
        Dim ekind As Integer
        Dim tkind As Integer
        skind = MIRInferExprFloatKind(ps, startExpr)
        ekind = MIRInferExprFloatKind(ps, endExpr)
        tkind = MIRInferExprFloatKind(ps, stepExpr)
        If skind = MIR_UXF_F80 Or ekind = MIR_UXF_F80 Or tkind = MIR_UXF_F80 Then
            errText = "mir: F80 arithmetic not supported"
            Return 0
        End If
        If skind <> MIR_UXF_UNKNOWN Or ekind <> MIR_UXF_UNKNOWN Or tkind <> MIR_UXF_UNKNOWN Then
            forFloat = 1
        Else
            Dim forTypeName As String
            If MIRFindNearestDeclaredType(ps, stmtIdx, st.value, forTypeName) <> 0 Then
                forFloat = MIRIsFloatTypeName(forTypeName)
            End If
        End If

        Dim zeroName As String
        zeroName = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_LOAD_CONST, zeroName, 1, IIf(forFloat <> 0, "0.0", "0")

        Dim condBlock As Integer, bodyBlock As Integer, incBlock As Integer, loopEnd As Integer
        condBlock = MIRAllocBlock(module, fnIdx)
        bodyBlock = MIRAllocBlock(module, fnIdx)
        incBlock = MIRAllocBlock(module, fnIdx)
        loopEnd = MIRAllocBlock(module, fnIdx)

        MIRAppendInstruction module, fnIdx, blkIdx, MIR_OP_JMP, "", 1, LTrim(Str(condBlock))

        Dim stepPos As String, cmpLe As String, cmpGe As String
        Dim notStepPos As String, leftCond As String, rightCond As String, loopCond As String
        stepPos = MIRNextTemp(tempSeed)
        cmpLe = MIRNextTemp(tempSeed)
        cmpGe = MIRNextTemp(tempSeed)
        notStepPos = MIRNextTemp(tempSeed)
        leftCond = MIRNextTemp(tempSeed)
        rightCond = MIRNextTemp(tempSeed)
        loopCond = MIRNextTemp(tempSeed)

        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_GT, stepPos, 2, stepName, zeroName
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_LE, cmpLe, 2, st.value, endName
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_GE, cmpGe, 2, st.value, endName
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_NOT, notStepPos, 1, stepPos
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_AND, leftCond, 2, stepPos, cmpLe
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_AND, rightCond, 2, notStepPos, cmpGe
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_OR, loopCond, 2, leftCond, rightCond
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_JZ, "", 2, loopCond, LTrim(Str(loopEnd))
        MIRAppendInstruction module, fnIdx, condBlock, MIR_OP_JMP, "", 1, LTrim(Str(bodyBlock))

        MIRPushLoopContext "FOR", loopEnd, incBlock

        Dim bodyBlk As Integer
        bodyBlk = bodyBlock
        If forCount > 3 Then
            If MIRLowerStmtRange(ps, stmtIdx, 3, forCount - 1, module, fnIdx, bodyBlk, tempSeed, errText) = 0 Then
                MIRPopLoopContext
                Return 0
            End If
        End If
        MIRAppendInstruction module, fnIdx, bodyBlk, MIR_OP_JMP, "", 1, LTrim(Str(incBlock))

        Dim nextVal As String
        nextVal = MIRNextTemp(tempSeed)
        MIRAppendInstruction module, fnIdx, incBlock, IIf(forFloat <> 0, MIR_OP_FADD, MIR_OP_ADD), nextVal, 2, st.value, stepName
        MIRAppendInstruction module, fnIdx, incBlock, MIR_OP_STORE_VAR, st.value, 1, nextVal
        MIRAppendInstruction module, fnIdx, incBlock, MIR_OP_JMP, "", 1, LTrim(Str(condBlock))

        MIRPopLoopContext

        blkIdx = loopEnd
        Return 1

    Case Else
        Return 1
    End Select
End Function

Private Function MIRRoutineBodyStmtCount(ByRef ps As ParseState, ByVal routineNodeIdx As Integer) As Integer
    If routineNodeIdx < 0 Or routineNodeIdx >= ps.ast.count Then Return 0

    Dim total As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(routineNodeIdx).firstChild
    Do While ch <> -1
        If MIRIsStmtKind(ps.ast.nodes(ch).kind) <> 0 Then total += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return total
End Function

Private Function MIRFindOwningClassName(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef classNameOut As String) As Integer
    classNameOut = ""
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim p As Integer
    p = ps.ast.nodes(nodeIdx).parent
    If p >= 0 And p < ps.ast.count Then
        If UCase(Trim(ps.ast.nodes(p).kind)) = "CLASS_STMT" Then
            classNameOut = UCase(Trim(ps.ast.nodes(p).value))
            Return IIf(classNameOut <> "", 1, 0)
        End If
    End If

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        If UCase(Trim(ps.ast.nodes(i).kind)) <> "CLASS_STMT" Then Continue For
        Dim ch As Integer
        ch = ps.ast.nodes(i).firstChild
        Do While ch <> -1
            If ch = nodeIdx Then
                classNameOut = UCase(Trim(ps.ast.nodes(i).value))
                Return IIf(classNameOut <> "", 1, 0)
            End If
            ch = ps.ast.nodes(ch).nextSibling
        Loop
    Next i

    Return 0
End Function

Private Function MIRResolveRoutineEntryName(ByRef ps As ParseState, ByVal routineNodeIdx As Integer, ByRef routineNameOut As String) As Integer
    routineNameOut = ""
    If routineNodeIdx < 0 Or routineNodeIdx >= ps.ast.count Then Return 0

    Dim k As String
    k = UCase(Trim(ps.ast.nodes(routineNodeIdx).kind))

    Select Case k
    Case "SUB_STMT", "FUNCTION_STMT"
        routineNameOut = UCase(Trim(ps.ast.nodes(routineNodeIdx).value))
        Return IIf(routineNameOut <> "", 1, 0)
    Case "CLASS_METHOD_DECL"
        Dim className As String
        If MIRFindOwningClassName(ps, routineNodeIdx, className) = 0 Then Return 0
        routineNameOut = className & "_" & UCase(Trim(ps.ast.nodes(routineNodeIdx).value))
        Return IIf(routineNameOut <> "", 1, 0)
    Case "CLASS_CONSTRUCTOR_DECL"
        Dim className2 As String
        If MIRFindOwningClassName(ps, routineNodeIdx, className2) = 0 Then Return 0
        routineNameOut = className2 & "_CTOR"
        Return 1
    Case "CLASS_DESTRUCTOR_DECL"
        Dim className3 As String
        If MIRFindOwningClassName(ps, routineNodeIdx, className3) = 0 Then Return 0
        routineNameOut = className3 & "_DTOR"
        Return 1
    End Select

    Return 0
End Function

Private Function MIREnsureFunctionEntry(ByRef module As MIRModule, ByRef functionNameRaw As String, ByRef fnIdxOut As Integer) As Integer
    Dim fnName As String
    fnName = UCase(Trim(functionNameRaw))
    If fnName = "" Then Return 0

    fnIdxOut = MIRFindFunctionIndex(module, fnName)
    If fnIdxOut <> -1 Then Return 1

    fnIdxOut = module.functionCount
    If module.functionCount = 0 Then
        ReDim module.functions(0)
    Else
        ReDim Preserve module.functions(module.functionCount)
    End If
    module.functionCount += 1

    Dim fn As MIRFunction Ptr
    fn = @module.functions(fnIdxOut)

    fn->name = fnName
    fn->entryBlock = 0
    fn->localVarCount = 0
    fn->paramVarCount = 0

    ReDim fn->blocks(0)
    fn->blockCount = 1
    fn->blocks(0).id = 0
    fn->blocks(0).instructionCount = 0
    fn->blocks(0).isEntry = 1
    fn->blocks(0).isExit = 1

    Return 1
End Function

Private Sub MIRAppendFunctionParam(ByRef module As MIRModule, ByVal fnIdx As Integer, ByRef paramNameRaw As String)
    Dim paramName As String
    paramName = UCase(Trim(paramNameRaw))
    If paramName = "" Then Exit Sub

    Dim fn As MIRFunction Ptr
    fn = @module.functions(fnIdx)

    Dim i As Integer
    For i = 0 To fn->paramVarCount - 1
        If UCase(Trim(fn->paramVars(i))) = paramName Then Exit Sub
    Next i

    If fn->paramVarCount = 0 Then
        ReDim fn->paramVars(0)
    Else
        ReDim Preserve fn->paramVars(fn->paramVarCount)
    End If
    fn->paramVars(fn->paramVarCount) = paramName
    fn->paramVarCount += 1
End Sub

Private Function MIRLowerRoutineNode(ByRef ps As ParseState, ByVal routineNodeIdx As Integer, ByRef module As MIRModule, ByRef tempSeed As Integer, ByRef errText As String) As Integer
    If routineNodeIdx < 0 Or routineNodeIdx >= ps.ast.count Then Return 1

    Dim k As String
    k = UCase(Trim(ps.ast.nodes(routineNodeIdx).kind))
    Select Case k
    Case "SUB_STMT", "FUNCTION_STMT", "CLASS_METHOD_DECL", "CLASS_CONSTRUCTOR_DECL", "CLASS_DESTRUCTOR_DECL"
        ' supported
    Case Else
        Return 1
    End Select

    If MIRRoutineBodyStmtCount(ps, routineNodeIdx) <= 0 Then Return 1

    Dim routineName As String
    If MIRResolveRoutineEntryName(ps, routineNodeIdx, routineName) = 0 Then
        errText = "mir: routine name resolve failed"
        Return 0
    End If

    Dim fnIdx As Integer
    If MIREnsureFunctionEntry(module, routineName, fnIdx) = 0 Then
        errText = "mir: function entry create failed " & routineName
        Return 0
    End If

    If k = "CLASS_METHOD_DECL" Or k = "CLASS_CONSTRUCTOR_DECL" Or k = "CLASS_DESTRUCTOR_DECL" Then
        MIRAppendFunctionParam module, fnIdx, "THIS"
    End If

    Dim ch As Integer
    ch = ps.ast.nodes(routineNodeIdx).firstChild
    Do While ch <> -1
        If UCase(Trim(ps.ast.nodes(ch).kind)) = "PARAM_DECL" Then
            MIRAppendFunctionParam module, fnIdx, ps.ast.nodes(ch).value
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Dim bodyBlock As Integer
    bodyBlock = 0

    ch = ps.ast.nodes(routineNodeIdx).firstChild
    Do While ch <> -1
        If MIRIsStmtKind(ps.ast.nodes(ch).kind) <> 0 Then
            If MIRLowerTopLevelStmt(ps, ch, module, fnIdx, bodyBlock, tempSeed, errText) = 0 Then Return 0
        End If
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Dim defaultRetName As String
    defaultRetName = "__result__"
    If k = "FUNCTION_STMT" Then
        defaultRetName = UCase(Trim(ps.ast.nodes(routineNodeIdx).value))
    End If
    MIRAppendInstruction module, fnIdx, bodyBlock, MIR_OP_RET, "", 1, defaultRetName
    Return 1
End Function

Private Function MIRLowerAllRoutineNodes(ByRef ps As ParseState, ByRef module As MIRModule, ByRef tempSeed As Integer, ByRef errText As String) As Integer
    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        Dim k As String
        k = UCase(Trim(ps.ast.nodes(i).kind))
        Select Case k
        Case "SUB_STMT", "FUNCTION_STMT", "CLASS_METHOD_DECL", "CLASS_CONSTRUCTOR_DECL", "CLASS_DESTRUCTOR_DECL"
            If MIRLowerRoutineNode(ps, i, module, tempSeed, errText) = 0 Then Return 0
        End Select
    Next i
    Return 1
End Function

Function MIRBuildModuleFromAST(ByRef ps As ParseState, ByRef moduleOut As MIRModule, ByRef errText As String) As Integer
    errText = ""
    gMirLowerLoopDepth = 0
    gMirLowerTryDepth = 0
    moduleOut.functionCount = 0
    moduleOut.globalVarCount = 0
    Erase moduleOut.functions
    Erase moduleOut.globalVars

    If ps.rootNode = -1 Then
        errText = "mir: ast root missing"
        Return 0
    End If

    MIREnsureMain moduleOut

    Dim tempSeed As Integer
    tempSeed = 0

    If MIRLowerAllRoutineNodes(ps, moduleOut, tempSeed, errText) = 0 Then Return 0

    Dim curBlock As Integer
    curBlock = 0

    Dim st As Integer
    st = ps.ast.nodes(ps.rootNode).firstChild
    Do While st <> -1
        If MIRLowerTopLevelStmt(ps, st, moduleOut, 0, curBlock, tempSeed, errText) = 0 Then Return 0
        st = ps.ast.nodes(st).nextSibling
    Loop

    MIRAppendInstruction moduleOut, 0, curBlock, MIR_OP_RET, "", 1, "__result__"

    ' Build MIR-level vtable map from AST (uses CLASS_METHOD_SLOT metadata)
    If MIRBuildVTableMap(ps, moduleOut, errText) = 0 Then Return 0

    Return 1
End Function

Private Function MIRBuildVTableMap(ByRef ps As ParseState, ByRef module As MIRModule, ByRef errText As String) As Integer
    errText = ""

    module.vtableClassCount = 0
    module.vtableEntryCount = 0
    Erase module.vtableClassNames
    Erase module.vtableClassSlotCounts
    Erase module.vtableClassSlotStart
    Erase module.vtableEntryKeys
    Erase module.vtableEntrySlots
    Erase module.vtableEntryClassIndex
    Erase module.vtableEntryFunctionIndex

    Dim st As Integer
    st = ps.ast.nodes(ps.rootNode).firstChild
    Do While st <> -1
        If UCase(ps.ast.nodes(st).kind) = "CLASS_STMT" Then
            Dim className As String
            className = UCase(Trim(ps.ast.nodes(st).value))
            If className <> "" Then
                ' collect base-chain types
                Dim typesList() As String
                Dim typeCount As Integer
                typeCount = 0

                Dim curType As String
                curType = className
                Do While curType <> ""
                    If typeCount = 0 Then
                        ReDim typesList(0)
                    Else
                        ReDim Preserve typesList(typeCount)
                    End If
                    typesList(typeCount) = UCase(Trim(curType))
                    typeCount += 1

                    Dim cnode As Integer
                    cnode = -1
                    Dim i As Integer
                    For i = 0 To ps.ast.count - 1
                        If UCase(Trim(ps.ast.nodes(i).kind)) = "CLASS_STMT" Then
                            If UCase(Trim(ps.ast.nodes(i).value)) = typesList(typeCount - 1) Then
                                cnode = i
                                Exit For
                            End If
                        End If
                    Next i
                    If cnode = -1 Then Exit Do

                    Dim baseNode As Integer
                    baseNode = MIRFindChildByKind(ps, cnode, "CLASS_BASE_REF")
                    If baseNode = -1 Then Exit Do
                    curType = UCase(Trim(ps.ast.nodes(baseNode).value))
                Loop

                ' find max slot
                Dim maxSlot As Integer
                maxSlot = -1
                Dim ti As Integer
                For ti = typeCount - 1 To 0 Step -1
                    Dim cn As Integer
                    cn = -1
                    Dim j As Integer
                    For j = 0 To ps.ast.count - 1
                        If UCase(Trim(ps.ast.nodes(j).kind)) = "CLASS_STMT" Then
                            If UCase(Trim(ps.ast.nodes(j).value)) = typesList(ti) Then
                                cn = j
                                Exit For
                            End If
                        End If
                    Next j
                    If cn = -1 Then Continue For
                    Dim ch As Integer
                    ch = ps.ast.nodes(cn).firstChild
                    Do While ch <> -1
                        If UCase(ps.ast.nodes(ch).kind) = "CLASS_METHOD_DECL" Then
                            Dim meta As Integer
                            meta = MIRFindChildByKind(ps, ch, "CLASS_METHOD_SLOT")
                            If meta <> -1 Then
                                Dim si As Integer
                                si = Val(ps.ast.nodes(meta).value)
                                If si > maxSlot Then maxSlot = si
                            End If
                        End If
                        ch = ps.ast.nodes(ch).nextSibling
                    Loop
                Next ti

                Dim slotCount As Integer
                If maxSlot < 0 Then
                    slotCount = 0
                Else
                    slotCount = maxSlot + 1
                End If

                Dim classIdx As Integer
                classIdx = module.vtableClassCount
                If module.vtableClassCount = 0 Then
                    ReDim module.vtableClassNames(0)
                    ReDim module.vtableClassSlotCounts(0)
                    ReDim module.vtableClassSlotStart(0)
                Else
                    ReDim Preserve module.vtableClassNames(module.vtableClassCount)
                    ReDim Preserve module.vtableClassSlotCounts(module.vtableClassCount)
                    ReDim Preserve module.vtableClassSlotStart(module.vtableClassCount)
                End If
                module.vtableClassNames(classIdx) = className
                module.vtableClassSlotCounts(classIdx) = slotCount
                module.vtableClassSlotStart(classIdx) = module.vtableEntryCount
                module.vtableClassCount += 1

                If slotCount > 0 Then
                    Dim implOwner() As String
                    Dim implMethod() As String
                    ReDim implOwner(slotCount - 1)
                    ReDim implMethod(slotCount - 1)

                    For ti = typeCount - 1 To 0 Step -1
                        Dim cn2 As Integer
                        cn2 = -1
                        Dim k As Integer
                        For k = 0 To ps.ast.count - 1
                            If UCase(Trim(ps.ast.nodes(k).kind)) = "CLASS_STMT" Then
                                If UCase(Trim(ps.ast.nodes(k).value)) = typesList(ti) Then
                                    cn2 = k
                                    Exit For
                                End If
                            End If
                        Next k
                        If cn2 = -1 Then Continue For
                        Dim ch2 As Integer
                        ch2 = ps.ast.nodes(cn2).firstChild
                        Do While ch2 <> -1
                            If UCase(ps.ast.nodes(ch2).kind) = "CLASS_METHOD_DECL" Then
                                Dim mname As String
                                mname = UCase(Trim(ps.ast.nodes(ch2).value))
                                Dim mch2 As Integer
                                mch2 = MIRFindChildByKind(ps, ch2, "CLASS_METHOD_SLOT")
                                If mch2 <> -1 Then
                                    Dim sidx As Integer
                                    sidx = Val(ps.ast.nodes(mch2).value)
                                    If sidx >= 0 And sidx < slotCount Then
                                        implOwner(sidx) = typesList(ti)
                                        implMethod(sidx) = mname
                                    End If
                                End If
                            End If
                            ch2 = ps.ast.nodes(ch2).nextSibling
                        Loop
                    Next ti

                    Dim i As Integer
                    For i = 0 To slotCount - 1
                        Dim key As String
                        key = className & "_" & UCase(Trim(implMethod(i)))

                        Dim eidx As Integer
                        eidx = module.vtableEntryCount
                        If module.vtableEntryCount = 0 Then
                            ReDim module.vtableEntryKeys(0)
                            ReDim module.vtableEntrySlots(0)
                            ReDim module.vtableEntryClassIndex(0)
                            ReDim module.vtableEntryFunctionIndex(0)
                        Else
                            ReDim Preserve module.vtableEntryKeys(module.vtableEntryCount)
                            ReDim Preserve module.vtableEntrySlots(module.vtableEntryCount)
                            ReDim Preserve module.vtableEntryClassIndex(module.vtableEntryCount)
                            ReDim Preserve module.vtableEntryFunctionIndex(module.vtableEntryCount)
                        End If

                        module.vtableEntryKeys(eidx) = UCase(Trim(key))
                        module.vtableEntrySlots(eidx) = i
                        module.vtableEntryClassIndex(eidx) = classIdx

                        Dim implRoutine As String
                        implRoutine = ""
                        If implOwner(i) <> "" And implMethod(i) <> "" Then
                            implRoutine = UCase(Trim(implOwner(i) & "_" & implMethod(i)))
                            module.vtableEntryFunctionIndex(eidx) = MIRFindFunctionIndex(module, implRoutine)
                        Else
                            module.vtableEntryFunctionIndex(eidx) = -1
                        End If

                        module.vtableEntryCount += 1
                    Next i
                End If
            End If
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    Return 1
End Function

Function MIROptimizeModule(ByRef module As MIRModule, ByRef errText As String) As Integer
    errText = ""
    If module.functionCount <= 0 Then Return 1

    Dim fi As Integer
    For fi = 0 To module.functionCount - 1
        Dim bi As Integer
        For bi = 0 To module.functions(fi).blockCount - 1
            Dim knownNames(Any) As String
            Dim knownVals(Any) As MIRValue
            Dim knownCount As Integer
            knownCount = 0

            Dim ii As Integer
            For ii = 0 To module.functions(fi).blocks(bi).instructionCount - 1
                Dim inst As MIRIRInstruction
                inst = module.functions(fi).blocks(bi).instructions(ii)

                If inst.opcode = MIR_OP_LOAD_CONST And Trim(inst.result) <> "" And inst.operandCount >= 1 Then
                    Dim cv As MIRValue
                    If MIRValueFromString(inst.operands(0), cv) <> 0 Then
                        Dim found As Integer
                        found = -1
                        Dim k As Integer
                        For k = 0 To knownCount - 1
                            If UCase(knownNames(k)) = UCase(inst.result) Then found = k
                        Next k
                        If found = -1 Then
                            If knownCount = 0 Then
                                ReDim knownNames(0)
                                ReDim knownVals(0)
                            Else
                                ReDim Preserve knownNames(knownCount)
                                ReDim Preserve knownVals(knownCount)
                            End If
                            knownNames(knownCount) = inst.result
                            knownVals(knownCount) = cv
                            knownCount += 1
                        Else
                            knownVals(found) = cv
                        End If
                    End If
                End If
            Next ii
        Next bi
    Next fi

    Return 1
End Function

