End Sub

Private Function FindStatementDispatchEntry(ByRef keywordText As String) As Integer
    Dim i As Integer
    For i = 0 To gStatementDispatchCount - 1
        If gStatementDispatchEntries(i).keyword = keywordText Then Return i
    Next i
    Return -1
End Function

Private Function IsTypeLikeKeyword(ByVal word As String) As Integer
    Dim k As String
    k = LCase(Trim(word))
    Select Case k
    Case "i8", "u8", "i16", "u16", "i32", "u32", "i64", "u64", "f32", "f64", "f80", "boolean", "string", "object", "ptr", "strptr", "byref", "byval", "cdecl", "stdcall"
        Return 1
    End Select
    Return 0
End Function

Private Function DispatchBasicStatementById(ByRef ps As ParseState, ByRef tk As Token, ByVal handlerId As Integer) As Integer
    Select Case handlerId
    Case STMT_HANDLER_PRINT
        Return ParsePrintStmt(ps, tk)
    Case STMT_HANDLER_INLINE
        Return ParseInlineStmt(ps, tk)
    Case STMT_HANDLER_CALL
        Return ParseCallStmt(ps, tk)
    Case STMT_HANDLER_DELETE
        Return ParseDeleteStmt(ps, tk)
    End Select

    Return -2
End Function

Private Function DispatchFlowStatementById(ByRef ps As ParseState, ByRef tk As Token, ByVal handlerId As Integer) As Integer
    Select Case handlerId
    Case STMT_HANDLER_IF
        Return ParseIfStmt(ps, tk)
    Case STMT_HANDLER_SELECT
        Return ParseSelectStmt(ps, tk)
    Case STMT_HANDLER_FOR
        Return ParseForStmt(ps, tk)
    Case STMT_HANDLER_FOR_EACH
        Return ParseForEachStmt(ps, tk)
    Case STMT_HANDLER_DO
        Return ParseDoStmt(ps, tk)
    Case STMT_HANDLER_DO_EACH
        Return ParseDoEachStmt(ps, tk)
    Case STMT_HANDLER_GOTO
        Return ParseGotoStmt(ps, tk)
    Case STMT_HANDLER_GOSUB
        Return ParseGosubStmt(ps, tk)
    Case STMT_HANDLER_RETURN
        Return ParseReturnStmt(ps, tk)
    Case STMT_HANDLER_EXIT
        Return ParseExitStmt(ps, tk)
    Case STMT_HANDLER_END
        Return ParseEndStmt(ps, tk)
    Case STMT_HANDLER_TRY
        Return ParseTryStmt(ps, tk)
    Case STMT_HANDLER_THROW
        Return ParseThrowStmt(ps, tk)
    Case STMT_HANDLER_ASSERT
        Return ParseAssertStmt(ps, tk)
    End Select

    Return -2
End Function

#include once "parser_stmt_decl_dispatch.fbs"

Private Function DispatchIoStatementById(ByRef ps As ParseState, ByRef tk As Token, ByVal handlerId As Integer) As Integer
    Select Case handlerId
    Case STMT_HANDLER_INPUT
        Return ParseInputStmt(ps, tk)
    Case STMT_HANDLER_OPEN
        Return ParseOpenStmt(ps, tk)
    Case STMT_HANDLER_CLOSE
        Return ParseCloseStmt(ps, tk)
    Case STMT_HANDLER_GET
        Return ParseGetStmt(ps, tk)
    Case STMT_HANDLER_PUT
        Return ParsePutStmt(ps, tk)
    Case STMT_HANDLER_SEEK
        Return ParseSeekStmt(ps, tk)
    Case STMT_HANDLER_LOCATE
        Return ParseLocateStmt(ps, tk)
    Case STMT_HANDLER_COLOR
        Return ParseColorStmt(ps, tk)
    Case STMT_HANDLER_CLS
        Return ParseClsStmt(ps, tk)
    Case STMT_HANDLER_INC
        Return ParseIncStmt(ps, tk)
    Case STMT_HANDLER_DEC
        Return ParseDecStmt(ps, tk)
    Case STMT_HANDLER_RANDOMIZE
        Return ParseRandomizeStmt(ps, tk)
    Case STMT_HANDLER_POKEB
        Return ParsePokebStmt(ps, tk)
    Case STMT_HANDLER_POKEW
        Return ParsePokewStmt(ps, tk)
    Case STMT_HANDLER_POKED
        Return ParsePokedStmt(ps, tk)
    Case STMT_HANDLER_POKE
        Return ParsePokeStmt(ps, tk)
    Case STMT_HANDLER_MEMCOPYB
        Return ParseMemcopybStmt(ps, tk)
    Case STMT_HANDLER_MEMFILLB
        Return ParseMemfillbStmt(ps, tk)
    Case STMT_HANDLER_POKES
        Return ParsePokesStmt(ps, tk)
    Case STMT_HANDLER_MEMCOPYW
        Return ParseMemcopywStmt(ps, tk)
    Case STMT_HANDLER_MEMCOPYD
        Return ParseMemcopydStmt(ps, tk)
    Case STMT_HANDLER_MEMFILLW
        Return ParseMemfillwStmt(ps, tk)
    Case STMT_HANDLER_MEMFILLD
        Return ParseMemfilldStmt(ps, tk)
    Case STMT_HANDLER_SETNEWOFFSET
        Return ParseSetnewoffsetStmt(ps, tk)
    End Select

    Return -2
End Function

Private Function DispatchStatementByHandlerId(ByRef ps As ParseState, ByRef tk As Token, ByVal handlerId As Integer) As Integer
    Dim stmtNode As Integer

    stmtNode = DispatchBasicStatementById(ps, tk, handlerId)
    If stmtNode <> -2 Then Return stmtNode

    stmtNode = DispatchFlowStatementById(ps, tk, handlerId)
    If stmtNode <> -2 Then Return stmtNode

    stmtNode = DispatchDeclStatementById(ps, tk, handlerId)
    If stmtNode <> -2 Then Return stmtNode

    stmtNode = DispatchIoStatementById(ps, tk, handlerId)
    If stmtNode <> -2 Then Return stmtNode

    Select Case handlerId
    Case STMT_HANDLER_EVENT
        Return ParseEventStmt(ps, tk)
    Case STMT_HANDLER_THREAD
        Return ParseThreadStmt(ps, tk)
    Case STMT_HANDLER_PARALEL
        Return ParseParalelStmt(ps, tk)
    Case STMT_HANDLER_PIPE
        Return ParsePipeStmt(ps, tk)
    Case STMT_HANDLER_SLOT
        Return ParseSlotStmt(ps, tk)
    Case STMT_HANDLER_ON
        Return ParseSlotOnStmt(ps, tk)
    Case STMT_HANDLER_OFF
        Return ParseSlotOffStmt(ps, tk)
    Case STMT_HANDLER_TRIGGER
        Return ParseTriggerStmt(ps, tk)
    End Select

    ps.lastError = "internal: unknown statement handler id " & Str(handlerId)
    Return -1
End Function

Private Function DispatchKeywordStatement(ByRef ps As ParseState, ByRef tk As Token) As Integer
    If tk.kind <> "KEYWORD" Then Return -2

    InitStatementDispatchRegistry

    Dim kw As String
    kw = UCase(tk.lexeme)

    Dim entryIdx As Integer
    entryIdx = FindStatementDispatchEntry(kw)
    If entryIdx = -1 Then Return -2

    Dim entry As StatementDispatchEntry
    entry = gStatementDispatchEntries(entryIdx)

    AdvanceTok ps

    If entry.lookaheadKeyword <> "" Then
        If MatchKeyword(ps, entry.lookaheadKeyword) Then
            Return DispatchStatementByHandlerId(ps, tk, entry.lookaheadHandlerId)
        End If
    End If

    Return DispatchStatementByHandlerId(ps, tk, entry.handlerId)
End Function

Private Function TryParseLabelStatement(ByRef ps As ParseState, ByRef tk As Token) As Integer
    If (tk.kind = "IDENT" Or tk.kind = "NUMBER") And LookToken(ps, 1).kind = "OP" And LookToken(ps, 1).lexeme = ":" Then
        AdvanceTok ps
        AdvanceTok ps
        Return MakeNodeFromToken(ps, "LABEL_STMT", tk.lexeme, "", tk)
    End If

    Return -2
End Function

Private Function TryParseIdentifierStatement(ByRef ps As ParseState, ByRef tk As Token) As Integer
    If tk.kind <> "IDENT" Then
        If tk.kind = "KEYWORD" Then
            If IsTypeLikeKeyword(tk.lexeme) = 0 Then Return -2
        Else
            Return -2
        End If
    End If

    ParserDiag ps, "[PDBG] TryParseIdentifierStatement tk.kind=" & tk.kind & " lexeme=" & tk.lexeme & " line=" & Str(tk.lineNo) & " col=" & Str(tk.colNo)

    Dim identTok As Token
    identTok = tk
    Dim n1 As Token
    n1 = LookToken(ps, 1)

    If IsLegacyInlineName(identTok.lexeme) Then
        ps.lastError = "legacy inline forms are disabled; use INLINE(...)"
        Return -1
    End If

    If IsDisabledUnderscoreCommand(identTok.lexeme, n1) Then
        ps.lastError = "underscore commands are disabled"
        Return -1
    End If

    If n1.kind = "OP" And (n1.lexeme = "=" Or n1.lexeme = "+=" Or n1.lexeme = "-=" Or n1.lexeme = "*=" Or n1.lexeme = "/=" Or n1.lexeme = "\=" Or n1.lexeme = "=+" Or n1.lexeme = "=-") Then
        AdvanceTok ps
        AdvanceTok ps

        ParserDiag ps, "[PDBG] TryParseIdentifierStatement assignment detected for " & identTok.lexeme

        Dim rhs As Integer
        rhs = ParseExpression(ps)
        If rhs = -1 Then Return -1

        Dim lhs As Integer
        lhs = MakeNodeFromToken(ps, "IDENT", identTok.lexeme, "", identTok)

        Dim assignNode As Integer
        assignNode = MakeNodeFromToken(ps, "ASSIGN_STMT", "", n1.lexeme, n1)
        ps.ast.nodes(assignNode).left = lhs
        ps.ast.nodes(assignNode).right = rhs
        Return assignNode
    End If

    If n1.kind = "OP" And n1.lexeme = "(" Then
        Dim depth As Integer
        Dim look As Integer
        Dim assignTok As Token
        depth = 0
        look = 1
        assignTok.kind = ""

        Do
            Dim scanTok As Token
            scanTok = LookToken(ps, look)
            If scanTok.kind = "EOF" Then Exit Do

            If scanTok.kind = "OP" Then
                If scanTok.lexeme = "(" Then
                    depth += 1
                ElseIf scanTok.lexeme = ")" Then
                    depth -= 1
                    If depth = 0 Then
                        assignTok = LookToken(ps, look + 1)
                        Exit Do
                    End If
                End If
            End If

            look += 1
        Loop

        If assignTok.kind = "OP" And (assignTok.lexeme = "=" Or assignTok.lexeme = "+=" Or assignTok.lexeme = "-=" Or assignTok.lexeme = "*=" Or assignTok.lexeme = "/=" Or assignTok.lexeme = "\=" Or assignTok.lexeme = "=+" Or assignTok.lexeme = "=-") Then
            AdvanceTok ps

            If MatchOp(ps, "(") = 0 Then
                ps.lastError = "indexed assignment: missing ("
                Return -1
            End If

            Dim lhsCall As Integer
            lhsCall = MakeNodeFromToken(ps, "CALL_EXPR", identTok.lexeme, "", identTok)

            If MatchOp(ps, ")") = 0 Then
                Do
                    Dim idxExpr As Integer
                    idxExpr = ParseExpression(ps)
                    If idxExpr = -1 Then Return -1
                    ASTAddChild ps.ast, lhsCall, idxExpr
                    If MatchOp(ps, ",") = 0 Then Exit Do
                Loop

                If MatchOp(ps, ")") = 0 Then
                    ps.lastError = "indexed assignment: missing )"
                    Return -1
                End If
            End If

            Dim opTok As Token
            opTok = CurToken(ps)
            AdvanceTok ps

            Dim rhsIndexed As Integer
            rhsIndexed = ParseExpression(ps)
            If rhsIndexed = -1 Then Return -1

            Dim assignIndexed As Integer
            assignIndexed = MakeNodeFromToken(ps, "ASSIGN_STMT", "", opTok.lexeme, opTok)
            ps.ast.nodes(assignIndexed).left = lhsCall
            ps.ast.nodes(assignIndexed).right = rhsIndexed
            Return assignIndexed
        End If
    End If

    If n1.kind = "OP" And (n1.lexeme = "++" Or n1.lexeme = "--") Then
        AdvanceTok ps
        AdvanceTok ps

        Dim lhs2 As Integer
        lhs2 = MakeNodeFromToken(ps, "IDENT", identTok.lexeme, "", identTok)

        Dim incNode As Integer
        incNode = MakeNodeFromToken(ps, "INCDEC_STMT", "", n1.lexeme, n1)
        ps.ast.nodes(incNode).left = lhs2
        Return incNode
    End If

    Return -2
End Function

Private Function ParseExpressionStatement(ByRef ps As ParseState, ByRef tk As Token) As Integer
    Dim exprNode As Integer
    exprNode = ParseExpression(ps)
    If exprNode = -1 Then
        ps.lastError = "statement parse failed"
        Return -1
    End If

    If exprNode <> -1 Then
        Dim exprKind As String
        exprKind = UCase(ps.ast.nodes(exprNode).kind)
        If exprKind = "BINARY" Then
            Dim exprOp As String
            exprOp = Trim(ps.ast.nodes(exprNode).op)
            If exprOp = "=" Or exprOp = "+=" Or exprOp = "-=" Or exprOp = "*=" Or exprOp = "/=" Or exprOp = "\=" Or exprOp = "=+" Or exprOp = "=-" Then
                Dim lhsNode As Integer
                lhsNode = ps.ast.nodes(exprNode).left
                If lhsNode <> -1 Then
                    Dim lhsKind As String
                    lhsKind = UCase(ps.ast.nodes(lhsNode).kind)
                    If lhsKind = "FIELD_EXPR" Then
                        Dim assignNode As Integer
                        assignNode = ASTNewNode(ps.ast, "ASSIGN_STMT", "", exprOp, tk.lineNo, tk.colNo)
                        ps.ast.nodes(assignNode).left = lhsNode
                        ps.ast.nodes(assignNode).right = ps.ast.nodes(exprNode).right
                        Return assignNode
                    End If
                End If
            End If
        End If
    End If

    Dim stNode As Integer
    stNode = ASTNewNode(ps.ast, "EXPR_STMT", "", "", tk.lineNo, tk.colNo)
    ps.ast.nodes(stNode).left = exprNode
    Return stNode
End Function

Function ParseSimpleStatement(ByRef ps As ParseState) As Integer
    Dim tk As Token
    tk = CurToken(ps)
    ParserDiag ps, "[PDBG] ParseSimpleStatement tk.kind=" & tk.kind & " lexeme=" & tk.lexeme & " line=" & Str(tk.lineNo) & " col=" & Str(tk.colNo)

    Dim labelStmt As Integer
    labelStmt = TryParseLabelStatement(ps, tk)
    If labelStmt <> -2 Then Return labelStmt

    Dim kwStmt As Integer
    kwStmt = DispatchKeywordStatement(ps, tk)
    If kwStmt <> -2 Then Return kwStmt

    Dim identStmt As Integer
    identStmt = TryParseIdentifierStatement(ps, tk)
    If identStmt <> -2 Then Return identStmt

    Return ParseExpressionStatement(ps, tk)
End Function
