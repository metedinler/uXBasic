Private Const STMT_HANDLER_TRIGGER = 870

Private Dim Shared gStatementDispatchEntries() As StatementDispatchEntry
Private Dim Shared gStatementDispatchCount As Integer
Private Dim Shared gStatementDispatchInitialized As Integer

Private Sub AddStatementDispatchEntry(ByRef keywordText As String, ByVal handlerId As Integer, ByRef lookaheadKeyword As String, ByVal lookaheadHandlerId As Integer)
    If gStatementDispatchCount = 0 Then
        ReDim gStatementDispatchEntries(0)
    Else
        ReDim Preserve gStatementDispatchEntries(gStatementDispatchCount)
    End If

    gStatementDispatchEntries(gStatementDispatchCount).keyword = keywordText
    gStatementDispatchEntries(gStatementDispatchCount).handlerId = handlerId
    gStatementDispatchEntries(gStatementDispatchCount).lookaheadKeyword = lookaheadKeyword
    gStatementDispatchEntries(gStatementDispatchCount).lookaheadHandlerId = lookaheadHandlerId
    gStatementDispatchCount += 1
End Sub

Private Sub InitStatementDispatchRegistry()
    If gStatementDispatchInitialized <> 0 Then Exit Sub

    gStatementDispatchCount = 0

    AddStatementDispatchEntry "PRINT", STMT_HANDLER_PRINT, "", 0
    AddStatementDispatchEntry "INLINE", STMT_HANDLER_INLINE, "", 0
    AddStatementDispatchEntry "CALL", STMT_HANDLER_CALL, "", 0

    AddStatementDispatchEntry "IF", STMT_HANDLER_IF, "", 0
    AddStatementDispatchEntry "SELECT", STMT_HANDLER_SELECT, "", 0
    AddStatementDispatchEntry "FOR", STMT_HANDLER_FOR, "EACH", STMT_HANDLER_FOR_EACH
    AddStatementDispatchEntry "DO", STMT_HANDLER_DO, "EACH", STMT_HANDLER_DO_EACH
    AddStatementDispatchEntry "GOTO", STMT_HANDLER_GOTO, "", 0
    AddStatementDispatchEntry "GOSUB", STMT_HANDLER_GOSUB, "", 0
    AddStatementDispatchEntry "RETURN", STMT_HANDLER_RETURN, "", 0
    AddStatementDispatchEntry "EXIT", STMT_HANDLER_EXIT, "", 0
    AddStatementDispatchEntry "END", STMT_HANDLER_END, "", 0
    AddStatementDispatchEntry "TRY", STMT_HANDLER_TRY, "", 0
    AddStatementDispatchEntry "THROW", STMT_HANDLER_THROW, "", 0
    AddStatementDispatchEntry "ASSERT", STMT_HANDLER_ASSERT, "", 0
    AddStatementDispatchEntry "DELETE", STMT_HANDLER_DELETE, "", 0

    AddStatementDispatchEntry "DECLARE", STMT_HANDLER_DECLARE, "", 0
    AddStatementDispatchEntry "SUB", STMT_HANDLER_SUB, "", 0
    AddStatementDispatchEntry "FUNCTION", STMT_HANDLER_FUNCTION, "", 0
    AddStatementDispatchEntry "CONST", STMT_HANDLER_CONST, "", 0
    AddStatementDispatchEntry "DIM", STMT_HANDLER_DIM, "", 0
    AddStatementDispatchEntry "REDIM", STMT_HANDLER_REDIM, "", 0
    AddStatementDispatchEntry "TYPE", STMT_HANDLER_TYPE, "", 0
    AddStatementDispatchEntry "CLASS", STMT_HANDLER_CLASS, "", 0
    AddStatementDispatchEntry "INTERFACE", STMT_HANDLER_INTERFACE, "", 0
    AddStatementDispatchEntry "NAMESPACE", STMT_HANDLER_NAMESPACE, "", 0
    AddStatementDispatchEntry "MODULE", STMT_HANDLER_MODULE, "", 0
    AddStatementDispatchEntry "MAIN", STMT_HANDLER_MAIN, "", 0
    AddStatementDispatchEntry "USING", STMT_HANDLER_USING, "", 0
    AddStatementDispatchEntry "ALIAS", STMT_HANDLER_ALIAS, "", 0
    AddStatementDispatchEntry "DEFINT", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "DEFLNG", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "DEFSNG", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "DEFDBL", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "DEFEXT", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "DEFSTR", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "DEFBYT", STMT_HANDLER_DEFTYPE, "", 0
    AddStatementDispatchEntry "SETSTRINGSIZE", STMT_HANDLER_SETSTRINGSIZE, "", 0
    AddStatementDispatchEntry "INCLUDE", STMT_HANDLER_INCLUDE, "", 0
    AddStatementDispatchEntry "IMPORT", STMT_HANDLER_IMPORT, "", 0

    AddStatementDispatchEntry "INPUT", STMT_HANDLER_INPUT, "", 0
    AddStatementDispatchEntry "OPEN", STMT_HANDLER_OPEN, "", 0
    AddStatementDispatchEntry "CLOSE", STMT_HANDLER_CLOSE, "", 0
    AddStatementDispatchEntry "GET", STMT_HANDLER_GET, "", 0
    AddStatementDispatchEntry "PUT", STMT_HANDLER_PUT, "", 0
    AddStatementDispatchEntry "SEEK", STMT_HANDLER_SEEK, "", 0
    AddStatementDispatchEntry "LOCATE", STMT_HANDLER_LOCATE, "", 0
    AddStatementDispatchEntry "COLOR", STMT_HANDLER_COLOR, "", 0
    AddStatementDispatchEntry "CLS", STMT_HANDLER_CLS, "", 0
    AddStatementDispatchEntry "INC", STMT_HANDLER_INC, "", 0
    AddStatementDispatchEntry "DEC", STMT_HANDLER_DEC, "", 0
    AddStatementDispatchEntry "RANDOMIZE", STMT_HANDLER_RANDOMIZE, "", 0
    AddStatementDispatchEntry "POKEB", STMT_HANDLER_POKEB, "", 0
    AddStatementDispatchEntry "POKEW", STMT_HANDLER_POKEW, "", 0
    AddStatementDispatchEntry "POKED", STMT_HANDLER_POKED, "", 0
    AddStatementDispatchEntry "POKE", STMT_HANDLER_POKE, "", 0
    AddStatementDispatchEntry "MEMCOPYB", STMT_HANDLER_MEMCOPYB, "", 0
    AddStatementDispatchEntry "MEMFILLB", STMT_HANDLER_MEMFILLB, "", 0
    AddStatementDispatchEntry "POKES", STMT_HANDLER_POKES, "", 0
