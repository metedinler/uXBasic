Private Function ExecRunSetNewOffsetStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef errText As String) As Integer
    Dim so0 As Integer
    Dim so1 As Integer
    so0 = ExecChildAt(ps, stmtIdx, 0)
    so1 = ExecChildAt(ps, stmtIdx, 1)
    If so0 = -1 Or so1 = -1 Then
        errText = "exec: SETNEWOFFSET args missing"
        Return 0
    End If

    If UCase(ps.ast.nodes(so0).kind) <> "IDENT" Then
        errText = "exec: SETNEWOFFSET target must be ident"
        Return 0
    End If

    Dim newAddr As Integer
    newAddr = ExecEvalNode(ps, es, so1, errText)
    If errText <> "" Then Return 0

    ExecSetVarAddr es, ps.ast.nodes(so0).value, CUInt(newAddr)
    ExecSetVar es, ps.ast.nodes(so0).value, newAddr
    Return 1
End Function

Private Function ExecRunDeleteStmt(ByRef ps As ParseState, ByRef es As ExecState, ByRef st As ASTNode, ByRef errText As String) As Integer
    Dim targetNode As Integer
    targetNode = st.left
    If targetNode = -1 Then
        errText = "exec: DELETE target missing"
        Return 0
    End If

    If UCase(ps.ast.nodes(targetNode).kind) <> "IDENT" Then
        errText = "exec: DELETE target must be ident"
        Return 0
    End If

    Dim varName As String
    varName = ps.ast.nodes(targetNode).value

    Dim varIdx As Integer
    varIdx = ExecFindVar(es, varName)
    If varIdx = -1 Then
        errText = "exec: DELETE variable not found " & UCase(varName)
        Return 0
    End If

    Dim declType As String
    declType = UCase(Trim(es.vars(varIdx).declType))
    Dim runtimeType As String
    runtimeType = UCase(Trim(es.vars(varIdx).runtimeClassType))

    If declType <> "OBJECT" And ExecFindClassDeclNode(ps, declType) = -1 Then
        errText = "exec: DELETE target must be class or OBJECT"
        Return 0
    End If

    Dim objAddr As UInteger
    objAddr = es.vars(varIdx).addr
    If objAddr = 0 Then objAddr = CUInt(ExecValueToInteger(es.vars(varIdx).value))

    If objAddr <> 0 Then
        Dim dtorType As String
        dtorType = runtimeType
        If dtorType = "" And declType <> "OBJECT" Then dtorType = declType

        If dtorType <> "" And ExecFindClassDeclNode(ps, dtorType) <> -1 Then
            If ExecInvokeClassDtorIfPresent(ps, es, dtorType, objAddr, errText) = 0 Then Return 0
        End If
    End If

    ExecSetVar es, varName, 0
    ExecSetVarAddr es, varName, 0
    es.vars(varIdx).runtimeClassType = ""
    Return 1
End Function

Private Function ExecRunMemoryCoreStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef st As ASTNode, ByRef errText As String) As Integer
    Select Case UCase(st.kind)
    Case "ASSIGN_STMT"
        Return ExecRunAssignStmt(ps, es, st, errText)
    Case "DELETE_STMT"
        Return ExecRunDeleteStmt(ps, es, st, errText)
    Case "INCDEC_STMT"
        Return ExecRunIncDecStmt(ps, es, st, errText)
    Case "RANDOMIZE_STMT"
        Return ExecRunRandomizeStmt(ps, es, stmtIdx, errText)
    Case "POKEB_STMT"
        Return ExecRunPokeBStmt(ps, es, stmtIdx, errText)
    Case "POKEW_STMT"
        Return ExecRunPokeWStmt(ps, es, stmtIdx, errText)
    Case "POKED_STMT"
        Return ExecRunPokeDStmt(ps, es, stmtIdx, errText)
    Case "MEMCOPYB_STMT"
        Return ExecRunMemCopyBStmt(ps, es, stmtIdx, errText)
    Case "MEMFILLB_STMT"
        Return ExecRunMemFillBStmt(ps, es, stmtIdx, errText)
    Case "POKES_STMT"
        Return ExecRunPokeSStmt(ps, es, stmtIdx, errText)
    Case "MEMCOPYW_STMT"
        Return ExecRunMemCopyWStmt(ps, es, stmtIdx, errText)
    Case "MEMCOPYD_STMT"
        Return ExecRunMemCopyDStmt(ps, es, stmtIdx, errText)
    Case "MEMFILLW_STMT"
        Return ExecRunMemFillWStmt(ps, es, stmtIdx, errText)
    Case "MEMFILLD_STMT"
        Return ExecRunMemFillDStmt(ps, es, stmtIdx, errText)
    Case "SETNEWOFFSET_STMT"
        Return ExecRunSetNewOffsetStmt(ps, es, stmtIdx, errText)
    End Select

    Return -2
End Function
