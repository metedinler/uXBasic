Private Function ExecRunAssignStmt(ByRef ps As ParseState, ByRef es As ExecState, ByRef st As ASTNode, ByRef errText As String) As Integer
    Dim lhs As Integer
    lhs = st.left
    If lhs = -1 Then
        errText = "exec: assign lhs missing"
        Return 0
    End If

    Dim rhsValue As ExecValue
    If ExecEvalExpression(ps, st.right, es, rhsValue, errText) = 0 Then Return 0

    Dim curValue As ExecValue
    Dim targetName As String
    Dim targetIdx As Integer
    Dim arrayVarIdx As Integer
    Dim arrayElemIdx As Integer
    Dim isArrayTarget As Integer
    isArrayTarget = 0

    If UCase(ps.ast.nodes(lhs).kind) = "IDENT" Then
        targetName = ps.ast.nodes(lhs).value
        If ExecGetVarValue(es, targetName, curValue) = 0 Then
            ExecValueInit curValue
        End If
    ElseIf ExecTryResolveArrayAccess(ps, es, lhs, arrayVarIdx, arrayElemIdx, errText) <> 0 Then
        isArrayTarget = 1
        targetName = es.vars(arrayVarIdx).nameText
        If ExecGetArrayElement(es, arrayVarIdx, arrayElemIdx, curValue) = 0 Then
            errText = "exec: array element read failed"
            Return 0
        End If
    ElseIf UCase(ps.ast.nodes(lhs).kind) = "FIELD_EXPR" Then
        If ExecReadFieldValue(ps, es, lhs, curValue, errText) = 0 Then Return 0
        targetName = "__FIELD__"
    Else
        If errText = "" Then errText = "exec: assign lhs must be ident, indexed array, or field"
        Return 0
    End If

    Dim opText As String
    opText = Trim(st.op)
    If opText = "" Then opText = "="

    Dim outValue As ExecValue
    Select Case opText
    Case "="
        outValue = rhsValue
    Case "+="
        If curValue.valueType = "FLOAT" Or rhsValue.valueType = "FLOAT" Then
            ExecValueSetFloat outValue, ExecValueToFloat(curValue) + ExecValueToFloat(rhsValue)
        Else
            ExecValueSetInteger outValue, ExecValueToInteger(curValue) + ExecValueToInteger(rhsValue)
        End If
    Case "-="
        If curValue.valueType = "FLOAT" Or rhsValue.valueType = "FLOAT" Then
            ExecValueSetFloat outValue, ExecValueToFloat(curValue) - ExecValueToFloat(rhsValue)
        Else
            ExecValueSetInteger outValue, ExecValueToInteger(curValue) - ExecValueToInteger(rhsValue)
        End If
    Case "*="
        If curValue.valueType = "FLOAT" Or rhsValue.valueType = "FLOAT" Then
            ExecValueSetFloat outValue, ExecValueToFloat(curValue) * ExecValueToFloat(rhsValue)
        Else
            ExecValueSetInteger outValue, ExecValueToInteger(curValue) * ExecValueToInteger(rhsValue)
        End If
    Case "/="
        If ExecValueToFloat(rhsValue) = 0.0 Then
            errText = "exec: division by zero"
            Return 0
        End If
        ExecValueSetFloat outValue, ExecValueToFloat(curValue) / ExecValueToFloat(rhsValue)
    Case "\="
        If ExecValueToInteger(rhsValue) = 0 Then
            errText = "exec: integer division by zero"
            Return 0
        End If
        ExecValueSetInteger outValue, ExecValueToInteger(curValue) \ ExecValueToInteger(rhsValue)
    Case "=+"
        outValue = rhsValue
    Case "=-"
        If rhsValue.valueType = "FLOAT" Then
            ExecValueSetFloat outValue, -ExecValueToFloat(rhsValue)
        Else
            ExecValueSetInteger outValue, -ExecValueToInteger(rhsValue)
        End If
    Case Else
        errText = "exec: unsupported assign op " & opText
        Return 0
    End Select

    If UCase(ps.ast.nodes(lhs).kind) = "FIELD_EXPR" Then
        If ExecWriteFieldValue(ps, es, lhs, outValue, errText) = 0 Then Return 0
    ElseIf isArrayTarget <> 0 Then
        If ExecSetArrayElement(es, arrayVarIdx, arrayElemIdx, outValue) = 0 Then
            errText = "exec: array element write failed"
            Return 0
        End If
    Else
        ExecSetVarValue es, targetName, outValue
    End If

    targetIdx = ExecFindVar(es, targetName)
    If targetIdx <> -1 Then
        Dim targetDeclType As String
        targetDeclType = UCase(Trim(es.vars(targetIdx).declType))
        Dim isClassLikeTarget As Integer
        isClassLikeTarget = 0
        If targetDeclType = "OBJECT" Then
            isClassLikeTarget = 1
        ElseIf targetDeclType <> "" And ExecFindClassDeclNode(ps, targetDeclType) <> -1 Then
            isClassLikeTarget = 1
        End If

        If isClassLikeTarget <> 0 And es.vars(targetIdx).isArray = 0 Then
            If opText <> "=" Then
                errText = "exec: class assignment only supports ="
                Return 0
            End If

            If st.right <> -1 And UCase(ps.ast.nodes(st.right).kind) = "NEW_EXPR" Then
                Dim rhsNewType As String
                rhsNewType = UCase(Trim(ps.ast.nodes(st.right).value))
                If ExecCanAssignClassType(ps, targetDeclType, rhsNewType) = 0 Then
                    errText = "exec: class assignment type mismatch expected=" & targetDeclType & " actual=" & rhsNewType
                    Return 0
                End If
                es.vars(targetIdx).runtimeClassType = rhsNewType
            ElseIf ExecValueToInteger(outValue) = 0 Then
                es.vars(targetIdx).runtimeClassType = ""
            ElseIf targetDeclType <> "OBJECT" Then
                es.vars(targetIdx).runtimeClassType = targetDeclType
            End If

            ExecSetVarAddr es, targetName, CUInt(ExecValueToInteger(outValue))
        End If
    End If

    Return 1
End Function

Private Function ExecRunIncDecStmt(ByRef ps As ParseState, ByRef es As ExecState, ByRef st As ASTNode, ByRef errText As String) As Integer
    Dim lhs2 As Integer
    lhs2 = st.left
    If lhs2 = -1 Then
        errText = "exec: inc/dec target missing"
        Return 0
    End If

    Dim curVal As Integer
    Dim nextValue As ExecValue
    Dim arrayVarIdx2 As Integer
    Dim arrayElemIdx2 As Integer
    If UCase(ps.ast.nodes(lhs2).kind) = "IDENT" Then
        curVal = ExecGetVar(es, ps.ast.nodes(lhs2).value)
    ElseIf ExecTryResolveArrayAccess(ps, es, lhs2, arrayVarIdx2, arrayElemIdx2, errText) <> 0 Then
        If ExecGetArrayElement(es, arrayVarIdx2, arrayElemIdx2, nextValue) = 0 Then
            errText = "exec: inc/dec array read failed"
            Return 0
        End If
        curVal = ExecValueToInteger(nextValue)
    ElseIf UCase(ps.ast.nodes(lhs2).kind) = "FIELD_EXPR" Then
        If ExecReadFieldValue(ps, es, lhs2, nextValue, errText) = 0 Then Return 0
        curVal = ExecValueToInteger(nextValue)
    Else
        If errText = "" Then errText = "exec: inc/dec target must be ident, indexed array, or field"
        Return 0
    End If

    If st.op = "++" Then
        ExecValueSetInteger nextValue, curVal + 1
    ElseIf st.op = "--" Then
        ExecValueSetInteger nextValue, curVal - 1
    Else
        errText = "exec: unknown inc/dec op"
        Return 0
    End If

    If UCase(ps.ast.nodes(lhs2).kind) = "IDENT" Then
        ExecSetVar es, ps.ast.nodes(lhs2).value, nextValue.intValue
    ElseIf UCase(ps.ast.nodes(lhs2).kind) = "FIELD_EXPR" Then
        If ExecWriteFieldValue(ps, es, lhs2, nextValue, errText) = 0 Then Return 0
    Else
        If ExecSetArrayElement(es, arrayVarIdx2, arrayElemIdx2, nextValue) = 0 Then
            errText = "exec: inc/dec array write failed"
            Return 0
        End If
    End If

    Return 1
End Function

Private Function ExecRunRandomizeStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef errText As String) As Integer
    Dim randomizeCount As Integer
    randomizeCount = ExecChildCount(ps, stmtIdx)

    If randomizeCount = 0 Then
        Randomize Timer
        Return 1
    End If

    Dim seedExpr As Integer
    seedExpr = ExecChildAt(ps, stmtIdx, 0)
    If seedExpr = -1 Then
        errText = "exec: RANDOMIZE seed missing"
        Return 0
    End If

    Dim seedValue As Integer
    seedValue = ExecEvalNode(ps, es, seedExpr, errText)
    If errText <> "" Then Return 0

    Randomize seedValue
    Return 1
End Function

Private Function ExecRunPokeBStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef errText As String) As Integer
    Dim pb0 As Integer
    Dim pb1 As Integer
    pb0 = ExecChildAt(ps, stmtIdx, 0)
    pb1 = ExecChildAt(ps, stmtIdx, 1)
    If pb0 = -1 Or pb1 = -1 Then
        errText = "exec: POKEB args missing"
        Return 0
    End If

    Dim pbAddr As Integer
    Dim pbVal As Integer
    pbAddr = ExecEvalNode(ps, es, pb0, errText)
    If errText <> "" Then Return 0
    pbVal = ExecEvalNode(ps, es, pb1, errText)
    If errText <> "" Then Return 0

    If VMemPokeB(CUInt(pbAddr), pbVal) = 0 Then
        errText = "exec: POKEB out of range"
        Return 0
    End If

    Return 1
End Function

