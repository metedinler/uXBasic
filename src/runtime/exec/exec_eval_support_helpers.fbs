Private Function ExecChildAt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal childPos As Integer) As Integer
    Dim i As Integer
    Dim ch As Integer

    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If i = childPos Then Return ch
        i += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return -1
End Function

Private Function ExecChildCount(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    Dim total As Integer
    Dim ch As Integer

    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        total += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return total
End Function

Private Function ExecFindChildByKind(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal kindText As String) As Integer
    Dim targetKind As String
    targetKind = UCase(kindText)

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If UCase(ps.ast.nodes(ch).kind) = targetKind Then Return ch
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return -1
End Function

Private Function ExecTypeElemSizeBytes(ByVal typeNameRaw As String) As Integer
    Dim typeName As String
    typeName = UCase(Trim(typeNameRaw))

    Select Case typeName
    Case "I8", "U8", "BYTE"
        Return 1
    Case "I16", "U16", "SHORT"
        Return 2
    Case "I32", "U32", "INTEGER", "LONG"
        Return 4
    Case "I64", "U64"
        Return 8
    Case "F32", "SINGLE"
        Return 4
    Case "F64", "DOUBLE", "F80", "EXTENDED"
        Return 8
    End Select

    Return 0
End Function

Private Function ExecNormalizeTypeName(ByVal typeNameRaw As String) As String
    Dim t As String
    t = UCase(Trim(typeNameRaw))

    Select Case t
    Case "INTEGER", "LONG"
        Return "I32"
    Case "SHORT"
        Return "I16"
    Case "BYTE"
        Return "I8"
    Case "SINGLE"
        Return "F32"
    Case "DOUBLE", "EXTENDED"
        Return "F64"
    End Select

    Return t
End Function

Private Function ExecParseBoundRange(ByRef ps As ParseState, ByRef es As ExecState, ByVal boundNode As Integer, ByRef lowerOut As Integer, ByRef upperOut As Integer, ByRef errText As String) As Integer
    If boundNode = -1 Then
        errText = "exec: DIM/REDIM bound node missing"
        Return 0
    End If

    Dim b As ASTNode
    b = ps.ast.nodes(boundNode)

    If UCase(b.kind) = "RANGE_EXPR" Then
        lowerOut = ExecEvalNode(ps, es, b.left, errText)
        If errText <> "" Then Return 0

        upperOut = ExecEvalNode(ps, es, b.right, errText)
        If errText <> "" Then Return 0
    Else
        lowerOut = 0
        upperOut = ExecEvalNode(ps, es, boundNode, errText)
        If errText <> "" Then Return 0
    End If

    If upperOut < lowerOut Then
        errText = "exec: DIM/REDIM invalid array bounds (lower > upper)"
        Return 0
    End If

    Return 1
End Function

Private Sub ExecSetVarDeclMeta(ByRef es As ExecState, ByRef nameText As String, ByRef declType As String, ByVal isArray As Integer, ByVal arrayDims As Integer, ByVal arrayLower As Integer, ByVal arrayUpper As Integer, ByVal arrayBytes As LongInt)
    Dim idx As Integer
    idx = ExecEnsureVar(es, nameText)
    If idx = -1 Then Exit Sub

    es.vars(idx).declType = ExecNormalizeTypeName(declType)
    es.vars(idx).isArray = isArray
    es.vars(idx).arrayDims = arrayDims
    es.vars(idx).arrayLower = arrayLower
    es.vars(idx).arrayUpper = arrayUpper
    es.vars(idx).arrayBytes = arrayBytes
End Sub

Private Function ExecLabelIndexOf(labelNames() As String, ByVal labelCount As Integer, ByRef needle As String) As Integer
    Dim i As Integer
    For i = 0 To labelCount - 1
        If labelNames(i) = needle Then Return i
    Next i
    Return -1
End Function

Private Function ExecBuildTopLevelLabelMap(ByRef ps As ParseState, ByVal rootNode As Integer, labelNames() As String, labelNodes() As Integer, ByRef labelCount As Integer, ByRef errText As String) As Integer
    labelCount = 0

    Dim st As Integer
    st = ps.ast.nodes(rootNode).firstChild
    Do While st <> -1
        If UCase(ps.ast.nodes(st).kind) = "LABEL_STMT" Then
            Dim labelName As String
            labelName = UCase(Trim(ps.ast.nodes(st).value))
            If labelName = "" Then
                errText = "exec: LABEL name missing"
                Return 0
            End If

            If ExecLabelIndexOf(labelNames(), labelCount, labelName) <> -1 Then
                errText = "exec: duplicate LABEL " & labelName
                Return 0
            End If

            If labelCount = 0 Then
                ReDim labelNames(0)
                ReDim labelNodes(0)
            Else
                ReDim Preserve labelNames(labelCount)
                ReDim Preserve labelNodes(labelCount)
            End If

            labelNames(labelCount) = labelName
            labelNodes(labelCount) = st
            labelCount += 1
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    Return 1
End Function

Private Function ExecEvalStringLiteral(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef textOut As String, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "exec: invalid string node"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    If UCase(n.kind) <> "STRING" Then
        errText = "exec: string literal expected"
        Return 0
    End If

    textOut = n.value
    Return 1
End Function

Private Function ExecFormatFileError(ByRef io As UxbFileRuntime) As String
    Dim errorCode As Integer
    errorCode = UxbFileGetLastError(io)
    Return UxbFormatError(errorCode, UxbFileErrorText(errorCode))
End Function

Private Function ExecHashText(ByRef textValue As String) As UInteger
    Dim h As UInteger
    h = CUInt(&h811C9DC5)

    Dim i As Integer
    For i = 1 To Len(textValue)
        h = h Xor CUInt(Asc(Mid(textValue, i, 1)) And &hFF)
        h *= CUInt(&h01000193)
    Next i

    Return h
End Function

Private Function ExecRol32(ByVal v As UInteger, ByVal s As Integer) As UInteger
    Dim shiftBits As Integer
    shiftBits = s And 31
    If shiftBits = 0 Then Return v
    Return (v Shl shiftBits) Or (v Shr (32 - shiftBits))
End Function

Private Function ExecRor32(ByVal v As UInteger, ByVal s As Integer) As UInteger
    Dim shiftBits As Integer
    shiftBits = s And 31
    If shiftBits = 0 Then Return v
    Return (v Shr shiftBits) Or (v Shl (32 - shiftBits))
End Function

Private Function ExecDebugInputQueuePop(ByRef lineOut As String) As Integer
    If gDebugInputQueueReadPos >= gDebugInputQueueCount Then Return 0
    lineOut = gDebugInputQueue(gDebugInputQueueReadPos)
    gDebugInputQueueReadPos += 1
    Return 1
End Function

Private Function ExecDebugKeyQueuePop(ByRef keyOut As Integer) As Integer
    If gDebugKeyQueueReadPos >= gDebugKeyQueueCount Then Return 0
    keyOut = gDebugKeyQueue(gDebugKeyQueueReadPos)
    gDebugKeyQueueReadPos += 1
    Return 1
End Function

Private Function ExecRoutineIndexOf(ByRef needle As String) As Integer
    Dim i As Integer
    For i = 0 To gRoutineDefCount - 1
        If gRoutineDefs(i).nameText = needle Then Return i
    Next i
    Return -1
End Function

Private Function ExecBuildTopLevelRoutineMap(ByRef ps As ParseState, ByVal rootNode As Integer, ByRef errText As String) As Integer
    gRoutineDefCount = 0
    Erase gRoutineDefs

    Dim st As Integer
    st = ps.ast.nodes(rootNode).firstChild
    Do While st <> -1
        Dim stKind As String
        stKind = UCase(ps.ast.nodes(st).kind)

        If stKind = "SUB_STMT" Or stKind = "FUNCTION_STMT" Then
            Dim routineName As String
            routineName = UCase(Trim(ps.ast.nodes(st).value))
            If routineName = "" Then
                errText = "exec: routine name missing"
                Return 0
            End If

            If ExecRoutineIndexOf(routineName) <> -1 Then
                errText = "exec: duplicate routine " & routineName
                Return 0
            End If

            If gRoutineDefCount = 0 Then
                ReDim gRoutineDefs(0)
            Else
                ReDim Preserve gRoutineDefs(gRoutineDefCount)
            End If

            gRoutineDefs(gRoutineDefCount).nameText = routineName
            gRoutineDefs(gRoutineDefCount).nodeIdx = st
            gRoutineDefs(gRoutineDefCount).routineKind = stKind
            gRoutineDefCount += 1
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    Return 1
End Function

Sub ExecSetFfiPolicyPath(ByRef pathText As String)
    Dim p As String
    p = Trim(pathText)
    If p = "" Then
        gFfiPolicyPath = "dist/config/ffi_allowlist.txt"
    Else
        gFfiPolicyPath = p
    End If

    gFfiAllowlistLoaded = 0
    gFfiAllowlistLoadFailed = 0
    gFfiAllowlistLoadFailReason = ""
    gFfiAllowEntryCount = 0
    Erase gFfiAllowEntries
End Sub

Private Function ExecGetFfiPolicyPath() As String
    If Trim(gFfiPolicyPath) = "" Then
        gFfiPolicyPath = "dist/config/ffi_allowlist.txt"
    End If
    Return gFfiPolicyPath
End Function

Sub ExecSetFfiPolicyMode(ByRef modeText As String)
    Dim m As String
    m = UCase(Trim(modeText))
    If m = "ENFORCE" Then
        gFfiPolicyEnforce = 1
    Else
        gFfiPolicyEnforce = 0
    End If
End Sub

Private Function ExecGetFfiPolicyMode() As String
    If gFfiPolicyEnforce <> 0 Then Return "ENFORCE"
    Return "REPORT_ONLY"
End Function

Private Sub ExecNormalizeError(ByRef errText As String)
    If errText = "" Then Exit Sub

    Dim t As String
    t = LCase(LTrim(errText))
    If Left(t, Len(EXEC_ERR_PREFIX)) <> EXEC_ERR_PREFIX Then
        errText = EXEC_ERR_PREFIX & errText
    End If
End Sub

Private Function ExecConsumeLoopExit(ByRef loopKind As String) As Integer
    If gExitRequest = "" Then Return 0

    Dim req As String
    req = UCase(gExitRequest)

    If req = "ANY" Or req = UCase(loopKind) Then
        gExitRequest = ""
        Return 1
    End If

    Return 2
End Function

Private Function ExecIsStmtNode(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim kindUpper As String
    kindUpper = UCase(ps.ast.nodes(nodeIdx).kind)

    If Len(kindUpper) < 5 Then Return 0
    If Right(kindUpper, 5) = "_STMT" Then Return 1
    Return 0
End Function

Private Function ExecClampI32(ByVal valueIn As Double) As Integer
    If valueIn > 2147483647# Then Return 2147483647
    If valueIn < -2147483648# Then Return -2147483648
    Return CInt(valueIn)
End Function

Private Function ExecTimerUnitScale(ByRef unitText As String, ByRef scaleOut As Double) As Integer
    Dim u As String
    u = LCase(Trim(unitText))

    Select Case u
    Case "ns"
        scaleOut = 1000000000#
    Case "us"
        scaleOut = 1000000#
    Case "ms"
        scaleOut = 1000#
    Case "s"
        scaleOut = 1#
    Case "min"
        scaleOut = 1# / 60#
    Case "h"
        scaleOut = 1# / 3600#
    Case "day"
        scaleOut = 1# / 86400#
    Case "year"
        scaleOut = 1# / (86400# * 365#)
    Case Else
        scaleOut = 0#
        Return 0
    End Select

    Return 1
End Function

Private Function ExecBuiltinArgAsTypeName(ByRef ps As ParseState, ByVal callNodeIdx As Integer, ByRef callName As String, ByRef typeNameOut As String, ByRef errText As String) As Integer
    Dim a0 As Integer
    a0 = ExecChildAt(ps, callNodeIdx, 0)
    If a0 = -1 Then
        errText = "exec: " & callName & " type arg missing"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(a0)
    If UCase(n.kind) <> "IDENT" And UCase(n.kind) <> "KEYWORD_REF" Then
        errText = "exec: " & callName & " expects type name"
        Return 0
    End If

    typeNameOut = n.value
    Return 1
End Function

Private Function ExecIsAllowedDllSignature(ByRef signatureText As String) As Integer
    Dim s As String
    s = UCase(Trim(signatureText))

    Select Case s
    Case "I32", "U64", "F64", "PTR", "STRPTR", "BYREF", "BYVAL", "CDECL", "STDCALL"
        Return 1
    End Select

    Return 0
End Function

Private Function ExecIsDllCallingConvention(ByRef conventionText As String) As Integer
    Dim s As String
    s = UCase(Trim(conventionText))

    Select Case s
    Case "CDECL", "STDCALL"
        Return 1
    End Select

    Return 0
End Function

Private Function ExecGetActiveFfiAbiName() As String
#Ifdef __FB_64BIT__
    Return "WIN64-MSABI"
#Else
    Return "X86-32"
#EndIf
End Function

Private Function ExecAreDllCallingConventionsCompatible(ByRef requestedConventionText As String, ByRef allowedConventionText As String) As Integer
    Dim req As String
    Dim allow As String
    req = UCase(Trim(requestedConventionText))
    allow = UCase(Trim(allowedConventionText))

    If req = "" Then req = "CDECL"
    If allow = "" Or allow = "*" Then Return 1
    If allow = req Then Return 1

#Ifdef __FB_64BIT__
    If (allow = "CDECL" Or allow = "STDCALL") And (req = "CDECL" Or req = "STDCALL") Then
        Return 1
    End If
#EndIf

    Return 0
End Function

Private Function ExecContainsInvalidDllChars(ByRef dllName As String) As Integer
    Dim i As Integer
    For i = 1 To Len(dllName)
        Dim ch As Integer
        ch = Asc(Mid(dllName, i, 1))

        If ch < 32 Then Return 1

        Select Case ch
        Case 34, 42, 59, 60, 62, 63, 124
            Return 1
        End Select
    Next i

    Return 0
End Function

Private Function ExecIsAbsoluteDllPath(ByRef dllName As String) As Integer
    Dim s As String
    s = Trim(dllName)

    If s = "" Then Return 0
    If Left(s, 1) = "\" Or Left(s, 1) = "/" Then Return 1

    If Len(s) >= 2 Then
        Dim firstCh As Integer
        firstCh = Asc(UCase(Left(s, 1)))
        If firstCh >= Asc("A") And firstCh <= Asc("Z") Then
            If Mid(s, 2, 1) = ":" Then Return 1
        End If
    End If

    Return 0
End Function

Private Function ExecHasDllPathSegments(ByRef dllName As String) As Integer
    If Instr(dllName, "..") > 0 Then Return 1
    If Instr(dllName, "\") > 0 Then Return 1
    If Instr(dllName, "/") > 0 Then Return 1
    Return 0
End Function

Private Function ExecNormalizeDllName(ByRef dllNameIn As String, ByRef dllNameOut As String, ByRef errText As String) As Integer
    dllNameOut = Trim(dllNameIn)

    If dllNameOut = "" Then
        errText = "exec: CALL(DLL) library cannot be empty (" & LTrim(Str(UXB_FFI_ERR_BAD_LIB)) & ")"
        Return 0
    End If

    If ExecIsAbsoluteDllPath(dllNameOut) <> 0 Then
        errText = "exec: CALL(DLL) library must not be absolute path (" & LTrim(Str(UXB_FFI_ERR_DLL_ABSOLUTE_PATH)) & ")"
        Return 0
    End If

    If ExecHasDllPathSegments(dllNameOut) <> 0 Then
        errText = "exec: CALL(DLL) library path segments not allowed (" & LTrim(Str(UXB_FFI_ERR_DLL_PATH_SEGMENTS)) & ")"
        Return 0
    End If

    If ExecContainsInvalidDllChars(dllNameOut) <> 0 Then
        errText = "exec: CALL(DLL) library contains invalid chars (" & LTrim(Str(UXB_FFI_ERR_DLL_INVALID_CHARS)) & ")"
        Return 0
    End If

    dllNameOut = UCase(dllNameOut)
    Return 1
End Function

Private Function ExecNormalizeFfiHashToken(ByRef hashIn As String, ByRef hashOut As String) As Integer
    hashOut = UCase(Trim(hashIn))
    If hashOut = "" Then Return 0
    If hashOut = "*" Then Return 1
    If Len(hashOut) <> 64 Then Return 0

    Dim i As Integer
    For i = 1 To Len(hashOut)
        Dim ch As Integer
        ch = Asc(Mid(hashOut, i, 1))
        If (ch >= Asc("0") And ch <= Asc("9")) Or (ch >= Asc("A") And ch <= Asc("F")) Then
            ' valid
        Else
            Return 0
        End If
    Next i

    Return 1
End Function

Private Function ExecNormalizeFfiSignerToken(ByRef signerIn As String, ByRef signerOut As String) As Integer
    signerOut = UCase(Trim(signerIn))
    If signerOut = "" Then Return 0
    If Instr(signerOut, "|") > 0 Then Return 0
    Return 1
End Function

Private Sub ExecFfiAllowlistAppend(ByRef dllName As String, ByRef symbolName As String, ByRef signatureText As String, ByRef callingConventionText As String, ByRef hashText As String, ByRef signerText As String)
    If gFfiAllowEntryCount = 0 Then
        ReDim gFfiAllowEntries(0)
    Else
        ReDim Preserve gFfiAllowEntries(gFfiAllowEntryCount)
    End If

    gFfiAllowEntries(gFfiAllowEntryCount).dllName = UCase(Trim(dllName))
    gFfiAllowEntries(gFfiAllowEntryCount).symbolName = UCase(Trim(symbolName))
    gFfiAllowEntries(gFfiAllowEntryCount).signatureText = UCase(Trim(signatureText))
    gFfiAllowEntries(gFfiAllowEntryCount).callingConventionText = UCase(Trim(callingConventionText))
    gFfiAllowEntries(gFfiAllowEntryCount).hashText = UCase(Trim(hashText))
    gFfiAllowEntries(gFfiAllowEntryCount).signerText = UCase(Trim(signerText))
    gFfiAllowEntryCount += 1
End Sub

Private Sub ExecSeedDefaultFfiAllowlist()
    Dim dll0 As String
    Dim symbol0 As String
    Dim sig0 As String
    Dim conv0 As String
    Dim hash0 As String
    Dim signer0 As String
    dll0 = "KERNEL32.DLL"
    symbol0 = "GETTICKCOUNT"
    sig0 = "I32"
    conv0 = "*"
    hash0 = "1111111111111111111111111111111111111111111111111111111111111111"
    signer0 = "CN=MICROSOFT WINDOWS"
    ExecFfiAllowlistAppend dll0, symbol0, sig0, conv0, hash0, signer0

    Dim dll1 As String
    Dim symbol1 As String
    Dim sig1 As String
    Dim conv1 As String
    Dim hash1 As String
    Dim signer1 As String
    dll1 = "USER32.DLL"
    symbol1 = "MESSAGEBOXA"
    sig1 = "I32"
    conv1 = "*"
    hash1 = "2222222222222222222222222222222222222222222222222222222222222222"
    signer1 = "CN=MICROSOFT WINDOWS"
    ExecFfiAllowlistAppend dll1, symbol1, sig1, conv1, hash1, signer1
End Sub

Private Function ExecParseFfiAllowlistLine(ByRef lineText As String, ByRef dllOut As String, ByRef symbolOut As String, ByRef sigOut As String, ByRef convOut As String, ByRef hashOut As String, ByRef signerOut As String) As Integer
    Dim lineTrim As String
    lineTrim = Trim(lineText)
    If lineTrim = "" Then Return 0
    If Left(lineTrim, 1) = "#" Then Return 0

    Dim p1 As Integer
    Dim p2 As Integer
    Dim p3 As Integer
    Dim p4 As Integer
    Dim p5 As Integer
    p1 = Instr(lineTrim, "|")
    If p1 <= 1 Then Return 0

    p2 = Instr(p1 + 1, lineTrim, "|")
    If p2 <= p1 + 1 Then Return 0

    p3 = Instr(p2 + 1, lineTrim, "|")
    p4 = 0
    p5 = 0
    If p3 > 0 Then
        p4 = Instr(p3 + 1, lineTrim, "|")
        If p4 <= p3 + 1 Then Return 0
        p5 = Instr(p4 + 1, lineTrim, "|")
        If p5 > 0 Then
            If p5 <= p4 + 1 Then Return 0
            If Instr(p5 + 1, lineTrim, "|") > 0 Then Return 0
        End If
    End If

    Dim dllCandidate As String
    dllCandidate = Trim(Left(lineTrim, p1 - 1))

    symbolOut = UCase(Trim(Mid(lineTrim, p1 + 1, p2 - p1 - 1)))

    If p3 > 0 Then
        Dim hashCandidate As String
        Dim signerCandidate As String
        sigOut = UCase(Trim(Mid(lineTrim, p2 + 1, p3 - p2 - 1)))

        If p5 > 0 Then
            Dim convCandidate As String
            convCandidate = UCase(Trim(Mid(lineTrim, p3 + 1, p4 - p3 - 1)))
            If convCandidate = "" Then
                convOut = "*"
            Else
                convOut = convCandidate
            End If
            hashCandidate = Mid(lineTrim, p4 + 1, p5 - p4 - 1)
            signerCandidate = Mid(lineTrim, p5 + 1)
        Else
            convOut = "*"
            hashCandidate = Mid(lineTrim, p3 + 1, p4 - p3 - 1)
            signerCandidate = Mid(lineTrim, p4 + 1)
        End If

        If ExecNormalizeFfiHashToken(hashCandidate, hashOut) = 0 Then Return 0
        If ExecNormalizeFfiSignerToken(signerCandidate, signerOut) = 0 Then Return 0
    Else
        sigOut = UCase(Trim(Mid(lineTrim, p2 + 1)))
        convOut = "*"
        hashOut = ""
        signerOut = ""
    End If

    Dim normalizeErr As String
    If ExecNormalizeDllName(dllCandidate, dllOut, normalizeErr) = 0 Then Return 0

    If symbolOut = "" Or sigOut = "" Then Return 0
    If ExecIsAllowedDllSignature(sigOut) = 0 Then Return 0
    If convOut <> "*" And ExecIsDllCallingConvention(convOut) = 0 Then Return 0

    Return 1
End Function

Private Sub ExecLoadFfiAllowlistIfNeeded()
    If gFfiAllowlistLoaded <> 0 Then Exit Sub
    gFfiAllowlistLoaded = 1
    gFfiAllowlistLoadFailed = 0
    gFfiAllowlistLoadFailReason = ""
    gFfiAllowEntryCount = 0
    Erase gFfiAllowEntries

    Dim policyPath As String
    policyPath = ExecGetFfiPolicyPath()

    If Dir(policyPath) = "" Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "file-not-found"
            DiagUyari "FFI policy file not found, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy file not found, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    Dim f As Integer
    f = FreeFile
    Open policyPath For Input As #f
    If Err <> 0 Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "open-failed"
            DiagUyari "FFI policy open failed, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy open failed, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    Dim headerSeen As Integer
    Dim headerValid As Integer
    headerSeen = 0
    headerValid = 0

    Do While Not Eof(f)
        Dim lineText As String
        Line Input #f, lineText

        Dim lineTrim As String
        lineTrim = Trim(lineText)

        If lineTrim <> "" Then
            If headerSeen = 0 Then
                headerSeen = 1

                Dim headerText As String
                headerText = UCase(lineTrim)
                If Left(headerText, 1) = "#" Then
                    headerText = UCase(Trim(Mid(lineTrim, 2)))
                End If

                If headerText <> UXB_FFI_POLICY_HEADER_V1 Then
                    Close #f
                    If ExecGetFfiPolicyMode() = "ENFORCE" Then
                        gFfiAllowlistLoadFailed = 1
                        gFfiAllowlistLoadFailReason = "header-invalid"
                        DiagUyari "FFI policy header invalid, enforce deny path=" & policyPath
                    Else
                        ExecSeedDefaultFfiAllowlist
                        DiagUyari "FFI policy header invalid, defaults active path=" & policyPath
                    End If
                    Exit Sub
                End If

                headerValid = 1
            Else
                Dim dllName As String
                Dim symbolName As String
                Dim signatureText As String
                Dim callingConventionText As String
                Dim hashText As String
                Dim signerText As String
                If ExecParseFfiAllowlistLine(lineText, dllName, symbolName, signatureText, callingConventionText, hashText, signerText) <> 0 Then
                    ExecFfiAllowlistAppend dllName, symbolName, signatureText, callingConventionText, hashText, signerText
                End If
            End If
        End If
    Loop

    Close #f

    If headerValid = 0 Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "header-missing"
            DiagUyari "FFI policy header missing, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy header missing, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    If gFfiAllowEntryCount = 0 Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "no-valid-entries"
            DiagUyari "FFI policy had no valid entries, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy had no valid entries, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    DiagBilgi "FFI policy loaded path=" & policyPath & " entries=" & LTrim(Str(gFfiAllowEntryCount))
End Sub

Private Function ExecPolicyDenyCode(ByRef reasonText As String) As Integer
    Select Case LCase(Trim(reasonText))
    Case "deny-policy-load-failed"
        Return UXB_FFI_ERR_POLICY_LOAD_FAILED
    Case "deny-attestation-required"
        Return UXB_FFI_ERR_POLICY_ATTEST_REQUIRED
    Case "deny-hash-mismatch"
        Return UXB_FFI_ERR_POLICY_HASH_MISMATCH
    Case "deny-signer-mismatch"
        Return UXB_FFI_ERR_POLICY_SIGNER_MISMATCH
    Case "deny-hash-extract-failed"
        Return UXB_FFI_ERR_POLICY_HASH_EXTRACT_FAILED
    Case "deny-signer-extract-failed"
        Return UXB_FFI_ERR_POLICY_SIGNER_EXTRACT_FAILED
    Case "deny-not-allowlisted"
        Return UXB_FFI_ERR_POLICY_DENY
    Case Else
        Return 0
    End Select
End Function

Private Function ExecPolicyDenyPhase(ByRef reasonText As String) As String
    Select Case LCase(Trim(reasonText))
    Case "deny-policy-load-failed"
        Return "policy-load"
    Case "deny-hash-mismatch", "deny-hash-extract-failed"
        Return "hash-verify"
    Case "deny-signer-mismatch", "deny-signer-extract-failed"
        Return "signer-verify"
    Case "deny-attestation-required"
        Return "attestation-required"
    Case "deny-not-allowlisted"
        Return "allowlist-lookup"
    Case Else
        Return "policy"
    End Select
End Function

Private Function ExecDllCallIsAllowlisted(ByRef dllName As String, ByRef symbolName As String, ByRef signatureText As String, ByRef callingConventionText As String, ByVal requireAttestation As Integer, ByRef denyReasonOut As String) As Integer
    ExecLoadFfiAllowlistIfNeeded

    If gFfiAllowlistLoadFailed <> 0 Then
        denyReasonOut = "deny-policy-load-failed"
        Return 0
    End If

    Dim dllKey As String
    Dim symbolKey As String
    Dim sigKey As String
    Dim convKey As String

    dllKey = UCase(Trim(dllName))
    symbolKey = UCase(Trim(symbolName))
    sigKey = UCase(Trim(signatureText))
    convKey = UCase(Trim(callingConventionText))

    Dim i As Integer
    For i = 0 To gFfiAllowEntryCount - 1
        If dllKey = gFfiAllowEntries(i).dllName And symbolKey = gFfiAllowEntries(i).symbolName And sigKey = gFfiAllowEntries(i).signatureText Then
            Dim allowConv As String
            allowConv = UCase(Trim(gFfiAllowEntries(i).callingConventionText))
            If ExecAreDllCallingConventionsCompatible(convKey, allowConv) = 0 Then
                GoTo NextAllowEntry
            End If

            If requireAttestation <> 0 Then
                If gFfiAllowEntries(i).hashText = "" Or gFfiAllowEntries(i).signerText = "" Then
                    denyReasonOut = "deny-attestation-required"
                    Return 0
                End If

                If gFfiAllowEntries(i).hashText = "*" Or gFfiAllowEntries(i).signerText = "*" Then
                    denyReasonOut = "deny-attestation-required"
                    Return 0
                End If

                Dim hashState As Integer
                hashState = FfiHashMatchState(gFfiAllowEntries(i).hashText, dllName)
                If hashState < 0 Then
                    denyReasonOut = "deny-hash-extract-failed"
                    Return 0
                End If

                If hashState = 0 Then
                    denyReasonOut = "deny-hash-mismatch"
                    Return 0
                End If

                Dim signerState As Integer
                signerState = FfiSignerMatchState(gFfiAllowEntries(i).signerText, dllName)
                If signerState < 0 Then
                    denyReasonOut = "deny-signer-extract-failed"
                    Return 0
                End If

                If signerState = 0 Then
                    denyReasonOut = "deny-signer-mismatch"
                    Return 0
                End If
            End If

            denyReasonOut = ""
            Return 1
        End If
NextAllowEntry:
    Next i

    denyReasonOut = "deny-not-allowlisted"
    Return 0
End Function

Private Sub ExecAuditDllPolicy(ByRef dllName As String, ByRef symbolName As String, ByRef signatureText As String, ByRef callingConventionText As String, ByRef modeText As String, ByVal allowDecision As Integer, ByRef reasonText As String)
    Dim msgText As String
    Dim denyCode As Integer
    denyCode = ExecPolicyDenyCode(reasonText)

    Dim phaseText As String
    phaseText = ExecPolicyDenyPhase(reasonText)

    msgText = "FFI CALL(DLL) event=ffi_policy_decision mode=" & modeText & " decision="
    If allowDecision <> 0 Then
        msgText &= "allow"
    Else
        msgText &= "deny"
    End If

    msgText &= " lib=" & dllName & " symbol=" & symbolName & " sig=" & signatureText & " conv=" & callingConventionText
    msgText &= " abi=" & ExecGetActiveFfiAbiName()
    msgText &= " allow=" & LTrim(Str(allowDecision)) & " deny_code=" & LTrim(Str(denyCode))
    msgText &= " phase=" & phaseText
    If reasonText <> "" Then msgText &= " reason=" & reasonText

    If allowDecision <> 0 Then
        DiagBilgi msgText
    Else
        DiagUyari msgText
    End If
End Sub
