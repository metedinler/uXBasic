Function ExecDebugGetLocateRow() As Integer
    Return gDebugLocateRow
End Function

Function ExecDebugGetLocateCol() As Integer
    Return gDebugLocateCol
End Function

Function ExecDebugGetColorFg() As Integer
    Return gDebugColorFg
End Function

Function ExecDebugGetColorBg() As Integer
    Return gDebugColorBg
End Function

Function ExecDebugGetClsCount() As Integer
    Return gDebugClsCount
End Function

Function ExecDebugGetPrintColumnPos() As Integer
    Return gDebugPrintColumnPos
End Function

Sub ExecDebugInputQueueClear()
    gDebugInputQueueCount = 0
    gDebugInputQueueReadPos = 0
    Erase gDebugInputQueue
End Sub

Sub ExecDebugInputQueuePush(ByRef lineText As String)
    If gDebugInputQueueCount = 0 Then
        ReDim gDebugInputQueue(0)
    Else
        ReDim Preserve gDebugInputQueue(gDebugInputQueueCount)
    End If

    gDebugInputQueue(gDebugInputQueueCount) = lineText
    gDebugInputQueueCount += 1
End Sub

Function ExecDebugGetInputQueueRemaining() As Integer
    Return gDebugInputQueueCount - gDebugInputQueueReadPos
End Function

Sub ExecDebugKeyQueueClear()
    gDebugKeyQueueCount = 0
    gDebugKeyQueueReadPos = 0
    Erase gDebugKeyQueue
End Sub

Sub ExecDebugKeyQueuePush(ByVal keyCode As Integer)
    If gDebugKeyQueueCount = 0 Then
        ReDim gDebugKeyQueue(0)
    Else
        ReDim Preserve gDebugKeyQueue(gDebugKeyQueueCount)
    End If

    gDebugKeyQueue(gDebugKeyQueueCount) = (keyCode And &hFF)
    gDebugKeyQueueCount += 1
End Sub

Function ExecDebugGetKeyQueueRemaining() As Integer
    Return gDebugKeyQueueCount - gDebugKeyQueueReadPos
End Function

Function ExecDebugGetDefTypeCount() As Integer
    Return gExecDebugLastDefTypeCount
End Function

Private Function ExecEvalPipeInvoke(ByRef ps As ParseState, ByRef es As ExecState, ByVal targetNodeIdx As Integer, ByRef pipeInput As ExecValue, ByRef result As ExecValue, ByRef errText As String) As Integer
    If targetNodeIdx < 0 Or targetNodeIdx >= ps.ast.count Then
        errText = "Expression: pipe target missing"
        Return 0
    End If

    Dim targetKind As String
    targetKind = UCase(ps.ast.nodes(targetNodeIdx).kind)

    If targetKind = "IDENT" Or targetKind = "KEYWORD_REF" Then
        Dim tmpName As String
        tmpName = "__UXB_PIPE_TMP"
        ExecEnsureVar es, tmpName
        ExecSetVarValue es, tmpName, pipeInput

        Dim identNode As Integer
        identNode = ASTNewNode(ps.ast, "IDENT", tmpName, "", ps.ast.nodes(targetNodeIdx).lineNo, ps.ast.nodes(targetNodeIdx).colNo)

        Dim callNode As Integer
        callNode = ASTNewNode(ps.ast, "CALL_EXPR", ps.ast.nodes(targetNodeIdx).value, "", ps.ast.nodes(targetNodeIdx).lineNo, ps.ast.nodes(targetNodeIdx).colNo)
        ASTAddChild ps.ast, callNode, identNode

        Dim callValue As Integer
        If ExecEvalCall(ps, es, ps.ast.nodes(targetNodeIdx).value, callNode, 1, callValue, errText) = 0 Then Return 0
        ExecValueSetInteger result, callValue
        Return 1
    End If

    If targetKind = "STRING" Then
        If ExecSlotTriggerPipeValue(ps, es, ps.ast.nodes(targetNodeIdx).value, pipeInput, result, errText) = 0 Then Return 0
        Return 1
    End If

    errText = "Expression: pipe target must be identifier or pipe name"
    Return 0
End Function

Function ExecDebugGetStringSize() As Integer
    Return gExecDebugLastStringSize
End Function

Private Function ExecIsBuiltinCallName(ByRef callName As String) As Integer
    Select Case UCase(callName)
    Case "DLL", "API", "CALL", "SIZEOF", "OFFSETOF", "LEN", "ABS", "INT", "SGN", "VAL", "ASC", "CINT", "CLNG", "CDBL", "CSNG", "FIX", "SQR", "SIN", "COS", "TAN", "ATN", "EXP", "LOG", "RND", "TIMER", "LOF", "EOF", "INKEY", "GETKEY", "PEEKB", "PEEKW", "PEEKD", "VARPTR", "SADD", "LPTR", "CODEPTR", _
         "LISTLEN", "LISTGET", "LISTSET", "LISTADD", "LISTREMOVE", "LISTCLEAR", "DICTLEN", "DICTHAS", "DICTGET", "DICTSET", "DICTCLEAR", "SETLEN", "SETHAS", "SETADD", "SETREMOVE", "SETCLEAR"
        Return 1
    End Select

    Return 0
End Function

Private Sub ExecSnapshotVars(ByRef es As ExecState, snapshotVars() As ExecVar, ByRef snapshotCount As Integer, ByRef snapshotNextAddr As UInteger)
    snapshotCount = es.count
    snapshotNextAddr = es.nextVarAddr

    If snapshotCount <= 0 Then
        Erase snapshotVars
        Exit Sub
    End If

    ReDim snapshotVars(snapshotCount - 1)

    Dim i As Integer
    For i = 0 To snapshotCount - 1
        snapshotVars(i) = es.vars(i)
    Next i
End Sub

Private Sub ExecRestoreVars(ByRef es As ExecState, snapshotVars() As ExecVar, ByVal snapshotCount As Integer, ByVal snapshotNextAddr As UInteger)
    es.count = snapshotCount
    es.nextVarAddr = snapshotNextAddr

    If snapshotCount <= 0 Then
        ' Erase es.vars - fixed array
        Exit Sub
    End If

    ' ReDim es.vars(snapshotCount - 1) - fixed array
    If snapshotCount > 256 Then
        ' overflow
        Exit Sub
    End If

    Dim i As Integer
    For i = 0 To snapshotCount - 1
        es.vars(i) = snapshotVars(i)
    Next i
End Sub

Private Function ExecResolveThisMeIdentValue(ByRef es As ExecState, ByRef identText As String, ByRef valueOut As Integer, ByRef errText As String) As Integer
    Dim identUpper As String
    identUpper = UCase(Trim(identText))

    Dim varIdx As Integer
    varIdx = ExecFindVar(es, identUpper)
    If varIdx <> -1 Then
        valueOut = ExecValueToInteger(es.vars(varIdx).value)
        Return 1
    End If

    If identUpper = "THIS" Or identUpper = "ME" Then
        errText = "exec: THIS/ME used outside method context"
        Return 0
    End If

    valueOut = 0
    Return 1
End Function

Private Function ExecResolveThisMeIdentAddr(ByRef es As ExecState, ByRef identText As String, ByRef addrOut As UInteger, ByRef errText As String) As Integer
    Dim identUpper As String
    identUpper = UCase(Trim(identText))

    Dim varIdx As Integer
    varIdx = ExecFindVar(es, identUpper)
    If varIdx <> -1 Then
        addrOut = es.vars(varIdx).addr
        Return 1
    End If

    If identUpper = "THIS" Or identUpper = "ME" Then
        errText = "exec: THIS/ME used outside method context"
        Return 0
    End If

    addrOut = ExecGetVarAddr(es, identUpper)
    Return 1
End Function

Private Function ExecBuildFieldPath(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef rootNameOut As String, ByRef pathOut As String, ByRef errText As String) As Integer
    rootNameOut = ""
    pathOut = ""

    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "exec: field access invalid node"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    Dim k As String
    k = UCase(n.kind)

    If k = "IDENT" Or k = "KEYWORD_REF" Then
        rootNameOut = UCase(Trim(n.value))
        Return IIf(rootNameOut <> "", 1, 0)
    End If

    If k <> "FIELD_EXPR" Then
        errText = "exec: field access base must be identifier or field"
        Return 0
    End If

    Dim parentRoot As String
    Dim parentPath As String
    If ExecBuildFieldPath(ps, n.left, parentRoot, parentPath, errText) = 0 Then Return 0

    rootNameOut = parentRoot
    If parentPath = "" Then
        pathOut = UCase(Trim(n.value))
    Else
        pathOut = parentPath & "." & UCase(Trim(n.value))
    End If

    Return IIf(rootNameOut <> "" And pathOut <> "", 1, 0)
End Function

Private Function ExecResolveFieldAccess(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef baseAddrOut As UInteger, ByRef targetTypeOut As String, ByRef targetSizeOut As Integer, ByRef errText As String) As Integer
    Dim rootName As String
    Dim pathText As String
    If ExecBuildFieldPath(ps, nodeIdx, rootName, pathText, errText) = 0 Then Return 0

    Dim rootIdx As Integer
    rootIdx = ExecFindVar(es, rootName)
    If rootIdx = -1 Then
        errText = "exec: field root variable missing " & rootName
        Return 0
    End If

    Dim rootDeclType As String
    Dim rootRuntimeType As String
    rootDeclType = UCase(Trim(es.vars(rootIdx).declType))
    rootRuntimeType = UCase(Trim(es.vars(rootIdx).runtimeClassType))

    Dim rootType As String
    Dim baseAddr As UInteger

    If rootDeclType = "OBJECT" Or ExecFindClassDeclNode(ps, rootDeclType) <> -1 Then
        rootType = IIf(rootRuntimeType <> "", rootRuntimeType, rootDeclType)
        baseAddr = CUInt(ExecValueToInteger(es.vars(rootIdx).value))
        If baseAddr = 0 Then baseAddr = es.vars(rootIdx).addr
    Else
        rootType = rootDeclType
        baseAddr = es.vars(rootIdx).addr
    End If

    If rootType = "" Then
        errText = "exec: field root type missing for " & rootName
        Return 0
    End If
    If baseAddr = 0 Then
        errText = "exec: field root address missing for " & rootName
        Return 0
    End If

    Dim fieldErr As String
    Dim fieldOffset As Integer
    If TypeLayoutResolvePath(ps, rootType, pathText, fieldOffset, targetTypeOut, targetSizeOut, fieldErr) = 0 Then
        errText = "exec: field resolve failed " & fieldErr
        Return 0
    End If

    baseAddrOut = baseAddr + CUInt(fieldOffset)
    targetTypeOut = UCase(Trim(targetTypeOut))
    Return 1
End Function

Private Function ExecReadFieldValue(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef valueOut As ExecValue, ByRef errText As String) As Integer
    Dim fieldAddr As UInteger
    Dim fieldType As String
    Dim fieldSize As Integer
    If ExecResolveFieldAccess(ps, es, nodeIdx, fieldAddr, fieldType, fieldSize, errText) = 0 Then Return 0

    Select Case fieldType
    Case "I8", "U8"
        ExecValueSetInteger valueOut, VMemPeekB(fieldAddr)
    Case "I16", "U16", "SHORT"
        ExecValueSetInteger valueOut, VMemPeekW(fieldAddr)
    Case Else
        If fieldSize = 1 Then
            ExecValueSetInteger valueOut, VMemPeekB(fieldAddr)
        ElseIf fieldSize = 2 Then
            ExecValueSetInteger valueOut, VMemPeekW(fieldAddr)
        Else
            ExecValueSetInteger valueOut, VMemPeekD(fieldAddr)
        End If
    End Select

    Return 1
End Function

Private Function ExecWriteFieldValue(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef valueIn As ExecValue, ByRef errText As String) As Integer
    Dim fieldAddr As UInteger
    Dim fieldType As String
    Dim fieldSize As Integer
    If ExecResolveFieldAccess(ps, es, nodeIdx, fieldAddr, fieldType, fieldSize, errText) = 0 Then Return 0

    Dim rawValue As Integer
    rawValue = ExecValueToInteger(valueIn)

    Select Case fieldType
    Case "I8", "U8"
        If VMemPokeB(fieldAddr, rawValue) = 0 Then errText = "exec: field write out of range": Return 0
    Case "I16", "U16", "SHORT"
        If VMemPokeW(fieldAddr, rawValue) = 0 Then errText = "exec: field write out of range": Return 0
    Case Else
        If VMemPokeD(fieldAddr, rawValue) = 0 Then errText = "exec: field write out of range": Return 0
    End Select

    Return 1
End Function

#include once "exec/exec_eval_builtin_categories.fbs"

Private Function ExecEvalBuiltinCall(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNameRaw As String, ByVal callNodeIdx As Integer, ByRef errText As String) As Integer
    Dim callName As String
    callName = UCase(Trim(callNameRaw))

    Select Case callName
    Case "DLL", "API", "CALL"
        Return ExecEvalBuiltinFfiCategory(ps, es, callName, callNodeIdx, errText)

    Case "SIZEOF", "OFFSETOF"
        Return ExecEvalBuiltinLayoutCategory(ps, es, callName, callNodeIdx, errText)

    Case "LEN", "ABS", "INT", "SGN", "VAL", "ASC", "CINT", "CLNG", "CDBL", "CSNG", "FIX", "SQR", "SIN", "COS", "TAN", "ATN", "EXP", "LOG"
        Return ExecEvalBuiltinScalarCategory(ps, es, callName, callNodeIdx, errText)

    Case "RND", "TIMER"
        Return ExecEvalBuiltinTimeRandomCategory(ps, es, callName, callNodeIdx, errText)

    Case "LOF", "EOF"
        Return ExecEvalBuiltinFileCategory(ps, es, callName, callNodeIdx, errText)

    Case "INKEY", "GETKEY"
        Return ExecEvalBuiltinKeyboardCategory(ps, es, callName, callNodeIdx, errText)

    Case "PEEKB", "PEEKW", "PEEKD"
        Return ExecEvalBuiltinPeekCategory(ps, es, callName, callNodeIdx, errText)

    Case "VARPTR", "SADD", "LPTR", "CODEPTR"
        Return ExecEvalBuiltinPointerCategory(ps, es, callName, callNodeIdx, errText)

    Case "LISTLEN", "LISTGET", "LISTSET", "LISTADD", "LISTREMOVE", "LISTCLEAR", "DICTLEN", "DICTHAS", "DICTGET", "DICTSET", "DICTCLEAR", "SETLEN", "SETHAS", "SETADD", "SETREMOVE", "SETCLEAR"
        Return ExecEvalBuiltinCollectionCategory(ps, es, callName, callNodeIdx, errText)

    Case Else
        errText = "exec: unsupported call " & callName
        Return 0
    End Select
End Function

#include once "exec/exec_call_dispatch_helpers.fbs"

Private Function ExecEvalUserCall(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNameRaw As String, ByVal callNodeIdx As Integer, ByVal expectValue As Integer, ByRef valueOut As Integer, ByRef errText As String) As Integer
    Dim callName As String
    callName = UCase(Trim(callNameRaw))

    Dim routineIdx As Integer
    routineIdx = ExecRoutineIndexOf(es, callName)
    If routineIdx = -1 Then
        errText = "exec: unsupported call " & callName
        Return 0
    End If

    Return ExecInvokeRoutineByIndex(ps, es, routineIdx, callNodeIdx, expectValue, 0, 0, valueOut, errText)
End Function

Private Function ExecTryResolveAliasDllTarget(ByRef ps As ParseState, ByRef aliasUpper As String, ByVal callLineNo As Integer, ByRef dllNameOut As String, ByRef symbolNameOut As String, ByRef signatureOut As String, ByRef conventionOut As String, ByRef foundOut As Integer, ByRef errText As String) As Integer
    foundOut = 0

    Dim bestAliasNode As Integer
    bestAliasNode = -1
    Dim bestLineNo As Integer
    bestLineNo = -2147483648

    Dim i As Integer
    For i = 0 To ps.ast.count - 1
        Dim n As ASTNode
        n = ps.ast.nodes(i)
        If UCase(n.kind) = "ALIAS_STMT" Then
            If UCase(Trim(n.value)) = aliasUpper Then
                If callLineNo <= 0 Then
                    bestAliasNode = i
                    Exit For
                End If
                If n.lineNo <= callLineNo And n.lineNo >= bestLineNo Then
                    bestAliasNode = i
                    bestLineNo = n.lineNo
                End If
            End If
        End If
    Next i

    If bestAliasNode = -1 Then Return 1

    Dim targetNode As Integer
    targetNode = ps.ast.nodes(bestAliasNode).firstChild
    If targetNode = -1 Or UCase(ps.ast.nodes(targetNode).kind) <> "ALIAS_TARGET" Then
        errText = "exec: ALIAS target missing for " & aliasUpper
        Return 0
    End If

    Dim targetText As String
    targetText = Trim(ps.ast.nodes(targetNode).value)
    If ExecTryParseAliasDllTarget(targetText, dllNameOut, symbolNameOut, signatureOut, conventionOut) = 0 Then
        errText = "exec: ALIAS target is not CALL(DLL, ...) for " & aliasUpper
        Return 0
    End If

    foundOut = 1
    Return 1
End Function

Private Function ExecEvalCall(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNameRaw As String, ByVal callNodeIdx As Integer, ByVal expectValue As Integer, ByRef valueOut As Integer, ByRef errText As String) As Integer
    Dim callName As String
    callName = UCase(Trim(callNameRaw))

    If ExecIsBuiltinCallName(callName) <> 0 Then
        valueOut = ExecEvalBuiltinCall(ps, es, callName, callNodeIdx, errText)
        If errText <> "" Then Return 0
        Return 1
    End If

    If InStr(callName, ".") > 0 Then
        Return ExecEvalMethodCall(ps, es, callName, callNodeIdx, expectValue, valueOut, errText)
    End If

    Dim aliasFound As Integer
    Dim aliasDll As String
    Dim aliasSymbol As String
    Dim aliasSig As String
    Dim aliasConv As String
    If ExecTryResolveAliasDllTarget(ps, callName, ps.ast.nodes(callNodeIdx).lineNo, aliasDll, aliasSymbol, aliasSig, aliasConv, aliasFound, errText) = 0 Then
        Return 0
    End If
    If aliasFound <> 0 Then
        valueOut = ExecEvalDllCallCore(ps, es, callNodeIdx, aliasDll, aliasSymbol, aliasSig, aliasConv, 0, errText)
        If errText <> "" Then Return 0
        Return 1
    End If

    Return ExecEvalUserCall(ps, es, callName, callNodeIdx, expectValue, valueOut, errText)
End Function

Private Function ExecEvalNode(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "exec: invalid node index"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    Select Case UCase(n.kind)
    Case "NUMBER"
        Return ValInt(n.value)

    Case "IDENT"
        Dim identValue As Integer
        If ExecResolveThisMeIdentValue(es, n.value, identValue, errText) = 0 Then Return 0
        Return identValue

    Case "KEYWORD_REF"
        Dim keywordValue As Integer
        If ExecResolveThisMeIdentValue(es, n.value, keywordValue, errText) = 0 Then Return 0
        Return keywordValue

    Case "UNARY"
        Dim rv As Integer
        Select Case n.op
        Case "+"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return rv
        Case "-"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return -rv
        Case "LNOT", "!"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            If rv = 0 Then Return -1 Else Return 0
        Case "NOT"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return Not rv
        Case "@"
            If n.right = -1 Then
                errText = "exec: address operand missing"
                Return 0
            End If

            Dim addrNode As ASTNode
            addrNode = ps.ast.nodes(n.right)
            If UCase(addrNode.kind) = "IDENT" Then
                Dim identAddr As UInteger
                If ExecResolveThisMeIdentAddr(es, addrNode.value, identAddr, errText) = 0 Then Return 0
                Return CInt(identAddr)
            End If

            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return &h10000000 Or (rv And &h00FFFFFF)
        Case Else
            errText = "exec: unsupported unary op " & n.op
            Return 0
        End Select

    Case "INCDEC_EXPR"
        Dim exprTarget As Integer
        exprTarget = n.left
        If exprTarget = -1 Then
            errText = "exec: INCDEC expression target missing"
            Return 0
        End If

        Dim oldVal As Integer
        Dim newVal As Integer
        Dim idxVar As Integer
        Dim idxElem As Integer
        Dim tmpVal As ExecValue

        If UCase(ps.ast.nodes(exprTarget).kind) = "IDENT" Then
            oldVal = ExecGetVar(es, ps.ast.nodes(exprTarget).value)
            If Trim(n.op) = "--" Then
                newVal = oldVal - 1
            Else
                newVal = oldVal + 1
            End If
            ExecSetVar es, ps.ast.nodes(exprTarget).value, newVal
        ElseIf ExecTryResolveArrayAccess(ps, es, exprTarget, idxVar, idxElem, errText) <> 0 Then
            If ExecGetArrayElement(es, idxVar, idxElem, tmpVal) = 0 Then
                errText = "exec: INCDEC expression array read failed"
                Return 0
            End If
            oldVal = ExecValueToInteger(tmpVal)
            If Trim(n.op) = "--" Then
                newVal = oldVal - 1
            Else
                newVal = oldVal + 1
            End If
            ExecValueSetInteger tmpVal, newVal
            If ExecSetArrayElement(es, idxVar, idxElem, tmpVal) = 0 Then
                errText = "exec: INCDEC expression array write failed"
                Return 0
            End If
        Else
            If errText = "" Then errText = "exec: INCDEC expression target must be ident or indexed array"
            Return 0
        End If

        If UCase(Trim(n.value)) = "POST" Then
            Return oldVal
        End If
        Return newVal

    Case "BINARY"
        Dim lv As Integer
        Dim rv2 As Integer
        lv = ExecEvalNode(ps, es, n.left, errText)
        If errText <> "" Then Return 0

        If n.op = "|>" Then
            Dim pipeInput As ExecValue
            Dim pipeOutput As ExecValue
            ExecValueSetInteger pipeInput, lv
            If ExecEvalPipeInvoke(ps, es, n.right, pipeInput, pipeOutput, errText) = 0 Then Return 0
            Return ExecValueToInteger(pipeOutput)
        End If

        Dim opNorm As String
        opNorm = UCase(Trim(n.op))

        If opNorm = "&&" Or opNorm = "AND" Then
            If lv = 0 Then Return 0
        ElseIf opNorm = "||" Or opNorm = "OR" Then
            If lv <> 0 Then Return -1
        End If

        rv2 = ExecEvalNode(ps, es, n.right, errText)
        If errText <> "" Then Return 0

        Select Case n.op
        Case "+"
            Return lv + rv2
        Case "-"
            Return lv - rv2
        Case "*"
            Return lv * rv2
        Case "**"
            If rv2 < 0 Then
                errText = "exec: negative exponent not supported"
                Return 0
            End If
            Dim p As Integer
            Dim acc As Integer
            acc = 1
            For p = 1 To rv2
                acc *= lv
            Next p
            Return acc
        Case "/", "\\"
            If rv2 = 0 Then
                errText = "exec: division by zero"
                Return 0
            End If
            Return lv \ rv2
        Case "%", "MOD"
            If rv2 = 0 Then
                errText = "exec: modulo by zero"
                Return 0
            End If
            Return lv Mod rv2
        Case "&"
            Return lv And rv2
        Case "|"
            Return lv Or rv2
        Case "AND"
            If rv2 <> 0 Then Return -1 Else Return 0
        Case "OR"
            If rv2 <> 0 Then Return -1 Else Return 0
        Case "&&"
            If lv = 0 Then Return 0
            If rv2 <> 0 Then Return -1 Else Return 0
        Case "||"
            If lv <> 0 Then Return -1
            If rv2 <> 0 Then Return -1 Else Return 0
        Case "XOR"
            Return lv Xor rv2
        Case "^"
            Return lv Xor rv2
        Case "<<", "SHL"
            Return CInt(CUInt(lv) Shl (rv2 And 31))
        Case ">>", "SHR"
            Return CInt(CUInt(lv) Shr (rv2 And 31))
        Case "ROL"
            Return CInt(ExecRol32(CUInt(lv), rv2))
        Case "ROR"
            Return CInt(ExecRor32(CUInt(lv), rv2))
        Case "="
            If lv = rv2 Then Return -1 Else Return 0
        Case "=="
            If lv = rv2 Then Return -1 Else Return 0
        Case "<>"
            If lv <> rv2 Then Return -1 Else Return 0
        Case "!="
            If lv <> rv2 Then Return -1 Else Return 0
        Case "<"
            If lv < rv2 Then Return -1 Else Return 0
        Case ">"
            If lv > rv2 Then Return -1 Else Return 0
        Case "<="
            If lv <= rv2 Then Return -1 Else Return 0
        Case ">="
            If lv >= rv2 Then Return -1 Else Return 0
        Case Else
            errText = "exec: unsupported binary op " & n.op
            Return 0
        End Select

    Case "TERNARY_EXPR"
        Dim condInt As Integer
        condInt = ExecEvalNode(ps, es, n.left, errText)
        If errText <> "" Then Return 0

        Dim thenExpr As Integer
        thenExpr = ExecChildAt(ps, nodeIdx, 0)
        If thenExpr = -1 Then
            errText = "exec: ternary true branch missing"
            Return 0
        End If

        If condInt <> 0 Then
            Return ExecEvalNode(ps, es, thenExpr, errText)
        End If
        Return ExecEvalNode(ps, es, n.right, errText)

    Case "CALL_EXPR"
        Dim arrVarIdx As Integer
        Dim arrElemIdx As Integer
        Dim arrValue As ExecValue
        Dim arrAccessTry As Integer
        arrAccessTry = ExecTryResolveArrayAccess(ps, es, nodeIdx, arrVarIdx, arrElemIdx, errText)
        If arrAccessTry <> 0 Then
            If ExecGetArrayElement(es, arrVarIdx, arrElemIdx, arrValue) = 0 Then
                errText = "exec: array element read failed"
                Return 0
            End If
            Return ExecValueToInteger(arrValue)
        End If
        If errText <> "" Then Return 0

        Dim callExprValue As Integer
        If ExecEvalCall(ps, es, n.value, nodeIdx, 1, callExprValue, errText) = 0 Then Return 0
        Return callExprValue

    Case "NEW_EXPR"
        Return ExecAllocClassInstance(ps, es, n.value, nodeIdx, errText)

    Case "FIELD_EXPR"
        Dim fieldValue As ExecValue
        If ExecReadFieldValue(ps, es, nodeIdx, fieldValue, errText) = 0 Then Return 0
        Return ExecValueToInteger(fieldValue)

    Case Else
        errText = "exec: unsupported node kind " & n.kind
        Return 0
    End Select
End Function

Private Function ExecRunDeclDirectiveStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef st As ASTNode, ByRef errText As String) As Integer
    Select Case UCase(st.kind)
    Case "TYPE_STMT", "CLASS_STMT", "INTERFACE_STMT", "DECLARE_SUB_STMT", "DECLARE_FUNCTION_STMT", "SUB_STMT", "FUNCTION_STMT"
        Return 1

    Case "DIM_STMT"
        If ExecEvalDIM(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "CONST_STMT"
        If ExecEvalCONST(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "REDIM_STMT"
        If ExecEvalREDIM(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "DEF_FN_STMT"
        errText = "exec: DEF FN not implemented (user functions missing)"
        Return 0

    Case "DEFTYPE_STMT", "DEFINT_STMT", "DEFLNG_STMT", "DEFSNG_STMT", "DEFDBL_STMT", "DEFEXT_STMT", "DEFSTR_STMT", "DEFBYT_STMT"
        If ExecEvalDEF(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "SETSTRINGSIZE_STMT"
        If ExecEvalSETSTRINGSIZE(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "INCLUDE_STMT", "INLINE_STMT", "IMPORT_STMT"
        Return 1
    End Select

    Return -2
End Function

Private Function ExecRunTailStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef st As ASTNode, ByRef errText As String) As Integer
    Select Case UCase(st.kind)
    Case "EXIT_STMT"
        Dim exitMode As String
        exitMode = UCase(st.op)
        If exitMode = "" Then exitMode = "ANY"

        If exitMode <> "ANY" And exitMode <> "FOR" And exitMode <> "DO" And exitMode <> "IF" Then
            errText = "exec: unsupported EXIT mode " & st.op
            Return 0
        End If

        es.runtime.exitRequest = exitMode
        Return 1

    Case "GOTO_STMT"
        If Trim(st.value) = "" Then
            errText = "exec: GOTO target missing"
            Return 0
        End If

        es.runtime.exitRequest = "GOTO:" & UCase(st.value)
        Return 1

    Case "GOSUB_STMT"
        If Trim(st.value) = "" Then
            errText = "exec: GOSUB target missing"
            Return 0
        End If

        es.runtime.exitRequest = "GOSUB:" & UCase(st.value)
        Return 1

    Case "END_STMT"
        es.runtime.exitRequest = "END"
        Return 1

    Case "RETURN_STMT"
        Dim returnCount As Integer
        returnCount = ExecChildCount(ps, stmtIdx)
        If returnCount > 1 Then
            errText = "exec: RETURN argument count invalid"
            Return 0
        End If

        If es.runtime.callContextDepth > 0 Then
            If returnCount = 1 Then
                Dim callReturnExpr As Integer
                callReturnExpr = ExecChildAt(ps, stmtIdx, 0)
                If callReturnExpr = -1 Then
                    errText = "exec: RETURN value missing"
                    Return 0
                End If

                es.runtime.callReturnValue = ExecEvalNode(ps, es, callReturnExpr, errText)
                If errText <> "" Then Return 0
                es.runtime.callReturnHasValue = 1
            Else
                es.runtime.callReturnValue = 0
                es.runtime.callReturnHasValue = 0
            End If

            es.runtime.exitRequest = "RETURN_CALL"
            Return 1
        End If

        If returnCount = 1 Then
            Dim returnExpr As Integer
            returnExpr = ExecChildAt(ps, stmtIdx, 0)
            If returnExpr = -1 Then
                errText = "exec: RETURN value missing"
                Return 0
            End If

            Dim returnValue As Integer
            returnValue = ExecEvalNode(ps, es, returnExpr, errText)
            If errText <> "" Then Return 0
        End If

        es.runtime.exitRequest = "RETURN"
        Return 1

    Case "LABEL_STMT"
        Return 1

    Case "EXPR_STMT"
        If st.left <> -1 Then
            Dim v As Integer
            v = ExecEvalNode(ps, es, st.left, errText)
            If errText <> "" Then Return 0
        End If
        Return 1

    Case "CALL_STMT"
        Dim ignoredCallResult As Integer
        If ExecEvalCall(ps, es, st.value, stmtIdx, 0, ignoredCallResult, errText) = 0 Then Return 0
        Return 1
    End Select

    Return -2
End Function

#include once "exec/exec_stmt_flow.fbs"
#include once "exec/exec_stmt_io_file.fbs"
#include once "exec/exec_stmt_memory_core.fbs"

Private Function ExecRunBlockChildren(ByRef ps As ParseState, ByRef es As ExecState, ByVal parentIdx As Integer, ByRef errText As String) As Integer
    Dim ch As Integer
    ch = ps.ast.nodes(parentIdx).firstChild

    Do While ch <> -1
        If ExecRunStmt(ps, es, ch, errText) = 0 Then Return 0
        If es.runtime.exitRequest <> "" Then Exit Do
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return 1
End Function

Private Function ExecRunStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef errText As String) As Integer
    Dim st As ASTNode
    st = ps.ast.nodes(stmtIdx)

    Select Case UCase(st.kind)
    Case "NAMESPACE_STMT", "MODULE_STMT", "MAIN_STMT"
        Return ExecRunBlockChildren(ps, es, stmtIdx, errText)
    Case "USING_STMT", "ALIAS_STMT"
        ' Scope metadata nodes are compile-time constructs; runtime treats them as no-op.
        Return 1
    End Select

    Dim declDirectiveResult As Integer
    declDirectiveResult = ExecRunDeclDirectiveStmt(ps, es, stmtIdx, st, errText)
    If declDirectiveResult <> -2 Then Return declDirectiveResult

    Dim tailResult As Integer
    tailResult = ExecRunTailStmt(ps, es, stmtIdx, st, errText)
    If tailResult <> -2 Then Return tailResult

    Dim flowResult As Integer
    flowResult = ExecRunFlowStmt(ps, es, stmtIdx, st, errText)
    If flowResult <> -2 Then Return flowResult

    Dim ioResult As Integer
    ioResult = ExecRunIoFileStmt(ps, es, stmtIdx, st, errText)
    If ioResult <> -2 Then Return ioResult

    Dim memoryCoreResult As Integer
    memoryCoreResult = ExecRunMemoryCoreStmt(ps, es, stmtIdx, st, errText)
    If memoryCoreResult <> -2 Then Return memoryCoreResult

    Dim slotResult As Integer
    slotResult = ExecSlotRunStmt(ps, es, stmtIdx, st, errText)
    If slotResult <> -2 Then Return slotResult

    errText = "exec: unsupported statement kind " & st.kind
    Return 0
End Function

Private Function ExecRunProgramScopeDtors(ByRef ps As ParseState, ByRef es As ExecState, ByRef errText As String) As Integer
    Dim i As Integer
    For i = es.count - 1 To 0 Step -1
        Dim declType As String
        declType = UCase(Trim(es.vars(i).declType))
        If declType = "" Then Continue For

        If ExecFindClassDeclNode(ps, declType) = -1 Then Continue For
        If es.vars(i).isArray <> 0 Then Continue For

        If ExecInvokeClassDtorIfPresent(ps, es, declType, es.vars(i).addr, errText) = 0 Then
            If errText = "" Then errText = "exec: destructor invoke failed " & declType
            Return 0
        End If
    Next i

    Return 1
End Function

Function ExecRunMemoryProgram(ByRef ps As ParseState, ByRef errText As String) As Integer
    Static es As ExecState
    ExecStateInit es
    gActiveRuntimeCtx = @es.runtime
    es.runtime.ffiPolicyEnforce = gFfiDefaultPolicyEnforce
    es.runtime.ffiPolicyPath = gFfiDefaultPolicyPath
    es.runtime.ffiResolverPath = gFfiDefaultResolverPath
    es.runtime.ffiResolverEnforce = gFfiDefaultResolverEnforce
    ExecCollectionsReset
    ExecSlotsReset es
    ExecDebugConsoleReset
    ExecContractInit es
    es.runtime.exitRequest = ""
    es.runtime.callContextDepth = 0
    es.runtime.callReturnValue = 0
    es.runtime.callReturnHasValue = 0
    es.runtime.currentRoutineName = ""
    es.runtime.currentRoutineNodeIdx = -1
    es.runtime.execException.active = 0
    es.runtime.execException.kindText = ""
    es.runtime.execException.code = 0
    es.runtime.execException.messageText = ""
    es.runtime.execException.lineNo = 0
    es.runtime.execException.colNo = 0
    es.runtime.execException.routineName = ""
    ExecValueInit es.runtime.execException.value

    If ps.rootNode = -1 Then
        errText = "exec: no AST root"
        ExecNormalizeError errText
        Return 0
    End If

    VMemInit

    Dim labelNames(Any) As String
    Dim labelNodes(Any) As Integer
    Dim labelCount As Integer
    If ExecBuildTopLevelLabelMap(ps, ps.rootNode, labelNames(), labelNodes(), labelCount, errText) = 0 Then
        ExecNormalizeError errText
        UxbFileCloseAll es.fileIo
        Return 0
    End If

    If ExecBuildTopLevelRoutineMap(ps, es, ps.rootNode, errText) = 0 Then
        ExecNormalizeError errText
        UxbFileCloseAll es.fileIo
        Return 0
    End If

    Dim callStack(Any) As Integer
    Dim callDepth As Integer

    Dim runGuard As Integer
    runGuard = 0

    Dim st As Integer
    st = ps.ast.nodes(ps.rootNode).firstChild

    Do While st <> -1
        runGuard += 1
        If runGuard > 1000000 Then
            errText = "exec: top-level iteration guard exceeded"
            ExecNormalizeError errText
            UxbFileCloseAll es.fileIo
            Return 0
        End If

        If ExecRunStmt(ps, es, st, errText) = 0 Then
            ExecNormalizeError errText
            UxbFileCloseAll es.fileIo
            Return 0
        End If

        If es.runtime.exitRequest <> "" Then
            Dim exitReq As String
            exitReq = UCase(es.runtime.exitRequest)

            If exitReq = "END" Then
                es.runtime.exitRequest = ""
                Exit Do
            End If

            If exitReq = "RETURN" Then
                If callDepth <= 0 Then
                    errText = "exec: RETURN used without GOSUB (" & LTrim(Str(UXB_CTRL_ERR_RETURN_WITHOUT_GOSUB)) & ")"
                    ExecNormalizeError errText
                    UxbFileCloseAll es.fileIo
                    Return 0
                End If

                callDepth -= 1
                st = callStack(callDepth)
                es.runtime.exitRequest = ""
                Continue Do
            ElseIf Left(exitReq, 5) = "GOTO:" Then
                Dim gotoTarget As String
                gotoTarget = Trim(Mid(es.runtime.exitRequest, 6))

                Dim gotoIdx As Integer
                gotoIdx = ExecLabelIndexOf(labelNames(), labelCount, gotoTarget)
                If gotoIdx = -1 Then
                    errText = "exec: GOTO target not found " & gotoTarget
                    ExecNormalizeError errText
                    UxbFileCloseAll es.fileIo
                    Return 0
                End If

                st = labelNodes(gotoIdx)
                es.runtime.exitRequest = ""
                Continue Do
            ElseIf Left(exitReq, 6) = "GOSUB:" Then
                Dim gosubTarget As String
                gosubTarget = Trim(Mid(es.runtime.exitRequest, 7))

                Dim gosubIdx As Integer
                gosubIdx = ExecLabelIndexOf(labelNames(), labelCount, gosubTarget)
                If gosubIdx = -1 Then
                    errText = "exec: GOSUB target not found " & gosubTarget
                    ExecNormalizeError errText
                    UxbFileCloseAll es.fileIo
                    Return 0
                End If

                If callDepth = 0 Then
                    ReDim callStack(0)
                Else
                    ReDim Preserve callStack(callDepth)
                End If

                callStack(callDepth) = ps.ast.nodes(st).nextSibling
                callDepth += 1

                st = labelNodes(gosubIdx)
                es.runtime.exitRequest = ""
                Continue Do
            ElseIf exitReq = "IF" Then
                errText = "exec: EXIT IF used outside IF block"
                ExecNormalizeError errText
                UxbFileCloseAll es.fileIo
                Return 0
            Else
                errText = "exec: EXIT used outside matching loop"
                ExecNormalizeError errText
                UxbFileCloseAll es.fileIo
                Return 0
            End If
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    If ExecRunProgramScopeDtors(ps, es, errText) = 0 Then
        ExecNormalizeError errText
        UxbFileCloseAll es.fileIo
        Return 0
    End If

    UxbFileCloseAll es.fileIo
    Return 1
End Function
