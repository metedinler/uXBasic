Function ExecDebugGetLocateRow() As Integer
    Return gDebugLocateRow
End Function

Function ExecDebugGetLocateCol() As Integer
    Return gDebugLocateCol
End Function

Function ExecDebugGetColorFg() As Integer
    Return gDebugColorFg
End Function

Function ExecDebugGetColorBg() As Integer
    Return gDebugColorBg
End Function

Function ExecDebugGetClsCount() As Integer
    Return gDebugClsCount
End Function

Function ExecDebugGetPrintColumnPos() As Integer
    Return gDebugPrintColumnPos
End Function

Sub ExecDebugInputQueueClear()
    gDebugInputQueueCount = 0
    gDebugInputQueueReadPos = 0
    Erase gDebugInputQueue
End Sub

Sub ExecDebugInputQueuePush(ByRef lineText As String)
    If gDebugInputQueueCount = 0 Then
        ReDim gDebugInputQueue(0)
    Else
        ReDim Preserve gDebugInputQueue(gDebugInputQueueCount)
    End If

    gDebugInputQueue(gDebugInputQueueCount) = lineText
    gDebugInputQueueCount += 1
End Sub

Private Function ExecDebugInputQueuePop(ByRef lineOut As String) As Integer
    If gDebugInputQueueReadPos >= gDebugInputQueueCount Then Return 0
    lineOut = gDebugInputQueue(gDebugInputQueueReadPos)
    gDebugInputQueueReadPos += 1
    Return 1
End Function

Function ExecDebugGetInputQueueRemaining() As Integer
    Return gDebugInputQueueCount - gDebugInputQueueReadPos
End Function

Sub ExecDebugKeyQueueClear()
    gDebugKeyQueueCount = 0
    gDebugKeyQueueReadPos = 0
    Erase gDebugKeyQueue
End Sub

Sub ExecDebugKeyQueuePush(ByVal keyCode As Integer)
    If gDebugKeyQueueCount = 0 Then
        ReDim gDebugKeyQueue(0)
    Else
        ReDim Preserve gDebugKeyQueue(gDebugKeyQueueCount)
    End If

    gDebugKeyQueue(gDebugKeyQueueCount) = (keyCode And &hFF)
    gDebugKeyQueueCount += 1
End Sub

Private Function ExecDebugKeyQueuePop(ByRef keyOut As Integer) As Integer
    If gDebugKeyQueueReadPos >= gDebugKeyQueueCount Then Return 0
    keyOut = gDebugKeyQueue(gDebugKeyQueueReadPos)
    gDebugKeyQueueReadPos += 1
    Return 1
End Function

Function ExecDebugGetKeyQueueRemaining() As Integer
    Return gDebugKeyQueueCount - gDebugKeyQueueReadPos
End Function

Private Function ExecRoutineIndexOf(ByRef needle As String) As Integer
    Dim i As Integer
    For i = 0 To gRoutineDefCount - 1
        If gRoutineDefs(i).nameText = needle Then Return i
    Next i
    Return -1
End Function

Private Function ExecBuildTopLevelRoutineMap(ByRef ps As ParseState, ByVal rootNode As Integer, ByRef errText As String) As Integer
    gRoutineDefCount = 0
    Erase gRoutineDefs

    Dim st As Integer
    st = ps.ast.nodes(rootNode).firstChild
    Do While st <> -1
        Dim stKind As String
        stKind = UCase(ps.ast.nodes(st).kind)

        If stKind = "SUB_STMT" Or stKind = "FUNCTION_STMT" Then
            Dim routineName As String
            routineName = UCase(Trim(ps.ast.nodes(st).value))
            If routineName = "" Then
                errText = "exec: routine name missing"
                Return 0
            End If

            If ExecRoutineIndexOf(routineName) <> -1 Then
                errText = "exec: duplicate routine " & routineName
                Return 0
            End If

            If gRoutineDefCount = 0 Then
                ReDim gRoutineDefs(0)
            Else
                ReDim Preserve gRoutineDefs(gRoutineDefCount)
            End If

            gRoutineDefs(gRoutineDefCount).nameText = routineName
            gRoutineDefs(gRoutineDefCount).nodeIdx = st
            gRoutineDefs(gRoutineDefCount).routineKind = stKind
            gRoutineDefCount += 1
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    Return 1
End Function

Sub ExecSetFfiPolicyPath(ByRef pathText As String)
    Dim p As String
    p = Trim(pathText)
    If p = "" Then
        gFfiPolicyPath = "dist/config/ffi_allowlist.txt"
    Else
        gFfiPolicyPath = p
    End If

    gFfiAllowlistLoaded = 0
    gFfiAllowlistLoadFailed = 0
    gFfiAllowlistLoadFailReason = ""
    gFfiAllowEntryCount = 0
    Erase gFfiAllowEntries
End Sub

Private Function ExecGetFfiPolicyPath() As String
    If Trim(gFfiPolicyPath) = "" Then
        gFfiPolicyPath = "dist/config/ffi_allowlist.txt"
    End If
    Return gFfiPolicyPath
End Function

Sub ExecSetFfiPolicyMode(ByRef modeText As String)
    Dim m As String
    m = UCase(Trim(modeText))
    If m = "ENFORCE" Then
        gFfiPolicyEnforce = 1
    Else
        gFfiPolicyEnforce = 0
    End If
End Sub

Private Function ExecGetFfiPolicyMode() As String
    If gFfiPolicyEnforce <> 0 Then Return "ENFORCE"
    Return "REPORT_ONLY"
End Function

Private Sub ExecNormalizeError(ByRef errText As String)
    If errText = "" Then Exit Sub

    Dim t As String
    t = LCase(LTrim(errText))
    If Left(t, Len(EXEC_ERR_PREFIX)) <> EXEC_ERR_PREFIX Then
        errText = EXEC_ERR_PREFIX & errText
    End If
End Sub

Private Function ExecConsumeLoopExit(ByRef loopKind As String) As Integer
    If gExitRequest = "" Then Return 0

    Dim req As String
    req = UCase(gExitRequest)

    If req = "ANY" Or req = UCase(loopKind) Then
        gExitRequest = ""
        Return 1
    End If

    Return 2
End Function

Private Function ExecIsStmtNode(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then Return 0

    Dim kindUpper As String
    kindUpper = UCase(ps.ast.nodes(nodeIdx).kind)

    If Len(kindUpper) < 5 Then Return 0
    If Right(kindUpper, 5) = "_STMT" Then Return 1
    Return 0
End Function

Private Function ExecClampI32(ByVal valueIn As Double) As Integer
    If valueIn > 2147483647# Then Return 2147483647
    If valueIn < -2147483648# Then Return -2147483648
    Return CInt(valueIn)
End Function

Private Function ExecTimerUnitScale(ByRef unitText As String, ByRef scaleOut As Double) As Integer
    Dim u As String
    u = LCase(Trim(unitText))

    Select Case u
    Case "ns"
        scaleOut = 1000000000#
    Case "us"
        scaleOut = 1000000#
    Case "ms"
        scaleOut = 1000#
    Case "s"
        scaleOut = 1#
    Case "min"
        scaleOut = 1# / 60#
    Case "h"
        scaleOut = 1# / 3600#
    Case "day"
        scaleOut = 1# / 86400#
    Case "year"
        scaleOut = 1# / (86400# * 365#)
    Case Else
        scaleOut = 0#
        Return 0
    End Select

    Return 1
End Function

Private Function ExecBuiltinGetArgNode(ByRef ps As ParseState, ByVal callNodeIdx As Integer, ByRef callName As String, ByRef argNodeIdx As Integer, ByRef errText As String) As Integer
    argNodeIdx = ExecChildAt(ps, callNodeIdx, 0)
    If argNodeIdx = -1 Then
        errText = "exec: " & callName & " arg missing"
        Return 0
    End If
    Return 1
End Function

Private Function ExecBuiltinArgAsInt(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNodeIdx As Integer, ByRef callName As String, ByRef valueOut As Integer, ByRef errText As String, ByVal allowString As Integer) As Integer
    Dim a0 As Integer
    If ExecBuiltinGetArgNode(ps, callNodeIdx, callName, a0, errText) = 0 Then Return 0

    Dim argNode As ASTNode
    argNode = ps.ast.nodes(a0)
    If allowString <> 0 And UCase(argNode.kind) = "STRING" Then
        valueOut = ValInt(argNode.value)
        Return 1
    End If

    valueOut = ExecEvalNode(ps, es, a0, errText)
    If errText <> "" Then Return 0
    Return 1
End Function

Private Function ExecBuiltinArgAsText(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNodeIdx As Integer, ByRef callName As String, ByRef textOut As String, ByRef errText As String) As Integer
    Dim a0 As Integer
    If ExecBuiltinGetArgNode(ps, callNodeIdx, callName, a0, errText) = 0 Then Return 0

    Dim argNode As ASTNode
    argNode = ps.ast.nodes(a0)

    If UCase(argNode.kind) = "STRING" Then
        textOut = argNode.value
        Return 1
    End If

    If UCase(argNode.kind) = "CALL_EXPR" Then
        Dim textCallName As String
        textCallName = UCase(Trim(argNode.value))

        Select Case textCallName
        Case "STR"
            Dim strValue As Integer
            If ExecBuiltinArgAsInt(ps, es, a0, textCallName, strValue, errText, 1) = 0 Then Return 0
            textOut = LTrim(Str(strValue))
            Return 1

        Case "UCASE"
            Dim ucSrc As String
            If ExecBuiltinArgAsText(ps, es, a0, textCallName, ucSrc, errText) = 0 Then Return 0
            textOut = UCase(ucSrc)
            Return 1

        Case "LCASE"
            Dim lcSrc As String
            If ExecBuiltinArgAsText(ps, es, a0, textCallName, lcSrc, errText) = 0 Then Return 0
            textOut = LCase(lcSrc)
            Return 1

        Case "CHR"
            Dim chrValue As Integer
            If ExecBuiltinArgAsInt(ps, es, a0, textCallName, chrValue, errText, 1) = 0 Then Return 0
            If chrValue < 0 Or chrValue > 255 Then
                errText = "exec: CHR range error"
                Return 0
            End If
            textOut = Chr(chrValue)
            Return 1

        Case "LTRIM"
            Dim ltrimSrc As String
            If ExecBuiltinArgAsText(ps, es, a0, textCallName, ltrimSrc, errText) = 0 Then Return 0
            textOut = LTrim(ltrimSrc)
            Return 1

        Case "RTRIM"
            Dim rtrimSrc As String
            If ExecBuiltinArgAsText(ps, es, a0, textCallName, rtrimSrc, errText) = 0 Then Return 0
            textOut = RTrim(rtrimSrc)
            Return 1

        Case "MID"
            Dim midArgc As Integer
            midArgc = ExecChildCount(ps, a0)
            If midArgc < 2 Or midArgc > 3 Then
                errText = "exec: MID expects 2 or 3 arguments"
                Return 0
            End If

            Dim midSrcNode As Integer
            Dim midStartNode As Integer
            midSrcNode = ExecChildAt(ps, a0, 0)
            midStartNode = ExecChildAt(ps, a0, 1)
            If midSrcNode = -1 Or midStartNode = -1 Then
                errText = "exec: MID args missing"
                Return 0
            End If

            Dim midSrc As String
            If ExecEvalNodeAsText(ps, es, midSrcNode, midSrc, errText) = 0 Then Return 0

            Dim midStart As Integer
            midStart = ExecEvalNode(ps, es, midStartNode, errText)
            If errText <> "" Then Return 0
            If midStart < 1 Then
                errText = "exec: MID start must be >= 1"
                Return 0
            End If

            If midStart > Len(midSrc) Then
                textOut = ""
                Return 1
            End If

            If midArgc = 2 Then
                textOut = Mid(midSrc, midStart)
                Return 1
            End If

            Dim midLenNode As Integer
            midLenNode = ExecChildAt(ps, a0, 2)
            If midLenNode = -1 Then
                errText = "exec: MID length arg missing"
                Return 0
            End If

            Dim midLen As Integer
            midLen = ExecEvalNode(ps, es, midLenNode, errText)
            If errText <> "" Then Return 0
            If midLen < 0 Then
                errText = "exec: MID length must be >= 0"
                Return 0
            End If

            textOut = Mid(midSrc, midStart, midLen)
            Return 1

        Case "SPACE"
            Dim spaceCount As Integer
            If ExecBuiltinArgAsInt(ps, es, a0, textCallName, spaceCount, errText, 1) = 0 Then Return 0
            If spaceCount < 0 Then
                errText = "exec: SPACE count must be >= 0"
                Return 0
            End If
            If spaceCount > EXEC_MAX_TEXT_LEN Then
                errText = "exec: SPACE count too large"
                Return 0
            End If

            textOut = Space(spaceCount)
            Return 1

        Case "STRING"
            Dim stringArgc As Integer
            stringArgc = ExecChildCount(ps, a0)
            If stringArgc <> 2 Then
                errText = "exec: STRING expects 2 arguments"
                Return 0
            End If

            Dim stringCountNode As Integer
            Dim stringCharNode As Integer
            stringCountNode = ExecChildAt(ps, a0, 0)
            stringCharNode = ExecChildAt(ps, a0, 1)
            If stringCountNode = -1 Or stringCharNode = -1 Then
                errText = "exec: STRING args missing"
                Return 0
            End If

            Dim stringCount As Integer
            stringCount = ExecEvalNode(ps, es, stringCountNode, errText)
            If errText <> "" Then Return 0
            If stringCount < 0 Then
                errText = "exec: STRING count must be >= 0"
                Return 0
            End If
            If stringCount > EXEC_MAX_TEXT_LEN Then
                errText = "exec: STRING count too large"
                Return 0
            End If

            Dim stringCharCode As Integer
            Dim stringCharAst As ASTNode
            stringCharAst = ps.ast.nodes(stringCharNode)
            If UCase(stringCharAst.kind) = "STRING" Then
                If Len(stringCharAst.value) = 0 Then
                    errText = "exec: STRING char arg empty"
                    Return 0
                End If
                stringCharCode = Asc(Left(stringCharAst.value, 1))
            Else
                stringCharCode = ExecEvalNode(ps, es, stringCharNode, errText)
                If errText <> "" Then Return 0
            End If

            If stringCharCode < 0 Or stringCharCode > 255 Then
                errText = "exec: STRING char code range error"
                Return 0
            End If

            textOut = String(stringCount, stringCharCode)
            Return 1
        End Select
    End If

    Dim v As Integer
    v = ExecEvalNode(ps, es, a0, errText)
    If errText <> "" Then Return 0

    textOut = LTrim(Str(v))
    Return 1
End Function

Private Function ExecEvalNodeAsText(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef textOut As String, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "exec: invalid text node"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    If UCase(n.kind) = "STRING" Then
        textOut = n.value
        Return 1
    End If

    If UCase(n.kind) = "CALL_EXPR" Then
        Dim textCallName As String
        textCallName = UCase(Trim(n.value))

        Select Case textCallName
        Case "STR"
            Dim strValue As Integer
            If ExecBuiltinArgAsInt(ps, es, nodeIdx, textCallName, strValue, errText, 1) = 0 Then Return 0
            textOut = LTrim(Str(strValue))
            Return 1

        Case "UCASE"
            Dim ucText As String
            If ExecBuiltinArgAsText(ps, es, nodeIdx, textCallName, ucText, errText) = 0 Then Return 0
            textOut = UCase(ucText)
            Return 1

        Case "LCASE"
            Dim lcText As String
            If ExecBuiltinArgAsText(ps, es, nodeIdx, textCallName, lcText, errText) = 0 Then Return 0
            textOut = LCase(lcText)
            Return 1

        Case "CHR"
            Dim chrValue As Integer
            If ExecBuiltinArgAsInt(ps, es, nodeIdx, textCallName, chrValue, errText, 1) = 0 Then Return 0
            If chrValue < 0 Or chrValue > 255 Then
                errText = "exec: CHR range error"
                Return 0
            End If
            textOut = Chr(chrValue)
            Return 1

        Case "LTRIM"
            Dim ltrimText As String
            If ExecBuiltinArgAsText(ps, es, nodeIdx, textCallName, ltrimText, errText) = 0 Then Return 0
            textOut = LTrim(ltrimText)
            Return 1

        Case "RTRIM"
            Dim rtrimText As String
            If ExecBuiltinArgAsText(ps, es, nodeIdx, textCallName, rtrimText, errText) = 0 Then Return 0
            textOut = RTrim(rtrimText)
            Return 1

        Case "MID"
            Dim midArgc2 As Integer
            midArgc2 = ExecChildCount(ps, nodeIdx)
            If midArgc2 < 2 Or midArgc2 > 3 Then
                errText = "exec: MID expects 2 or 3 arguments"
                Return 0
            End If

            Dim midSrcNode2 As Integer
            Dim midStartNode2 As Integer
            midSrcNode2 = ExecChildAt(ps, nodeIdx, 0)
            midStartNode2 = ExecChildAt(ps, nodeIdx, 1)
            If midSrcNode2 = -1 Or midStartNode2 = -1 Then
                errText = "exec: MID args missing"
                Return 0
            End If

            Dim midSrc2 As String
            If ExecEvalNodeAsText(ps, es, midSrcNode2, midSrc2, errText) = 0 Then Return 0

            Dim midStart2 As Integer
            midStart2 = ExecEvalNode(ps, es, midStartNode2, errText)
            If errText <> "" Then Return 0
            If midStart2 < 1 Then
                errText = "exec: MID start must be >= 1"
                Return 0
            End If

            If midStart2 > Len(midSrc2) Then
                textOut = ""
                Return 1
            End If

            If midArgc2 = 2 Then
                textOut = Mid(midSrc2, midStart2)
                Return 1
            End If

            Dim midLenNode2 As Integer
            midLenNode2 = ExecChildAt(ps, nodeIdx, 2)
            If midLenNode2 = -1 Then
                errText = "exec: MID length arg missing"
                Return 0
            End If

            Dim midLen2 As Integer
            midLen2 = ExecEvalNode(ps, es, midLenNode2, errText)
            If errText <> "" Then Return 0
            If midLen2 < 0 Then
                errText = "exec: MID length must be >= 0"
                Return 0
            End If

            textOut = Mid(midSrc2, midStart2, midLen2)
            Return 1

        Case "SPACE"
            Dim spaceCount2 As Integer
            If ExecBuiltinArgAsInt(ps, es, nodeIdx, textCallName, spaceCount2, errText, 1) = 0 Then Return 0
            If spaceCount2 < 0 Then
                errText = "exec: SPACE count must be >= 0"
                Return 0
            End If
            If spaceCount2 > EXEC_MAX_TEXT_LEN Then
                errText = "exec: SPACE count too large"
                Return 0
            End If

            textOut = Space(spaceCount2)
            Return 1

        Case "STRING"
            Dim stringArgc2 As Integer
            stringArgc2 = ExecChildCount(ps, nodeIdx)
            If stringArgc2 <> 2 Then
                errText = "exec: STRING expects 2 arguments"
                Return 0
            End If

            Dim stringCountNode2 As Integer
            Dim stringCharNode2 As Integer
            stringCountNode2 = ExecChildAt(ps, nodeIdx, 0)
            stringCharNode2 = ExecChildAt(ps, nodeIdx, 1)
            If stringCountNode2 = -1 Or stringCharNode2 = -1 Then
                errText = "exec: STRING args missing"
                Return 0
            End If

            Dim stringCount2 As Integer
            stringCount2 = ExecEvalNode(ps, es, stringCountNode2, errText)
            If errText <> "" Then Return 0
            If stringCount2 < 0 Then
                errText = "exec: STRING count must be >= 0"
                Return 0
            End If
            If stringCount2 > EXEC_MAX_TEXT_LEN Then
                errText = "exec: STRING count too large"
                Return 0
            End If

            Dim stringCharCode2 As Integer
            Dim stringCharAst2 As ASTNode
            stringCharAst2 = ps.ast.nodes(stringCharNode2)
            If UCase(stringCharAst2.kind) = "STRING" Then
                If Len(stringCharAst2.value) = 0 Then
                    errText = "exec: STRING char arg empty"
                    Return 0
                End If
                stringCharCode2 = Asc(Left(stringCharAst2.value, 1))
            Else
                stringCharCode2 = ExecEvalNode(ps, es, stringCharNode2, errText)
                If errText <> "" Then Return 0
            End If

            If stringCharCode2 < 0 Or stringCharCode2 > 255 Then
                errText = "exec: STRING char code range error"
                Return 0
            End If

            textOut = String(stringCount2, stringCharCode2)
            Return 1
        End Select
    End If

    Dim numericValue As Integer
    numericValue = ExecEvalNode(ps, es, nodeIdx, errText)
    If errText <> "" Then Return 0

    textOut = LTrim(Str(numericValue))
    Return 1
End Function

Private Function ExecBuiltinArgAsTypeName(ByRef ps As ParseState, ByVal callNodeIdx As Integer, ByRef callName As String, ByRef typeNameOut As String, ByRef errText As String) As Integer
    Dim a0 As Integer
    a0 = ExecChildAt(ps, callNodeIdx, 0)
    If a0 = -1 Then
        errText = "exec: " & callName & " type arg missing"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(a0)
    If UCase(n.kind) <> "IDENT" And UCase(n.kind) <> "KEYWORD_REF" Then
        errText = "exec: " & callName & " expects type name"
        Return 0
    End If

    typeNameOut = n.value
    Return 1
End Function

Private Function ExecIsAllowedDllSignature(ByRef signatureText As String) As Integer
    Dim s As String
    s = UCase(Trim(signatureText))

    Select Case s
    Case "I32", "U64", "F64", "PTR", "STRPTR", "BYREF", "BYVAL"
        Return 1
    End Select

    Return 0
End Function

Private Function ExecContainsInvalidDllChars(ByRef dllName As String) As Integer
    Dim i As Integer
    For i = 1 To Len(dllName)
        Dim ch As Integer
        ch = Asc(Mid(dllName, i, 1))

        If ch < 32 Then Return 1

        Select Case ch
        Case 34, 42, 59, 60, 62, 63, 124
            Return 1
        End Select
    Next i

    Return 0
End Function

Private Function ExecIsAbsoluteDllPath(ByRef dllName As String) As Integer
    Dim s As String
    s = Trim(dllName)

    If s = "" Then Return 0
    If Left(s, 1) = "\" Or Left(s, 1) = "/" Then Return 1

    If Len(s) >= 2 Then
        Dim firstCh As Integer
        firstCh = Asc(UCase(Left(s, 1)))
        If firstCh >= Asc("A") And firstCh <= Asc("Z") Then
            If Mid(s, 2, 1) = ":" Then Return 1
        End If
    End If

    Return 0
End Function

Private Function ExecHasDllPathSegments(ByRef dllName As String) As Integer
    If Instr(dllName, "..") > 0 Then Return 1
    If Instr(dllName, "\") > 0 Then Return 1
    If Instr(dllName, "/") > 0 Then Return 1
    Return 0
End Function

Private Function ExecNormalizeDllName(ByRef dllNameIn As String, ByRef dllNameOut As String, ByRef errText As String) As Integer
    dllNameOut = Trim(dllNameIn)

    If dllNameOut = "" Then
        errText = "exec: CALL(DLL) library cannot be empty (" & LTrim(Str(UXB_FFI_ERR_BAD_LIB)) & ")"
        Return 0
    End If

    If ExecIsAbsoluteDllPath(dllNameOut) <> 0 Then
        errText = "exec: CALL(DLL) library must not be absolute path (" & LTrim(Str(UXB_FFI_ERR_DLL_ABSOLUTE_PATH)) & ")"
        Return 0
    End If

    If ExecHasDllPathSegments(dllNameOut) <> 0 Then
        errText = "exec: CALL(DLL) library path segments not allowed (" & LTrim(Str(UXB_FFI_ERR_DLL_PATH_SEGMENTS)) & ")"
        Return 0
    End If

    If ExecContainsInvalidDllChars(dllNameOut) <> 0 Then
        errText = "exec: CALL(DLL) library contains invalid chars (" & LTrim(Str(UXB_FFI_ERR_DLL_INVALID_CHARS)) & ")"
        Return 0
    End If

    dllNameOut = UCase(dllNameOut)
    Return 1
End Function

Private Function ExecNormalizeFfiHashToken(ByRef hashIn As String, ByRef hashOut As String) As Integer
    hashOut = UCase(Trim(hashIn))
    If hashOut = "" Then Return 0
    If hashOut = "*" Then Return 1
    If Len(hashOut) <> 64 Then Return 0

    Dim i As Integer
    For i = 1 To Len(hashOut)
        Dim ch As Integer
        ch = Asc(Mid(hashOut, i, 1))
        If (ch >= Asc("0") And ch <= Asc("9")) Or (ch >= Asc("A") And ch <= Asc("F")) Then
            ' valid
        Else
            Return 0
        End If
    Next i

    Return 1
End Function

Private Function ExecNormalizeFfiSignerToken(ByRef signerIn As String, ByRef signerOut As String) As Integer
    signerOut = UCase(Trim(signerIn))
    If signerOut = "" Then Return 0
    If Instr(signerOut, "|") > 0 Then Return 0
    Return 1
End Function

Private Sub ExecFfiAllowlistAppend(ByRef dllName As String, ByRef symbolName As String, ByRef signatureText As String, ByRef hashText As String, ByRef signerText As String)
    If gFfiAllowEntryCount = 0 Then
        ReDim gFfiAllowEntries(0)
    Else
        ReDim Preserve gFfiAllowEntries(gFfiAllowEntryCount)
    End If

    gFfiAllowEntries(gFfiAllowEntryCount).dllName = UCase(Trim(dllName))
    gFfiAllowEntries(gFfiAllowEntryCount).symbolName = UCase(Trim(symbolName))
    gFfiAllowEntries(gFfiAllowEntryCount).signatureText = UCase(Trim(signatureText))
    gFfiAllowEntries(gFfiAllowEntryCount).hashText = UCase(Trim(hashText))
    gFfiAllowEntries(gFfiAllowEntryCount).signerText = UCase(Trim(signerText))
    gFfiAllowEntryCount += 1
End Sub

Private Sub ExecSeedDefaultFfiAllowlist()
    Dim dll0 As String
    Dim symbol0 As String
    Dim sig0 As String
    Dim hash0 As String
    Dim signer0 As String
    dll0 = "KERNEL32.DLL"
    symbol0 = "GETTICKCOUNT"
    sig0 = "I32"
    hash0 = "1111111111111111111111111111111111111111111111111111111111111111"
    signer0 = "CN=MICROSOFT WINDOWS"
    ExecFfiAllowlistAppend dll0, symbol0, sig0, hash0, signer0

    Dim dll1 As String
    Dim symbol1 As String
    Dim sig1 As String
    Dim hash1 As String
    Dim signer1 As String
    dll1 = "USER32.DLL"
    symbol1 = "MESSAGEBOXA"
    sig1 = "I32"
    hash1 = "2222222222222222222222222222222222222222222222222222222222222222"
    signer1 = "CN=MICROSOFT WINDOWS"
    ExecFfiAllowlistAppend dll1, symbol1, sig1, hash1, signer1
End Sub

Private Function ExecParseFfiAllowlistLine(ByRef lineText As String, ByRef dllOut As String, ByRef symbolOut As String, ByRef sigOut As String, ByRef hashOut As String, ByRef signerOut As String) As Integer
    Dim lineTrim As String
    lineTrim = Trim(lineText)
    If lineTrim = "" Then Return 0
    If Left(lineTrim, 1) = "#" Then Return 0

    Dim p1 As Integer
    Dim p2 As Integer
    Dim p3 As Integer
    Dim p4 As Integer
    p1 = Instr(lineTrim, "|")
    If p1 <= 1 Then Return 0

    p2 = Instr(p1 + 1, lineTrim, "|")
    If p2 <= p1 + 1 Then Return 0

    p3 = Instr(p2 + 1, lineTrim, "|")
    p4 = 0
    If p3 > 0 Then
        p4 = Instr(p3 + 1, lineTrim, "|")
        If p4 <= p3 + 1 Then Return 0
        If Instr(p4 + 1, lineTrim, "|") > 0 Then Return 0
    End If

    Dim dllCandidate As String
    dllCandidate = Trim(Left(lineTrim, p1 - 1))

    symbolOut = UCase(Trim(Mid(lineTrim, p1 + 1, p2 - p1 - 1)))

    If p3 > 0 Then
        Dim hashCandidate As String
        Dim signerCandidate As String
        sigOut = UCase(Trim(Mid(lineTrim, p2 + 1, p3 - p2 - 1)))
        hashCandidate = Mid(lineTrim, p3 + 1, p4 - p3 - 1)
        signerCandidate = Mid(lineTrim, p4 + 1)
        If ExecNormalizeFfiHashToken(hashCandidate, hashOut) = 0 Then Return 0
        If ExecNormalizeFfiSignerToken(signerCandidate, signerOut) = 0 Then Return 0
    Else
        sigOut = UCase(Trim(Mid(lineTrim, p2 + 1)))
        hashOut = ""
        signerOut = ""
    End If

    Dim normalizeErr As String
    If ExecNormalizeDllName(dllCandidate, dllOut, normalizeErr) = 0 Then Return 0

    If symbolOut = "" Or sigOut = "" Then Return 0
    If ExecIsAllowedDllSignature(sigOut) = 0 Then Return 0

    Return 1
End Function

Private Sub ExecLoadFfiAllowlistIfNeeded()
    If gFfiAllowlistLoaded <> 0 Then Exit Sub
    gFfiAllowlistLoaded = 1
    gFfiAllowlistLoadFailed = 0
    gFfiAllowlistLoadFailReason = ""
    gFfiAllowEntryCount = 0
    Erase gFfiAllowEntries

    Dim policyPath As String
    policyPath = ExecGetFfiPolicyPath()

    If Dir(policyPath) = "" Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "file-not-found"
            DiagUyari "FFI policy file not found, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy file not found, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    Dim f As Integer
    f = FreeFile
    Open policyPath For Input As #f
    If Err <> 0 Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "open-failed"
            DiagUyari "FFI policy open failed, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy open failed, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    Dim headerSeen As Integer
    Dim headerValid As Integer
    headerSeen = 0
    headerValid = 0

    Do While Not Eof(f)
        Dim lineText As String
        Line Input #f, lineText

        Dim lineTrim As String
        lineTrim = Trim(lineText)

        If lineTrim <> "" Then
            If headerSeen = 0 Then
                headerSeen = 1

                Dim headerText As String
                headerText = UCase(lineTrim)
                If Left(headerText, 1) = "#" Then
                    headerText = UCase(Trim(Mid(lineTrim, 2)))
                End If

                If headerText <> UXB_FFI_POLICY_HEADER_V1 Then
                    Close #f
                    If ExecGetFfiPolicyMode() = "ENFORCE" Then
                        gFfiAllowlistLoadFailed = 1
                        gFfiAllowlistLoadFailReason = "header-invalid"
                        DiagUyari "FFI policy header invalid, enforce deny path=" & policyPath
                    Else
                        ExecSeedDefaultFfiAllowlist
                        DiagUyari "FFI policy header invalid, defaults active path=" & policyPath
                    End If
                    Exit Sub
                End If

                headerValid = 1
            Else
                Dim dllName As String
                Dim symbolName As String
                Dim signatureText As String
                Dim hashText As String
                Dim signerText As String
                If ExecParseFfiAllowlistLine(lineText, dllName, symbolName, signatureText, hashText, signerText) <> 0 Then
                    ExecFfiAllowlistAppend dllName, symbolName, signatureText, hashText, signerText
                End If
            End If
        End If
    Loop

    Close #f

    If headerValid = 0 Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "header-missing"
            DiagUyari "FFI policy header missing, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy header missing, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    If gFfiAllowEntryCount = 0 Then
        If ExecGetFfiPolicyMode() = "ENFORCE" Then
            gFfiAllowlistLoadFailed = 1
            gFfiAllowlistLoadFailReason = "no-valid-entries"
            DiagUyari "FFI policy had no valid entries, enforce deny path=" & policyPath
        Else
            ExecSeedDefaultFfiAllowlist
            DiagUyari "FFI policy had no valid entries, defaults active path=" & policyPath
        End If
        Exit Sub
    End If

    DiagBilgi "FFI policy loaded path=" & policyPath & " entries=" & LTrim(Str(gFfiAllowEntryCount))
End Sub

Private Function ExecPolicyDenyCode(ByRef reasonText As String) As Integer
    Select Case LCase(Trim(reasonText))
    Case "deny-policy-load-failed"
        Return UXB_FFI_ERR_POLICY_LOAD_FAILED
    Case "deny-attestation-required"
        Return UXB_FFI_ERR_POLICY_ATTEST_REQUIRED
    Case "deny-hash-mismatch"
        Return UXB_FFI_ERR_POLICY_HASH_MISMATCH
    Case "deny-signer-mismatch"
        Return UXB_FFI_ERR_POLICY_SIGNER_MISMATCH
    Case "deny-hash-extract-failed"
        Return UXB_FFI_ERR_POLICY_HASH_EXTRACT_FAILED
    Case "deny-signer-extract-failed"
        Return UXB_FFI_ERR_POLICY_SIGNER_EXTRACT_FAILED
    Case "deny-not-allowlisted"
        Return UXB_FFI_ERR_POLICY_DENY
    Case Else
        Return 0
    End Select
End Function

Private Function ExecPolicyDenyPhase(ByRef reasonText As String) As String
    Select Case LCase(Trim(reasonText))
    Case "deny-policy-load-failed"
        Return "policy-load"
    Case "deny-hash-mismatch", "deny-hash-extract-failed"
        Return "hash-verify"
    Case "deny-signer-mismatch", "deny-signer-extract-failed"
        Return "signer-verify"
    Case "deny-attestation-required"
        Return "attestation-required"
    Case "deny-not-allowlisted"
        Return "allowlist-lookup"
    Case Else
        Return "policy"
    End Select
End Function

Private Function ExecDllCallIsAllowlisted(ByRef dllName As String, ByRef symbolName As String, ByRef signatureText As String, ByVal requireAttestation As Integer, ByRef denyReasonOut As String) As Integer
    ExecLoadFfiAllowlistIfNeeded

    If gFfiAllowlistLoadFailed <> 0 Then
        denyReasonOut = "deny-policy-load-failed"
        Return 0
    End If

    Dim dllKey As String
    Dim symbolKey As String
    Dim sigKey As String

    dllKey = UCase(Trim(dllName))
    symbolKey = UCase(Trim(symbolName))
    sigKey = UCase(Trim(signatureText))

    Dim i As Integer
    For i = 0 To gFfiAllowEntryCount - 1
        If dllKey = gFfiAllowEntries(i).dllName And symbolKey = gFfiAllowEntries(i).symbolName And sigKey = gFfiAllowEntries(i).signatureText Then
            If requireAttestation <> 0 Then
                If gFfiAllowEntries(i).hashText = "" Or gFfiAllowEntries(i).signerText = "" Then
                    denyReasonOut = "deny-attestation-required"
                    Return 0
                End If

                If gFfiAllowEntries(i).hashText = "*" Or gFfiAllowEntries(i).signerText = "*" Then
                    denyReasonOut = "deny-attestation-required"
                    Return 0
                End If

                Dim hashState As Integer
                hashState = FfiHashMatchState(gFfiAllowEntries(i).hashText, dllName)
                If hashState < 0 Then
                    denyReasonOut = "deny-hash-extract-failed"
                    Return 0
                End If

                If hashState = 0 Then
                    denyReasonOut = "deny-hash-mismatch"
                    Return 0
                End If

                Dim signerState As Integer
                signerState = FfiSignerMatchState(gFfiAllowEntries(i).signerText, dllName)
                If signerState < 0 Then
                    denyReasonOut = "deny-signer-extract-failed"
                    Return 0
                End If

                If signerState = 0 Then
                    denyReasonOut = "deny-signer-mismatch"
                    Return 0
                End If
            End If

            denyReasonOut = ""
            Return 1
        End If
    Next i

    denyReasonOut = "deny-not-allowlisted"
    Return 0
End Function

Private Sub ExecAuditDllPolicy(ByRef dllName As String, ByRef symbolName As String, ByRef signatureText As String, ByRef modeText As String, ByVal allowDecision As Integer, ByRef reasonText As String)
    Dim msgText As String
    Dim denyCode As Integer
    denyCode = ExecPolicyDenyCode(reasonText)

    Dim phaseText As String
    phaseText = ExecPolicyDenyPhase(reasonText)

    msgText = "FFI CALL(DLL) event=ffi_policy_decision mode=" & modeText & " decision="
    If allowDecision <> 0 Then
        msgText &= "allow"
    Else
        msgText &= "deny"
    End If

    msgText &= " lib=" & dllName & " symbol=" & symbolName & " sig=" & signatureText
    msgText &= " allow=" & LTrim(Str(allowDecision)) & " deny_code=" & LTrim(Str(denyCode))
    msgText &= " phase=" & phaseText
    If reasonText <> "" Then msgText &= " reason=" & reasonText

    If allowDecision <> 0 Then
        DiagBilgi msgText
    Else
        DiagUyari msgText
    End If
End Sub

Private Function ExecIsBuiltinCallName(ByRef callName As String) As Integer
    Select Case UCase(callName)
    Case "DLL", "SIZEOF", "OFFSETOF", "LEN", "ABS", "INT", "SGN", "VAL", "ASC", "CINT", "CLNG", "CDBL", "CSNG", "FIX", "SQR", "SIN", "COS", "TAN", "ATN", "EXP", "LOG", "RND", "TIMER", "LOF", "EOF", "INKEY", "GETKEY", "PEEKB", "PEEKW", "PEEKD", "VARPTR", "SADD", "LPTR", "CODEPTR"
        Return 1
    End Select

    Return 0
End Function

Private Sub ExecSnapshotVars(ByRef es As ExecState, snapshotVars() As ExecVar, ByRef snapshotCount As Integer, ByRef snapshotNextAddr As UInteger)
    snapshotCount = es.count
    snapshotNextAddr = es.nextVarAddr

    If snapshotCount <= 0 Then
        Erase snapshotVars
        Exit Sub
    End If

    ReDim snapshotVars(snapshotCount - 1)

    Dim i As Integer
    For i = 0 To snapshotCount - 1
        snapshotVars(i) = es.vars(i)
    Next i
End Sub

Private Sub ExecRestoreVars(ByRef es As ExecState, snapshotVars() As ExecVar, ByVal snapshotCount As Integer, ByVal snapshotNextAddr As UInteger)
    es.count = snapshotCount
    es.nextVarAddr = snapshotNextAddr

    If snapshotCount <= 0 Then
        ' Erase es.vars - fixed array
        Exit Sub
    End If

    ' ReDim es.vars(snapshotCount - 1) - fixed array
    If snapshotCount > 256 Then
        ' overflow
        Exit Sub
    End If

    Dim i As Integer
    For i = 0 To snapshotCount - 1
        es.vars(i) = snapshotVars(i)
    Next i
End Sub

Private Function ExecEvalBuiltinCall(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNameRaw As String, ByVal callNodeIdx As Integer, ByRef errText As String) As Integer
    Dim callName As String
    callName = UCase(callNameRaw)

    Select Case callName
    Case "DLL"
        Dim ffiArgCount As Integer
        ffiArgCount = ExecChildCount(ps, callNodeIdx)
        If ffiArgCount < 4 Then
            errText = "exec: CALL(DLL) expects at least 4 arguments (" & LTrim(Str(UXB_FFI_ERR_BAD_ARITY)) & ")"
            Return 0
        End If

        Dim dllNode As Integer
        dllNode = ExecChildAt(ps, callNodeIdx, 0)
        If dllNode = -1 Or UCase(ps.ast.nodes(dllNode).kind) <> "STRING" Then
            errText = "exec: CALL(DLL) library must be string literal (" & LTrim(Str(UXB_FFI_ERR_BAD_LIB)) & ")"
            Return 0
        End If

        Dim dllName As String
        If ExecNormalizeDllName(ps.ast.nodes(dllNode).value, dllName, errText) = 0 Then
            Return 0
        End If

        Dim symbolNode As Integer
        symbolNode = ExecChildAt(ps, callNodeIdx, 1)
        If symbolNode = -1 Or UCase(ps.ast.nodes(symbolNode).kind) <> "STRING" Then
            errText = "exec: CALL(DLL) symbol must be string literal (" & LTrim(Str(UXB_FFI_ERR_BAD_SYMBOL)) & ")"
            Return 0
        End If

        Dim symbolName As String
        symbolName = Trim(ps.ast.nodes(symbolNode).value)
        If symbolName = "" Then
            errText = "exec: CALL(DLL) symbol cannot be empty (" & LTrim(Str(UXB_FFI_ERR_BAD_SYMBOL)) & ")"
            Return 0
        End If

        Dim sigNode As Integer
        sigNode = ExecChildAt(ps, callNodeIdx, 2)
        If sigNode = -1 Or UCase(ps.ast.nodes(sigNode).kind) <> "KEYWORD_REF" Then
            errText = "exec: CALL(DLL) signature token must be keyword (" & LTrim(Str(UXB_FFI_ERR_BAD_SIGNATURE)) & ")"
            Return 0
        End If

        Dim signatureText As String
        signatureText = UCase(Trim(ps.ast.nodes(sigNode).value))
        If ExecIsAllowedDllSignature(signatureText) = 0 Then
            errText = "exec: CALL(DLL) invalid signature token " & signatureText & " (" & LTrim(Str(UXB_FFI_ERR_BAD_SIGNATURE)) & ")"
            Return 0
        End If

        If signatureText = "BYREF" Then
            Dim byrefNode As Integer
            byrefNode = ExecChildAt(ps, callNodeIdx, 3)
            If byrefNode = -1 Or UCase(ps.ast.nodes(byrefNode).kind) <> "IDENT" Then
                errText = "exec: CALL(DLL) BYREF requires addressable target argument (" & LTrim(Str(UXB_FFI_ERR_BYREF_TARGET)) & ")"
                Return 0
            End If
        End If

        Dim denyReason As String
        Dim allowDecision As Integer
        Dim requireAttestation As Integer
        Dim ffiMode As String
        ffiMode = ExecGetFfiPolicyMode()
        requireAttestation = IIf(ffiMode = "ENFORCE", 1, 0)
        allowDecision = ExecDllCallIsAllowlisted(dllName, symbolName, signatureText, requireAttestation, denyReason)
        ExecAuditDllPolicy dllName, symbolName, signatureText, ffiMode, allowDecision, denyReason

        If allowDecision = 0 And ffiMode = "ENFORCE" Then
            If denyReason = "deny-policy-load-failed" Then
                errText = "exec: CALL(DLL) denied by policy load failed (" & LTrim(Str(UXB_FFI_ERR_POLICY_LOAD_FAILED)) & ")"
                Return 0
            End If
            If denyReason = "deny-attestation-required" Then
                errText = "exec: CALL(DLL) denied by policy attestation required (" & LTrim(Str(UXB_FFI_ERR_POLICY_ATTEST_REQUIRED)) & ")"
                Return 0
            End If
            If denyReason = "deny-hash-extract-failed" Then
                errText = "exec: CALL(DLL) denied by policy hash extraction failed (" & LTrim(Str(UXB_FFI_ERR_POLICY_HASH_EXTRACT_FAILED)) & ")"
                Return 0
            End If
            If denyReason = "deny-hash-mismatch" Then
                errText = "exec: CALL(DLL) denied by policy hash mismatch (" & LTrim(Str(UXB_FFI_ERR_POLICY_HASH_MISMATCH)) & ")"
                Return 0
            End If
            If denyReason = "deny-signer-extract-failed" Then
                errText = "exec: CALL(DLL) denied by policy signer extraction failed (" & LTrim(Str(UXB_FFI_ERR_POLICY_SIGNER_EXTRACT_FAILED)) & ")"
                Return 0
            End If
            If denyReason = "deny-signer-mismatch" Then
                errText = "exec: CALL(DLL) denied by policy signer mismatch (" & LTrim(Str(UXB_FFI_ERR_POLICY_SIGNER_MISMATCH)) & ")"
                Return 0
            End If
            errText = "exec: CALL(DLL) denied by policy (" & LTrim(Str(UXB_FFI_ERR_POLICY_DENY)) & ")"
            Return 0
        End If

        ' FFI-1 report-only mode: do not execute external call yet, return deterministic no-op value.
        Return 0

    Case "SIZEOF"
        Dim sizeofType As String
        If ExecBuiltinArgAsTypeName(ps, callNodeIdx, callName, sizeofType, errText) = 0 Then Return 0

        Dim sizeofOut As Integer
        Dim sizeofErr As String
        If TypeLayoutSizeOf(ps, sizeofType, sizeofOut, sizeofErr) = 0 Then
            errText = "exec: SIZEOF failed " & sizeofErr
            Return 0
        End If
        Return sizeofOut

    Case "OFFSETOF"
        Dim offsetofType As String
        If ExecBuiltinArgAsTypeName(ps, callNodeIdx, callName, offsetofType, errText) = 0 Then Return 0

        Dim p1 As Integer
        p1 = ExecChildAt(ps, callNodeIdx, 1)
        If p1 = -1 Or UCase(ps.ast.nodes(p1).kind) <> "STRING" Then
            errText = "exec: OFFSETOF expects string path"
            Return 0
        End If

        Dim offsetofOut As Integer
        Dim offsetofErr As String
        If TypeLayoutOffsetOf(ps, offsetofType, ps.ast.nodes(p1).value, offsetofOut, offsetofErr) = 0 Then
            errText = "exec: OFFSETOF failed " & offsetofErr
            Return 0
        End If
        Return offsetofOut

    Case "LEN"
        Dim lenText As String
        If ExecBuiltinArgAsText(ps, es, callNodeIdx, callName, lenText, errText) = 0 Then Return 0
        Return Len(lenText)

    Case "ABS"
        Dim absValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, absValue, errText, 1) = 0 Then Return 0
        Return Abs(absValue)

    Case "INT"
        Dim intValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, intValue, errText, 1) = 0 Then Return 0
        Return CInt(Int(intValue))

    Case "SGN"
        Dim sgnValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, sgnValue, errText, 1) = 0 Then Return 0
        If sgnValue < 0 Then Return -1
        If sgnValue > 0 Then Return 1
        Return 0

    Case "VAL"
        Dim valText As String
        If ExecBuiltinArgAsText(ps, es, callNodeIdx, callName, valText, errText) = 0 Then Return 0
        Return ValInt(valText)

    Case "ASC"
        Dim ascText As String
        If ExecBuiltinArgAsText(ps, es, callNodeIdx, callName, ascText, errText) = 0 Then Return 0
        If Len(ascText) = 0 Then
            errText = "exec: ASC empty string"
            Return 0
        End If
        Return Asc(Left(ascText, 1))

    Case "CINT"
        Dim cintValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, cintValue, errText, 1) = 0 Then Return 0
        Return CInt(cintValue)

    Case "CLNG"
        Dim clngValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, clngValue, errText, 1) = 0 Then Return 0
        Return CInt(CLng(clngValue))

    Case "CDBL"
        Dim cdblValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, cdblValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(CDbl(cdblValue))

    Case "CSNG"
        Dim csngValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, csngValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(CSng(csngValue))

    Case "FIX"
        Dim fixValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, fixValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(Fix(CDbl(fixValue)))

    Case "SQR"
        Dim sqrValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, sqrValue, errText, 1) = 0 Then Return 0
        If sqrValue < 0 Then
            errText = "exec: SQR domain error"
            Return 0
        End If
        Return ExecClampI32(Sqr(CDbl(sqrValue)))

    Case "SIN"
        Dim sinValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, sinValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(Sin(CDbl(sinValue)))

    Case "COS"
        Dim cosValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, cosValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(Cos(CDbl(cosValue)))

    Case "TAN"
        Dim tanValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, tanValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(Tan(CDbl(tanValue)))

    Case "ATN"
        Dim atnValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, atnValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(Atn(CDbl(atnValue)))

    Case "EXP"
        Dim expValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, expValue, errText, 1) = 0 Then Return 0
        Return ExecClampI32(Exp(CDbl(expValue)))

    Case "LOG"
        Dim logValue As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, logValue, errText, 1) = 0 Then Return 0
        If logValue <= 0 Then
            errText = "exec: LOG domain error"
            Return 0
        End If
        Return ExecClampI32(Log(CDbl(logValue)))

    Case "RND"
        Dim rndArgc As Integer
        rndArgc = ExecChildCount(ps, callNodeIdx)

        Dim rndValue As Single
        If rndArgc = 0 Then
            rndValue = Rnd
        Else
            Dim rndSeedArg As Integer
            If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, rndSeedArg, errText, 1) = 0 Then Return 0
            rndValue = Rnd(rndSeedArg)
        End If

        Return ExecClampI32(CDbl(rndValue) * 2147483647#)

    Case "TIMER"
        Dim timerArgc As Integer
        timerArgc = ExecChildCount(ps, callNodeIdx)

        If timerArgc = 0 Then
            Return ExecClampI32(Timer)
        ElseIf timerArgc = 1 Then
            Dim tu0 As Integer
            tu0 = ExecChildAt(ps, callNodeIdx, 0)
            If tu0 = -1 Or UCase(ps.ast.nodes(tu0).kind) <> "STRING" Then
                errText = "exec: TIMER(unit) expects string unit"
                Return 0
            End If

            Dim scale1 As Double
            If ExecTimerUnitScale(ps.ast.nodes(tu0).value, scale1) = 0 Then
                errText = "exec: invalid TIMER unit"
                Return 0
            End If

            Return ExecClampI32(Timer * scale1)
        ElseIf timerArgc = 3 Then
            Dim t0 As Integer
            Dim t1 As Integer
            Dim t2 As Integer
            t0 = ExecChildAt(ps, callNodeIdx, 0)
            t1 = ExecChildAt(ps, callNodeIdx, 1)
            t2 = ExecChildAt(ps, callNodeIdx, 2)
            If t0 = -1 Or t1 = -1 Or t2 = -1 Then
                errText = "exec: TIMER(start,end,unit) args missing"
                Return 0
            End If
            If UCase(ps.ast.nodes(t2).kind) <> "STRING" Then
                errText = "exec: TIMER(start,end,unit) expects string unit"
                Return 0
            End If

            Dim startValue As Integer
            Dim endValue As Integer
            startValue = ExecEvalNode(ps, es, t0, errText)
            If errText <> "" Then Return 0
            endValue = ExecEvalNode(ps, es, t1, errText)
            If errText <> "" Then Return 0

            Dim scale3 As Double
            If ExecTimerUnitScale(ps.ast.nodes(t2).value, scale3) = 0 Then
                errText = "exec: invalid TIMER unit"
                Return 0
            End If

            Return ExecClampI32((CDbl(endValue) - CDbl(startValue)) * scale3)
        End If

        errText = "exec: TIMER expects 0, 1 or 3 arguments"
        Return 0

    Case "LOF"
        Dim lofHandle As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, lofHandle, errText, 1) = 0 Then Return 0

        If lofHandle < 1 Or lofHandle > 255 Or es.fileIo.channels(lofHandle).inUse = 0 Then
            errText = "exec: LOF channel not open"
            Return 0
        End If

        Err = 0
        Dim lofOut As LongInt
        lofOut = Lof(lofHandle)
        If Err <> 0 Then
            errText = "exec: LOF failed " & ExecFormatFileError(es.fileIo)
            Return 0
        End If

        Return ExecClampI32(CDbl(lofOut))

    Case "EOF"
        Dim eofHandle As Integer
        If ExecBuiltinArgAsInt(ps, es, callNodeIdx, callName, eofHandle, errText, 1) = 0 Then Return 0

        If eofHandle < 1 Or eofHandle > 255 Or es.fileIo.channels(eofHandle).inUse = 0 Then
            errText = "exec: EOF channel not open"
            Return 0
        End If

        If Eof(eofHandle) Then Return -1 Else Return 0

    Case "INKEY", "GETKEY"
        Dim keyArgc As Integer
        keyArgc = ExecChildCount(ps, callNodeIdx)

        If callName = "GETKEY" Then
            If keyArgc <> 0 Then
                errText = "exec: GETKEY expects 0 arguments"
                Return 0
            End If
        Else
            If keyArgc < 1 Or keyArgc > 2 Then
                errText = "exec: INKEY expects 1 or 2 arguments"
                Return 0
            End If

            Dim keyFlagsNode As Integer
            keyFlagsNode = ExecChildAt(ps, callNodeIdx, 0)
            If keyFlagsNode = -1 Then
                errText = "exec: INKEY arg missing"
                Return 0
            End If

            Dim keyFlags As Integer
            keyFlags = ExecEvalNode(ps, es, keyFlagsNode, errText)
            If errText <> "" Then Return 0
        End If

        Dim keyValue As Integer
        keyValue = 0
        If ExecDebugKeyQueuePop(keyValue) = 0 Then keyValue = 0

        If callName = "INKEY" And keyArgc = 2 Then
            Dim stateNode As Integer
            stateNode = ExecChildAt(ps, callNodeIdx, 1)
            If stateNode = -1 Then
                errText = "exec: INKEY state arg missing"
                Return 0
            End If

            If UCase(ps.ast.nodes(stateNode).kind) <> "IDENT" Then
                errText = "exec: INKEY state target must be variable"
                Return 0
            End If

            If keyValue <> 0 Then
                ExecSetVar es, ps.ast.nodes(stateNode).value, 1
            Else
                ExecSetVar es, ps.ast.nodes(stateNode).value, 0
            End If
        End If

        Return keyValue

    Case "PEEKB"
        Dim a0 As Integer
        a0 = ExecChildAt(ps, callNodeIdx, 0)
        If a0 = -1 Then
            errText = "exec: PEEKB arg missing"
            Return 0
        End If
        Dim addr As Integer
        addr = ExecEvalNode(ps, es, a0, errText)
        If errText <> "" Then Return 0
        Return VMemPeekB(CUInt(addr))

    Case "PEEKW"
        Dim w0 As Integer
        w0 = ExecChildAt(ps, callNodeIdx, 0)
        If w0 = -1 Then
            errText = "exec: PEEKW arg missing"
            Return 0
        End If
        Dim addrW As Integer
        addrW = ExecEvalNode(ps, es, w0, errText)
        If errText <> "" Then Return 0
        Return VMemPeekW(CUInt(addrW))

    Case "PEEKD"
        Dim d0 As Integer
        d0 = ExecChildAt(ps, callNodeIdx, 0)
        If d0 = -1 Then
            errText = "exec: PEEKD arg missing"
            Return 0
        End If
        Dim addrD As Integer
        addrD = ExecEvalNode(ps, es, d0, errText)
        If errText <> "" Then Return 0
        Return VMemPeekD(CUInt(addrD))

    Case "VARPTR"
        Dim v0 As Integer
        v0 = ExecChildAt(ps, callNodeIdx, 0)
        If v0 = -1 Then
            errText = "exec: VARPTR arg missing"
            Return 0
        End If

        Dim argNode As ASTNode
        argNode = ps.ast.nodes(v0)
        If UCase(argNode.kind) <> "IDENT" Then
            errText = "exec: VARPTR requires identifier, got " & argNode.kind
            Return 0
        End If

        Return CInt(ExecGetVarAddr(es, argNode.value))

    Case "SADD"
        Dim s0 As Integer
        s0 = ExecChildAt(ps, callNodeIdx, 0)
        If s0 = -1 Then
            errText = "exec: SADD arg missing"
            Return 0
        End If

        Dim sNode As ASTNode
        sNode = ps.ast.nodes(s0)
        Dim sKind As String
        sKind = UCase(sNode.kind)
        If sKind <> "STRING" And sKind <> "IDENT" Then
            errText = "exec: SADD requires STRING or IDENT, got " & sNode.kind
            Return 0
        End If

        Return CInt(&h20000000 Or (ExecHashText(sNode.value) And &h0FFFFFFF))

    Case "LPTR"
        Dim l0 As Integer
        l0 = ExecChildAt(ps, callNodeIdx, 0)
        If l0 = -1 Then
            errText = "exec: LPTR arg missing"
            Return 0
        End If

        Dim lNode As ASTNode
        lNode = ps.ast.nodes(l0)
        Dim lKind As String
        lKind = UCase(lNode.kind)
        If lKind <> "IDENT" And lKind <> "KEYWORD_REF" Then
            errText = "exec: LPTR requires IDENT/KEYWORD_REF, got " & lNode.kind
            Return 0
        End If

        Dim labelName As String
        labelName = UCase(Trim(lNode.value))
        If labelName = "" Then
            errText = "exec: LPTR requires non-empty label"
            Return 0
        End If

        Return CInt(&h30000000 Or (ExecHashText(labelName & ":" & lKind) And &h0FFFFFFF))

    Case "CODEPTR"
        Dim c0 As Integer
        c0 = ExecChildAt(ps, callNodeIdx, 0)
        If c0 = -1 Then
            errText = "exec: CODEPTR arg missing"
            Return 0
        End If

        Dim cNode As ASTNode
        cNode = ps.ast.nodes(c0)
        Dim cKind As String
        cKind = UCase(cNode.kind)
        If cKind <> "IDENT" And cKind <> "KEYWORD_REF" Then
            errText = "exec: CODEPTR requires IDENT/KEYWORD_REF, got " & cNode.kind
            Return 0
        End If

        Dim routineName As String
        routineName = UCase(Trim(cNode.value))
        If routineName = "" Then
            errText = "exec: CODEPTR requires non-empty routine name"
            Return 0
        End If

        Return CInt(&h40000000 Or (ExecHashText(routineName & ":" & cKind) And &h0FFFFFFF))

    Case Else
        errText = "exec: unsupported call " & callName
        Return 0
    End Select
End Function

Private Function ExecEvalUserCall(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNameRaw As String, ByVal callNodeIdx As Integer, ByVal expectValue As Integer, ByRef valueOut As Integer, ByRef errText As String) As Integer
    Dim callName As String
    callName = UCase(Trim(callNameRaw))

    Dim routineIdx As Integer
    routineIdx = ExecRoutineIndexOf(callName)
    If routineIdx = -1 Then
        errText = "exec: unsupported call " & callName
        Return 0
    End If

    Dim routineNodeIdx As Integer
    Dim routineKind As String
    routineNodeIdx = gRoutineDefs(routineIdx).nodeIdx
    routineKind = gRoutineDefs(routineIdx).routineKind

    If expectValue <> 0 And routineKind <> "FUNCTION_STMT" Then
        errText = "exec: call in expression requires FUNCTION " & callName
        Return 0
    End If

    Dim paramNames(Any) As String
    Dim paramCount As Integer

    Dim bodyStart As Integer
    bodyStart = ps.ast.nodes(routineNodeIdx).firstChild
    Do While bodyStart <> -1
        Dim childKind As String
        childKind = UCase(ps.ast.nodes(bodyStart).kind)
        If childKind <> "PARAM_DECL" Then Exit Do

        If paramCount = 0 Then
            ReDim paramNames(0)
        Else
            ReDim Preserve paramNames(paramCount)
        End If

        paramNames(paramCount) = ps.ast.nodes(bodyStart).value
        paramCount += 1
        bodyStart = ps.ast.nodes(bodyStart).nextSibling
    Loop

    If routineKind = "FUNCTION_STMT" And bodyStart <> -1 And UCase(ps.ast.nodes(bodyStart).kind) = "RETURN_TYPE" Then
        bodyStart = ps.ast.nodes(bodyStart).nextSibling
    End If

    Dim actualCount As Integer
    actualCount = ExecChildCount(ps, callNodeIdx)
    If actualCount <> paramCount Then
        errText = "exec: call arity mismatch " & callName & " expected=" & LTrim(Str(paramCount)) & " actual=" & LTrim(Str(actualCount))
        Return 0
    End If

    Dim argValues(Any) As Integer
    If actualCount > 0 Then ReDim argValues(actualCount - 1)

    Dim ai As Integer
    For ai = 0 To actualCount - 1
        Dim argNode As Integer
        argNode = ExecChildAt(ps, callNodeIdx, ai)
        If argNode = -1 Then
            errText = "exec: call argument missing"
            Return 0
        End If

        argValues(ai) = ExecEvalNode(ps, es, argNode, errText)
        If errText <> "" Then Return 0
    Next ai

    Dim snapshotVars(Any) As ExecVar
    Dim snapshotCount As Integer
    Dim snapshotNextAddr As UInteger
    ExecSnapshotVars es, snapshotVars(), snapshotCount, snapshotNextAddr

    For ai = 0 To paramCount - 1
        ExecSetVar es, paramNames(ai), argValues(ai)
    Next ai

    If routineKind = "FUNCTION_STMT" Then
        ExecSetVar es, ps.ast.nodes(routineNodeIdx).value, 0
    End If

    Dim savedReturnValue As Integer
    Dim savedReturnHasValue As Integer
    savedReturnValue = gCallReturnValue
    savedReturnHasValue = gCallReturnHasValue
    gCallReturnValue = 0
    gCallReturnHasValue = 0
    gCallContextDepth += 1

    Dim bodyNode As Integer
    bodyNode = bodyStart
    Do While bodyNode <> -1
        If ExecRunStmt(ps, es, bodyNode, errText) = 0 Then
            gCallContextDepth -= 1
            gCallReturnValue = savedReturnValue
            gCallReturnHasValue = savedReturnHasValue
            ExecRestoreVars es, snapshotVars(), snapshotCount, snapshotNextAddr
            Return 0
        End If

        If gExitRequest <> "" Then
            Dim callReq As String
            callReq = UCase(gExitRequest)

            If callReq = "RETURN_CALL" Then
                gExitRequest = ""
                Exit Do
            End If

            If callReq <> "END" Then
                errText = "exec: unsupported control transfer inside user call"
                gCallContextDepth -= 1
                gCallReturnValue = savedReturnValue
                gCallReturnHasValue = savedReturnHasValue
                ExecRestoreVars es, snapshotVars(), snapshotCount, snapshotNextAddr
                Return 0
            End If

            Exit Do
        End If

        bodyNode = ps.ast.nodes(bodyNode).nextSibling
    Loop

    If routineKind = "FUNCTION_STMT" Then
        If gCallReturnHasValue <> 0 Then
            valueOut = gCallReturnValue
        Else
            valueOut = ExecGetVar(es, ps.ast.nodes(routineNodeIdx).value)
        End If
    Else
        valueOut = 0
    End If

    gCallContextDepth -= 1
    gCallReturnValue = savedReturnValue
    gCallReturnHasValue = savedReturnHasValue
    ExecRestoreVars es, snapshotVars(), snapshotCount, snapshotNextAddr
    Return 1
End Function

Private Function ExecEvalCall(ByRef ps As ParseState, ByRef es As ExecState, ByVal callNameRaw As String, ByVal callNodeIdx As Integer, ByVal expectValue As Integer, ByRef valueOut As Integer, ByRef errText As String) As Integer
    Dim callName As String
    callName = UCase(Trim(callNameRaw))

    If ExecIsBuiltinCallName(callName) <> 0 Then
        valueOut = ExecEvalBuiltinCall(ps, es, callName, callNodeIdx, errText)
        If errText <> "" Then Return 0
        Return 1
    End If

    Return ExecEvalUserCall(ps, es, callName, callNodeIdx, expectValue, valueOut, errText)
End Function

Private Function ExecEvalNode(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "exec: invalid node index"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    Select Case UCase(n.kind)
    Case "NUMBER"
        Return ValInt(n.value)

    Case "IDENT"
        Return ExecGetVar(es, n.value)

    Case "UNARY"
        Dim rv As Integer
        Select Case n.op
        Case "+"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return rv
        Case "-"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return -rv
        Case "NOT"
            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return Not rv
        Case "@"
            If n.right = -1 Then
                errText = "exec: address operand missing"
                Return 0
            End If

            Dim addrNode As ASTNode
            addrNode = ps.ast.nodes(n.right)
            If UCase(addrNode.kind) = "IDENT" Then
                Return CInt(ExecGetVarAddr(es, addrNode.value))
            End If

            rv = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            Return &h10000000 Or (rv And &h00FFFFFF)
        Case Else
            errText = "exec: unsupported unary op " & n.op
            Return 0
        End Select

    Case "BINARY"
        Dim lv As Integer
        Dim rv2 As Integer
        lv = ExecEvalNode(ps, es, n.left, errText)
        If errText <> "" Then Return 0
        rv2 = ExecEvalNode(ps, es, n.right, errText)
        If errText <> "" Then Return 0

        Select Case n.op
        Case "+"
            Return lv + rv2
        Case "-"
            Return lv - rv2
        Case "*"
            Return lv * rv2
        Case "**"
            If rv2 < 0 Then
                errText = "exec: negative exponent not supported"
                Return 0
            End If
            Dim p As Integer
            Dim acc As Integer
            acc = 1
            For p = 1 To rv2
                acc *= lv
            Next p
            Return acc
        Case "/", "\\"
            If rv2 = 0 Then
                errText = "exec: division by zero"
                Return 0
            End If
            Return lv \ rv2
        Case "%", "MOD"
            If rv2 = 0 Then
                errText = "exec: modulo by zero"
                Return 0
            End If
            Return lv Mod rv2
        Case "AND"
            Return lv And rv2
        Case "OR"
            Return lv Or rv2
        Case "XOR"
            Return lv Xor rv2
        Case "<<", "SHL"
            Return CInt(CUInt(lv) Shl (rv2 And 31))
        Case ">>", "SHR"
            Return CInt(CUInt(lv) Shr (rv2 And 31))
        Case "ROL"
            Return CInt(ExecRol32(CUInt(lv), rv2))
        Case "ROR"
            Return CInt(ExecRor32(CUInt(lv), rv2))
        Case "="
            If lv = rv2 Then Return -1 Else Return 0
        Case "<>"
            If lv <> rv2 Then Return -1 Else Return 0
        Case "<"
            If lv < rv2 Then Return -1 Else Return 0
        Case ">"
            If lv > rv2 Then Return -1 Else Return 0
        Case "<="
            If lv <= rv2 Then Return -1 Else Return 0
        Case ">="
            If lv >= rv2 Then Return -1 Else Return 0
        Case Else
            errText = "exec: unsupported binary op " & n.op
            Return 0
        End Select

    Case "CALL_EXPR"
        Dim callExprValue As Integer
        If ExecEvalCall(ps, es, n.value, nodeIdx, 1, callExprValue, errText) = 0 Then Return 0
        Return callExprValue

    Case Else
        errText = "exec: unsupported node kind " & n.kind
        Return 0
    End Select
End Function

Private Function ExecRunDeclDirectiveStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef st As ASTNode, ByRef errText As String) As Integer
    Select Case UCase(st.kind)
    Case "TYPE_STMT", "CLASS_STMT", "DECLARE_SUB_STMT", "DECLARE_FUNCTION_STMT", "SUB_STMT", "FUNCTION_STMT"
        Return 1

    Case "DIM_STMT"
        If ExecEvalDIM(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "CONST_STMT"
        If ExecEvalCONST(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "REDIM_STMT"
        If ExecEvalREDIM(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "DEF_FN_STMT"
        errText = "exec: DEF FN not implemented (user functions missing)"
        Return 0

    Case "DEFINT_STMT", "DEFLNG_STMT", "DEFSNG_STMT", "DEFDBL_STMT", "DEFEXT_STMT", "DEFSTR_STMT", "DEFBYT_STMT"
        If ExecEvalDEF(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "SETSTRINGSIZE_STMT"
        If ExecEvalSETSTRINGSIZE(ps, stmtIdx, es, errText) = 0 Then Return 0
        Return 1

    Case "INCLUDE_STMT", "INLINE_STMT", "IMPORT_STMT"
        Return 1
    End Select

    Return -2
End Function

Private Function ExecRunTailStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef st As ASTNode, ByRef errText As String) As Integer
    Select Case UCase(st.kind)
    Case "EXIT_STMT"
        Dim exitMode As String
        exitMode = UCase(st.op)
        If exitMode = "" Then exitMode = "ANY"

        If exitMode <> "ANY" And exitMode <> "FOR" And exitMode <> "DO" And exitMode <> "IF" Then
            errText = "exec: unsupported EXIT mode " & st.op
            Return 0
        End If

        gExitRequest = exitMode
        Return 1

    Case "GOTO_STMT"
        If Trim(st.value) = "" Then
            errText = "exec: GOTO target missing"
            Return 0
        End If

        gExitRequest = "GOTO:" & UCase(st.value)
        Return 1

    Case "GOSUB_STMT"
        If Trim(st.value) = "" Then
            errText = "exec: GOSUB target missing"
            Return 0
        End If

        gExitRequest = "GOSUB:" & UCase(st.value)
        Return 1

    Case "END_STMT"
        gExitRequest = "END"
        Return 1

    Case "RETURN_STMT"
        Dim returnCount As Integer
        returnCount = ExecChildCount(ps, stmtIdx)
        If returnCount > 1 Then
            errText = "exec: RETURN argument count invalid"
            Return 0
        End If

        If gCallContextDepth > 0 Then
            If returnCount = 1 Then
                Dim callReturnExpr As Integer
                callReturnExpr = ExecChildAt(ps, stmtIdx, 0)
                If callReturnExpr = -1 Then
                    errText = "exec: RETURN value missing"
                    Return 0
                End If

                gCallReturnValue = ExecEvalNode(ps, es, callReturnExpr, errText)
                If errText <> "" Then Return 0
                gCallReturnHasValue = 1
            Else
                gCallReturnValue = 0
                gCallReturnHasValue = 0
            End If

            gExitRequest = "RETURN_CALL"
            Return 1
        End If

        If returnCount = 1 Then
            Dim returnExpr As Integer
            returnExpr = ExecChildAt(ps, stmtIdx, 0)
            If returnExpr = -1 Then
                errText = "exec: RETURN value missing"
                Return 0
            End If

            Dim returnValue As Integer
            returnValue = ExecEvalNode(ps, es, returnExpr, errText)
            If errText <> "" Then Return 0
        End If

        gExitRequest = "RETURN"
        Return 1

    Case "LABEL_STMT"
        Return 1

    Case "EXPR_STMT"
        If st.left <> -1 Then
            Dim v As Integer
            v = ExecEvalNode(ps, es, st.left, errText)
            If errText <> "" Then Return 0
        End If
        Return 1

    Case "CALL_STMT"
        Dim ignoredCallResult As Integer
        If ExecEvalCall(ps, es, st.value, stmtIdx, 0, ignoredCallResult, errText) = 0 Then Return 0
        Return 1
    End Select

    Return -2
End Function

#include once "exec/exec_stmt_flow.fbs"
#include once "exec/exec_stmt_io_file.fbs"

Private Function ExecRunStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef errText As String) As Integer
    Dim st As ASTNode
    st = ps.ast.nodes(stmtIdx)

    Dim declDirectiveResult As Integer
    declDirectiveResult = ExecRunDeclDirectiveStmt(ps, es, stmtIdx, st, errText)
    If declDirectiveResult <> -2 Then Return declDirectiveResult

    Dim tailResult As Integer
    tailResult = ExecRunTailStmt(ps, es, stmtIdx, st, errText)
    If tailResult <> -2 Then Return tailResult

    Select Case UCase(st.kind)
    Case "IF_STMT", "SELECT_STMT", "FOR_STMT", "DO_STMT", "FOR_EACH_STMT", "DO_EACH_STMT"
        Return ExecRunFlowStmt(ps, es, stmtIdx, st, errText)

    Case "PRINT_STMT", "INPUT_STMT", "INPUT_FILE_STMT", "LOCATE_STMT", "COLOR_STMT", "CLS_STMT", "OPEN_STMT", "CLOSE_STMT", "GET_STMT", "PUT_STMT", "SEEK_STMT"
        Return ExecRunIoFileStmt(ps, es, stmtIdx, st, errText)

    Case "ASSIGN_STMT"
        Dim lhs As Integer
        lhs = st.left
        If lhs = -1 Then
            errText = "exec: assign lhs missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(lhs).kind) <> "IDENT" Then
            errText = "exec: assign lhs must be ident"
            Return 0
        End If

        Dim rhsVal As Integer
        rhsVal = ExecEvalNode(ps, es, st.right, errText)
        If errText <> "" Then Return 0

        ExecSetVar es, ps.ast.nodes(lhs).value, rhsVal
        Return 1

    Case "INCDEC_STMT"
        Dim lhs2 As Integer
        lhs2 = st.left
        If lhs2 = -1 Or UCase(ps.ast.nodes(lhs2).kind) <> "IDENT" Then
            errText = "exec: inc/dec target must be ident"
            Return 0
        End If

        Dim curVal As Integer
        curVal = ExecGetVar(es, ps.ast.nodes(lhs2).value)

        If st.op = "++" Then
            ExecSetVar es, ps.ast.nodes(lhs2).value, curVal + 1
        ElseIf st.op = "--" Then
            ExecSetVar es, ps.ast.nodes(lhs2).value, curVal - 1
        Else
            errText = "exec: unknown inc/dec op"
            Return 0
        End If

        Return 1

    Case "RANDOMIZE_STMT"
        Dim randomizeCount As Integer
        randomizeCount = ExecChildCount(ps, stmtIdx)

        If randomizeCount = 0 Then
            Randomize Timer
            Return 1
        End If

        Dim seedExpr As Integer
        seedExpr = ExecChildAt(ps, stmtIdx, 0)
        If seedExpr = -1 Then
            errText = "exec: RANDOMIZE seed missing"
            Return 0
        End If

        Dim seedValue As Integer
        seedValue = ExecEvalNode(ps, es, seedExpr, errText)
        If errText <> "" Then Return 0

        Randomize seedValue
        Return 1

    Case "POKEB_STMT"
        Dim pb0 As Integer
        Dim pb1 As Integer
        pb0 = ExecChildAt(ps, stmtIdx, 0)
        pb1 = ExecChildAt(ps, stmtIdx, 1)
        If pb0 = -1 Or pb1 = -1 Then
            errText = "exec: POKEB args missing"
            Return 0
        End If
        Dim pbAddr As Integer
        Dim pbVal As Integer
        pbAddr = ExecEvalNode(ps, es, pb0, errText)
        If errText <> "" Then Return 0
        pbVal = ExecEvalNode(ps, es, pb1, errText)
        If errText <> "" Then Return 0
        If VMemPokeB(CUInt(pbAddr), pbVal) = 0 Then
            errText = "exec: POKEB out of range"
            Return 0
        End If
        Return 1

    Case "POKEW_STMT"
        Dim pw0 As Integer
        Dim pw1 As Integer
        pw0 = ExecChildAt(ps, stmtIdx, 0)
        pw1 = ExecChildAt(ps, stmtIdx, 1)
        If pw0 = -1 Or pw1 = -1 Then
            errText = "exec: POKEW args missing"
            Return 0
        End If
        Dim pwAddr As Integer
        Dim pwVal As Integer
        pwAddr = ExecEvalNode(ps, es, pw0, errText)
        If errText <> "" Then Return 0
        pwVal = ExecEvalNode(ps, es, pw1, errText)
        If errText <> "" Then Return 0
        If VMemPokeW(CUInt(pwAddr), pwVal) = 0 Then
            errText = "exec: POKEW out of range"
            Return 0
        End If
        Return 1

    Case "POKED_STMT"
        Dim pd0 As Integer
        Dim pd1 As Integer
        pd0 = ExecChildAt(ps, stmtIdx, 0)
        pd1 = ExecChildAt(ps, stmtIdx, 1)
        If pd0 = -1 Or pd1 = -1 Then
            errText = "exec: POKED args missing"
            Return 0
        End If
        Dim pdAddr As Integer
        Dim pdVal As Integer
        pdAddr = ExecEvalNode(ps, es, pd0, errText)
        If errText <> "" Then Return 0
        pdVal = ExecEvalNode(ps, es, pd1, errText)
        If errText <> "" Then Return 0
        If VMemPokeD(CUInt(pdAddr), pdVal) = 0 Then
            errText = "exec: POKED out of range"
            Return 0
        End If
        Return 1

    Case "MEMCOPYB_STMT"
        Dim mc0 As Integer
        Dim mc1 As Integer
        Dim mc2 As Integer
        mc0 = ExecChildAt(ps, stmtIdx, 0)
        mc1 = ExecChildAt(ps, stmtIdx, 1)
        mc2 = ExecChildAt(ps, stmtIdx, 2)
        If mc0 = -1 Or mc1 = -1 Or mc2 = -1 Then
            errText = "exec: MEMCOPYB args missing"
            Return 0
        End If

        Dim srcAddr As Integer
        Dim dstAddr As Integer
        Dim copyLen As Integer
        srcAddr = ExecEvalNode(ps, es, mc0, errText)
        If errText <> "" Then Return 0
        dstAddr = ExecEvalNode(ps, es, mc1, errText)
        If errText <> "" Then Return 0
        copyLen = ExecEvalNode(ps, es, mc2, errText)
        If errText <> "" Then Return 0

        If copyLen < 0 Then
            errText = "exec: MEMCOPYB negative length"
            Return 0
        End If

        If VMemCopyB(CUInt(srcAddr), CUInt(dstAddr), CUInt(copyLen)) = 0 Then
            errText = "exec: MEMCOPYB out of range"
            Return 0
        End If
        Return 1

    Case "MEMFILLB_STMT"
        Dim mf0 As Integer
        Dim mf1 As Integer
        Dim mf2 As Integer
        mf0 = ExecChildAt(ps, stmtIdx, 0)
        mf1 = ExecChildAt(ps, stmtIdx, 1)
        mf2 = ExecChildAt(ps, stmtIdx, 2)
        If mf0 = -1 Or mf1 = -1 Or mf2 = -1 Then
            errText = "exec: MEMFILLB args missing"
            Return 0
        End If

        Dim fillAddr As Integer
        Dim fillVal As Integer
        Dim fillLen As Integer
        fillAddr = ExecEvalNode(ps, es, mf0, errText)
        If errText <> "" Then Return 0
        fillVal = ExecEvalNode(ps, es, mf1, errText)
        If errText <> "" Then Return 0
        fillLen = ExecEvalNode(ps, es, mf2, errText)
        If errText <> "" Then Return 0

        If fillLen < 0 Then
            errText = "exec: MEMFILLB negative length"
            Return 0
        End If

        If VMemFillB(CUInt(fillAddr), fillVal, CUInt(fillLen)) = 0 Then
            errText = "exec: MEMFILLB out of range"
            Return 0
        End If
        Return 1

    Case "POKES_STMT"
        Dim ps0 As Integer
        Dim ps1 As Integer
        ps0 = ExecChildAt(ps, stmtIdx, 0)
        ps1 = ExecChildAt(ps, stmtIdx, 1)
        If ps0 = -1 Or ps1 = -1 Then
            errText = "exec: POKES args missing"
            Return 0
        End If

        Dim pokeAddr As Integer
        pokeAddr = ExecEvalNode(ps, es, ps0, errText)
        If errText <> "" Then Return 0

        Dim textValue As String
        If ExecEvalNodeAsText(ps, es, ps1, textValue, errText) = 0 Then Return 0

        If VMemPokeS(CUInt(pokeAddr), textValue) = 0 Then
            errText = "exec: POKES out of range"
            Return 0
        End If
        Return 1

    Case "MEMCOPYW_STMT"
        Dim mcw0 As Integer
        Dim mcw1 As Integer
        Dim mcw2 As Integer
        mcw0 = ExecChildAt(ps, stmtIdx, 0)
        mcw1 = ExecChildAt(ps, stmtIdx, 1)
        mcw2 = ExecChildAt(ps, stmtIdx, 2)
        If mcw0 = -1 Or mcw1 = -1 Or mcw2 = -1 Then
            errText = "exec: MEMCOPYW args missing"
            Return 0
        End If

        Dim srcW As Integer
        Dim dstW As Integer
        Dim lenW As Integer
        srcW = ExecEvalNode(ps, es, mcw0, errText)
        If errText <> "" Then Return 0
        dstW = ExecEvalNode(ps, es, mcw1, errText)
        If errText <> "" Then Return 0
        lenW = ExecEvalNode(ps, es, mcw2, errText)
        If errText <> "" Then Return 0

        If lenW < 0 Then
            errText = "exec: MEMCOPYW negative length"
            Return 0
        End If

        If VMemCopyW(CUInt(srcW), CUInt(dstW), CUInt(lenW)) = 0 Then
            errText = "exec: MEMCOPYW out of range"
            Return 0
        End If
        Return 1

    Case "MEMCOPYD_STMT"
        Dim mcd0 As Integer
        Dim mcd1 As Integer
        Dim mcd2 As Integer
        mcd0 = ExecChildAt(ps, stmtIdx, 0)
        mcd1 = ExecChildAt(ps, stmtIdx, 1)
        mcd2 = ExecChildAt(ps, stmtIdx, 2)
        If mcd0 = -1 Or mcd1 = -1 Or mcd2 = -1 Then
            errText = "exec: MEMCOPYD args missing"
            Return 0
        End If

        Dim srcD As Integer
        Dim dstD As Integer
        Dim lenD As Integer
        srcD = ExecEvalNode(ps, es, mcd0, errText)
        If errText <> "" Then Return 0
        dstD = ExecEvalNode(ps, es, mcd1, errText)
        If errText <> "" Then Return 0
        lenD = ExecEvalNode(ps, es, mcd2, errText)
        If errText <> "" Then Return 0

        If lenD < 0 Then
            errText = "exec: MEMCOPYD negative length"
            Return 0
        End If

        If VMemCopyD(CUInt(srcD), CUInt(dstD), CUInt(lenD)) = 0 Then
            errText = "exec: MEMCOPYD out of range"
            Return 0
        End If
        Return 1

    Case "MEMFILLW_STMT"
        Dim mfw0 As Integer
        Dim mfw1 As Integer
        Dim mfw2 As Integer
        mfw0 = ExecChildAt(ps, stmtIdx, 0)
        mfw1 = ExecChildAt(ps, stmtIdx, 1)
        mfw2 = ExecChildAt(ps, stmtIdx, 2)
        If mfw0 = -1 Or mfw1 = -1 Or mfw2 = -1 Then
            errText = "exec: MEMFILLW args missing"
            Return 0
        End If

        Dim fillWAddr As Integer
        Dim fillWVal As Integer
        Dim fillWLen As Integer
        fillWAddr = ExecEvalNode(ps, es, mfw0, errText)
        If errText <> "" Then Return 0
        fillWVal = ExecEvalNode(ps, es, mfw1, errText)
        If errText <> "" Then Return 0
        fillWLen = ExecEvalNode(ps, es, mfw2, errText)
        If errText <> "" Then Return 0

        If fillWLen < 0 Then
            errText = "exec: MEMFILLW negative length"
            Return 0
        End If

        If VMemFillW(CUInt(fillWAddr), fillWVal, CUInt(fillWLen)) = 0 Then
            errText = "exec: MEMFILLW out of range"
            Return 0
        End If
        Return 1

    Case "MEMFILLD_STMT"
        Dim mfd0 As Integer
        Dim mfd1 As Integer
        Dim mfd2 As Integer
        mfd0 = ExecChildAt(ps, stmtIdx, 0)
        mfd1 = ExecChildAt(ps, stmtIdx, 1)
        mfd2 = ExecChildAt(ps, stmtIdx, 2)
        If mfd0 = -1 Or mfd1 = -1 Or mfd2 = -1 Then
            errText = "exec: MEMFILLD args missing"
            Return 0
        End If

        Dim fillDAddr As Integer
        Dim fillDVal As Integer
        Dim fillDLen As Integer
        fillDAddr = ExecEvalNode(ps, es, mfd0, errText)
        If errText <> "" Then Return 0
        fillDVal = ExecEvalNode(ps, es, mfd1, errText)
        If errText <> "" Then Return 0
        fillDLen = ExecEvalNode(ps, es, mfd2, errText)
        If errText <> "" Then Return 0

        If fillDLen < 0 Then
            errText = "exec: MEMFILLD negative length"
            Return 0
        End If

        If VMemFillD(CUInt(fillDAddr), fillDVal, CUInt(fillDLen)) = 0 Then
            errText = "exec: MEMFILLD out of range"
            Return 0
        End If
        Return 1

    Case "SETNEWOFFSET_STMT"
        Dim so0 As Integer
        Dim so1 As Integer
        so0 = ExecChildAt(ps, stmtIdx, 0)
        so1 = ExecChildAt(ps, stmtIdx, 1)
        If so0 = -1 Or so1 = -1 Then
            errText = "exec: SETNEWOFFSET args missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(so0).kind) <> "IDENT" Then
            errText = "exec: SETNEWOFFSET target must be ident"
            Return 0
        End If

        Dim newAddr As Integer
        newAddr = ExecEvalNode(ps, es, so1, errText)
        If errText <> "" Then Return 0

        ExecSetVarAddr es, ps.ast.nodes(so0).value, CUInt(newAddr)
        ExecSetVar es, ps.ast.nodes(so0).value, newAddr
        Return 1

    Case Else
        errText = "exec: unsupported statement kind " & st.kind
        Return 0
    End Select
End Function

Function ExecRunMemoryProgram(ByRef ps As ParseState, ByRef errText As String) As Integer
    Dim es As ExecState
    ExecStateInit es
    ExecDebugConsoleReset
    ExecContractInit  ' Execution contract'ları initialize et
    gExitRequest = ""
    gCallContextDepth = 0
    gCallReturnValue = 0
    gCallReturnHasValue = 0

    If ps.rootNode = -1 Then
        errText = "exec: no AST root"
        ExecNormalizeError errText
        Return 0
    End If

    VMemInit

    Dim labelNames(Any) As String
    Dim labelNodes(Any) As Integer
    Dim labelCount As Integer
    If ExecBuildTopLevelLabelMap(ps, ps.rootNode, labelNames(), labelNodes(), labelCount, errText) = 0 Then
        ExecNormalizeError errText
        UxbFileCloseAll es.fileIo
        Return 0
    End If

    If ExecBuildTopLevelRoutineMap(ps, ps.rootNode, errText) = 0 Then
        ExecNormalizeError errText
        UxbFileCloseAll es.fileIo
        Return 0
    End If

    Dim callStack(Any) As Integer
    Dim callDepth As Integer

    Dim runGuard As Integer
    runGuard = 0

    Dim st As Integer
    st = ps.ast.nodes(ps.rootNode).firstChild

    Do While st <> -1
        runGuard += 1
        If runGuard > 1000000 Then
            errText = "exec: top-level iteration guard exceeded"
            ExecNormalizeError errText
            UxbFileCloseAll es.fileIo
            Return 0
        End If

        If ExecRunStmt(ps, es, st, errText) = 0 Then
            ExecNormalizeError errText
            UxbFileCloseAll es.fileIo
            Return 0
        End If

        If gExitRequest <> "" Then
            Dim exitReq As String
            exitReq = UCase(gExitRequest)

            If exitReq = "END" Then
                gExitRequest = ""
                Exit Do
            End If

            If exitReq = "RETURN" Then
                If callDepth <= 0 Then
                    errText = "exec: RETURN used without GOSUB (" & LTrim(Str(UXB_CTRL_ERR_RETURN_WITHOUT_GOSUB)) & ")"
                    ExecNormalizeError errText
                    UxbFileCloseAll es.fileIo
                    Return 0
                End If

                callDepth -= 1
                st = callStack(callDepth)
                gExitRequest = ""
                Continue Do
            ElseIf Left(exitReq, 5) = "GOTO:" Then
                Dim gotoTarget As String
                gotoTarget = Trim(Mid(gExitRequest, 6))

                Dim gotoIdx As Integer
                gotoIdx = ExecLabelIndexOf(labelNames(), labelCount, gotoTarget)
                If gotoIdx = -1 Then
                    errText = "exec: GOTO target not found " & gotoTarget
                    ExecNormalizeError errText
                    UxbFileCloseAll es.fileIo
                    Return 0
                End If

                st = labelNodes(gotoIdx)
                gExitRequest = ""
                Continue Do
            ElseIf Left(exitReq, 6) = "GOSUB:" Then
                Dim gosubTarget As String
                gosubTarget = Trim(Mid(gExitRequest, 7))

                Dim gosubIdx As Integer
                gosubIdx = ExecLabelIndexOf(labelNames(), labelCount, gosubTarget)
                If gosubIdx = -1 Then
                    errText = "exec: GOSUB target not found " & gosubTarget
                    ExecNormalizeError errText
                    UxbFileCloseAll es.fileIo
                    Return 0
                End If

                If callDepth = 0 Then
                    ReDim callStack(0)
                Else
                    ReDim Preserve callStack(callDepth)
                End If

                callStack(callDepth) = ps.ast.nodes(st).nextSibling
                callDepth += 1

                st = labelNodes(gosubIdx)
                gExitRequest = ""
                Continue Do
            ElseIf exitReq = "IF" Then
                errText = "exec: EXIT IF used outside IF block"
                ExecNormalizeError errText
                UxbFileCloseAll es.fileIo
                Return 0
            Else
                errText = "exec: EXIT used outside matching loop"
                ExecNormalizeError errText
                UxbFileCloseAll es.fileIo
                Return 0
            End If
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    UxbFileCloseAll es.fileIo
    Return 1
End Function
