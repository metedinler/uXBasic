' MIR Evaluator functions
Private Sub MIREvaluatorInit(ByRef mir As MIREvaluator)
    mir.blockCount = 0
    mir.currentBlock = 0
End Sub

Private Sub MIRBlockInit(ByRef blk As MIRBlock)
    blk.count = 0
End Sub

Private Sub MIRAddInstruction(ByRef blk As MIRBlock, ByRef opcode As String, ByRef op1 As String, ByRef op2 As String, ByRef op3 As String)
    If blk.count = 0 Then
        ReDim blk.instructions(0)
    Else
        ReDim Preserve blk.instructions(blk.count)
    End If
    
    blk.instructions(blk.count).opcode = opcode
    blk.instructions(blk.count).operand1 = op1
    blk.instructions(blk.count).operand2 = op2
    blk.instructions(blk.count).operand3 = op3
    blk.count += 1
End Sub

Private Function MIRGenerateFromAST(ByRef mir As MIREvaluator, ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "mir: invalid node index"
        Return 0
    End If
    
    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    
    Select Case UCase(n.kind)
    Case "NUMBER"
        MIRAddInstruction mir.blocks(mir.currentBlock), "LOAD_CONST", n.value, "", ""
        Return 1
        
    Case "IDENT"
        MIRAddInstruction mir.blocks(mir.currentBlock), "LOAD_VAR", n.value, "", ""
        Return 1
        
    Case "BINARY"
        If MIRGenerateFromAST(mir, ps, n.left, errText) = 0 Then Return 0
        If MIRGenerateFromAST(mir, ps, n.right, errText) = 0 Then Return 0
        
        Select Case n.op
        Case "+"
            MIRAddInstruction mir.blocks(mir.currentBlock), "ADD", "", "", ""
        Case "-"
            MIRAddInstruction mir.blocks(mir.currentBlock), "SUB", "", "", ""
        Case "*"
            MIRAddInstruction mir.blocks(mir.currentBlock), "MUL", "", "", ""
        Case "="
            MIRAddInstruction mir.blocks(mir.currentBlock), "EQ", "", "", ""
        Case Else
            errText = "mir: unsupported binary op " & n.op
            Return 0
        End Select
        Return 1
        
    Case Else
        errText = "mir: unsupported node kind " & n.kind
        Return 0
    End Select
End Function

Private Function MIRExecute(ByRef mir As MIREvaluator, ByRef es As ExecState, ByRef errText As String) As Integer
    ' Basit MIR execution, şimdilik placeholder
    errText = "mir: MIR execution not fully implemented"
    Return 0
End Function

Private Sub ExecDebugConsoleReset()
    gDebugLocateRow = 0
    gDebugLocateCol = 0
    gDebugColorFg = 0
    gDebugColorBg = 0
    gDebugClsCount = 0
    gDebugPrintColumnPos = 0
End Sub

' ===== EXECUTION CONTRACT IMPLEMENTATIONS =====
' YOK R öğeleri için runtime execution ekleme

Type ExecConstEntry
    nameText As String
    value As ExecValue
End Type

Type ExecDefTypeEntry
    typeChar As String  ' I, L, S, D, E, T, B, Y
    typeName As String  ' INTEGER, LONG, SINGLE, DOUBLE, EXTENDED, STRING, BOOLEAN, BYTE
End Type

Dim Shared gExecConsts() As ExecConstEntry
Dim Shared gExecConstCount As Integer
Dim Shared gExecDefTypes() As ExecDefTypeEntry
Dim Shared gExecDefTypeCount As Integer
Dim Shared gExecStringSize As Integer

Private Sub ExecContractInit()
    gExecConstCount = 0
    gExecDefTypeCount = 0
    gExecStringSize = 255  ' Default string size
End Sub

' CONST execution contract
Function ExecEvalCONST(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' CONST name = value
    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 2 Then
        errText = "CONST: İsim ve değer gerekli"
        Return 0
    End If

    Dim nameNode As Integer
    nameNode = ExecChildAt(ps, nodeIdx, 0)
    If nameNode = -1 Then
        errText = "CONST: İsim düğümü bulunamadı"
        Return 0
    End If

    Dim valueNode As Integer
    valueNode = ExecChildAt(ps, nodeIdx, 1)
    If valueNode = -1 Then
        errText = "CONST: Değer düğümü bulunamadı"
        Return 0
    End If

    Dim constName As String
    constName = UCase(Trim(ps.ast.nodes(nameNode).value))
    If constName = "" Then
        errText = "CONST: Geçersiz sabit adı"
        Return 0
    End If

    ' Check if already defined
    Dim i As Integer
    For i = 0 To gExecConstCount - 1
        If UCase(gExecConsts(i).nameText) = constName Then
            errText = "CONST: Sabit zaten tanımlanmış: " & constName
            Return 0
        End If
    Next

    ' Evaluate value
    Dim constValue As ExecValue
    If ExecEvalExpression(ps, valueNode, es, constValue, errText) = 0 Then
        Return 0
    End If

    ' Add to const table
    If gExecConstCount = 0 Then
        ReDim gExecConsts(0)
    Else
        ReDim Preserve gExecConsts(gExecConstCount)
    End If

    gExecConsts(gExecConstCount).nameText = constName
    gExecConsts(gExecConstCount).value = constValue
    gExecConstCount += 1

    Return 1
End Function

' DIM execution contract
Function ExecEvalDIM(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' DIM decl[, decl...] where each decl is DIM_DECL [DIM_BOUNDS] TYPE_REF [INIT_EXPR]
    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "DIM: declaration required"
        Return 0
    End If

    Dim declPos As Integer
    For declPos = 0 To childCount - 1
        Dim declNode As Integer
        declNode = ExecChildAt(ps, nodeIdx, declPos)
        If declNode = -1 Then
            errText = "DIM: declaration node missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(declNode).kind) <> "DIM_DECL" Then
            errText = "DIM: invalid declaration node"
            Return 0
        End If

        Dim varName As String
        varName = UCase(Trim(ps.ast.nodes(declNode).value))
        If varName = "" Then
            errText = "DIM: invalid variable name"
            Return 0
        End If

        If ExecFindVar(es, varName) <> -1 Then
            errText = "DIM: duplicate variable " & varName
            Return 0
        End If

        Dim typeNode As Integer
        typeNode = ExecFindChildByKind(ps, declNode, "TYPE_REF")
        If typeNode = -1 Then
            errText = "DIM: type reference missing"
            Return 0
        End If

        Dim declType As String
        declType = UCase(Trim(ps.ast.nodes(typeNode).value))
        If declType = "" Then
            errText = "DIM: invalid type"
            Return 0
        End If

        Dim boundsNode As Integer
        boundsNode = ExecFindChildByKind(ps, declNode, "DIM_BOUNDS")

        Dim varValue As ExecValue
        ExecValueInit varValue

        If boundsNode <> -1 Then
            Dim dimCount As Integer
            dimCount = ExecChildCount(ps, boundsNode)
            If dimCount <> 1 Then
                errText = "DIM: only single-dimension arrays supported in R3.N"
                Return 0
            End If

            Dim boundExpr As Integer
            boundExpr = ExecChildAt(ps, boundsNode, 0)
            If boundExpr = -1 Then
                errText = "DIM: array bound missing"
                Return 0
            End If

            Dim lowerBound As Integer
            Dim upperBound As Integer
            If ExecParseBoundRange(ps, es, boundExpr, lowerBound, upperBound, errText) = 0 Then Return 0

            Dim extent As LongInt
            extent = CLng(upperBound) - CLng(lowerBound) + 1
            If extent <= 0 Then
                errText = "DIM: invalid array extent"
                Return 0
            End If

            Dim elemSize As Integer
            elemSize = ExecTypeElemSizeBytes(declType)
            If elemSize <= 0 Then
                errText = "DIM: unsupported array element type " & declType
                Return 0
            End If

            Dim totalBytes As LongInt
            totalBytes = extent * CLng(elemSize)
            If totalBytes <= 0 Or totalBytes > &h7FFFFFFF Then
                errText = "DIM: array byte overflow"
                Return 0
            End If

            varValue.valueType = "ARRAY"
            ExecSetVarValue es, varName, varValue
            ExecSetVarDeclMeta es, varName, declType, 1, 1, lowerBound, upperBound, totalBytes
        Else
            Dim initNode As Integer
            initNode = ExecFindChildByKind(ps, declNode, "INIT_EXPR")
            If initNode <> -1 Then
                If ps.ast.nodes(initNode).left = -1 Then
                    errText = "DIM: invalid initializer"
                    Return 0
                End If

                Dim initValue As ExecValue
                If ExecEvalExpression(ps, ps.ast.nodes(initNode).left, es, initValue, errText) = 0 Then Return 0
                varValue = initValue
            End If

            ExecSetVarValue es, varName, varValue
            ExecSetVarDeclMeta es, varName, declType, 0, 0, 0, 0, 0
        End If
    Next declPos

    Return 1
End Function

' REDIM execution contract
Function ExecEvalREDIM(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' REDIM decl[, decl...] where each decl is REDIM_DECL DIM_BOUNDS TYPE_REF
    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "REDIM: declaration required"
        Return 0
    End If

    Dim declPos As Integer
    For declPos = 0 To childCount - 1
        Dim declNode As Integer
        declNode = ExecChildAt(ps, nodeIdx, declPos)
        If declNode = -1 Then
            errText = "REDIM: declaration node missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(declNode).kind) <> "REDIM_DECL" Then
            errText = "REDIM: invalid declaration node"
            Return 0
        End If

        Dim varName As String
        varName = UCase(Trim(ps.ast.nodes(declNode).value))
        If varName = "" Then
            errText = "REDIM: invalid variable name"
            Return 0
        End If

        Dim varIdx As Integer
        varIdx = ExecFindVar(es, varName)
        If varIdx = -1 Then
            errText = "REDIM: variable not declared " & varName
            Return 0
        End If

        If es.vars(varIdx).isArray = 0 Or es.vars(varIdx).value.valueType <> "ARRAY" Then
            errText = "REDIM: target is not array " & varName
            Return 0
        End If

        Dim typeNode As Integer
        typeNode = ExecFindChildByKind(ps, declNode, "TYPE_REF")
        If typeNode = -1 Then
            errText = "REDIM: type reference missing"
            Return 0
        End If

        Dim redimType As String
        redimType = UCase(Trim(ps.ast.nodes(typeNode).value))
        If redimType = "" Then
            errText = "REDIM: invalid type"
            Return 0
        End If

        If es.vars(varIdx).declType <> "" And redimType <> es.vars(varIdx).declType Then
            errText = "REDIM: type mismatch for " & varName
            Return 0
        End If

        Dim boundsNode As Integer
        boundsNode = ExecFindChildByKind(ps, declNode, "DIM_BOUNDS")
        If boundsNode = -1 Then
            errText = "REDIM: array bounds required"
            Return 0
        End If

        Dim dimCount As Integer
        dimCount = ExecChildCount(ps, boundsNode)
        If dimCount <> 1 Then
            errText = "REDIM: only single-dimension arrays supported in R3.N"
            Return 0
        End If

        If es.vars(varIdx).arrayDims <> 1 Then
            errText = "REDIM: dimension count mismatch for " & varName
            Return 0
        End If

        Dim boundExpr As Integer
        boundExpr = ExecChildAt(ps, boundsNode, 0)
        If boundExpr = -1 Then
            errText = "REDIM: array bound missing"
            Return 0
        End If

        Dim lowerBound As Integer
        Dim upperBound As Integer
        If ExecParseBoundRange(ps, es, boundExpr, lowerBound, upperBound, errText) = 0 Then Return 0

        Dim extent As LongInt
        extent = CLng(upperBound) - CLng(lowerBound) + 1
        If extent <= 0 Then
            errText = "REDIM: invalid array extent"
            Return 0
        End If

        Dim elemSize As Integer
        elemSize = ExecTypeElemSizeBytes(redimType)
        If elemSize <= 0 Then
            errText = "REDIM: unsupported array element type " & redimType
            Return 0
        End If

        Dim totalBytes As LongInt
        totalBytes = extent * CLng(elemSize)
        If totalBytes <= 0 Or totalBytes > &h7FFFFFFF Then
            errText = "REDIM: array byte overflow"
            Return 0
        End If

        Dim newValue As ExecValue
        ExecValueInit newValue
        newValue.valueType = "ARRAY"
        es.vars(varIdx).value = newValue
        ExecSetVarDeclMeta es, varName, redimType, 1, 1, lowerBound, upperBound, totalBytes
    Next declPos

    Return 1
End Function

' DEF* execution contract
Function ExecEvalDEF(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' DEFINT/DEFLNG/DEFSNG/DEFDBL/DEFEXT/DEFSTR/DEFBYT varlist
    Dim stmtKind As String
    stmtKind = UCase(ps.ast.nodes(nodeIdx).kind)

    Dim typeChar As String
    Dim typeName As String

    Select Case stmtKind
    Case "DEFINT"
        typeChar = "I"
        typeName = "INTEGER"
    Case "DEFLNG"
        typeChar = "L"
        typeName = "LONG"
    Case "DEFSNG"
        typeChar = "S"
        typeName = "SINGLE"
    Case "DEFDBL"
        typeChar = "D"
        typeName = "DOUBLE"
    Case "DEFEXT"
        typeChar = "E"
        typeName = "EXTENDED"
    Case "DEFSTR"
        typeChar = "T"
        typeName = "STRING"
    Case "DEFBYT"
        typeChar = "B"
        typeName = "BYTE"
    Case Else
        errText = "DEF: Bilinmeyen DEF türü: " & stmtKind
        Return 0
    End Select

    ' Add to def type table
    If gExecDefTypeCount = 0 Then
        ReDim gExecDefTypes(0)
    Else
        ReDim Preserve gExecDefTypes(gExecDefTypeCount)
    End If

    gExecDefTypes(gExecDefTypeCount).typeChar = typeChar
    gExecDefTypes(gExecDefTypeCount).typeName = typeName
    gExecDefTypeCount += 1

    Return 1
End Function

' SETSTRINGSIZE execution contract
Function ExecEvalSETSTRINGSIZE(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' SETSTRINGSIZE size
    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "SETSTRINGSIZE: Boyut değeri gerekli"
        Return 0
    End If

    Dim sizeNode As Integer
    sizeNode = ExecChildAt(ps, nodeIdx, 0)
    If sizeNode = -1 Then
        errText = "SETSTRINGSIZE: Boyut düğümü bulunamadı"
        Return 0
    End If

    Dim sizeValue As ExecValue
    If ExecEvalExpression(ps, sizeNode, es, sizeValue, errText) = 0 Then
        Return 0
    End If

    If sizeValue.valueType <> "INTEGER" Then
        errText = "SETSTRINGSIZE: Boyut tamsayı olmalı"
        Return 0
    End If

    If sizeValue.intValue <= 0 Then
        errText = "SETSTRINGSIZE: Boyut pozitif olmalı"
        Return 0
    End If

    gExecStringSize = sizeValue.intValue
    Return 1
End Function

' Helper: Evaluate expression (simplified)
Function ExecEvalExpression(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef result As ExecValue, ByRef errText As String) As Integer
    If nodeIdx = -1 Then
        errText = "Expression: Geçersiz düğüm"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    Select Case UCase(n.kind)
    Case "NUMBER"
        If InStr(n.value, ".") > 0 Then
            ExecValueSetFloat result, Val(n.value)
        Else
            ExecValueSetInteger result, Val(n.value)
        End If
        Return 1

    Case "STRING"
        ExecValueSetString result, n.value
        Return 1

    Case "IDENT"
        Dim varName As String
        varName = UCase(n.value)
        ' Check consts first
        Dim i As Integer
        For i = 0 To gExecConstCount - 1
            If UCase(gExecConsts(i).nameText) = varName Then
                result = gExecConsts(i).value
                Return 1
            End If
        Next
        ' Then variables
        If ExecGetVarValue(es, varName, result) = 0 Then
            errText = "Expression: Tanımlanmamış değişken: " & varName
            Return 0
        End If
        Return 1

    Case "BINARY"
        Dim leftVal As ExecValue, rightVal As ExecValue
        If ExecEvalExpression(ps, n.left, es, leftVal, errText) = 0 Then Return 0
        If ExecEvalExpression(ps, n.right, es, rightVal, errText) = 0 Then Return 0

        Select Case n.op
        Case "+"
            If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
                ExecValueSetInteger result, leftVal.intValue + rightVal.intValue
            ElseIf leftVal.valueType = "FLOAT" Or rightVal.valueType = "FLOAT" Then
                ExecValueSetFloat result, ExecValueToFloat(leftVal) + ExecValueToFloat(rightVal)
            Else
                errText = "Expression: + işlemi bu tipler için desteklenmiyor"
                Return 0
            End If
        Case "-"
            If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
                ExecValueSetInteger result, leftVal.intValue - rightVal.intValue
            Else
                ExecValueSetFloat result, ExecValueToFloat(leftVal) - ExecValueToFloat(rightVal)
            End If
        Case "*"
            If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
                ExecValueSetInteger result, leftVal.intValue * rightVal.intValue
            Else
                ExecValueSetFloat result, ExecValueToFloat(leftVal) * ExecValueToFloat(rightVal)
            End If
        Case "="
            Dim cmp As Integer
            If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
                cmp = (leftVal.intValue = rightVal.intValue)
            ElseIf leftVal.valueType = "FLOAT" Or rightVal.valueType = "FLOAT" Then
                cmp = (ExecValueToFloat(leftVal) = ExecValueToFloat(rightVal))
            Else
                cmp = (leftVal.stringValue = rightVal.stringValue)
            End If
            ExecValueSetInteger result, cmp
        Case Else
            errText = "Expression: Desteklenmeyen ikili işlem: " & n.op
            Return 0
        End Select
        Return 1

    Case Else
        errText = "Expression: Desteklenmeyen ifade türü: " & n.kind
        Return 0
    End Select
End Function

