#include once "file_io.fbs"
#include once "error_format.fbs"
#include once "diagnostics.fbs"
#include once "ffi_signer.fbs"

Type ExecValue
    valueType As String  ' INTEGER, FLOAT, STRING
    intValue As Integer
    floatValue As Double
    stringValue As String
    ' Array and object support removed for simplicity
End Type

Type ExecVar
    nameText As String
    value As ExecValue
    addr As UInteger
    declType As String
    isArray As Integer
    arrayDims As Integer
    arrayLower As Integer
    arrayUpper As Integer
    arrayBytes As LongInt
    ' typeBinding As TypeBinding
End Type

Type ExecArray
    dims As Integer
    bounds(Any) As Integer  ' lower/upper pairs
    elements(Any) As ExecValue
    totalElements As Integer
End Type

Type ExecObject
    typeName As String
    fields(Any) As ExecValue
    fieldNames(Any) As String
    fieldCount As Integer
End Type

Type ExecCollection
    kind As String  ' LIST, DICT, SET
    listItems(Any) As ExecValue
    dictKeys(Any) As String
    dictValues(Any) As ExecValue
    setItems(Any) As String
    count As Integer
End Type

Type ExecState
    vars(0 to 255) As ExecVar
    count As Integer
    nextVarAddr As UInteger
    fileIo As UxbFileRuntime
    ' arrays(Any) As ExecArray
    ' arrayCount As Integer
    ' objects(Any) As ExecObject
    ' objectCount As Integer
    ' collections(Any) As ExecCollection
    ' collectionCount As Integer
End Type

Declare Function ExecEvalExpression(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef result As ExecValue, ByRef errText As String) As Integer

Declare Function ExecEnsureVar(ByRef es As ExecState, ByRef nameText As String) As Integer
Declare Function ExecEvalNode(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef errText As String) As Integer

Type ExecFfiAllowEntry
    dllName As String
    symbolName As String
    signatureText As String
    hashText As String
    signerText As String
End Type

Type ExecRoutineDef
    nameText As String
    nodeIdx As Integer
    routineKind As String
End Type

Type MIRInstruction
    opcode As String
    operand1 As String
    operand2 As String
    operand3 As String
End Type

Type MIRBlock
    instructions(Any) As MIRInstruction
    count As Integer
End Type

Type MIREvaluator
    blocks(Any) As MIRBlock
    blockCount As Integer
    currentBlock As Integer
End Type

Private Sub ExecStateInit(ByRef es As ExecState)
    es.count = 0
    es.nextVarAddr = &h1000
    ' es.arrayCount = 0
    ' es.objectCount = 0
    ' es.collectionCount = 0
    UxbFileInit es.fileIo
End Sub

Private Sub ExecValueInit(ByRef ev As ExecValue)
    ev.valueType = "INTEGER"
    ev.intValue = 0
    ev.floatValue = 0.0
    ev.stringValue = ""
End Sub

Private Sub ExecValueSetInteger(ByRef ev As ExecValue, ByVal value As Integer)
    ExecValueInit ev
    ev.valueType = "INTEGER"
    ev.intValue = value
End Sub

Private Sub ExecValueSetFloat(ByRef ev As ExecValue, ByVal value As Double)
    ExecValueInit ev
    ev.valueType = "FLOAT"
    ev.floatValue = value
End Sub

Private Sub ExecValueSetString(ByRef ev As ExecValue, ByRef value As String)
    ExecValueInit ev
    ev.valueType = "STRING"
    ev.stringValue = value
End Sub

Private Function ExecValueToInteger(ByRef ev As ExecValue) As Integer
    Select Case ev.valueType
    Case "INTEGER"
        Return ev.intValue
    Case "FLOAT"
        Return CInt(ev.floatValue)
    Case "STRING"
        Return ValInt(ev.stringValue)
    Case Else
        Return 0
    End Select
End Function

Private Function ExecValueToFloat(ByRef ev As ExecValue) As Double
    Select Case ev.valueType
    Case "INTEGER"
        Return CDbl(ev.intValue)
    Case "FLOAT"
        Return ev.floatValue
    Case "STRING"
        Return Val(ev.stringValue)
    Case Else
        Return 0.0
    End Select
End Function

Private Function ExecValueToString(ByRef ev As ExecValue) As String
    Select Case ev.valueType
    Case "INTEGER"
        Return LTrim(Str(ev.intValue))
    Case "FLOAT"
        Return LTrim(Str(ev.floatValue))
    Case "STRING"
        Return ev.stringValue
    Case Else
        Return ""
    End Select
End Function

Private Function ExecFindVar(ByRef es As ExecState, ByRef nameText As String) As Integer
    Dim u As String
    u = UCase(nameText)

    Dim i As Integer
    For i = 0 To es.count - 1
        If UCase(es.vars(i).nameText) = u Then Return i
    Next i

    Return -1
End Function

Private Function ExecGetVar(ByRef es As ExecState, ByRef nameText As String) As Integer
    Dim idx As Integer
    idx = ExecFindVar(es, nameText)
    If idx = -1 Then Return 0
    Return ExecValueToInteger(es.vars(idx).value)
End Function

Private Function ExecGetVarValue(ByRef es As ExecState, ByRef nameText As String, ByRef valueOut As ExecValue) As Integer
    Dim idx As Integer
    idx = ExecFindVar(es, nameText)
    If idx = -1 Then
        ExecValueInit valueOut
        Return 0
    End If
    valueOut = es.vars(idx).value
    Return 1
End Function

Private Sub ExecSetVarValue(ByRef es As ExecState, ByRef nameText As String, ByRef value As ExecValue)
    Dim idx As Integer
    idx = ExecEnsureVar(es, nameText)
    es.vars(idx).value = value
End Sub

Private Function ExecEnsureVar(ByRef es As ExecState, ByRef nameText As String) As Integer
    Dim idx As Integer
    idx = ExecFindVar(es, nameText)

    If idx <> -1 Then Return idx

    If es.count >= 256 Then
        ' overflow
        Return -1
    End If

    idx = es.count
    es.vars(idx).nameText = nameText
    ExecValueInit es.vars(idx).value
    es.vars(idx).addr = es.nextVarAddr
    es.vars(idx).declType = ""
    es.vars(idx).isArray = 0
    es.vars(idx).arrayDims = 0
    es.vars(idx).arrayLower = 0
    es.vars(idx).arrayUpper = 0
    es.vars(idx).arrayBytes = 0
    es.nextVarAddr += 4
    es.count += 1

    Return idx
End Function

Private Function ExecGetVarAddr(ByRef es As ExecState, ByRef nameText As String) As UInteger
    Dim idx As Integer
    idx = ExecEnsureVar(es, nameText)
    Return es.vars(idx).addr
End Function

Private Sub ExecSetVarAddr(ByRef es As ExecState, ByRef nameText As String, ByVal addr As UInteger)
    Dim idx As Integer
    idx = ExecEnsureVar(es, nameText)
    es.vars(idx).addr = addr
End Sub

Private Sub ExecSetVar(ByRef es As ExecState, ByRef nameText As String, ByVal value As Integer)
    Dim idx As Integer
    idx = ExecEnsureVar(es, nameText)
    ExecValueSetInteger es.vars(idx).value, value
End Sub

Private Function ExecChildAt(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal childPos As Integer) As Integer
    Dim i As Integer
    Dim ch As Integer

    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If i = childPos Then Return ch
        i += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return -1
End Function

Private Function ExecChildCount(ByRef ps As ParseState, ByVal nodeIdx As Integer) As Integer
    Dim total As Integer
    Dim ch As Integer

    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        total += 1
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return total
End Function

Private Function ExecFindChildByKind(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByVal kindText As String) As Integer
    Dim targetKind As String
    targetKind = UCase(kindText)

    Dim ch As Integer
    ch = ps.ast.nodes(nodeIdx).firstChild
    Do While ch <> -1
        If UCase(ps.ast.nodes(ch).kind) = targetKind Then Return ch
        ch = ps.ast.nodes(ch).nextSibling
    Loop

    Return -1
End Function

Private Function ExecTypeElemSizeBytes(ByVal typeNameRaw As String) As Integer
    Dim typeName As String
    typeName = UCase(Trim(typeNameRaw))

    Select Case typeName
    Case "I8", "U8", "BYTE"
        Return 1
    Case "I16", "U16", "SHORT"
        Return 2
    Case "I32", "U32", "INTEGER", "LONG"
        Return 4
    Case "I64", "U64"
        Return 8
    Case "F32", "SINGLE"
        Return 4
    Case "F64", "DOUBLE", "F80", "EXTENDED"
        Return 8
    End Select

    Return 0
End Function

Private Function ExecParseBoundRange(ByRef ps As ParseState, ByRef es As ExecState, ByVal boundNode As Integer, ByRef lowerOut As Integer, ByRef upperOut As Integer, ByRef errText As String) As Integer
    If boundNode = -1 Then
        errText = "exec: DIM/REDIM bound node missing"
        Return 0
    End If

    Dim b As ASTNode
    b = ps.ast.nodes(boundNode)

    If UCase(b.kind) = "RANGE_EXPR" Then
        lowerOut = ExecEvalNode(ps, es, b.left, errText)
        If errText <> "" Then Return 0

        upperOut = ExecEvalNode(ps, es, b.right, errText)
        If errText <> "" Then Return 0
    Else
        lowerOut = 0
        upperOut = ExecEvalNode(ps, es, boundNode, errText)
        If errText <> "" Then Return 0
    End If

    If upperOut < lowerOut Then
        errText = "exec: DIM/REDIM invalid array bounds (lower > upper)"
        Return 0
    End If

    Return 1
End Function

Private Sub ExecSetVarDeclMeta(ByRef es As ExecState, ByRef nameText As String, ByRef declType As String, ByVal isArray As Integer, ByVal arrayDims As Integer, ByVal arrayLower As Integer, ByVal arrayUpper As Integer, ByVal arrayBytes As LongInt)
    Dim idx As Integer
    idx = ExecEnsureVar(es, nameText)
    If idx = -1 Then Exit Sub

    es.vars(idx).declType = UCase(Trim(declType))
    es.vars(idx).isArray = isArray
    es.vars(idx).arrayDims = arrayDims
    es.vars(idx).arrayLower = arrayLower
    es.vars(idx).arrayUpper = arrayUpper
    es.vars(idx).arrayBytes = arrayBytes
End Sub

Private Function ExecLabelIndexOf(labelNames() As String, ByVal labelCount As Integer, ByRef needle As String) As Integer
    Dim i As Integer
    For i = 0 To labelCount - 1
        If labelNames(i) = needle Then Return i
    Next i
    Return -1
End Function

Private Function ExecBuildTopLevelLabelMap(ByRef ps As ParseState, ByVal rootNode As Integer, labelNames() As String, labelNodes() As Integer, ByRef labelCount As Integer, ByRef errText As String) As Integer
    labelCount = 0

    Dim st As Integer
    st = ps.ast.nodes(rootNode).firstChild
    Do While st <> -1
        If UCase(ps.ast.nodes(st).kind) = "LABEL_STMT" Then
            Dim labelName As String
            labelName = UCase(Trim(ps.ast.nodes(st).value))
            If labelName = "" Then
                errText = "exec: LABEL name missing"
                Return 0
            End If

            If ExecLabelIndexOf(labelNames(), labelCount, labelName) <> -1 Then
                errText = "exec: duplicate LABEL " & labelName
                Return 0
            End If

            If labelCount = 0 Then
                ReDim labelNames(0)
                ReDim labelNodes(0)
            Else
                ReDim Preserve labelNames(labelCount)
                ReDim Preserve labelNodes(labelCount)
            End If

            labelNames(labelCount) = labelName
            labelNodes(labelCount) = st
            labelCount += 1
        End If

        st = ps.ast.nodes(st).nextSibling
    Loop

    Return 1
End Function

Private Function ExecEvalStringLiteral(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef textOut As String, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "exec: invalid string node"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    If UCase(n.kind) <> "STRING" Then
        errText = "exec: string literal expected"
        Return 0
    End If

    textOut = n.value
    Return 1
End Function

Private Function ExecFormatFileError(ByRef io As UxbFileRuntime) As String
    Dim errorCode As Integer
    errorCode = UxbFileGetLastError(io)
    Return UxbFormatError(errorCode, UxbFileErrorText(errorCode))
End Function

Private Function ExecHashText(ByRef textValue As String) As UInteger
    Dim h As UInteger
    h = CUInt(&h811C9DC5)

    Dim i As Integer
    For i = 1 To Len(textValue)
        h = h Xor CUInt(Asc(Mid(textValue, i, 1)) And &hFF)
        h *= CUInt(&h01000193)
    Next i

    Return h
End Function

Private Function ExecRol32(ByVal v As UInteger, ByVal s As Integer) As UInteger
    Dim shiftBits As Integer
    shiftBits = s And 31
    If shiftBits = 0 Then Return v
    Return (v Shl shiftBits) Or (v Shr (32 - shiftBits))
End Function

Private Function ExecRor32(ByVal v As UInteger, ByVal s As Integer) As UInteger
    Dim shiftBits As Integer
    shiftBits = s And 31
    If shiftBits = 0 Then Return v
    Return (v Shr shiftBits) Or (v Shl (32 - shiftBits))
End Function

Declare Function ExecEvalNodeAsText(ByRef ps As ParseState, ByRef es As ExecState, ByVal nodeIdx As Integer, ByRef textOut As String, ByRef errText As String) As Integer
Declare Function ExecRunStmt(ByRef ps As ParseState, ByRef es As ExecState, ByVal stmtIdx As Integer, ByRef errText As String) As Integer

