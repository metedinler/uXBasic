' MIR Evaluator functions
Private Sub MIREvaluatorInit(ByRef mir As MIREvaluator)
    mir.blockCount = 0
    mir.currentBlock = 0
End Sub

Private Sub MIRBlockInit(ByRef blk As MIRBlock)
    blk.count = 0
End Sub

Private Sub MIRAddInstruction(ByRef blk As MIRBlock, ByRef opcode As String, ByRef op1 As String, ByRef op2 As String, ByRef op3 As String)
    If blk.count = 0 Then
        ReDim blk.instructions(0)
    Else
        ReDim Preserve blk.instructions(blk.count)
    End If
    
    blk.instructions(blk.count).opcode = opcode
    blk.instructions(blk.count).operand1 = op1
    blk.instructions(blk.count).operand2 = op2
    blk.instructions(blk.count).operand3 = op3
    blk.count += 1
End Sub

Private Function MIRGenerateFromAST(ByRef mir As MIREvaluator, ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef errText As String) As Integer
    If nodeIdx < 0 Or nodeIdx >= ps.ast.count Then
        errText = "mir: invalid node index"
        Return 0
    End If
    
    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)
    
    Select Case UCase(n.kind)
    Case "NUMBER"
        MIRAddInstruction mir.blocks(mir.currentBlock), "LOAD_CONST", n.value, "", ""
        Return 1
        
    Case "IDENT"
        MIRAddInstruction mir.blocks(mir.currentBlock), "LOAD_VAR", n.value, "", ""
        Return 1
        
    Case "BINARY"
        If MIRGenerateFromAST(mir, ps, n.left, errText) = 0 Then Return 0
        If MIRGenerateFromAST(mir, ps, n.right, errText) = 0 Then Return 0
        
        Select Case n.op
        Case "+"
            MIRAddInstruction mir.blocks(mir.currentBlock), "ADD", "", "", ""
        Case "-"
            MIRAddInstruction mir.blocks(mir.currentBlock), "SUB", "", "", ""
        Case "*"
            MIRAddInstruction mir.blocks(mir.currentBlock), "MUL", "", "", ""
        Case "="
            MIRAddInstruction mir.blocks(mir.currentBlock), "EQ", "", "", ""
        Case Else
            errText = "mir: unsupported binary op " & n.op
            Return 0
        End Select
        Return 1
        
    Case Else
        errText = "mir: unsupported node kind " & n.kind
        Return 0
    End Select
End Function

Private Function MIRExecute(ByRef mir As MIREvaluator, ByRef es As ExecState, ByRef errText As String) As Integer
    ' Basit MIR execution, şimdilik placeholder
    errText = "mir: MIR execution not fully implemented"
    Return 0
End Function

Private Sub ExecDebugConsoleReset()
    gDebugLocateRow = 0
    gDebugLocateCol = 0
    gDebugColorFg = 0
    gDebugColorBg = 0
    gDebugClsCount = 0
    gDebugPrintColumnPos = 0
End Sub

' ===== EXECUTION CONTRACT IMPLEMENTATIONS =====
' YOK R öğeleri için runtime execution ekleme

Private Sub ExecContractInit(ByRef es As ExecState)
    es.constCount = 0
    es.defTypeCount = 0
    es.stringSize = 255
    Erase es.consts
    Erase es.defTypes
    gExecDebugLastDefTypeCount = es.defTypeCount
    gExecDebugLastStringSize = es.stringSize
End Sub

#include once "exec/exec_class_layout_helpers.fbs"

' CONST execution contract
Function ExecEvalCONST(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' Parser emits CONST_STMT with one or more CONST_DECL children.
    Dim declCount As Integer
    declCount = ExecChildCount(ps, nodeIdx)
    If declCount < 1 Then
        errText = "CONST: İsim ve değer gerekli"
        Return 0
    End If

    Dim declPos As Integer
    For declPos = 0 To declCount - 1
        Dim declNode As Integer
        declNode = ExecChildAt(ps, nodeIdx, declPos)
        If declNode = -1 Or UCase(ps.ast.nodes(declNode).kind) <> "CONST_DECL" Then
            errText = "CONST: Geçersiz sabit bildirimi"
            Return 0
        End If

        Dim constName As String
        constName = UCase(Trim(ps.ast.nodes(declNode).value))
        If constName = "" Then
            errText = "CONST: Geçersiz sabit adı"
            Return 0
        End If

        Dim valueNode As Integer
        valueNode = ps.ast.nodes(declNode).left
        If valueNode = -1 Then
            errText = "CONST: Değer düğümü bulunamadı"
            Return 0
        End If

        ' Check if already defined
        Dim i As Integer
        For i = 0 To es.constCount - 1
            If UCase(es.consts(i).nameText) = constName Then
                errText = "CONST: Sabit zaten tanımlanmış: " & constName
                Return 0
            End If
        Next

        ' Evaluate value
        Dim constValue As ExecValue
        If ExecEvalExpression(ps, valueNode, es, constValue, errText) = 0 Then
            Return 0
        End If

        ' Add to const table
        If es.constCount = 0 Then
            ReDim es.consts(0)
        Else
            ReDim Preserve es.consts(es.constCount)
        End If

        es.consts(es.constCount).nameText = constName
        es.consts(es.constCount).value = constValue
        es.constCount += 1
    Next

    Return 1
End Function

' DIM execution contract
Function ExecEvalDIM(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' DIM decl[, decl...] where each decl is DIM_DECL [DIM_BOUNDS] TYPE_REF [INIT_EXPR]
    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "DIM: declaration required"
        Return 0
    End If

    Dim declPos As Integer
    For declPos = 0 To childCount - 1
        Dim declNode As Integer
        declNode = ExecChildAt(ps, nodeIdx, declPos)
        If declNode = -1 Then
            errText = "DIM: declaration node missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(declNode).kind) <> "DIM_DECL" Then
            errText = "DIM: invalid declaration node"
            Return 0
        End If

        Dim varName As String
        varName = UCase(Trim(ps.ast.nodes(declNode).value))
        If varName = "" Then
            errText = "DIM: invalid variable name"
            Return 0
        End If

        If ExecFindVar(es, varName) <> -1 Then
            errText = "DIM: duplicate variable " & varName
            Return 0
        End If

        Dim typeNode As Integer
        typeNode = ExecFindChildByKind(ps, declNode, "TYPE_REF")
        If typeNode = -1 Then
            errText = "DIM: type reference missing"
            Return 0
        End If

        Dim declType As String
        declType = UCase(Trim(ps.ast.nodes(typeNode).value))
        If declType = "" Then
            errText = "DIM: invalid type"
            Return 0
        End If

        Dim boundsNode As Integer
        boundsNode = ExecFindChildByKind(ps, declNode, "DIM_BOUNDS")

        Dim varValue As ExecValue
        ExecValueInit varValue

        If boundsNode <> -1 Then
            Dim dimCount As Integer
            dimCount = ExecChildCount(ps, boundsNode)
            If dimCount <> 1 Then
                errText = "DIM: only single-dimension arrays supported in R3.N"
                Return 0
            End If

            Dim boundExpr As Integer
            boundExpr = ExecChildAt(ps, boundsNode, 0)
            If boundExpr = -1 Then
                errText = "DIM: array bound missing"
                Return 0
            End If

            Dim lowerBound As Integer
            Dim upperBound As Integer
            If ExecParseBoundRange(ps, es, boundExpr, lowerBound, upperBound, errText) = 0 Then Return 0

            Dim extent As LongInt
            extent = CLng(upperBound) - CLng(lowerBound) + 1
            If extent <= 0 Then
                errText = "DIM: invalid array extent"
                Return 0
            End If

            Dim elemSize As Integer
            elemSize = ExecTypeElemSizeBytes(declType)
            If elemSize <= 0 Then
                errText = "DIM: unsupported array element type " & declType
                Return 0
            End If

            Dim totalBytes As LongInt
            totalBytes = extent * CLng(elemSize)
            If totalBytes <= 0 Or totalBytes > &h7FFFFFFF Then
                errText = "DIM: array byte overflow"
                Return 0
            End If

            varValue.valueType = "ARRAY"
            ExecSetVarValue es, varName, varValue
            ExecSetVarDeclMeta es, varName, declType, 1, 1, lowerBound, upperBound, totalBytes
            If ExecArrayResizeVar(es, varName, lowerBound, upperBound, 0) = 0 Then
                errText = "DIM: array storage init failed"
                Return 0
            End If
        Else
            Dim initNode As Integer
            initNode = ExecFindChildByKind(ps, declNode, "INIT_EXPR")
            If declType = "LIST" Or declType = "DICT" Or declType = "SET" Then
                Dim collHandle As Integer
                collHandle = ExecCollectionCreate(declType)
                ExecValueSetInteger varValue, collHandle
            ElseIf ExecFindClassDeclNode(ps, declType) <> -1 Or declType = "OBJECT" Then
                If initNode <> -1 Then
                    If ps.ast.nodes(initNode).left = -1 Then
                        errText = "DIM: invalid class initializer"
                        Return 0
                    End If

                    Dim initExprNode As Integer
                    initExprNode = ps.ast.nodes(initNode).left
                    If UCase(ps.ast.nodes(initExprNode).kind) <> "NEW_EXPR" Then
                        errText = "DIM: class initializer must be NEW " & declType
                        Return 0
                    End If

                    Dim newType As String
                    newType = UCase(Trim(ps.ast.nodes(initExprNode).value))
                    If ExecCanAssignClassType(ps, declType, newType) = 0 Then
                        errText = "DIM: class initializer type mismatch expected=" & declType & " actual=" & newType
                        Return 0
                    End If

                    Dim initValue As ExecValue
                    If ExecEvalExpression(ps, initExprNode, es, initValue, errText) = 0 Then Return 0
                    varValue = initValue
                End If
            ElseIf initNode <> -1 Then
                If ps.ast.nodes(initNode).left = -1 Then
                    errText = "DIM: invalid initializer"
                    Return 0
                End If

                Dim initValue As ExecValue
                If ExecEvalExpression(ps, ps.ast.nodes(initNode).left, es, initValue, errText) = 0 Then Return 0
                varValue = initValue
            End If

            ExecSetVarValue es, varName, varValue
            ExecSetVarDeclMeta es, varName, declType, 0, 0, 0, 0, 0
            Dim aggregateSize As Integer
            Dim aggregateErr As String
            Dim hasAggregateLayout As Integer
            hasAggregateLayout = 0
            If TypeLayoutSizeOf(ps, declType, aggregateSize, aggregateErr) <> 0 Then
                If ExecFindClassDeclNode(ps, declType) = -1 And declType <> "OBJECT" Then
                    hasAggregateLayout = 1
                End If
            End If

            If hasAggregateLayout <> 0 Then
                Dim aggVarIdx As Integer
                aggVarIdx = ExecFindVar(es, varName)
                If aggVarIdx = -1 Then
                    errText = "DIM: aggregate variable allocation failed " & varName
                    Return 0
                End If
                If VMemFillB(es.vars(aggVarIdx).addr, 0, CUInt(aggregateSize)) = 0 Then
                    errText = "DIM: aggregate allocation out of range"
                    Return 0
                End If
                Dim aggEnd As UInteger
                aggEnd = es.vars(aggVarIdx).addr + CUInt(aggregateSize)
                If aggEnd > es.nextVarAddr Then es.nextVarAddr = aggEnd
            ElseIf ExecFindClassDeclNode(ps, declType) <> -1 Then
                If initNode <> -1 Then
                    ExecSetVarAddr es, varName, CUInt(ExecValueToInteger(varValue))
                    Dim initExprNode2 As Integer
                    initExprNode2 = ps.ast.nodes(initNode).left
                    If initExprNode2 <> -1 Then
                        es.vars(ExecFindVar(es, varName)).runtimeClassType = UCase(Trim(ps.ast.nodes(initExprNode2).value))
                    End If
                Else
                    If ExecConfigureClassStorage(ps, es, varName, declType, errText) = 0 Then Return 0
                    es.vars(ExecFindVar(es, varName)).runtimeClassType = declType
                End If
            ElseIf declType = "OBJECT" Then
                If initNode <> -1 Then
                    ExecSetVarAddr es, varName, CUInt(ExecValueToInteger(varValue))
                    Dim initExprNode3 As Integer
                    initExprNode3 = ps.ast.nodes(initNode).left
                    If initExprNode3 <> -1 Then
                        es.vars(ExecFindVar(es, varName)).runtimeClassType = UCase(Trim(ps.ast.nodes(initExprNode3).value))
                    End If
                End If
            End If
        End If
    Next declPos

    Return 1
End Function

' REDIM execution contract
Function ExecEvalREDIM(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' REDIM decl[, decl...] where each decl is REDIM_DECL DIM_BOUNDS TYPE_REF
    Dim preserveMode As Integer
    preserveMode = (UCase(Trim(ps.ast.nodes(nodeIdx).op)) = "PRESERVE")

    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "REDIM: declaration required"
        Return 0
    End If

    Dim declPos As Integer
    For declPos = 0 To childCount - 1
        Dim declNode As Integer
        declNode = ExecChildAt(ps, nodeIdx, declPos)
        If declNode = -1 Then
            errText = "REDIM: declaration node missing"
            Return 0
        End If

        If UCase(ps.ast.nodes(declNode).kind) <> "REDIM_DECL" Then
            errText = "REDIM: invalid declaration node"
            Return 0
        End If

        Dim varName As String
        varName = UCase(Trim(ps.ast.nodes(declNode).value))
        If varName = "" Then
            errText = "REDIM: invalid variable name"
            Return 0
        End If

        Dim varIdx As Integer
        varIdx = ExecFindVar(es, varName)
        If varIdx = -1 Then
            errText = "REDIM: variable not declared " & varName
            Return 0
        End If

        If es.vars(varIdx).isArray = 0 Or es.vars(varIdx).value.valueType <> "ARRAY" Then
            errText = "REDIM: target is not array " & varName
            Return 0
        End If

        Dim typeNode As Integer
        typeNode = ExecFindChildByKind(ps, declNode, "TYPE_REF")
        If typeNode = -1 Then
            errText = "REDIM: type reference missing"
            Return 0
        End If

        Dim redimType As String
        redimType = ExecNormalizeTypeName(ps.ast.nodes(typeNode).value)
        If redimType = "" Then
            errText = "REDIM: invalid type"
            Return 0
        End If

        Dim declTypeNorm As String
        declTypeNorm = ExecNormalizeTypeName(es.vars(varIdx).declType)
        If declTypeNorm <> "" And redimType <> declTypeNorm Then
            errText = "REDIM: type mismatch for " & varName
            Return 0
        End If

        Dim boundsNode As Integer
        boundsNode = ExecFindChildByKind(ps, declNode, "DIM_BOUNDS")
        If boundsNode = -1 Then
            errText = "REDIM: array bounds required"
            Return 0
        End If

        Dim dimCount As Integer
        dimCount = ExecChildCount(ps, boundsNode)
        If dimCount < 1 Then
            errText = "REDIM: at least one dimension required"
            Return 0
        End If

        Dim elemSize As Integer
        elemSize = ExecTypeElemSizeBytes(redimType)
        If elemSize <= 0 Then
            errText = "REDIM: unsupported array element type " & redimType
            Return 0
        End If

        Dim totalElements As LongInt
        totalElements = 1
        Dim firstLower As Integer
        Dim firstUpper As Integer
        firstLower = 0
        firstUpper = -1

        Dim dimPos As Integer
        For dimPos = 0 To dimCount - 1
            Dim boundExpr As Integer
            boundExpr = ExecChildAt(ps, boundsNode, dimPos)
            If boundExpr = -1 Then
                errText = "REDIM: array bound missing"
                Return 0
            End If

            Dim lowerBound As Integer
            Dim upperBound As Integer
            If ExecParseBoundRange(ps, es, boundExpr, lowerBound, upperBound, errText) = 0 Then Return 0

            Dim extent As LongInt
            extent = CLng(upperBound) - CLng(lowerBound) + 1
            If extent <= 0 Then
                errText = "REDIM: invalid array extent"
                Return 0
            End If

            If dimPos = 0 Then
                firstLower = lowerBound
                firstUpper = upperBound
            End If

            If totalElements > &h7FFFFFFF \ extent Then
                errText = "REDIM: array byte overflow"
                Return 0
            End If
            totalElements *= extent
        Next dimPos

        Dim totalBytes As LongInt
        totalBytes = totalElements * CLng(elemSize)
        If totalBytes <= 0 Or totalBytes > &h7FFFFFFF Then
            errText = "REDIM: array byte overflow"
            Return 0
        End If

        Dim newValue As ExecValue
        ExecValueInit newValue
        newValue.valueType = "ARRAY"

        es.vars(varIdx).value = newValue
        If ExecArrayResizeVar(es, varName, firstLower, firstUpper, preserveMode) = 0 Then
            errText = "REDIM: array storage resize failed"
            Return 0
        End If
        ExecSetVarDeclMeta es, varName, redimType, 1, dimCount, firstLower, firstUpper, totalBytes
    Next declPos

    Return 1
End Function

' DEF* execution contract
Function ExecEvalDEF(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' DEFINT/DEFLNG/DEFSNG/DEFDBL/DEFEXT/DEFSTR/DEFBYT varlist
    Dim stmtKind As String
    stmtKind = UCase(ps.ast.nodes(nodeIdx).kind)

    If stmtKind = "DEFTYPE_STMT" Then
        stmtKind = UCase(Trim(ps.ast.nodes(nodeIdx).op))
    End If

    Dim typeChar As String
    Dim typeName As String

    Select Case stmtKind
    Case "DEFINT", "DEFINT_STMT"
        typeChar = "I"
        typeName = "INTEGER"
    Case "DEFLNG", "DEFLNG_STMT"
        typeChar = "L"
        typeName = "LONG"
    Case "DEFSNG", "DEFSNG_STMT"
        typeChar = "S"
        typeName = "SINGLE"
    Case "DEFDBL", "DEFDBL_STMT"
        typeChar = "D"
        typeName = "DOUBLE"
    Case "DEFEXT", "DEFEXT_STMT"
        typeChar = "E"
        typeName = "EXTENDED"
    Case "DEFSTR", "DEFSTR_STMT"
        typeChar = "T"
        typeName = "STRING"
    Case "DEFBYT", "DEFBYT_STMT"
        typeChar = "B"
        typeName = "I8"
    Case Else
        errText = "DEF: Bilinmeyen DEF türü: " & stmtKind
        Return 0
    End Select

    ' Add to def type table
    If es.defTypeCount = 0 Then
        ReDim es.defTypes(0)
    Else
        ReDim Preserve es.defTypes(es.defTypeCount)
    End If

    es.defTypes(es.defTypeCount).typeChar = typeChar
    es.defTypes(es.defTypeCount).typeName = typeName
    es.defTypeCount += 1
    gExecDebugLastDefTypeCount = es.defTypeCount

    Return 1
End Function

' SETSTRINGSIZE execution contract
Function ExecEvalSETSTRINGSIZE(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef errText As String) As Integer
    ' SETSTRINGSIZE size
    Dim childCount As Integer
    childCount = ExecChildCount(ps, nodeIdx)
    If childCount < 1 Then
        errText = "SETSTRINGSIZE: Boyut değeri gerekli"
        Return 0
    End If

    Dim sizeNode As Integer
    sizeNode = ExecChildAt(ps, nodeIdx, 0)
    If sizeNode = -1 Then
        errText = "SETSTRINGSIZE: Boyut düğümü bulunamadı"
        Return 0
    End If

    Dim sizeValue As Integer
    sizeValue = ExecEvalNode(ps, es, sizeNode, errText)
    If errText <> "" Then Return 0

    If sizeValue <= 0 Then
        errText = "SETSTRINGSIZE: Boyut pozitif olmalı"
        Return 0
    End If

    es.stringSize = sizeValue
    gExecDebugLastStringSize = es.stringSize
    Return 1
End Function

Private Function ExecEvalBinaryValues(ByRef leftVal As ExecValue, ByRef rightVal As ExecValue, ByRef opText As String, ByRef result As ExecValue, ByRef errText As String) As Integer
    Select Case opText
    Case "+"
        If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
            ExecValueSetInteger result, leftVal.intValue + rightVal.intValue
        ElseIf leftVal.valueType = "FLOAT" Or rightVal.valueType = "FLOAT" Then
            ExecValueSetFloat result, ExecValueToFloat(leftVal) + ExecValueToFloat(rightVal)
        Else
            errText = "Expression: + işlemi bu tipler için desteklenmiyor"
            Return 0
        End If
    Case "-"
        If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
            ExecValueSetInteger result, leftVal.intValue - rightVal.intValue
        Else
            ExecValueSetFloat result, ExecValueToFloat(leftVal) - ExecValueToFloat(rightVal)
        End If
    Case "*"
        If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
            ExecValueSetInteger result, leftVal.intValue * rightVal.intValue
        Else
            ExecValueSetFloat result, ExecValueToFloat(leftVal) * ExecValueToFloat(rightVal)
        End If
    Case "**"
        Dim powBase As Integer
        Dim powExp As Integer
        powBase = ExecValueToInteger(leftVal)
        powExp = ExecValueToInteger(rightVal)
        If powExp < 0 Then
            errText = "Expression: negative exponent not supported"
            Return 0
        End If
        Dim pi As Integer
        Dim pacc As Integer
        pacc = 1
        For pi = 1 To powExp
            pacc *= powBase
        Next pi
        ExecValueSetInteger result, pacc
    Case "/"
        If ExecValueToFloat(rightVal) = 0.0 Then
            errText = "Expression: sıfıra bölme"
            Return 0
        End If
        ExecValueSetFloat result, ExecValueToFloat(leftVal) / ExecValueToFloat(rightVal)
    Case "\\"
        Dim divInt As Integer
        divInt = ExecValueToInteger(rightVal)
        If divInt = 0 Then
            errText = "Expression: sıfıra bölme"
            Return 0
        End If
        ExecValueSetInteger result, ExecValueToInteger(leftVal) \ divInt
    Case "%", "MOD"
        Dim modInt As Integer
        modInt = ExecValueToInteger(rightVal)
        If modInt = 0 Then
            errText = "Expression: mod sıfır"
            Return 0
        End If
        ExecValueSetInteger result, ExecValueToInteger(leftVal) Mod modInt
    Case "&"
        ExecValueSetInteger result, ExecValueToInteger(leftVal) And ExecValueToInteger(rightVal)
    Case "|"
        ExecValueSetInteger result, ExecValueToInteger(leftVal) Or ExecValueToInteger(rightVal)
    Case "AND"
        ExecValueSetInteger result, IIf((ExecValueToInteger(leftVal) <> 0) And (ExecValueToInteger(rightVal) <> 0), -1, 0)
    Case "OR"
        ExecValueSetInteger result, IIf((ExecValueToInteger(leftVal) <> 0) Or (ExecValueToInteger(rightVal) <> 0), -1, 0)
    Case "&&"
        ExecValueSetInteger result, IIf((ExecValueToInteger(leftVal) <> 0) And (ExecValueToInteger(rightVal) <> 0), -1, 0)
    Case "||"
        ExecValueSetInteger result, IIf((ExecValueToInteger(leftVal) <> 0) Or (ExecValueToInteger(rightVal) <> 0), -1, 0)
    Case "XOR"
        ExecValueSetInteger result, ExecValueToInteger(leftVal) Xor ExecValueToInteger(rightVal)
    Case "<<", "SHL"
        ExecValueSetInteger result, CInt(CUInt(ExecValueToInteger(leftVal)) Shl (ExecValueToInteger(rightVal) And 31))
    Case ">>", "SHR"
        ExecValueSetInteger result, CInt(CUInt(ExecValueToInteger(leftVal)) Shr (ExecValueToInteger(rightVal) And 31))
    Case "ROL"
        ExecValueSetInteger result, CInt(ExecRol32(CUInt(ExecValueToInteger(leftVal)), ExecValueToInteger(rightVal)))
    Case "ROR"
        ExecValueSetInteger result, CInt(ExecRor32(CUInt(ExecValueToInteger(leftVal)), ExecValueToInteger(rightVal)))
    Case "="
        Dim cmp As Integer
        If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
            cmp = (leftVal.intValue = rightVal.intValue)
        ElseIf leftVal.valueType = "FLOAT" Or rightVal.valueType = "FLOAT" Then
            cmp = (ExecValueToFloat(leftVal) = ExecValueToFloat(rightVal))
        Else
            cmp = (leftVal.stringValue = rightVal.stringValue)
        End If
        ExecValueSetInteger result, cmp
    Case "<>"
        Dim cmpNe As Integer
        If leftVal.valueType = "INTEGER" And rightVal.valueType = "INTEGER" Then
            cmpNe = (leftVal.intValue <> rightVal.intValue)
        ElseIf leftVal.valueType = "FLOAT" Or rightVal.valueType = "FLOAT" Then
            cmpNe = (ExecValueToFloat(leftVal) <> ExecValueToFloat(rightVal))
        Else
            cmpNe = (ExecValueToString(leftVal) <> ExecValueToString(rightVal))
        End If
        ExecValueSetInteger result, cmpNe
    Case "<"
        ExecValueSetInteger result, IIf(ExecValueToFloat(leftVal) < ExecValueToFloat(rightVal), -1, 0)
    Case ">"
        ExecValueSetInteger result, IIf(ExecValueToFloat(leftVal) > ExecValueToFloat(rightVal), -1, 0)
    Case "<="
        ExecValueSetInteger result, IIf(ExecValueToFloat(leftVal) <= ExecValueToFloat(rightVal), -1, 0)
    Case ">="
        ExecValueSetInteger result, IIf(ExecValueToFloat(leftVal) >= ExecValueToFloat(rightVal), -1, 0)
    Case Else
        errText = "Expression: Desteklenmeyen ikili işlem: " & opText
        Return 0
    End Select

    Return 1
End Function

' Helper: Evaluate expression (simplified)
Function ExecEvalExpression(ByRef ps As ParseState, ByVal nodeIdx As Integer, ByRef es As ExecState, ByRef result As ExecValue, ByRef errText As String) As Integer
    If nodeIdx = -1 Then
        errText = "Expression: Geçersiz düğüm"
        Return 0
    End If

    Dim n As ASTNode
    n = ps.ast.nodes(nodeIdx)

    Select Case UCase(n.kind)
    Case "NUMBER"
        If InStr(n.value, ".") > 0 Or InStr(UCase(n.value), "E") > 0 Then
            ExecValueSetFloat result, Val(n.value)
        Else
            ExecValueSetInteger result, Val(n.value)
        End If
        Return 1

    Case "STRING"
        ExecValueSetString result, n.value
        Return 1

    Case "IDENT", "KEYWORD_REF"
        Dim varName As String
        varName = UCase(n.value)
        ' Check consts first
        Dim i As Integer
        For i = 0 To es.constCount - 1
            If UCase(es.consts(i).nameText) = varName Then
                result = es.consts(i).value
                Return 1
            End If
        Next
        ' Then variables
        If ExecGetVarValue(es, varName, result) = 0 Then
            errText = "Expression: Tanımlanmamış değişken: " & varName
            Return 0
        End If
        Return 1

    Case "UNARY"
        Dim rightVal As ExecValue
        If n.op <> "@" Then
            If ExecEvalExpression(ps, n.right, es, rightVal, errText) = 0 Then Return 0
        End If

        Select Case UCase(n.op)
        Case "+"
            result = rightVal
        Case "-"
            If rightVal.valueType = "FLOAT" Then
                ExecValueSetFloat result, -ExecValueToFloat(rightVal)
            Else
                ExecValueSetInteger result, -ExecValueToInteger(rightVal)
            End If
        Case "NOT"
            ExecValueSetInteger result, Not ExecValueToInteger(rightVal)
        Case "@"
            If n.right = -1 Then
                errText = "Expression: address operand missing"
                Return 0
            End If

            Dim addrNode As ASTNode
            addrNode = ps.ast.nodes(n.right)
            If UCase(addrNode.kind) = "IDENT" Then
                ExecValueSetInteger result, CInt(ExecGetVarAddr(es, addrNode.value))
                Return 1
            End If

            Dim addrInt As Integer
            addrInt = ExecEvalNode(ps, es, n.right, errText)
            If errText <> "" Then Return 0
            ExecValueSetInteger result, (&h10000000 Or (addrInt And &h00FFFFFF))
        Case Else
            errText = "Expression: Desteklenmeyen tekli işlem: " & n.op
            Return 0
        End Select

        Return 1

    Case "INCDEC_EXPR"
        Dim targetNode As Integer
        targetNode = n.left
        If targetNode = -1 Then
            errText = "Expression: inc/dec target missing"
            Return 0
        End If

        Dim curVal As ExecValue
        Dim nextVal As ExecValue
        Dim targetName As String
        Dim arrayVarIdx As Integer
        Dim arrayElemIdx As Integer
        Dim isIndexedTarget As Integer
        isIndexedTarget = 0

        If UCase(ps.ast.nodes(targetNode).kind) = "IDENT" Then
            targetName = ps.ast.nodes(targetNode).value
            If ExecGetVarValue(es, targetName, curVal) = 0 Then ExecValueInit curVal
        ElseIf ExecTryResolveArrayAccess(ps, es, targetNode, arrayVarIdx, arrayElemIdx, errText) <> 0 Then
            isIndexedTarget = 1
            If ExecGetArrayElement(es, arrayVarIdx, arrayElemIdx, curVal) = 0 Then
                errText = "Expression: inc/dec array read failed"
                Return 0
            End If
        Else
            If errText = "" Then errText = "Expression: inc/dec target must be ident or indexed array"
            Return 0
        End If

        If Trim(n.op) = "--" Then
            ExecValueSetInteger nextVal, ExecValueToInteger(curVal) - 1
        Else
            ExecValueSetInteger nextVal, ExecValueToInteger(curVal) + 1
        End If

        If isIndexedTarget <> 0 Then
            If ExecSetArrayElement(es, arrayVarIdx, arrayElemIdx, nextVal) = 0 Then
                errText = "Expression: inc/dec array write failed"
                Return 0
            End If
        Else
            ExecSetVarValue es, targetName, nextVal
        End If

        If UCase(Trim(n.value)) = "POST" Then
            result = curVal
        Else
            result = nextVal
        End If
        Return 1

    Case "BINARY"
        Dim leftVal As ExecValue, rightVal As ExecValue
        If ExecEvalExpression(ps, n.left, es, leftVal, errText) = 0 Then Return 0

        If n.op = "|>" Then
            If n.right = -1 Then
                errText = "Expression: pipe target missing"
                Return 0
            End If

            Dim pipeOutput As ExecValue
            If ExecEvalPipeInvoke(ps, es, n.right, leftVal, pipeOutput, errText) = 0 Then Return 0
            result = pipeOutput
            Return 1
        End If

        If n.op = "&&" Or UCase(Trim(n.op)) = "AND" Then
            If ExecValueToInteger(leftVal) = 0 Then
                ExecValueSetInteger result, 0
                Return 1
            End If
        ElseIf n.op = "||" Or UCase(Trim(n.op)) = "OR" Then
            If ExecValueToInteger(leftVal) <> 0 Then
                ExecValueSetInteger result, -1
                Return 1
            End If
        End If

        If ExecEvalExpression(ps, n.right, es, rightVal, errText) = 0 Then Return 0

        If ExecEvalBinaryValues(leftVal, rightVal, n.op, result, errText) = 0 Then Return 0
        Return 1

    Case "TERNARY_EXPR"
        Dim condVal As ExecValue
        If ExecEvalExpression(ps, n.left, es, condVal, errText) = 0 Then Return 0

        Dim thenNode As Integer
        thenNode = ExecChildAt(ps, nodeIdx, 0)
        If thenNode = -1 Then
            errText = "Expression: ternary true branch missing"
            Return 0
        End If

        If ExecValueToInteger(condVal) <> 0 Then
            Return ExecEvalExpression(ps, thenNode, es, result, errText)
        End If
        Return ExecEvalExpression(ps, n.right, es, result, errText)

    Case "CALL_EXPR"
        Dim arrayVarIdx As Integer
        Dim arrayElemIdx As Integer
        Dim arrayTry As Integer
        arrayTry = ExecTryResolveArrayAccess(ps, es, nodeIdx, arrayVarIdx, arrayElemIdx, errText)
        If arrayTry <> 0 Then
            If ExecGetArrayElement(es, arrayVarIdx, arrayElemIdx, result) = 0 Then
                errText = "Expression: array element read failed"
                Return 0
            End If
            Return 1
        End If
        If errText <> "" Then Return 0

        Dim callExprValue As Integer
        callExprValue = ExecEvalNode(ps, es, nodeIdx, errText)
        If errText <> "" Then Return 0
        ExecValueSetInteger result, callExprValue
        Return 1

    Case "NEW_EXPR"
        Dim newExprValue As Integer
        newExprValue = ExecEvalNode(ps, es, nodeIdx, errText)
        If errText <> "" Then Return 0
        ExecValueSetInteger result, newExprValue
        Return 1

    Case "FIELD_EXPR"
        Return ExecReadFieldValue(ps, es, nodeIdx, result, errText)

    Case Else
        errText = "Expression: Desteklenmeyen ifade türü: " & n.kind
        Return 0
    End Select
End Function

